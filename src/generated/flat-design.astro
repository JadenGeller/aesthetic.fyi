---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet" />

<div class="flat-page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-shapes" aria-hidden="true">
        <div class="shape shape-circle"></div>
        <div class="shape shape-square"></div>
        <div class="shape shape-rect"></div>
      </div>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <h2 class="section-heading">What This Is</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="body-text">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class={`char-card char-card-${i % 6}`}>
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <h2 class="section-heading">Style Reference</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-label">PROMPT</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <pre class="prompt-text">{aesthetic.prompt}</pre>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <h2 class="section-heading">When to Use</h2>
      <div class="use-columns">
        <div class="use-column">
          <h3 class="use-heading use-heading-good">Good for</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column">
          <h3 class="use-heading use-heading-not">Not for</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-not">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="body-text">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <h2 class="section-heading section-heading-white">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; All aesthetics</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     BASE
     ======================================== */
  .flat-page {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    background: #ffffff;
    color: #2c3e50;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background: #3498db;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-logo {
    font-weight: 700;
    font-size: 0.95rem;
    color: #ffffff;
    text-decoration: none;
    padding: 6px 14px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 2px;
    letter-spacing: 0.01em;
  }

  .nav-logo:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .nav-divider {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 4px;
  }

  .nav-current {
    font-weight: 400;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    padding: 6px 14px;
  }

  .nav-current:hover {
    color: #ffffff;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #2c3e50;
    padding: 80px 24px 72px;
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-shapes {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 50%;
    z-index: 0;
    pointer-events: none;
  }

  .shape {
    position: absolute;
  }

  .shape-circle {
    width: 180px;
    height: 180px;
    background: #3498db;
    border-radius: 50%;
    top: 10%;
    right: 10%;
    opacity: 0.3;
  }

  .shape-square {
    width: 100px;
    height: 100px;
    background: #e67e22;
    border-radius: 0;
    bottom: 15%;
    right: 35%;
    opacity: 0.25;
  }

  .shape-rect {
    width: 160px;
    height: 60px;
    background: #2ecc71;
    border-radius: 0;
    top: 40%;
    right: 5%;
    opacity: 0.2;
  }

  .hero-title {
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 7rem);
    line-height: 1;
    margin: 0 0 20px 0;
    color: #ffffff;
    letter-spacing: -0.02em;
    position: relative;
    z-index: 1;
  }

  .hero-tagline {
    font-weight: 400;
    font-size: clamp(1.05rem, 2.5vw, 1.35rem);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    max-width: 500px;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 72px 24px;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-heading {
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1;
    margin: 0 0 40px 0;
    color: #2c3e50;
    letter-spacing: -0.01em;
  }

  .section-heading-white {
    color: #ffffff;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #ffffff;
  }

  .about-content {
    max-width: 720px;
  }

  .body-text {
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.75;
    margin: 0 0 20px 0;
    color: #2c3e50;
  }

  .body-text:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #ecf0f1;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }

  .char-card {
    padding: 28px 24px 24px;
    border-radius: 2px;
    position: relative;
  }

  .char-card-0 {
    background: #3498db;
    color: #ffffff;
  }

  .char-card-1 {
    background: #2ecc71;
    color: #ffffff;
  }

  .char-card-2 {
    background: #e67e22;
    color: #ffffff;
  }

  .char-card-3 {
    background: #e74c3c;
    color: #ffffff;
  }

  .char-card-4 {
    background: #9b59b6;
    color: #ffffff;
  }

  .char-card-5 {
    background: #2c3e50;
    color: #ffffff;
  }

  .char-number {
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.6;
    display: block;
    margin-bottom: 12px;
  }

  .char-title {
    font-weight: 700;
    font-size: 1.35rem;
    margin: 0 0 10px 0;
    letter-spacing: -0.01em;
  }

  .char-description {
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    opacity: 0.9;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #ffffff;
  }

  .prompt-block {
    background: #2c3e50;
    border-radius: 2px;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    background: #34495e;
  }

  .prompt-label {
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.6);
  }

  .copy-button {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    background: #3498db;
    color: #ffffff;
    border: none;
    border-radius: 2px;
    padding: 8px 20px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .copy-button:hover {
    background: #2980b9;
  }

  .copy-button.copied {
    background: #2ecc71;
  }

  .prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.85);
    padding: 24px;
    margin: 0;
    white-space: normal;
    word-wrap: break-word;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #ecf0f1;
  }

  .use-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .use-column {
    border-radius: 2px;
    overflow: hidden;
  }

  .use-heading {
    font-weight: 700;
    font-size: 1.1rem;
    margin: 0;
    padding: 16px 24px;
    color: #ffffff;
  }

  .use-heading-good {
    background: #2ecc71;
  }

  .use-heading-not {
    background: #e74c3c;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
    background: #ffffff;
  }

  .use-item {
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    padding: 14px 24px;
    border-bottom: 1px solid #ecf0f1;
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '+';
    font-weight: 700;
    color: #2ecc71;
    flex-shrink: 0;
  }

  .use-item-not::before {
    content: '\2013';
    font-weight: 700;
    color: #e74c3c;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #ffffff;
  }

  .history-content {
    max-width: 720px;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #3498db;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 24px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 2px;
    text-decoration: none;
    color: #ffffff;
    position: relative;
  }

  .related-card:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  .related-relationship {
    font-weight: 400;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.7;
  }

  .related-name {
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
  }

  .related-arrow {
    font-size: 1.1rem;
    position: absolute;
    bottom: 20px;
    right: 20px;
    opacity: 0.6;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #2c3e50;
    padding: 48px 24px;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-align: center;
  }

  .footer-logo {
    font-weight: 700;
    font-size: 1rem;
    color: #ffffff;
    text-decoration: none;
    padding: 8px 18px;
    background: #3498db;
    border-radius: 2px;
  }

  .footer-logo:hover {
    background: #2980b9;
  }

  .footer-tagline {
    font-weight: 400;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .footer-back {
    font-weight: 700;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    padding: 8px 18px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 2px;
  }

  .footer-back:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 56px 20px 48px;
    }

    .section {
      padding: 56px 20px;
    }

    .section-heading {
      margin-bottom: 28px;
    }

    .characteristics-grid {
      grid-template-columns: 1fr;
    }

    .use-columns {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .hero-shapes {
      opacity: 0.4;
      width: 100%;
    }

    .prompt-header {
      padding: 12px 16px;
      flex-wrap: wrap;
      gap: 10px;
    }

    .prompt-text {
      padding: 20px 16px;
      font-size: 0.85rem;
    }

    .nav-inner {
      padding: 12px 16px;
    }

    .footer {
      padding: 36px 20px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 40px 16px 36px;
    }

    .section {
      padding: 40px 16px;
    }

    .nav-inner {
      padding: 10px 12px;
      gap: 6px;
    }

    .nav-logo {
      font-size: 0.85rem;
      padding: 5px 10px;
    }

    .nav-current {
      font-size: 0.8rem;
      padding: 5px 10px;
    }

    .char-card {
      padding: 22px 18px 18px;
    }

    .copy-button {
      padding: 6px 14px;
      font-size: 0.75rem;
    }

    .use-item {
      padding: 12px 16px;
      font-size: 0.95rem;
    }

    .related-card {
      padding: 18px;
    }
  }
</style>
