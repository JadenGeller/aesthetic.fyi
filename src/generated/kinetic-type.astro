---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&family=Syne:wght@400;700;800&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">
        <span class="hero-word hero-word-1">Kinetic</span>
        <span class="hero-word hero-word-2">Typography</span>
      </h1>
      <div class="hero-line"></div>
      <p class="hero-tagline">
        <span class="hero-tagline-word" style="--word-i: 0">The</span>
        <span class="hero-tagline-word" style="--word-i: 1">text</span>
        <span class="hero-tagline-word" style="--word-i: 2">does</span>
        <span class="hero-tagline-word" style="--word-i: 3">not</span>
        <span class="hero-tagline-word" style="--word-i: 4">wait.</span>
      </p>
    </div>
    <div class="hero-bg-letter hero-bg-letter-1">K</div>
    <div class="hero-bg-letter hero-bg-letter-2">T</div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading anim-slide-up">Motion as Message</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string, i: number) => (
          <p class="about-paragraph anim-fade-in" style={`--delay: ${i * 0.2}s`}>{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading anim-slide-up">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card" style={`--card-i: ${i}`}>
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-accent"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading anim-slide-up">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading anim-slide-up">Right Stage, Wrong Stage</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading anim-slide-up">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string, i: number) => (
          <p class="history-paragraph anim-fade-in" style={`--delay: ${i * 0.2}s`}>{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading anim-slide-up">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }, i: number) => (
          <a href={`/${rel.slug}`} class="related-card" style={`--card-i: ${i}`}>
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-line"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-line"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     KEYFRAMES
     ======================================== */
  @keyframes slideUpReveal {
    from {
      transform: translateY(100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes slideUpFade {
    from {
      transform: translateY(40px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes expandLine {
    from {
      transform: scaleX(0);
    }
    to {
      transform: scaleX(1);
    }
  }

  @keyframes wordReveal {
    from {
      transform: translateY(110%);
      opacity: 0;
      text-shadow: 0 0 16px rgba(255, 255, 255, 0.6);
    }
    to {
      transform: translateY(0);
      opacity: 1;
      text-shadow: 0 0 0px rgba(255, 255, 255, 0);
    }
  }

  @keyframes bgLetterDrift {
    0% {
      transform: translateY(10px) rotate(-5deg) scale(0.95);
      opacity: 0;
    }
    50% {
      opacity: 0.04;
    }
    100% {
      transform: translateY(-10px) rotate(2deg) scale(1);
      opacity: 0.03;
    }
  }

  @keyframes pulseGlow {
    0%, 100% {
      text-shadow: 0 0 8px rgba(0, 255, 136, 0.3);
    }
    50% {
      text-shadow: 0 0 20px rgba(0, 255, 136, 0.6);
    }
  }

  @keyframes cardSlideUp {
    from {
      transform: translateY(60px);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes labelSlide {
    from {
      transform: translateX(-20px);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Space Grotesk', sans-serif;
    background-color: #111111;
    color: #ffffff;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: #111111;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 16px 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    color: #ffffff;
    text-decoration: none;
    letter-spacing: -0.02em;
    padding: 6px 16px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    transition: border-color 0.3s, background 0.3s;
  }

  .nav-logo:hover {
    border-color: #00FF88;
    background: rgba(0, 255, 136, 0.05);
  }

  .nav-divider {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.2);
    font-weight: 400;
  }

  .nav-current {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    letter-spacing: 0.02em;
    padding: 6px 16px;
    border: 1px solid transparent;
    transition: border-color 0.3s, color 0.3s;
  }

  .nav-current:hover {
    border-color: rgba(255, 255, 255, 0.15);
    color: rgba(255, 255, 255, 0.8);
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #111111;
    padding: 120px 40px 100px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .hero-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    color: #00FF88;
    display: inline-block;
    margin-bottom: 32px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    animation: labelSlide 0.6s ease-out 0.2s both;
  }

  .hero-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(3.5rem, 12vw, 8rem);
    line-height: 0.95;
    margin: 0 0 32px 0;
    color: #ffffff;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  .hero-word {
    display: block;
    overflow: hidden;
  }

  .hero-word > * {
    display: inline-block;
  }

  .hero-word-1 {
    animation: slideUpReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both;
    text-shadow: 0 0 40px rgba(255, 255, 255, 0.15);
  }

  .hero-word-2 {
    animation: slideUpReveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s both;
    text-shadow: 0 0 40px rgba(0, 255, 136, 0.1);
    color: #00FF88;
  }

  .hero-line {
    width: 60px;
    height: 2px;
    background: #00FF88;
    margin: 0 auto 32px;
    transform-origin: left;
    animation: expandLine 0.6s ease-out 1s both;
  }

  .hero-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 500px;
    color: rgba(255, 255, 255, 0.6);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0 8px;
  }

  .hero-tagline-word {
    display: inline-block;
    overflow: hidden;
    animation: wordReveal 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(1.2s + var(--word-i) * 0.08s);
  }

  .hero-bg-letter {
    position: absolute;
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.03);
    pointer-events: none;
    line-height: 1;
    user-select: none;
  }

  .hero-bg-letter-1 {
    font-size: 40vw;
    top: -5%;
    left: -8%;
    animation: bgLetterDrift 8s ease-in-out infinite alternate;
  }

  .hero-bg-letter-2 {
    font-size: 35vw;
    bottom: -15%;
    right: -5%;
    animation: bgLetterDrift 10s ease-in-out 1s infinite alternate-reverse;
  }

  /* ========================================
     SHARED ANIMATION CLASSES
     ======================================== */
  .anim-slide-up {
    animation: slideUpFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .anim-fade-in {
    animation: fadeIn 0.6s ease-out both;
    animation-delay: var(--delay, 0s);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 100px 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    position: relative;
  }

  .section-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
  }

  .section-rule {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
  }

  .section-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    color: #00FF88;
    white-space: nowrap;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.05;
    margin: 0 0 56px 0;
    color: #ffffff;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #ffffff;
    color: #111111;
  }

  .about-section .section-label {
    color: #111111;
  }

  .about-section .section-rule {
    background: rgba(0, 0, 0, 0.12);
  }

  .about-section .section-heading {
    color: #111111;
  }

  .about-content {
    max-width: 680px;
  }

  .about-paragraph {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.85;
    margin: 0 0 28px 0;
    color: #333333;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #111111;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 36px 28px 28px;
    position: relative;
    background: rgba(255, 255, 255, 0.02);
    animation: cardSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--card-i) * 0.1s);
    transition: border-color 0.3s, background 0.3s;
  }

  .char-card:hover {
    border-color: #00FF88;
    background: rgba(0, 255, 136, 0.03);
  }

  .char-number {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: #00FF88;
    display: block;
    margin-bottom: 12px;
    letter-spacing: 0.15em;
  }

  .char-accent {
    width: 24px;
    height: 2px;
    background: rgba(255, 255, 255, 0.2);
    margin-bottom: 16px;
    transition: background 0.3s, width 0.3s;
  }

  .char-card:hover .char-accent {
    background: #00FF88;
    width: 40px;
  }

  .char-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin: 0 0 12px 0;
    color: #ffffff;
    letter-spacing: -0.01em;
  }

  .char-description {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.7;
    margin: 0;
    color: rgba(255, 255, 255, 0.5);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #0a0a0a;
  }

  .prompt-block {
    border: 1px solid rgba(255, 255, 255, 0.1);
    max-width: 760px;
    position: relative;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
  }

  .prompt-header-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    color: #00FF88;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    background: transparent;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 6px 20px;
    cursor: pointer;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: background 0.3s, border-color 0.3s, color 0.3s;
  }

  .copy-button:hover {
    background: #00FF88;
    border-color: #00FF88;
    color: #111111;
  }

  .copy-button.copied {
    background: #00FF88;
    border-color: #00FF88;
    color: #111111;
  }

  .prompt-text {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.6);
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #ffffff;
    color: #111111;
  }

  .use-section .section-label {
    color: #111111;
  }

  .use-section .section-rule {
    background: rgba(0, 0, 0, 0.12);
  }

  .use-section .section-heading {
    color: #111111;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 800px;
  }

  .use-column {
    border: 1px solid rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }

  .use-column-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    margin: 0;
    padding: 16px 22px;
    text-align: left;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .use-good .use-column-heading {
    background: #111111;
    color: #00FF88;
  }

  .use-bad .use-column-heading {
    background: rgba(0, 0, 0, 0.03);
    color: #666666;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #333333;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '\2192';
    color: #00CC6A;
    flex-shrink: 0;
    font-weight: 700;
  }

  .use-item-bad::before {
    content: '\00D7';
    color: #999999;
    flex-shrink: 0;
    font-weight: 700;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #0a0a0a;
  }

  .history-content {
    max-width: 680px;
  }

  .history-paragraph {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.85;
    margin: 0 0 28px 0;
    color: rgba(255, 255, 255, 0.65);
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #111111;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 800px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 28px 22px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    text-decoration: none;
    color: #ffffff;
    position: relative;
    overflow: hidden;
    animation: cardSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--card-i) * 0.08s);
    transition: border-color 0.3s, background 0.3s;
  }

  .related-card:hover {
    border-color: #00FF88;
    background: rgba(0, 255, 136, 0.04);
  }

