---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Courier+Prime:ital,wght@0,400;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-noise"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-scratch"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Analog Decay</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy & Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Venue, Wrong Venue</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Courier Prime', monospace;
    background-color: #2A2A2A;
    color: #E8E0D0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
  }

  /* Global noise overlay on entire page */
  .page::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 0, 0, 0.03) 2px,
        rgba(0, 0, 0, 0.03) 4px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 3px,
        rgba(0, 0, 0, 0.02) 3px,
        rgba(0, 0, 0, 0.02) 6px
      );
    pointer-events: none;
    z-index: 1000;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 3px solid #3E3229;
    background: #1E1E1E;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav::after {
    content: '';
    position: absolute;
    bottom: -6px;
    left: 0;
    right: 0;
    height: 3px;
    background: repeating-linear-gradient(
      90deg,
      #3E3229 0px,
      #3E3229 8px,
      transparent 8px,
      transparent 12px
    );
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Special Elite', cursive;
    font-weight: 400;
    font-size: 1rem;
    color: #B8860B;
    text-decoration: none;
    padding: 6px 18px;
    border: 2px solid #3E3229;
    transition: background 0.2s, border-color 0.2s;
  }

  .nav-logo:hover {
    background: rgba(184, 134, 11, 0.1);
    border-color: #B8860B;
  }

  .nav-divider {
    font-family: 'Courier Prime', monospace;
    font-size: 1.2rem;
    color: #3E3229;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Special Elite', cursive;
    font-weight: 400;
    font-size: 0.95rem;
    color: #8A7A6A;
    text-decoration: none;
    padding: 6px 18px;
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }

  .nav-current:hover {
    border-color: #3E3229;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #2A2A2A;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 3px solid #3E3229;
    clip-path: polygon(
      0% 0%, 100% 0%, 100% 93%, 98% 95%, 95% 93%,
      90% 96%, 85% 94%, 80% 97%, 75% 94%, 70% 96%,
      65% 93%, 60% 97%, 55% 94%, 50% 96%, 45% 93%,
      40% 97%, 35% 94%, 30% 96%, 25% 93%, 20% 97%,
      15% 94%, 10% 96%, 5% 93%, 2% 95%, 0% 97%
    );
    padding-bottom: 120px;
  }

  /* Noise texture overlay */
  .hero-noise {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle 1px at 10% 15%, rgba(184, 134, 11, 0.3) 50%, transparent 50%),
      radial-gradient(circle 1px at 25% 35%, rgba(232, 224, 208, 0.15) 50%, transparent 50%),
      radial-gradient(circle 1px at 40% 10%, rgba(184, 134, 11, 0.2) 50%, transparent 50%),
      radial-gradient(circle 1px at 55% 45%, rgba(232, 224, 208, 0.1) 50%, transparent 50%),
      radial-gradient(circle 1px at 70% 20%, rgba(184, 134, 11, 0.25) 50%, transparent 50%),
      radial-gradient(circle 1px at 85% 40%, rgba(232, 224, 208, 0.12) 50%, transparent 50%),
      radial-gradient(circle 1px at 15% 60%, rgba(184, 134, 11, 0.18) 50%, transparent 50%),
      radial-gradient(circle 1px at 30% 75%, rgba(232, 224, 208, 0.14) 50%, transparent 50%),
      radial-gradient(circle 1px at 50% 80%, rgba(184, 134, 11, 0.22) 50%, transparent 50%),
      radial-gradient(circle 1px at 65% 55%, rgba(232, 224, 208, 0.1) 50%, transparent 50%),
      radial-gradient(circle 1px at 80% 70%, rgba(184, 134, 11, 0.15) 50%, transparent 50%),
      radial-gradient(circle 1px at 95% 85%, rgba(232, 224, 208, 0.13) 50%, transparent 50%),
      radial-gradient(circle 2px at 20% 90%, rgba(62, 50, 41, 0.4) 50%, transparent 50%),
      radial-gradient(circle 2px at 75% 5%, rgba(62, 50, 41, 0.35) 50%, transparent 50%);
    pointer-events: none;
    opacity: 0.8;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    color: #8A7A6A;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-bottom: 1px solid #3E3229;
    padding-bottom: 4px;
  }

  .hero-title {
    font-family: 'Special Elite', cursive;
    font-weight: 400;
    font-size: clamp(3rem, 9vw, 6rem);
    line-height: 1.05;
    margin: 0 0 24px 0;
    color: #E8E0D0;
    text-shadow:
      3px 3px 0px rgba(62, 50, 41, 0.8),
      -1px -1px 0px rgba(184, 134, 11, 0.3);
    letter-spacing: -0.02em;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }

  .hero-scratch {
    display: block;
    width: 120px;
    height: 3px;
    background: repeating-linear-gradient(
      90deg,
      #B8860B 0px,
      #B8860B 6px,
      transparent 6px,
      transparent 10px,
      #3E3229 10px,
      #3E3229 18px,
      transparent 18px,
      transparent 22px
    );
  }

  .hero-tagline {
    font-family: 'Courier Prime', monospace;
    font-weight: 400;
    font-size: clamp(0.9rem, 2.2vw, 1.15rem);
    line-height: 1.8;
    margin: 0 auto;
    max-width: 520px;
    color: #8A7A6A;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 3px solid #3E3229;
    position: relative;
  }

  .section::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 4px,
        rgba(62, 50, 41, 0.04) 4px,
        rgba(62, 50, 41, 0.04) 5px
      );
    pointer-events: none;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 2px;
    background: repeating-linear-gradient(
      90deg,
      #3E3229 0px,
      #3E3229 4px,
      transparent 4px,
      transparent 8px
    );
  }

  .section-label {
    font-family: 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.75rem;
    color: #8A7A6A;
    white-space: nowrap;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Special Elite', cursive;
    font-weight: 400;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #E8E0D0;
    text-shadow: 2px 2px 0px rgba(62, 50, 41, 0.6);
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #242424;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px solid #3E3229;
    pointer-events: none;
    clip-path: polygon(
      0% 2%, 3% 0%, 97% 0%, 100% 3%,
      100% 97%, 97% 100%, 3% 100%, 0% 98%
    );
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: left;
  }

  .about-paragraph {
    font-family: 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #C8C0B0;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #2A2A2A;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 2px solid #3E3229;
    padding: 32px 28px 28px;
    position: relative;
    text-align: left;
    background: #222222;
    transition: box-shadow 0.2s, border-color 0.2s;
    clip-path: polygon(
      0% 0%, 97% 0%, 100% 3%, 100% 100%,
      3% 100%, 0% 97%
    );
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 1px,
        rgba(62, 50, 41, 0.06) 1px,
        rgba(62, 50, 41, 0.06) 2px
      );
    pointer-events: none;
  }

  .char-card:hover {
    box-shadow: 4px 4px 0px #3E3229, -2px -2px 0px rgba(184, 134, 11, 0.2);
    border-color: #B8860B;
  }

  .char-number {
    font-family: 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.75rem;
    color: #B8860B;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 40px;
    height: 2px;
    background: repeating-linear-gradient(
      90deg,
      #B8860B 0px,
      #B8860B 4px,
      transparent 4px,
      transparent 8px
    );
    margin: 0 0 14px;
  }

  .char-title {
    font-family: 'Special Elite', cursive;
    font-weight: 400;
    font-size: 1.25rem;
    margin: 0 0 12px 0;
    color: #E8E0D0;
  }

  .char-description {
    font-family: 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.75;
    margin: 0;
    color: #8A7A6A;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #242424;
  }

  .prompt-block {
    border: 2px solid #3E3229;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-block::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 3px,
        rgba(62, 50, 41, 0.05) 3px,
        rgba(62, 50, 41, 0.05) 4px
      );
    pointer-events: none;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 2px solid #3E3229;
    background: rgba(62, 50, 41, 0.3);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.75rem;
    color: #B8860B;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Special Elite', cursive;
    font-weight: 400;
    font-size: 0.85rem;
    background: transparent;
    color: #E8E0D0;
    border: 2px solid #3E3229;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }

  .copy-button:hover {
    background: rgba(184, 134, 11, 0.15);
    border-color: #B8860B;
  }

  .copy-button.copied {
    background: rgba(184, 134, 11, 0.25);
    border-color: #B8860B;
    color: #B8860B;
  }

  .prompt-text {
    font-family: 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.85;
    color: #C8C0B0;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #2A2A2A;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 2px solid #3E3229;
    overflow: hidden;
    position: relative;
  }

  .use-column::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 1px,
        rgba(62, 50, 41, 0.04) 1px,
        rgba(62, 50, 41, 0.04) 2px
      );
    pointer-events: none;
    z-index: 1;
  }

  .use-column-heading {
    font-family: 'Special Elite', cursive;
    font-weight: 400;
    font-size: 1.05rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 2px solid #3E3229;
  }

  .use-good .use-column-heading {
    background: rgba(184, 134, 11, 0.12);
    color: #B8860B;
  }

  .use-bad .use-column-heading {
    background: rgba(62, 50, 41, 0.3);
    color: #8A7A6A;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(62, 50, 41, 0.5);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #C8C0B0;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 6px;
    height: 6px;
    background: #B8860B;
    flex-shrink: 0;
    margin-top: 7px;
    transform: rotate(45deg);
  }

  .use-item-bad::before {
    content: '\00D7';
    color: #5A4A3A;
    flex-shrink: 0;
    font-weight: bold;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #242424;
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px solid #3E3229;
    pointer-events: none;
    clip-path: polygon(
      2% 0%, 98% 0%, 100% 2%, 100% 98%,
      98% 100%, 2% 100%, 0% 98%, 0% 2%
    );
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: left;
  }

  .history-paragraph {
    font-family: 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #C8C0B0;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
