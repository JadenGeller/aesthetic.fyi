---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&family=Courier+Prime:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- SCANLINES OVERLAY -->
  <div class="scanlines"></div>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <span class="nav-border-left">║</span>
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">//</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
      <span class="nav-border-right">║</span>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-box-top">╔════════════════════════════════════════╗</div>
    <div class="hero-inner">
      <span class="hero-label">&gt;_ A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">════════════════════</div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
      <span class="hero-cursor">█</span>
    </div>
    <div class="hero-box-bottom">╚════════════════════════════════════════╝</div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-rule">════════</span>
        <span class="section-label">[ What This Is ]</span>
        <span class="section-rule">════════</span>
      </div>
      <h2 class="section-heading">&gt; System.describe()</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-rule">════════</span>
        <span class="section-label">[ Design Tokens ]</span>
        <span class="section-rule">════════</span>
      </div>
      <h2 class="section-heading">&gt; Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <div class="char-card-top">╔══════════════════════════╗</div>
            <div class="char-card-body">
              <span class="char-number">[{String(i + 1).padStart(2, '0')}]</span>
              <div class="char-divider">──────────</div>
              <h3 class="char-title">{char.title}</h3>
              <p class="char-description">{char.description}</p>
            </div>
            <div class="char-card-bottom">╚══════════════════════════╝</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-rule">════════</span>
        <span class="section-label">[ Style Reference ]</span>
        <span class="section-rule">════════</span>
      </div>
      <h2 class="section-heading">&gt; Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">$ cat prompt.txt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>[COPY]</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-rule">════════</span>
        <span class="section-label">[ When to Use ]</span>
        <span class="section-rule">════════</span>
      </div>
      <h2 class="section-heading">&gt; Compatibility Check</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">// COMPATIBLE</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">// INCOMPATIBLE</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-rule">════════</span>
        <span class="section-label">[ Origins ]</span>
        <span class="section-rule">════════</span>
      </div>
      <h2 class="section-heading">&gt; History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-rule">════════</span>
        <span class="section-label">[ Explore ]</span>
        <span class="section-rule">════════</span>
      </div>
      <h2 class="section-heading">&gt; Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">// {rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">-&gt;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament">════════════════════════════════</div>
      <a href="/" class="footer-logo">&gt; aesthetic.fyi</a>
      <span class="footer-tagline">// Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&lt;── Back to All Aesthetics</a>
      <div class="footer-ornament">════════════════════════════════</div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = '[COPIED]';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    background-color: #1a1a2e;
    color: #33FF33;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
  }

  /* ========================================
     SCANLINES OVERLAY
     ======================================== */
  .scanlines {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.08) 2px,
      rgba(0, 0, 0, 0.08) 4px
    );
    pointer-events: none;
    z-index: 1000;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid #33FF33;
    background: #1a1a2e;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 12px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .nav-border-left,
  .nav-border-right {
    color: #33FF33;
    opacity: 0.4;
    font-size: 1rem;
  }

  .nav-logo {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 500;
    font-size: 0.9rem;
    color: #33FF33;
    text-decoration: none;
    padding: 4px 12px;
    border: 1px solid #33FF33;
    border-radius: 0;
    transition: background 0.2s, color 0.2s;
  }

  .nav-logo:hover {
    background: #33FF33;
    color: #1a1a2e;
  }

  .nav-divider {
    font-size: 0.9rem;
    color: #FFB000;
    opacity: 0.6;
  }

  .nav-current {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.85rem;
    color: #FFB000;
    text-decoration: none;
    padding: 4px 12px;
    border: 1px solid transparent;
    border-radius: 0;
    transition: border-color 0.2s;
  }

  .nav-current:hover {
    border-color: #FFB000;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #1a1a2e;
    padding: 72px 32px 64px;
    text-align: center;
    position: relative;
    border-bottom: 1px solid #33FF33;
  }

  .hero-box-top,
  .hero-box-bottom {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-size: 0.75rem;
    color: #33FF33;
    opacity: 0.3;
    overflow: hidden;
    white-space: nowrap;
    text-align: center;
    letter-spacing: 0.05em;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 40px 0;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    color: #FFB000;
    display: inline-block;
    margin-bottom: 20px;
    letter-spacing: 0.1em;
  }

  .hero-title {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 600;
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    line-height: 1.1;
    margin: 0 0 20px 0;
    color: #33FF33;
    text-shadow: 0 0 20px rgba(51, 255, 51, 0.4), 0 0 40px rgba(51, 255, 51, 0.15);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-rule {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-size: 0.8rem;
    color: #33FF33;
    opacity: 0.5;
    margin-bottom: 20px;
    letter-spacing: 0.1em;
  }

  .hero-tagline {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 400;
    font-size: clamp(0.85rem, 2vw, 1.05rem);
    line-height: 1.8;
    margin: 0 auto;
    max-width: 520px;
    color: #FFB000;
  }

  .hero-cursor {
    display: inline-block;
    color: #33FF33;
    font-size: 1.2rem;
    margin-top: 16px;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 72px 32px;
    border-bottom: 1px solid rgba(51, 255, 51, 0.3);
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-bottom: 12px;
  }

  .section-rule {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-size: 0.7rem;
    color: #33FF33;
    opacity: 0.3;
    letter-spacing: 0.05em;
    overflow: hidden;
    white-space: nowrap;
    max-width: 80px;
  }

  .section-label {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.75rem;
    color: #FFB000;
    white-space: nowrap;
    letter-spacing: 0.08em;
  }

  .section-heading {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 600;
    font-size: clamp(1.4rem, 4vw, 2rem);
    line-height: 1.2;
    margin: 0 0 40px 0;
    text-align: center;
    color: #33FF33;
    text-shadow: 0 0 10px rgba(51, 255, 51, 0.3);
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #16162a;
  }

  .about-section::before {
    content: '╔══════════════════════════════════════════════════════════════╗';
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-size: 0.6rem;
    color: #33FF33;
    opacity: 0.15;
    white-space: nowrap;
    pointer-events: none;
  }

  .about-section::after {
    content: '╚══════════════════════════════════════════════════════════════╝';
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-size: 0.6rem;
    color: #33FF33;
    opacity: 0.15;
    white-space: nowrap;
    pointer-events: none;
  }

  .about-content {
    max-width: 640px;
    margin: 0 auto;
    text-align: left;
  }

  .about-paragraph {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.85;
    margin: 0 0 20px 0;
    color: #33FF33;
    opacity: 0.85;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #1a1a2e;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .char-card {
    border: 1px solid rgba(51, 255, 51, 0.3);
    border-radius: 0;
    padding: 0;
    position: relative;
    text-align: left;
    background: #16162a;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .char-card:hover {
    border-color: #33FF33;
    box-shadow: 0 0 15px rgba(51, 255, 51, 0.1);
  }

  .char-card-top,
  .char-card-bottom {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-size: 0.55rem;
    color: #33FF33;
    opacity: 0.2;
    padding: 4px 12px;
    overflow: hidden;
    white-space: nowrap;
    letter-spacing: 0.05em;
  }

  .char-card-body {
    padding: 16px 20px 20px;
  }

  .char-number {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 500;
    font-size: 0.75rem;
    color: #FFB000;
    display: block;
    margin-bottom: 8px;
    letter-spacing: 0.1em;
  }

  .char-divider {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-size: 0.6rem;
    color: #33FF33;
    opacity: 0.3;
    margin-bottom: 12px;
    letter-spacing: 0.05em;
  }

  .char-title {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 600;
    font-size: 1.05rem;
    margin: 0 0 10px 0;
    color: #33FF33;
    text-shadow: 0 0 8px rgba(51, 255, 51, 0.25);
  }

  .char-description {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.85rem;
    line-height: 1.7;
    margin: 0;
    color: #33FF33;
    opacity: 0.6;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #16162a;
  }

  .prompt-block {
    border: 1px solid rgba(51, 255, 51, 0.4);
    border-radius: 0;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    background: #12122a;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 20px;
    border-bottom: 1px solid rgba(51, 255, 51, 0.3);
    background: rgba(51, 255, 51, 0.05);
  }

  .prompt-header-label {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    color: #FFB000;
    letter-spacing: 0.05em;
  }

  .copy-button {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 500;
    font-size: 0.8rem;
    background: transparent;
    color: #33FF33;
    border: 1px solid #33FF33;
    border-radius: 0;
    padding: 4px 16px;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    letter-spacing: 0.05em;
  }

  .copy-button:hover {
    background: #33FF33;
    color: #1a1a2e;
  }

  .copy-button.copied {
    background: #FFB000;
    color: #1a1a2e;
    border-color: #FFB000;
  }

  .prompt-text {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #33FF33;
    opacity: 0.8;
    padding: 20px;
    margin: 0;
    white-space: pre-wrap;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #1a1a2e;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid rgba(51, 255, 51, 0.3);
    border-radius: 0;
    overflow: hidden;
    position: relative;
  }

  .use-column-heading {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 500;
    font-size: 0.85rem;
    margin: 0;
    padding: 12px 18px;
    text-align: left;
    border-bottom: 1px solid rgba(51, 255, 51, 0.3);
    letter-spacing: 0.05em;
  }

  .use-good .use-column-heading {
    background: rgba(51, 255, 51, 0.08);
    color: #33FF33;
  }

  .use-bad .use-column-heading {
    background: rgba(255, 176, 0, 0.08);
    color: #FFB000;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.85rem;
    line-height: 1.5;
    padding: 10px 18px;
    border-bottom: 1px solid rgba(51, 255, 51, 0.1);
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good {
    color: #33FF33;
    opacity: 0.8;
  }

  .use-item-good::before {
    content: '[+]';
    color: #33FF33;
    flex-shrink: 0;
    font-size: 0.8rem;
  }

  .use-item-bad {
    color: #FFB000;
    opacity: 0.7;
  }

  .use-item-bad::before {
    content: '[-]';
    color: #FFB000;
    flex-shrink: 0;
    font-size: 0.8rem;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #16162a;
  }

  .history-section::before {
    content: '╔══════════════════════════════════════════════════════════════╗';
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-size: 0.6rem;
    color: #33FF33;
    opacity: 0.15;
    white-space: nowrap;
    pointer-events: none;
  }

  .history-section::after {
    content: '╚══════════════════════════════════════════════════════════════╝';
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-size: 0.6rem;
    color: #33FF33;
    opacity: 0.15;
    white-space: nowrap;
    pointer-events: none;
  }

  .history-content {
    max-width: 640px;
    margin: 0 auto;
    text-align: left;
  }

  .history-paragraph {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.85;
    margin: 0 0 20px 0;
    color: #33FF33;
    opacity: 0.85;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #1a1a2e;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    padding: 20px 18px;
    border: 1px solid rgba(51, 255, 51, 0.25);
    border-radius: 0;
    text-decoration: none;
    color: #33FF33;
    position: relative;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .related-card:hover {
    border-color: #33FF33;
    box-shadow: 0 0 12px rgba(51, 255, 51, 0.1);
  }

  .related-relationship {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 400;
    font-size: 0.65rem;
    color: #FFB000;
    opacity: 0.7;
    letter-spacing: 0.05em;
  }

  .related-name {
    font-family: 'IBM Plex Mono', 'Courier Prime', monospace;
    font-weight: 600;
    font-size: 1rem;
    color: #33FF33;
