---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;1,400&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-texture"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-crack"></div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
      </div>
      <h2 class="section-heading">An Imperfect Philosophy</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header section-header-right">
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading section-heading-right">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header section-header-right">
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading section-heading-right">Right Vessel, Wrong Vessel</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header section-header-right">
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading section-heading-right">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-crack"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-crack"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied.';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Cormorant', serif;
    background-color: #F5F0EA;
    color: #8B8680;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid #D6CFC6;
    background: #F5F0EA;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: #6B6560;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid #D6CFC6;
    border-radius: 2px 6px 4px 8px;
    transition: background 0.3s, border-color 0.3s;
  }

  .nav-logo:hover {
    background: rgba(181, 161, 142, 0.1);
    border-color: #B5A18E;
  }

  .nav-divider {
    font-size: 1rem;
    color: #C8C0B6;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.95rem;
    color: #A39E96;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid transparent;
    border-radius: 6px 2px 8px 4px;
    transition: border-color 0.3s;
  }

  .nav-current:hover {
    border-color: #D6CFC6;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #F5F0EA;
    padding: 120px 32px 100px;
    text-align: left;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid #D6CFC6;
  }

  .hero-texture {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle 1px at 20% 30%, #C8C0B6 40%, transparent 40%),
      radial-gradient(circle 1px at 60% 15%, #C8C0B6 40%, transparent 40%),
      radial-gradient(circle 1px at 80% 45%, #C8C0B6 40%, transparent 40%),
      radial-gradient(circle 1px at 35% 70%, #C8C0B6 40%, transparent 40%),
      radial-gradient(circle 1px at 75% 80%, #C8C0B6 40%, transparent 40%),
      radial-gradient(circle 1px at 15% 85%, #C8C0B6 40%, transparent 40%),
      radial-gradient(circle 1px at 90% 20%, #C8C0B6 40%, transparent 40%),
      radial-gradient(circle 1px at 45% 50%, #C8C0B6 40%, transparent 40%),
      radial-gradient(circle 1px at 10% 55%, #C8C0B6 40%, transparent 40%),
      radial-gradient(circle 1px at 55% 90%, #C8C0B6 40%, transparent 40%),
      radial-gradient(circle 1px at 85% 65%, #C8C0B6 40%, transparent 40%),
      radial-gradient(circle 1px at 30% 10%, #C8C0B6 40%, transparent 40%);
    opacity: 0.35;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    padding-left: 8%;
  }

  .hero-label {
    font-family: 'Cormorant', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: #A39E96;
    display: inline-block;
    margin-bottom: 28px;
    letter-spacing: 0.12em;
    text-transform: lowercase;
  }

  .hero-title {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.0;
    margin: 0 0 32px 0;
    color: #6B6560;
    letter-spacing: -0.02em;
  }

  .hero-crack {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, #B5A18E 0%, #B5A18E 30%, transparent 31%, transparent 38%, #B5A18E 39%, #B5A18E 55%, transparent 56%, transparent 62%, #B5A18E 63%, #B5A18E 100%);
    margin-bottom: 28px;
    opacity: 0.7;
  }

  .hero-tagline {
    font-family: 'Cormorant', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.05rem, 2.5vw, 1.35rem);
    line-height: 1.8;
    margin: 0;
    max-width: 440px;
    color: #A39E96;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 100px 32px;
    border-bottom: 1px solid #D6CFC6;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-header-right {
    justify-content: flex-end;
  }

  .section-rule {
    width: 60px;
    height: 1px;
    background: #C8C0B6;
  }

  .section-label {
    font-family: 'Cormorant', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.8rem;
    color: #A39E96;
    white-space: nowrap;
    letter-spacing: 0.08em;
    text-transform: lowercase;
  }

  .section-heading {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 56px 0;
    color: #6B6560;
  }

  .section-heading-right {
    text-align: right;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #F0EBE4;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 24px;
    left: 24px;
    right: 28px;
    bottom: 20px;
    border: 1px solid #D6CFC6;
    border-radius: 3px 10px 6px 14px;
    pointer-events: none;
    opacity: 0.5;
  }

  .about-content {
    max-width: 580px;
    margin: 0 0 0 auto;
    padding-right: 5%;
  }

  .about-paragraph {
    font-family: 'Cormorant', serif;
    font-weight: 400;
    font-size: 1.2rem;
    line-height: 2.0;
    margin: 0 0 28px 0;
    color: #8B8680;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #F5F0EA;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 20px 24px;
  }

  .char-card {
    border: 1px solid #D6CFC6;
    border-radius: 4px 12px 6px 10px;
    padding: 36px 28px 28px;
    position: relative;
    background: #F5F0EA;
    transition: box-shadow 0.4s, border-color 0.4s;
  }

  .char-card:nth-child(even) {
    border-radius: 10px 4px 12px 6px;
    transform: translateY(12px);
  }

  .char-card:hover {
    box-shadow: 0 4px 24px rgba(107, 101, 96, 0.06);
    border-color: #B5A18E;
  }

  .char-number {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.75rem;
    color: #B5A18E;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.1em;
  }

  .char-divider {
    width: 20px;
    height: 1px;
    background: linear-gradient(90deg, #B5A18E 60%, transparent 61%, transparent 70%, #B5A18E 71%);
    margin-bottom: 14px;
  }

  .char-title {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.25rem;
    margin: 0 0 12px 0;
    color: #6B6560;
  }

  .char-description {
    font-family: 'Cormorant', serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.8;
    margin: 0;
    color: #A39E96;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #F0EBE4;
  }

  .prompt-block {
    border: 1px solid #D6CFC6;
    border-radius: 6px 14px 4px 10px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid #D6CFC6;
    background: rgba(181, 161, 142, 0.08);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Cormorant', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.8rem;
    color: #A39E96;
    letter-spacing: 0.05em;
    text-transform: lowercase;
  }

  .copy-button {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    background: transparent;
    color: #6B6560;
    border: 1px solid #D6CFC6;
    border-radius: 2px 6px 4px 8px;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.3s, border-color 0.3s;
  }

  .copy-button:hover {
    background: rgba(181, 161, 142, 0.12);
    border-color: #B5A18E;
  }

  .copy-button.copied {
    background: rgba(181, 161, 142, 0.18);
    border-color: #B5A18E;
  }

  .prompt-text {
    font-family: 'Cormorant', serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.9;
    color: #8B8680;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #F5F0EA;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 0 0 auto;
  }

  .use-column {
    border: 1px solid #D6CFC6;
    overflow: hidden;
    position: relative;
  }

  .use-good {
    border-radius: 4px 12px 6px 10px;
  }

  .use-bad {
    border-radius: 10px 4px 12px 6px;
  }

  .use-column-heading {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.05rem;
    margin: 0;
    padding: 16px 22px;
    border-bottom: 1px solid #D6CFC6;
  }

  .use-good .use-column-heading {
    background: rgba(122, 139, 105, 0.08);
    color: #7A8B69;
  }

  .use-bad .use-column-heading {
    background: rgba(139, 134, 128, 0.06);
    color: #A39E96;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Cormorant', serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(214, 207, 198, 0.5);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #8B8680;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 1px 3px 2px 4px;
    background: #7A8B69;
    flex-shrink: 0;
    margin-top: 8px;
    opacity: 0.7;
  }

  .use-item-bad::before {
    content: '\2013';
    color: #C8C0B6;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #F0EBE4;
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 28px;
    right: 24px;
    bottom: 24px;
    border: 1px solid #D6CFC6;
    border-radius: 10px 3px 14px 6px;
    pointer-events: none;
    opacity: 0.5;
  }

  .history-content {
    max-width: 580px;
    margin: 0;
    padding-left: 5%;
  }

  .history-paragraph {
    font-family: 'Cormorant', serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 2.0;
    margin: 0 0 28px 0;
    color: #8B8680;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #F5F0EA;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 18px;
    max-width: 780px;
    margin: 0 0 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    padding: 28px 22px;
    border: 1px solid #D6CFC6;
    text-decoration: none;
    color: #8B8680;
    position: relative;
    transition: box-shadow 0.4s, border-color 0.4s;
  }

  .related-card:nth-child(1) { border-radius: 4px 12px 6px 10px; }
  .related-card:nth-child(2) { border-radius: 10px 4px 12px 6px; }
  .related-card:nth-child(3) { border-radius: 6px 10px 4px 12px; }
  .related-card:nth-child(4) { border-radius: 12px 6px 10px 4px; }
  .related-card:nth-child(5) { border-radius: 3px 14px 8px 10px; }

  .related-card:hover {
    box-shadow: 0 4px 20px rgba(107, 101, 96, 0.06);
    border-color: #B5A18E;
  }

  .related-relationship {
    font-family: 'Cormorant', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.72rem;
    color: #B5A18E;
    letter-spacing: 0.05em;
    text-transform: lowercase;
  }

  .related-name {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1.15rem;
    color: #6B6560;
  }

  .related-arrow {
    font-size: 0.9rem;
    color: #C8C0B6;
    margin-top: auto;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #F0EBE4;
    padding: 72px 32px;
    border-top: 1px solid #D6CFC6;
  }

  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .footer-crack {
    width: 50px;
    height: 1px;
    background: linear-gradient(90deg, #C8C0B6 0%, #C8C0B6 40%, transparent 41%, transparent 50%, #C8C0B6 51%, #C8C0B6 100%);
    opacity: 0.6;
  }

  .footer-logo {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: #6B6560;
    text-decoration: none;
    padding: 8px 24px;
    border: 1px solid #D6CFC6;
    border-radius: 6px 2px 8px 4px;
    transition: background 0.3s;
  }

  .footer-logo:hover {
    background: rgba(181, 161, 142, 0.1);
  }

  .footer-tagline {
    font-family: 'Cormorant', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: #A39E96;
  }

  .footer-back {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.9rem;
    color: #6B6560;
    text-decoration: none;
    padding: 6px 20px;
    border: 1px solid transparent;
    border-radius: 2px 8px 4px 6px;
    transition: border-color 0.3s;
  }

  .footer-back:hover {
    border-color: #D6CFC6;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 80px 24px 64px;
    }

