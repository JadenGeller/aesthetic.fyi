---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700&display=swap" rel="stylesheet" />

<div class="corp-page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-blobs" aria-hidden="true">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
      <div class="blob blob-4"></div>
    </div>
    <div class="hero-inner">
      <div class="hero-badge">Web Aesthetic</div>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
      <!-- CSS illustration: three friendly abstract people -->
      <div class="hero-people" aria-hidden="true">
        <div class="person person-1">
          <div class="person-head"></div>
          <div class="person-body"></div>
        </div>
        <div class="person person-2">
          <div class="person-head"></div>
          <div class="person-body"></div>
        </div>
        <div class="person person-3">
          <div class="person-head"></div>
          <div class="person-body"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <h2 class="section-heading">What This Is</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="body-text">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class={`char-card char-card-${i % 6}`}>
            <div class="char-icon" aria-hidden="true">
              <div class={`char-shape char-shape-${i % 6}`}></div>
            </div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <h2 class="section-heading">Style Reference</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <pre class="prompt-text">{aesthetic.prompt}</pre>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <h2 class="section-heading">When to Use</h2>
      <div class="use-columns">
        <div class="use-column use-column-good">
          <h3 class="use-heading use-heading-good">Good for</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-column-not">
          <h3 class="use-heading use-heading-not">Not for</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-not">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="body-text">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <h2 class="section-heading section-heading-white">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; All aesthetics</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     BASE
     ======================================== */
  .corp-page {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    background: #ffffff;
    color: #1A1A2E;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background: #ffffff;
    border-bottom: 1px solid #E8E8EF;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-logo {
    font-weight: 700;
    font-size: 0.95rem;
    color: #6C5CE7;
    text-decoration: none;
    padding: 6px 16px;
    background: #F0EDFF;
    border-radius: 9999px;
    letter-spacing: 0.01em;
    transition: background 0.2s ease;
  }

  .nav-logo:hover {
    background: #E4DFFF;
  }

  .nav-divider {
    font-size: 1rem;
    color: #C8C8D4;
    margin: 0 4px;
  }

  .nav-current {
    font-weight: 600;
    font-size: 0.9rem;
    color: #1A1A2E;
    text-decoration: none;
    padding: 6px 14px;
  }

  .nav-current:hover {
    color: #6C5CE7;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: linear-gradient(135deg, #6C5CE7 0%, #74B9FF 60%, #00B894 100%);
    padding: 80px 24px 88px;
    position: relative;
    overflow: hidden;
  }

  .hero-blobs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    opacity: 0.15;
  }

  .blob-1 {
    width: 300px;
    height: 300px;
    background: #ffffff;
    top: -60px;
    right: -40px;
    border-radius: 50% 50% 50% 30%;
  }

  .blob-2 {
    width: 180px;
    height: 180px;
    background: #FF6B6B;
    bottom: -40px;
    left: 10%;
    opacity: 0.12;
  }

  .blob-3 {
    width: 120px;
    height: 120px;
    background: #ffffff;
    top: 30%;
    left: 5%;
    opacity: 0.1;
  }

  .blob-4 {
    width: 80px;
    height: 80px;
    background: #00B894;
    top: 15%;
    right: 25%;
    opacity: 0.2;
    border-radius: 30% 50% 50% 50%;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-badge {
    display: inline-block;
    font-weight: 600;
    font-size: 0.8rem;
    color: #ffffff;
    background: rgba(255, 255, 255, 0.2);
    padding: 6px 18px;
    border-radius: 9999px;
    margin-bottom: 20px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .hero-title {
    font-weight: 700;
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    line-height: 1.05;
    margin: 0 0 20px 0;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .hero-tagline {
    font-weight: 400;
    font-size: clamp(1.05rem, 2.5vw, 1.35rem);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    max-width: 480px;
  }

  /* CSS Illustration: People */
  .hero-people {
    display: flex;
    gap: 24px;
    margin-top: 40px;
  }

  .person {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .person-head {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.35);
  }

  .person-body {
    width: 22px;
    height: 32px;
    border-radius: 8px 8px 4px 4px;
    background: rgba(255, 255, 255, 0.25);
  }

  .person-1 .person-head { background: rgba(255, 107, 107, 0.5); }
  .person-1 .person-body { background: rgba(255, 107, 107, 0.35); }

  .person-2 .person-head { background: rgba(0, 184, 148, 0.5); }
  .person-2 .person-body { background: rgba(0, 184, 148, 0.35); }

  .person-3 .person-head { background: rgba(116, 185, 255, 0.5); }
  .person-3 .person-body { background: rgba(116, 185, 255, 0.35); }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 80px 24px;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-heading {
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    line-height: 1.1;
    margin: 0 0 40px 0;
    color: #1A1A2E;
    letter-spacing: -0.01em;
  }

  .section-heading-white {
    color: #ffffff;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #ffffff;
  }

  .about-content {
    max-width: 720px;
  }

  .body-text {
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.8;
    margin: 0 0 20px 0;
    color: #3A3A52;
  }

  .body-text:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #F8F9FA;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }

  .char-card {
    background: #ffffff;
    padding: 28px 24px 24px;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .char-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
  }

  .char-icon {
    margin-bottom: 16px;
  }

  .char-shape {
    width: 40px;
    height: 40px;
    border-radius: 10px;
  }

  .char-shape-0 { background: #F0EDFF; }
  .char-shape-1 { background: #E8FAF5; }
  .char-shape-2 { background: #FFE8E8; }
  .char-shape-3 { background: #E8F4FF; }
  .char-shape-4 { background: #FFF3E8; }
  .char-shape-5 { background: #F0FFF0; }

  .char-card-0 { border-top: 3px solid #6C5CE7; }
  .char-card-1 { border-top: 3px solid #00B894; }
  .char-card-2 { border-top: 3px solid #FF6B6B; }
  .char-card-3 { border-top: 3px solid #74B9FF; }
  .char-card-4 { border-top: 3px solid #FDCB6E; }
  .char-card-5 { border-top: 3px solid #00B894; }

  .char-title {
    font-weight: 700;
    font-size: 1.2rem;
    margin: 0 0 8px 0;
    color: #1A1A2E;
    letter-spacing: -0.01em;
  }

  .char-description {
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
    color: #5A5A72;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #ffffff;
  }

  .prompt-block {
    background: #1A1A2E;
    border-radius: 12px;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    background: #252540;
  }

  .prompt-label {
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.5);
  }

  .copy-button {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    background: #6C5CE7;
    color: #ffffff;
    border: none;
    border-radius: 9999px;
    padding: 8px 22px;
    cursor: pointer;
    letter-spacing: 0.03em;
    transition: background 0.2s ease;
  }

  .copy-button:hover {
    background: #5A4BD1;
  }

  .copy-button.copied {
    background: #00B894;
  }

  .prompt-text {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.8);
    padding: 24px;
    margin: 0;
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #F8F9FA;
  }

  .use-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .use-column {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .use-heading {
    font-weight: 700;
    font-size: 1rem;
    margin: 0;
    padding: 16px 24px;
    color: #ffffff;
    letter-spacing: 0.02em;
  }

  .use-heading-good {
    background: #00B894;
  }

  .use-heading-not {
    background: #FF6B6B;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
    background: #ffffff;
  }

  .use-item {
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    padding: 14px 24px;
    border-bottom: 1px solid #F0F0F5;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #3A3A52;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '\2713';
    font-weight: 700;
    color: #00B894;
    flex-shrink: 0;
  }

  .use-item-not::before {
    content: '\2717';
    font-weight: 700;
    color: #FF6B6B;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #ffffff;
  }

  .history-content {
    max-width: 720px;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: linear-gradient(135deg, #6C5CE7 0%, #74B9FF 100%);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 24px;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    text-decoration: none;
    color: #ffffff;
    position: relative;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .related-card:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: translateY(-2px);
  }

  .related-relationship {
    font-weight: 400;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.7;
  }

  .related-name {
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
  }

  .related-arrow {
    font-size: 1.1rem;
    position: absolute;
    bottom: 20px;
    right: 20px;
    opacity: 0.6;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #1A1A2E;
    padding: 48px 24px;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-align: center;
  }

  .footer-logo {
    font-weight: 700;
    font-size: 1rem;
    color: #ffffff;
    text-decoration: none;
    padding: 8px 22px;
    background: #6C5CE7;
    border-radius: 9999px;
    transition: background 0.2s ease;
  }

  .footer-logo:hover {
    background: #5A4BD1;
  }

  .footer-tagline {
    font-weight: 400;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.45);
  }

  .footer-back {
    font-weight: 600;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    padding: 8px 22px;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 9999px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .footer-back:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 56px 20px 60px;
    }

    .section {
      padding: 56px 20px;
    }

    .section-heading {
      margin-bottom: 28px;
    }

    .characteristics-grid {
      grid-template-columns: 1fr;
    }

    .use-columns {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .hero-blobs .blob-1 {
      width: 180px;
      height: 180px;
    }

    .hero-people {
      gap: 16px;
      margin-top: 32px;
    }

    .prompt-header {
      padding: 12px 16px;
      flex-wrap: wrap;
      gap: 10px;
    }

    .prompt-text {
      padding: 20px 16px;
      font-size: 0.85rem;
    }

    .nav-inner {
      padding: 12px 16px;
    }

    .footer {
      padding: 36px 20px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 40px 16px 48px;
    }

    .section {
      padding: 40px 16px;
    }

    .nav-inner {
      padding: 10px 12px;
      gap: 6px;
    }

    .nav-logo {
      font-size: 0.85rem;
      padding: 5px 12px;
    }

    .nav-current {
      font-size: 0.8rem;
      padding: 5px 10px;
    }

    .char-card {
      padding: 22px 18px 18px;
    }

    .copy-button {
      padding: 6px 16px;
      font-size: 0.75rem;
    }

    .use-item {
      padding: 12px 16px;
      font-size: 0.95rem;
    }

    .related-card {
      padding: 18px;
    }

    .hero-people {
      gap: 12px;
    }

    .person-head {
      width: 22px;
      height: 22px;
    }

    .person-body {
      width: 18px;
      height: 26px;
    }
  }
</style>
