---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider"></span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-line"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">East Meets North</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy & Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Place, Wrong Place</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    background-color: #F7F4EF;
    color: #3D3834;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid #DDD0C0;
    background: #F7F4EF;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
  }

  .nav-logo {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    color: #3D3834;
    text-decoration: none;
    letter-spacing: 0.04em;
    padding: 6px 16px;
    border: 1px solid #DDD0C0;
    border-radius: 3px;
    transition: background 0.3s, border-color 0.3s;
  }

  .nav-logo:hover {
    background: rgba(221, 208, 192, 0.2);
    border-color: #9B9590;
  }

  .nav-divider {
    width: 20px;
    height: 1px;
    background: #DDD0C0;
  }

  .nav-current {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    color: #9B9590;
    text-decoration: none;
    letter-spacing: 0.04em;
    padding: 6px 16px;
    border: 1px solid transparent;
    border-radius: 3px;
    transition: border-color 0.3s;
  }

  .nav-current:hover {
    border-color: #DDD0C0;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #F7F4EF;
    padding: 120px 32px 100px;
    text-align: center;
    position: relative;
    border-bottom: 1px solid #DDD0C0;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    color: #9B9590;
    display: inline-block;
    margin-bottom: 32px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: clamp(3.2rem, 10vw, 6rem);
    line-height: 1;
    margin: 0 0 32px 0;
    color: #3D3834;
    letter-spacing: -0.02em;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 32px;
  }

  .hero-line {
    width: 48px;
    height: 1px;
    background: #DDD0C0;
  }

  .hero-tagline {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    line-height: 1.8;
    margin: 0 auto;
    max-width: 480px;
    color: #9B9590;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 96px 32px;
    border-bottom: 1px solid #DDD0C0;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 60px;
    height: 1px;
    background: #DDD0C0;
  }

  .section-label {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    color: #9B9590;
    white-space: nowrap;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    line-height: 1.15;
    margin: 0 0 56px 0;
    text-align: center;
    color: #3D3834;
    letter-spacing: -0.01em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #F3EFE9;
  }

  .about-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: left;
  }

  .about-paragraph {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.95;
    margin: 0 0 28px 0;
    color: #3D3834;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #F7F4EF;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .char-card {
    border: 1px solid #DDD0C0;
    border-radius: 3px;
    padding: 36px 28px 28px;
    position: relative;
    text-align: left;
    background: #F7F4EF;
    transition: box-shadow 0.3s, border-color 0.3s;
  }

  .char-card:hover {
    box-shadow: 0 2px 12px rgba(61, 56, 52, 0.05);
    border-color: #9B9590;
  }

  .char-number {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 0.7rem;
    color: #9B9590;
    display: block;
    margin-bottom: 12px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 24px;
    height: 1px;
    background: #DDD0C0;
    margin: 0 0 16px;
  }

  .char-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    margin: 0 0 12px 0;
    color: #3D3834;
    letter-spacing: 0.01em;
  }

  .char-description {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.75;
    margin: 0;
    color: #9B9590;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #F3EFE9;
  }

  .prompt-block {
    border: 1px solid #DDD0C0;
    border-radius: 3px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid #DDD0C0;
    background: rgba(221, 208, 192, 0.12);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    color: #9B9590;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    background: transparent;
    color: #3D3834;
    border: 1px solid #DDD0C0;
    border-radius: 3px;
    padding: 6px 20px;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: background 0.3s, border-color 0.3s;
  }

  .copy-button:hover {
    background: rgba(221, 208, 192, 0.25);
    border-color: #9B9590;
  }

  .copy-button.copied {
    background: rgba(221, 208, 192, 0.35);
    border-color: #9B9590;
  }

  .prompt-text {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.85;
    color: #3D3834;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #F7F4EF;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid #DDD0C0;
    border-radius: 3px;
    overflow: hidden;
    position: relative;
  }

  .use-column-heading {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    margin: 0;
    padding: 16px 22px;
    text-align: left;
    border-bottom: 1px solid #DDD0C0;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .use-good .use-column-heading {
    background: rgba(221, 208, 192, 0.15);
    color: #3D3834;
  }

  .use-bad .use-column-heading {
    background: rgba(61, 56, 52, 0.03);
    color: #9B9590;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(221, 208, 192, 0.5);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: #3D3834;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #DDD0C0;
    flex-shrink: 0;
    margin-top: 7px;
  }

  .use-item-bad::before {
    content: '\2013';
    color: #9B9590;
    flex-shrink: 0;
    font-weight: 300;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #F3EFE9;
  }

  .history-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: left;
  }

  .history-paragraph {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.95;
    margin: 0 0 28px 0;
    color: #3D3834;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #F7F4EF;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    padding: 28px 24px;
    border: 1px solid #DDD0C0;
    border-radius: 3px;
    text-decoration: none;
    color: #3D3834;
    text-align: left;
    position: relative;
    transition: box-shadow 0.3s, border-color 0.3s;
  }

  .related-card:hover {
    box-shadow: 0 2px 12px rgba(61, 56, 52, 0.05);
    border-color: #9B9590;
  }

  .related-relationship {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    color: #9B9590;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .related-name {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 1.15rem;
    color: #3D3834;
  }

  .related-arrow {
    font-size: 0.9rem;
    color: #DDD0C0;
    margin-top: 4px;
    transition: color 0.3s;
  }

  .related-card:hover .related-arrow {
    color: #9B9590;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #F3EFE9;
    padding: 72px 32px;
    border-top: 1px solid #DDD0C0;
  }

  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-ornament {
    width: 48px;
    height: 1px;
    background: #DDD0C0;
  }

  .footer-logo {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    color: #3D3834;
    text-decoration: none;
    padding: 8px 20px;
    border: 1px solid #DDD0C0;
    border-radius: 3px;
    letter-spacing: 0.04em;
    transition: background 0.3s;
  }

  .footer-logo:hover {
    background: rgba(221, 208, 192, 0.2);
  }

  .footer-tagline {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    color: #9B9590;
    letter-spacing: 0.04em;
  }

  .footer-back {
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    color: #3D3834;
    text-decoration: none;
    padding: 6px 20px;
    border: 1px solid transparent;
    border-radius: 3px;
    letter-spacing: 0.04em;
    transition: border-color 0.3s;
  }

  .footer-back:hover {
    border-color: #DDD0C0;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 80px 24px 64px;
    }

    .section {
      padding: 72px 24px;
    }

    .section-heading {
      margin-bottom: 40px;
    }

    .characteristics-grid {
      grid-template-columns: 1fr;
    }

    .use-grid {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .prompt-text {
      font-size: 0.88rem;
      padding: 22px 18px;
    }

    .prompt-header {
      padding: 12px 18px;
      flex-wrap: wrap;
      gap: 10px;
    }

    .nav-inner {
      padding: 12px 20px;
    }

    .footer {
      padding: 56px 24px;
    }

    .about-content,
    .history-content {
      text-align: left;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 56px 16px 44px;
    }

    .section {
      padding: 52px 16px;
    }

    .nav-inner {
      padding: 10px 16px;
      gap: 12px;
    }

    .nav-logo {
      font-size: 0.85rem;
      padding: 5px 12px;
    }

    .nav-current {
      font-size: 0.8rem;
      padding: 5px 10px;
    }

    .char-card {
      padding: 28px 20px 22px;
    }

    .copy-button {
      padding: 5px 14px;
      font-size: 0.75rem;
    }

    .use-item {
      padding: 11px 16px;
      font-size: 0.85rem;
    }

    .related-card {
      padding: 22px 18px;
    }

    .section-header {
      gap: 12px;
    }

    .section-rule {
      max-width: 36px;
    }

    .hero-title {
      letter-spacing: -0.03em;
    }

    .about-paragraph,
    .history-paragraph {
      font-size: 0.95rem;
      line-height: 1.85;
    }
  }
</style>
