---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-bar"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-grid-bg"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">The Protocol Layer</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-grid-bg"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Deploy or Revert</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-grid-bg"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Inter', sans-serif;
    background-color: #0D0B1A;
    color: #E8E6F0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     ANIMATIONS
     ======================================== */
  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes glowPulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.8; }
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid rgba(123, 47, 190, 0.2);
    background: rgba(13, 11, 26, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #E8E6F0;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid rgba(123, 47, 190, 0.3);
    border-radius: 10px;
    background: rgba(123, 47, 190, 0.08);
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  .nav-logo:hover {
    background: rgba(123, 47, 190, 0.15);
    border-color: rgba(123, 47, 190, 0.5);
    box-shadow: 0 0 16px rgba(123, 47, 190, 0.15);
  }

  .nav-divider {
    font-size: 1rem;
    color: rgba(123, 47, 190, 0.4);
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    color: rgba(232, 230, 240, 0.6);
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid transparent;
    border-radius: 10px;
    transition: border-color 0.3s, color 0.3s;
  }

  .nav-current:hover {
    border-color: rgba(123, 47, 190, 0.2);
    color: #E8E6F0;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #0D0B1A;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(123, 47, 190, 0.15);
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(123, 47, 190, 0.08) 0%, transparent 40%, rgba(41, 98, 255, 0.06) 60%, transparent 80%, rgba(0, 191, 165, 0.05) 100%);
    background-size: 200% 200%;
    animation: gradientShift 12s ease infinite;
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(0deg, rgba(123, 47, 190, 0.04) 0px, rgba(123, 47, 190, 0.04) 1px, transparent 1px, transparent 60px),
      repeating-linear-gradient(90deg, rgba(123, 47, 190, 0.04) 0px, rgba(123, 47, 190, 0.04) 1px, transparent 1px, transparent 60px);
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(123, 47, 190, 0.12) 0%, rgba(41, 98, 255, 0.06) 40%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
    animation: glowPulse 6s ease-in-out infinite;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.75rem;
    color: rgba(0, 191, 165, 0.8);
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 6px 16px;
    border: 1px solid rgba(0, 191, 165, 0.2);
    border-radius: 20px;
    background: rgba(0, 191, 165, 0.06);
  }

  .hero-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.05;
    margin: 0 0 24px 0;
    background: linear-gradient(135deg, #E8E6F0 0%, #7B2FBE 40%, #2962FF 70%, #00BFA5 100%);
    background-size: 200% 200%;
    animation: gradientShift 8s ease infinite;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }

  .hero-bar {
    width: 80px;
    height: 2px;
    background: linear-gradient(90deg, #7B2FBE, #2962FF, #00BFA5);
    border-radius: 1px;
  }

  .hero-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 520px;
    color: rgba(232, 230, 240, 0.6);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 1px solid rgba(123, 47, 190, 0.12);
    position: relative;
    overflow: hidden;
  }

  .section-grid-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(0deg, rgba(123, 47, 190, 0.025) 0px, rgba(123, 47, 190, 0.025) 1px, transparent 1px, transparent 80px),
      repeating-linear-gradient(90deg, rgba(123, 47, 190, 0.025) 0px, rgba(123, 47, 190, 0.025) 1px, transparent 1px, transparent 80px);
    pointer-events: none;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(123, 47, 190, 0.4), transparent);
  }

  .section-label {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.7rem;
    color: rgba(0, 191, 165, 0.7);
    white-space: nowrap;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #E8E6F0;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #0F0D1F;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: rgba(232, 230, 240, 0.75);
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #0D0B1A;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 1px solid rgba(123, 47, 190, 0.15);
    border-radius: 14px;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: box-shadow 0.3s, border-color 0.3s, background 0.3s;
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: -1px;
    left: -1px;
    right: -1px;
    bottom: -1px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(123, 47, 190, 0.2), rgba(41, 98, 255, 0.1), rgba(0, 191, 165, 0.1));
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .char-card:hover {
    box-shadow: 0 4px 30px rgba(123, 47, 190, 0.12), 0 0 20px rgba(41, 98, 255, 0.06);
    border-color: rgba(123, 47, 190, 0.3);
    background: rgba(255, 255, 255, 0.05);
  }

  .char-card:hover::before {
    opacity: 1;
  }

  .char-number {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: rgba(0, 191, 165, 0.6);
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 32px;
    height: 2px;
    background: linear-gradient(90deg, #7B2FBE, #2962FF);
    margin: 0 auto 14px;
    border-radius: 1px;
  }

  .char-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin: 0 0 12px 0;
    color: #E8E6F0;
  }

  .char-description {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.75;
    margin: 0;
    color: rgba(232, 230, 240, 0.55);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #0F0D1F;
  }

  .prompt-block {
    border: 1px solid rgba(123, 47, 190, 0.2);
    border-radius: 14px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(123, 47, 190, 0.15);
    background: rgba(123, 47, 190, 0.06);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.7rem;
    color: rgba(0, 191, 165, 0.7);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    background: rgba(123, 47, 190, 0.12);
    color: #E8E6F0;
    border: 1px solid rgba(123, 47, 190, 0.3);
    border-radius: 8px;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
    letter-spacing: 0.05em;
  }

  .copy-button:hover {
    background: rgba(123, 47, 190, 0.2);
    border-color: rgba(123, 47, 190, 0.5);
    box-shadow: 0 0 12px rgba(123, 47, 190, 0.15);
  }

  .copy-button.copied {
    background: rgba(0, 191, 165, 0.15);
    border-color: rgba(0, 191, 165, 0.4);
    box-shadow: 0 0 12px rgba(0, 191, 165, 0.15);
  }

  .prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.85;
    color: rgba(232, 230, 240, 0.7);
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #0D0B1A;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid rgba(123, 47, 190, 0.15);
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .use-column-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 1px solid rgba(123, 47, 190, 0.12);
  }

  .use-good .use-column-heading {
    background: rgba(0, 191, 165, 0.06);
    color: rgba(0, 191, 165, 0.9);
  }

  .use-bad .use-column-heading {
    background: rgba(123, 47, 190, 0.06);
    color: rgba(232, 230, 240, 0.5);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(123, 47, 190, 0.08);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: rgba(232, 230, 240, 0.7);
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00BFA5;
    flex-shrink: 0;
    margin-top: 7px;
    box-shadow: 0 0 6px rgba(0, 191, 165, 0.4);
  }

  .use-item-bad::before {
    content: '\2013';
    color: rgba(123, 47, 190, 0.4);
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #0F0D1F;
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: rgba(232, 230, 240, 0.75);
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #0D0B1A;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 28px 20px;
    border: 1px solid rgba(123, 47, 190, 0.15);
    border-radius: 14px;
    text-decoration: none;
    color: #E8E6F0;
    text-align: center;
    position: relative;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: box-shadow 0.3s, border-color 0.3s, background 0.3s;
  }

  .related-card:hover {
    box-shadow: 0 4px 24px rgba(123, 47, 190, 0.12), 0 0 16px rgba(41, 98, 255, 0.06);
    border-color: rgba(123, 47, 190, 0.3);
    background: rgba(255, 255, 255, 0.04);
  }

  .related-relationship {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.65rem;
    color: rgba(0, 191, 165, 0.6);
    letter-spacing: 0.1em;
    text-transform: uppercase;
