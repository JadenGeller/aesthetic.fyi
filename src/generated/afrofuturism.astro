---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Nunito:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-starfield"></div>
    <div class="hero-chevrons"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-diamond"></span>
        <span class="hero-line"></span>
        <span class="hero-diamond"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">A Cosmic Declaration</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Orbit, Wrong Orbit</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Nunito', sans-serif;
    background-color: #0D0D0D;
    color: #E8E0D0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid rgba(212, 175, 55, 0.3);
    background: linear-gradient(180deg, #1A0F3D, #0D0D0D);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: #D4AF37;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid rgba(212, 175, 55, 0.4);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background 0.3s, border-color 0.3s;
    clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    padding-left: 22px;
    padding-right: 22px;
  }

  .nav-logo:hover {
    background: rgba(212, 175, 55, 0.1);
    border-color: #D4AF37;
  }

  .nav-divider {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.9rem;
    color: rgba(212, 175, 55, 0.4);
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Orbitron', sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    color: #00CED1;
    text-decoration: none;
    padding: 6px 18px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid transparent;
    transition: border-color 0.3s;
  }

  .nav-current:hover {
    border-color: rgba(0, 206, 209, 0.3);
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: linear-gradient(170deg, #2D1B69 0%, #1A0F3D 40%, #0D0D0D 100%);
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(212, 175, 55, 0.3);
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      linear-gradient(135deg, transparent 48%, rgba(0, 206, 209, 0.03) 50%, transparent 52%),
      linear-gradient(45deg, transparent 48%, rgba(212, 175, 55, 0.03) 50%, transparent 52%);
    background-size: 60px 60px;
    pointer-events: none;
  }

  /* Starfield effect */
  .hero-starfield {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle 1.5px at 10% 15%, #D4AF37 100%, transparent 100%),
      radial-gradient(circle 1px at 20% 45%, rgba(255, 255, 255, 0.7) 100%, transparent 100%),
      radial-gradient(circle 1.5px at 35% 10%, rgba(255, 255, 255, 0.8) 100%, transparent 100%),
      radial-gradient(circle 1px at 45% 60%, #D4AF37 100%, transparent 100%),
      radial-gradient(circle 2px at 55% 20%, rgba(212, 175, 55, 0.6) 100%, transparent 100%),
      radial-gradient(circle 1px at 65% 75%, rgba(255, 255, 255, 0.6) 100%, transparent 100%),
      radial-gradient(circle 1.5px at 75% 35%, rgba(255, 255, 255, 0.9) 100%, transparent 100%),
      radial-gradient(circle 1px at 85% 55%, #D4AF37 100%, transparent 100%),
      radial-gradient(circle 1px at 15% 80%, rgba(255, 255, 255, 0.5) 100%, transparent 100%),
      radial-gradient(circle 1.5px at 90% 85%, rgba(212, 175, 55, 0.7) 100%, transparent 100%),
      radial-gradient(circle 1px at 30% 70%, rgba(0, 206, 209, 0.5) 100%, transparent 100%),
      radial-gradient(circle 1px at 50% 40%, rgba(255, 255, 255, 0.6) 100%, transparent 100%),
      radial-gradient(circle 2px at 70% 90%, rgba(0, 206, 209, 0.4) 100%, transparent 100%),
      radial-gradient(circle 1px at 5% 50%, rgba(255, 255, 255, 0.5) 100%, transparent 100%),
      radial-gradient(circle 1px at 95% 10%, rgba(212, 175, 55, 0.5) 100%, transparent 100%),
      radial-gradient(circle 1px at 40% 30%, rgba(255, 255, 255, 0.4) 100%, transparent 100%),
      radial-gradient(circle 1.5px at 80% 65%, rgba(255, 255, 255, 0.7) 100%, transparent 100%),
      radial-gradient(circle 1px at 25% 90%, rgba(212, 175, 55, 0.4) 100%, transparent 100%),
      radial-gradient(circle 1px at 60% 5%, rgba(255, 255, 255, 0.6) 100%, transparent 100%),
      radial-gradient(circle 1px at 92% 40%, rgba(0, 206, 209, 0.3) 100%, transparent 100%);
    opacity: 0.7;
    pointer-events: none;
  }

  /* African-inspired chevron border pattern */
  .hero-chevrons {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40px;
    background:
      linear-gradient(135deg, #D4AF37 25%, transparent 25%) -20px 0,
      linear-gradient(225deg, #D4AF37 25%, transparent 25%) -20px 0,
      linear-gradient(315deg, #D4AF37 25%, transparent 25%),
      linear-gradient(45deg, #D4AF37 25%, transparent 25%);
    background-size: 40px 40px;
    background-color: transparent;
    opacity: 0.12;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Orbitron', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    color: #00CED1;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 9vw, 5rem);
    line-height: 1.1;
    margin: 0 0 24px 0;
    color: #D4AF37;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-shadow: 0 0 40px rgba(212, 175, 55, 0.3);
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .hero-diamond {
    width: 8px;
    height: 8px;
    background: #D4AF37;
    transform: rotate(45deg);
  }

  .hero-line {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, rgba(212, 175, 55, 0.2), #D4AF37, rgba(212, 175, 55, 0.2));
  }

  .hero-tagline {
    font-family: 'Nunito', sans-serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.8;
    margin: 0 auto;
    max-width: 520px;
    color: rgba(232, 224, 208, 0.7);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 1px solid rgba(212, 175, 55, 0.15);
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #D4AF37, transparent);
  }

  .section-label {
    font-family: 'Orbitron', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    color: #00CED1;
    white-space: nowrap;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: clamp(1.6rem, 5vw, 2.5rem);
    line-height: 1.2;
    margin: 0 0 48px 0;
    text-align: center;
    color: #D4AF37;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: linear-gradient(180deg, #0D0D0D, #1A0F3D 50%, #0D0D0D);
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 1px solid rgba(212, 175, 55, 0.15);
    pointer-events: none;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Nunito', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: rgba(232, 224, 208, 0.85);
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #0D0D0D;
    overflow: hidden;
  }

  /* Triangle pattern across the top */
  .characteristics-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 24px;
    background:
      linear-gradient(135deg, #D4AF37 33.33%, transparent 33.33%) 0 0,
      linear-gradient(225deg, #D4AF37 33.33%, transparent 33.33%) 0 0;
    background-size: 24px 24px;
    opacity: 0.08;
    pointer-events: none;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 1px solid rgba(212, 175, 55, 0.25);
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: linear-gradient(180deg, rgba(45, 27, 105, 0.3), rgba(13, 13, 13, 0.9));
    transition: box-shadow 0.3s, border-color 0.3s;
    clip-path: polygon(12px 0, 100% 0, calc(100% - 12px) 100%, 0 100%);
    padding-left: 36px;
    padding-right: 36px;
  }

  .char-card:hover {
    box-shadow: 0 4px 30px rgba(212, 175, 55, 0.12);
    border-color: rgba(212, 175, 55, 0.5);
  }

  .char-number {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: #00CED1;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 32px;
    height: 2px;
    background: linear-gradient(90deg, #D4AF37, rgba(0, 206, 209, 0.5));
    margin: 0 auto 14px;
  }

  .char-title {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    margin: 0 0 12px 0;
    color: #D4AF37;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .char-description {
    font-family: 'Nunito', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    margin: 0;
    color: rgba(232, 224, 208, 0.6);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: linear-gradient(180deg, #0D0D0D, #1A0F3D 50%, #0D0D0D);
  }

  .prompt-block {
    border: 1px solid rgba(212, 175, 55, 0.3);
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(212, 175, 55, 0.2);
    background: rgba(45, 27, 105, 0.3);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Orbitron', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    color: #00CED1;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    background: transparent;
    color: #D4AF37;
    border: 1px solid rgba(212, 175, 55, 0.4);
    padding: 6px 20px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: background 0.3s, border-color 0.3s;
    clip-path: polygon(6px 0, 100% 0, calc(100% - 6px) 100%, 0 100%);
    padding-left: 16px;
    padding-right: 16px;
  }

  .copy-button:hover {
    background: rgba(212, 175, 55, 0.15);
    border-color: #D4AF37;
  }

  .copy-button.copied {
    background: rgba(212, 175, 55, 0.2);
    border-color: #D4AF37;
    color: #00CED1;
  }

  .prompt-text {
    font-family: 'Nunito', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(232, 224, 208, 0.8);
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #0D0D0D;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid rgba(212, 175, 55, 0.2);
    overflow: hidden;
    position: relative;
  }

  .use-column-heading {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px solid rgba(212, 175, 55, 0.2);
  }

  .use-good .use-column-heading {
    background: rgba(212, 175, 55, 0.1);
    color: #D4AF37;
  }

  .use-bad .use-column-heading {
    background: rgba(0, 206, 209, 0.05);
    color: rgba(0, 206, 209, 0.7);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Nunito', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(212, 175, 55, 0.08);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: rgba(232, 224, 208, 0.75);
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 6px;
    height: 6px;
    background: #D4AF37;
    flex-shrink: 0;
    margin-top: 7px;
    transform: rotate(45deg);
  }

  .use-item-bad::before {
    content: '\2013';
    color: rgba(0, 206, 209, 0.5);
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: linear-gradient(180deg, #0D0D0D, #2D1B69 50%, #0D0D0D);
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 1px solid rgba(212, 175, 55, 0.12);
    pointer-events: none;
  }

  /* Starfield in history section */
  .history-section::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle 1px at 8% 25%, rgba(212, 175, 55, 0.4) 100%, transparent 100%),
      radial-gradient(circle 1px at 22% 65%, rgba(255, 255, 255, 0.3) 100%, transparent 100%),
