---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<div class="dash-page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
      <div class="nav-right" aria-hidden="true">
        <span class="status-dot status-green"></span>
        <span class="nav-status">All systems nominal</span>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <h1 class="hero-title">{aesthetic.name}</h1>
        <p class="hero-tagline">{aesthetic.tagline}</p>
      </div>
      <div class="hero-stats" aria-hidden="true">
        <div class="stat-card">
          <span class="stat-label">Page Views</span>
          <span class="stat-number">24,891</span>
          <span class="stat-change stat-positive">+12.4%</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Avg. Session</span>
          <span class="stat-number">3:42</span>
          <span class="stat-change stat-positive">+8.1%</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Bounce Rate</span>
          <span class="stat-number">23.6%</span>
          <span class="stat-change stat-negative">-2.3%</span>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-heading">What This Is</h2>
        <span class="section-badge">Overview</span>
      </div>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="body-text">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-heading">Characteristics</h2>
        <span class="section-badge">{aesthetic.characteristics.length} metrics</span>
      </div>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <div class="char-top">
              <span class="char-index">{String(i + 1).padStart(2, '0')}</span>
              <span class={`status-dot ${i % 3 === 0 ? 'status-indigo' : i % 3 === 1 ? 'status-green' : 'status-amber'}`}></span>
            </div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
            <div class="char-bar-chart" aria-hidden="true">
              <div class="bar" style={`height: ${55 + i * 8}%; background: ${i % 3 === 0 ? '#6366F1' : i % 3 === 1 ? '#10B981' : '#F59E0B'};`}></div>
              <div class="bar" style={`height: ${35 + i * 6}%; background: ${i % 3 === 0 ? '#6366F1' : i % 3 === 1 ? '#10B981' : '#F59E0B'}; opacity: 0.7;`}></div>
              <div class="bar" style={`height: ${65 + i * 4}%; background: ${i % 3 === 0 ? '#6366F1' : i % 3 === 1 ? '#10B981' : '#F59E0B'}; opacity: 0.85;`}></div>
              <div class="bar" style={`height: ${45 + i * 7}%; background: ${i % 3 === 0 ? '#6366F1' : i % 3 === 1 ? '#10B981' : '#F59E0B'}; opacity: 0.6;`}></div>
              <div class="bar" style={`height: ${70 + i * 3}%; background: ${i % 3 === 0 ? '#6366F1' : i % 3 === 1 ? '#10B981' : '#F59E0B'};`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-heading">Style Reference</h2>
        <span class="section-badge">Prompt</span>
      </div>
      <div class="prompt-block">
        <div class="prompt-header">
          <div class="prompt-label-row">
            <span class="status-dot status-indigo"></span>
            <span class="prompt-label">DESIGN SPEC</span>
          </div>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <pre class="prompt-text">{aesthetic.prompt}</pre>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-heading">When to Use</h2>
        <span class="section-badge">Analysis</span>
      </div>
      <div class="use-columns">
        <div class="use-column use-column-good">
          <div class="use-heading-bar use-heading-good">
            <span class="status-dot status-green"></span>
            <h3 class="use-heading">Good for</h3>
          </div>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-column-not">
          <div class="use-heading-bar use-heading-not">
            <span class="status-dot status-red"></span>
            <h3 class="use-heading">Not for</h3>
          </div>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-not">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-heading">History</h2>
        <span class="section-badge">Timeline</span>
      </div>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string, i: number) => (
          <div class="history-block">
            <div class="history-marker" aria-hidden="true">
              <span class="history-dot"></span>
              {i < aesthetic.history.split('\n\n').length - 1 && <span class="history-line"></span>}
            </div>
            <p class="body-text">{paragraph}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <h2 class="section-heading">Related Styles</h2>
        <span class="section-badge">{aesthetic.related.length} connections</span>
      </div>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }, i: number) => (
          <a href={`/${rel.slug}`} class="related-card">
            <div class="related-top">
              <span class={`status-dot ${i % 3 === 0 ? 'status-indigo' : i % 3 === 1 ? 'status-green' : 'status-amber'}`}></span>
              <span class="related-relationship">{rel.relationship}</span>
            </div>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-left">
        <a href="/" class="footer-logo">aesthetic.fyi</a>
        <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      </div>
      <div class="footer-right">
        <div class="footer-status" aria-hidden="true">
          <span class="status-dot status-green"></span>
          <span class="footer-status-text">Operational</span>
        </div>
        <a href="/" class="footer-back">&larr; All aesthetics</a>
      </div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     BASE
     ======================================== */
  .dash-page {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 400;
    background: #0F1117;
    color: #FFFFFF;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     STATUS DOTS
     ======================================== */
  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }

  .status-green {
    background: #10B981;
    box-shadow: 0 0 6px rgba(16, 185, 129, 0.5);
  }

  .status-red {
    background: #EF4444;
    box-shadow: 0 0 6px rgba(239, 68, 68, 0.5);
  }

  .status-amber {
    background: #F59E0B;
    box-shadow: 0 0 6px rgba(245, 158, 11, 0.5);
  }

  .status-indigo {
    background: #6366F1;
    box-shadow: 0 0 6px rgba(99, 102, 241, 0.5);
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background: #1A1D27;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-logo {
    font-weight: 600;
    font-size: 0.95rem;
    color: #FFFFFF;
    text-decoration: none;
    padding: 6px 14px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    letter-spacing: 0.01em;
    transition: background 0.2s ease;
  }

  .nav-logo:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .nav-divider {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.3);
    margin: 0 4px;
  }

  .nav-current {
    font-weight: 500;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    padding: 6px 14px;
    transition: color 0.2s ease;
  }

  .nav-current:hover {
    color: #FFFFFF;
  }

  .nav-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-status {
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.4);
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #0F1117;
    padding: 80px 24px 64px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .hero-title {
    font-weight: 700;
    font-size: clamp(2.8rem, 7vw, 4.5rem);
    line-height: 1.05;
    margin: 0;
    color: #FFFFFF;
    letter-spacing: -0.03em;
  }

  .hero-tagline {
    font-weight: 400;
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
    max-width: 420px;
  }

  .hero-stats {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .stat-card {
    background: #1A1D27;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .stat-label {
    font-weight: 500;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.45);
    min-width: 110px;
  }

  .stat-number {
    font-weight: 700;
    font-size: 1.8rem;
    color: #FFFFFF;
    letter-spacing: -0.02em;
    flex: 1;
  }

  .stat-change {
    font-weight: 600;
    font-size: 0.85rem;
    padding: 4px 10px;
    border-radius: 6px;
  }

  .stat-positive {
    color: #10B981;
    background: rgba(16, 185, 129, 0.12);
  }

  .stat-negative {
    color: #EF4444;
    background: rgba(239, 68, 68, 0.12);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 72px 24px;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 40px;
  }

  .section-heading {
    font-weight: 700;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    line-height: 1.1;
    margin: 0;
    color: #FFFFFF;
    letter-spacing: -0.02em;
  }

  .section-badge {
    font-weight: 500;
    font-size: 0.75rem;
    color: #6366F1;
    background: rgba(99, 102, 241, 0.12);
    padding: 4px 12px;
    border-radius: 6px;
    letter-spacing: 0.02em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #1A1D27;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .about-content {
    max-width: 720px;
  }

  .body-text {
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.75;
    margin: 0 0 20px 0;
    color: rgba(255, 255, 255, 0.75);
  }

  .body-text:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #0F1117;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 16px;
  }

  .char-card {
    padding: 24px;
    border-radius: 12px;
    background: #1A1D27;
    border: 1px solid rgba(255, 255, 255, 0.06);
    position: relative;
    transition: background 0.2s ease, border-color 0.2s ease;
    overflow: hidden;
  }

  .char-card:hover {
    background: #2A2D3A;
    border-color: rgba(255, 255, 255, 0.1);
  }

  .char-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .char-index {
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.3);
  }

  .char-title {
    font-weight: 600;
    font-size: 1.2rem;
    margin: 0 0 8px 0;
    letter-spacing: -0.01em;
    color: #FFFFFF;
  }

  .char-description {
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0 0 16px 0;
    color: rgba(255, 255, 255, 0.5);
  }

  .char-bar-chart {
    display: flex;
    align-items: flex-end;
    gap: 4px;
    height: 32px;
  }

  .bar {
    flex: 1;
    border-radius: 3px 3px 0 0;
    min-width: 0;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #1A1D27;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .prompt-block {
    background: #0F1117;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .prompt-label-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .prompt-label {
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.4);
  }

  .copy-button {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    background: #6366F1;
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    padding: 8px 20px;
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: filter 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 0 12px rgba(99, 102, 241, 0.25);
  }

  .copy-button:hover {
    filter: brightness(1.15);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.35);
  }

  .copy-button.copied {
    background: #10B981;
    box-shadow: 0 0 12px rgba(16, 185, 129, 0.3);
  }

  .prompt-text {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.75);
    padding: 24px;
    margin: 0;
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #0F1117;
  }

  .use-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .use-column {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: #1A1D27;
  }

  .use-heading-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 16px 24px;
  }

  .use-heading {
    font-weight: 600;
    font-size: 1rem;
    margin: 0;
    color: #FFFFFF;
  }

  .use-heading-good {
    background: rgba(16, 185, 129, 0.08);
    border-bottom: 1px solid rgba(16, 185, 129, 0.12);
  }

  .use-heading-not {
    background: rgba(239, 68, 68, 0.08);
    border-bottom: 1px solid rgba(239, 68, 68, 0.12);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: rgba(255, 255, 255, 0.75);
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10B981;
    flex-shrink: 0;
    margin-top: 6px;
  }

  .use-item-not::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #EF4444;
    flex-shrink: 0;
    margin-top: 6px;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #1A1D27;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .history-content {
    max-width: 720px;
  }

  .history-block {
    display: flex;
    gap: 20px;
    margin-bottom: 0;
  }

  .history-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    padding-top: 8px;
  }

  .history-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #6366F1;
    box-shadow: 0 0 8px rgba(99, 102, 241, 0.4);
    flex-shrink: 0;
  }

  .history-line {
    width: 2px;
    flex: 1;
    background: rgba(99, 102, 241, 0.2);
    margin-top: 8px;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #0F1117;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    background: #1A1D27;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    text-decoration: none;
    color: #FFFFFF;
    position: relative;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .related-card:hover {
    background: #2A2D3A;
    border-color: rgba(99, 102, 241, 0.3);
    box-shadow: 0 0 16px rgba(99, 102, 241, 0.1);
  }

  .related-top {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .related-relationship {
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.4);
  }

  .related-name {
    font-weight: 600;
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    color: #FFFFFF;
  }

  .related-arrow {
    font-size: 1.1rem;
    position: absolute;
    bottom: 20px;
    right: 20px;
    color: rgba(255, 255, 255, 0.25);
    transition: color 0.2s ease;
  }

  .related-card:hover .related-arrow {
    color: #6366F1;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #1A1D27;
    padding: 40px 24px;
