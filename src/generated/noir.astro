---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- FILM GRAIN OVERLAY -->
  <div class="film-grain" aria-hidden="true"></div>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-blinds" aria-hidden="true"></div>
    <div class="hero-beam" aria-hidden="true"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-line"></span>
        <span class="hero-diamond"></span>
        <span class="hero-line"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-beam" aria-hidden="true"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Atmosphere as Interface</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-blinds" aria-hidden="true"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-beam section-beam-reverse" aria-hidden="true"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Light &amp; Shadow</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-blinds section-blinds-subtle" aria-hidden="true"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Lora', serif;
    background-color: #0a0a0a;
    color: #F5F5F5;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
    overflow-x: hidden;
  }

  /* ========================================
     FILM GRAIN OVERLAY
     ======================================== */
  .film-grain {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1000;
    opacity: 0.035;
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid #222;
    background: rgba(10, 10, 10, 0.95);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1rem;
    color: #C8A96E;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid #333;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .nav-logo:hover {
    border-color: #C8A96E;
    box-shadow: 0 0 12px rgba(200, 169, 110, 0.15);
  }

  .nav-divider {
    font-size: 1rem;
    color: #333;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Playfair Display', serif;
    font-weight: 400;
    font-size: 0.95rem;
    color: #888;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid transparent;
    transition: border-color 0.3s, color 0.3s;
  }

  .nav-current:hover {
    border-color: #333;
    color: #F5F5F5;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #0a0a0a;
    padding: 120px 32px 100px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid #222;
  }

  /* Venetian blind shadow stripes across hero */
  .hero-blinds {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 18px,
      rgba(245, 245, 245, 0.03) 18px,
      rgba(245, 245, 245, 0.03) 20px
    );
    pointer-events: none;
  }

  /* Diagonal light beam cutting across the hero */
  .hero-beam {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      125deg,
      transparent 0%,
      transparent 30%,
      rgba(245, 245, 245, 0.02) 35%,
      rgba(245, 245, 245, 0.05) 40%,
      rgba(245, 245, 245, 0.02) 45%,
      transparent 50%,
      transparent 100%
    );
    pointer-events: none;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Lora', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: #666;
    display: inline-block;
    margin-bottom: 28px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: clamp(3.5rem, 10vw, 7rem);
    line-height: 1;
    margin: 0 0 28px 0;
    color: #F5F5F5;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.8), 0 0 60px rgba(200, 169, 110, 0.08);
    letter-spacing: 0.05em;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 28px;
  }

  .hero-line {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #C8A96E, transparent);
  }

  .hero-diamond {
    width: 8px;
    height: 8px;
    background: #C8A96E;
    transform: rotate(45deg);
    box-shadow: 0 0 8px rgba(200, 169, 110, 0.4);
  }

  .hero-tagline {
    font-family: 'Lora', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.8;
    margin: 0 auto;
    max-width: 500px;
    color: #999;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 96px 32px;
    border-bottom: 1px solid #222;
    position: relative;
    overflow: hidden;
  }

  .section-inner {
    max-width: 760px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #333, transparent);
  }

  .section-label {
    font-family: 'Lora', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.8rem;
    color: #666;
    white-space: nowrap;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #F5F5F5;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
  }

  /* Diagonal light beam for sections */
  .section-beam {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      135deg,
      transparent 0%,
      transparent 60%,
      rgba(245, 245, 245, 0.015) 65%,
      rgba(245, 245, 245, 0.035) 70%,
      rgba(245, 245, 245, 0.015) 75%,
      transparent 80%,
      transparent 100%
    );
    pointer-events: none;
  }

  .section-beam-reverse {
    background: linear-gradient(
      -135deg,
      transparent 0%,
      transparent 55%,
      rgba(245, 245, 245, 0.015) 60%,
      rgba(245, 245, 245, 0.035) 65%,
      rgba(245, 245, 245, 0.015) 70%,
      transparent 75%,
      transparent 100%
    );
  }

  /* Venetian blind overlays for sections */
  .section-blinds {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent 0px,
      transparent 24px,
      rgba(245, 245, 245, 0.02) 24px,
      rgba(245, 245, 245, 0.02) 26px
    );
    pointer-events: none;
  }

  .section-blinds-subtle {
    opacity: 0.6;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #0e0e0e;
  }

  .about-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #ccc;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #0a0a0a;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 1px solid #222;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: linear-gradient(
      145deg,
      #0e0e0e 0%,
      #0a0a0a 50%,
      #111 100%
    );
    transition: box-shadow 0.3s, border-color 0.3s;
  }

  .char-card:hover {
    box-shadow:
      0 4px 30px rgba(0, 0, 0, 0.6),
      0 0 1px rgba(200, 169, 110, 0.3);
    border-color: #333;
  }

  .char-number {
    font-family: 'Lora', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.75rem;
    color: #C8A96E;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 24px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #C8A96E, transparent);
    margin: 0 auto 14px;
  }

  .char-title {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin: 0 0 12px 0;
    color: #F5F5F5;
  }

  .char-description {
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    margin: 0;
    color: #888;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #0e0e0e;
  }

  .prompt-block {
    border: 1px solid #222;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid #222;
    background: rgba(200, 169, 110, 0.04);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Lora', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.8rem;
    color: #C8A96E;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 0.85rem;
    background: transparent;
    color: #C8A96E;
    border: 1px solid #333;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  .copy-button:hover {
    background: rgba(200, 169, 110, 0.08);
    border-color: #C8A96E;
    box-shadow: 0 0 12px rgba(200, 169, 110, 0.1);
  }

  .copy-button.copied {
    background: rgba(200, 169, 110, 0.12);
    border-color: #C8A96E;
  }

  .prompt-text {
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.85;
    color: #ccc;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #0a0a0a;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 700px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid #222;
    overflow: hidden;
    position: relative;
  }

  .use-column-heading {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1.05rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 1px solid #222;
  }

  .use-good .use-column-heading {
    background: rgba(200, 169, 110, 0.06);
    color: #C8A96E;
  }

  .use-bad .use-column-heading {
    background: rgba(245, 245, 245, 0.02);
    color: #666;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(34, 34, 34, 0.8);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #ccc;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 6px;
    height: 6px;
    background: #C8A96E;
    box-shadow: 0 0 6px rgba(200, 169, 110, 0.4);
    flex-shrink: 0;
    margin-top: 7px;
  }

  .use-item-bad::before {
    content: '\2013';
    color: #444;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #0e0e0e;
  }

  .history-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #ccc;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #0a0a0a;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 700px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 28px 20px;
    border: 1px solid #222;
    text-decoration: none;
    color: #ccc;
    text-align: center;
    position: relative;
    transition: box-shadow 0.3s, border-color 0.3s;
    background: linear-gradient(
      160deg,
      rgba(245, 245, 245, 0.02) 0%,
      transparent 40%,
      transparent 100%
    );
  }

  .related-card:hover {
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.5),
      0 0 1px rgba(200, 169, 110, 0.3);
    border-color: #333;
  }

  .related-relationship {
    font-family: 'Lora', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.7rem;
    color: #666;
    letter-spacing: 0.08em;
  }

  .related-name {
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: #F5F5F5;
  }

  .related-arrow {
    font-size: 1rem;
    color: #C8A96E;
    text-shadow: 0 0 6px rgba(200, 169, 110, 0.3);
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #080808;
    padding: 64px 32px;
    border-top: 1px solid #222;
  }

  .footer-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-ornament {
    width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #333, transparent);
  }

