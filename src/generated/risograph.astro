---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Work+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-halftone"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">
        <span class="hero-title-text">{aesthetic.name}</span>
      </h1>
      <div class="hero-rule">
        <span class="hero-swatch hero-swatch-pink"></span>
        <span class="hero-swatch hero-swatch-blue"></span>
        <span class="hero-swatch hero-swatch-green"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Ink on Paper</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy & Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Stock, Wrong Stock</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Work Sans', sans-serif;
    background-color: #F5F0E8;
    color: #2A2A2A;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
  }

  /* Paper texture overlay */
  .page::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.5;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 2px solid #3D5A99;
    background: #F5F0E8;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .nav-logo {
    font-family: 'Work Sans', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: #F5F0E8;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 6px 16px;
    background: #3D5A99;
    border: none;
    transition: background 0.2s;
    position: relative;
  }

  .nav-logo::after {
    content: 'aesthetic.fyi';
    position: absolute;
    top: 2px;
    left: 2px;
    padding: 6px 16px;
    font-family: 'Work Sans', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: transparent;
    background: #F5587B;
    z-index: -1;
    mix-blend-mode: multiply;
  }

  .nav-logo:hover {
    background: #F5587B;
  }

  .nav-divider {
    font-size: 1rem;
    font-weight: 700;
    color: #3D5A99;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Work Sans', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    color: #F5587B;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 6px 14px;
    border: 2px solid #F5587B;
    transition: background 0.2s, color 0.2s;
  }

  .nav-current:hover {
    background: #F5587B;
    color: #F5F0E8;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #F5F0E8;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 2px solid #3D5A99;
  }

  /* Halftone dot pattern background */
  .hero-halftone {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      radial-gradient(circle 2px, rgba(245, 88, 123, 0.15) 50%, transparent 50%);
    background-size: 12px 12px;
    background-position: 0 0;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Work Sans', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: #F5F0E8;
    display: inline-block;
    margin-bottom: 28px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: #5EBD73;
    padding: 6px 18px;
  }

  .hero-title {
    font-family: 'Work Sans', sans-serif;
    font-weight: 800;
    font-size: clamp(3.5rem, 10vw, 7rem);
    line-height: 0.95;
    margin: 0 0 28px 0;
    color: #3D5A99;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    position: relative;
  }

  /* Misregistration effect on title */
  .hero-title-text {
    position: relative;
    display: inline-block;
  }

  .hero-title-text::before {
    content: attr(data-text);
    position: absolute;
    top: 3px;
    left: -3px;
    color: #F5587B;
    z-index: -1;
    mix-blend-mode: multiply;
  }

  .hero-title-text::after {
    content: attr(data-text);
    position: absolute;
    top: -2px;
    left: 2px;
    color: #5EBD73;
    z-index: -2;
    mix-blend-mode: multiply;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 28px;
  }

  .hero-swatch {
    width: 32px;
    height: 12px;
  }

  .hero-swatch-pink {
    background: #F5587B;
  }

  .hero-swatch-blue {
    background: #3D5A99;
  }

  .hero-swatch-green {
    background: #5EBD73;
  }

  .hero-tagline {
    font-family: 'Work Sans', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 480px;
    color: #3D5A99;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 2px solid #3D5A99;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 60px;
    height: 2px;
    background: #F5587B;
  }

  .section-label {
    font-family: 'Work Sans', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: #F5587B;
    white-space: nowrap;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Work Sans', sans-serif;
    font-weight: 800;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.1;
    margin: 0 0 48px 0;
    text-align: center;
    color: #3D5A99;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    position: relative;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #F5F0E8;
    position: relative;
  }

  /* Halftone overlay for about section */
  .about-section::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      radial-gradient(circle 1.5px, rgba(61, 90, 153, 0.07) 50%, transparent 50%);
    background-size: 10px 10px;
    pointer-events: none;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: left;
    position: relative;
    z-index: 1;
  }

  .about-paragraph {
    font-family: 'Work Sans', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #2A2A2A;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #3D5A99;
    border-bottom-color: #F5587B;
  }

  .characteristics-section .section-label {
    color: #F5F0E8;
  }

  .characteristics-section .section-heading {
    color: #F5F0E8;
  }

  .characteristics-section .section-rule {
    background: #F5587B;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    position: relative;
    z-index: 1;
  }

  .char-card {
    border: 2px solid rgba(245, 240, 232, 0.3);
    padding: 28px 24px 24px;
    position: relative;
    text-align: left;
    background: rgba(245, 240, 232, 0.08);
    transition: background 0.2s, border-color 0.2s;
  }

  .char-card:hover {
    background: rgba(245, 240, 232, 0.14);
    border-color: #F5587B;
  }

  /* Misregistration on card hover */
  .char-card::before {
    content: '';
    position: absolute;
    top: 3px;
    left: -3px;
    right: -3px;
    bottom: -3px;
    border: 2px solid rgba(245, 88, 123, 0.25);
    pointer-events: none;
    mix-blend-mode: multiply;
  }

  .char-number {
    font-family: 'Work Sans', sans-serif;
    font-weight: 800;
    font-size: 0.7rem;
    color: #5EBD73;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.1em;
  }

  .char-divider {
    width: 24px;
    height: 2px;
    background: #F5587B;
    margin: 0 0 14px;
  }

  .char-title {
    font-family: 'Work Sans', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    margin: 0 0 10px 0;
    color: #F5F0E8;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .char-description {
    font-family: 'Work Sans', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
    color: rgba(245, 240, 232, 0.7);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #F5F0E8;
  }

  .prompt-block {
    border: 2px solid #3D5A99;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  /* Misregistration on prompt block */
  .prompt-block::before {
    content: '';
    position: absolute;
    top: 4px;
    left: -4px;
    right: -4px;
    bottom: -4px;
    border: 2px solid rgba(245, 88, 123, 0.2);
    pointer-events: none;
    z-index: 0;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 20px;
    border-bottom: 2px solid #3D5A99;
    background: #3D5A99;
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Work Sans', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: #F5F0E8;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Work Sans', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    background: #F5587B;
    color: #F5F0E8;
    border: none;
    padding: 6px 18px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: background 0.2s;
  }

  .copy-button:hover {
    background: #e0456a;
  }

  .copy-button.copied {
    background: #5EBD73;
  }

  .prompt-text {
    font-family: 'Work Sans', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.85;
    color: #2A2A2A;
    padding: 24px 20px;
    margin: 0;
    white-space: pre-wrap;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #F5F0E8;
    position: relative;
  }

  .use-section::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      radial-gradient(circle 1.5px, rgba(94, 189, 115, 0.08) 50%, transparent 50%);
    background-size: 10px 10px;
    pointer-events: none;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 780px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .use-column {
    border: 2px solid #3D5A99;
    overflow: hidden;
    position: relative;
  }

  /* Misregistration on columns */
  .use-column::before {
    content: '';
    position: absolute;
    top: 3px;
    left: -3px;
    right: -3px;
    bottom: -3px;
    border: 2px solid rgba(245, 88, 123, 0.2);
    pointer-events: none;
    z-index: 0;
  }

  .use-column-heading {
    font-family: 'Work Sans', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    margin: 0;
    padding: 14px 20px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 2px solid #3D5A99;
  }

  .use-good .use-column-heading {
    background: #5EBD73;
    color: #F5F0E8;
  }

  .use-bad .use-column-heading {
    background: #F5587B;
    color: #F5F0E8;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Work Sans', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.5;
    padding: 12px 20px;
    border-bottom: 1px solid rgba(61, 90, 153, 0.15);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #2A2A2A;
    position: relative;
    z-index: 1;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 8px;
    height: 8px;
    background: #5EBD73;
    flex-shrink: 0;
    margin-top: 5px;
  }

  .use-item-bad::before {
    content: '';
    width: 8px;
    height: 2px;
    background: #F5587B;
    flex-shrink: 0;
    margin-top: 9px;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #F5587B;
    border-bottom-color: #3D5A99;
  }

  .history-section .section-label {
    color: #F5F0E8;
  }

  .history-section .section-heading {
    color: #F5F0E8;
  }

  .history-section .section-rule {
    background: #F5F0E8;
  }

  /* Halftone overlay on history */
  .history-section::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      radial-gradient(circle 1.5px, rgba(245, 240, 232, 0.12) 50%, transparent 50%);
    background-size: 8px 8px;
    pointer-events: none;
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: left;
    position: relative;
    z-index: 1;
  }

  .history-paragraph {
    font-family: 'Work Sans', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #F5F0E8;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #F5F0E8;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    padding: 24px 20px;
    border: 2px solid #3D5A99;
    text-decoration: none;
    color: #2A2A2A;
    position: relative;
    transition: background 0.2s, border-color 0.2s;
  }

