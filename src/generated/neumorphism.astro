---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-current">{aesthetic.name}</span>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-label-wrap">
        <span class="hero-label">Web Aesthetic</span>
      </div>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-heading">What This Is</h2>
      <div class="about-panel">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="body-text">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }) => (
          <div class="char-card">
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-heading">Style Reference</h2>
      <div class="prompt-panel">
        <pre class="prompt-text">{aesthetic.prompt}</pre>
        <button class="copy-button" data-prompt={aesthetic.prompt}>Copy prompt</button>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-heading">When to Use</h2>
      <div class="use-grid">
        <div class="use-column">
          <h3 class="use-heading use-heading-good">Good for</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column">
          <h3 class="use-heading use-heading-not">Not for</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-heading">History</h2>
      <div class="about-panel">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="body-text">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-relationship">{rel.relationship}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <p class="footer-tagline">Every web aesthetic, demonstrated.</p>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', async () => {
        const prompt = copyButton.getAttribute('data-prompt');
        if (prompt) {
          try {
            await navigator.clipboard.writeText(prompt);
            const original = copyButton.textContent;
            copyButton.textContent = 'Copied!';
            copyButton.classList.add('copied');
            setTimeout(() => {
              copyButton.textContent = original;
              copyButton.classList.remove('copied');
            }, 2000);
          } catch {
            const textarea = document.createElement('textarea');
            textarea.value = prompt || '';
            textarea.style.position = 'fixed';
            textarea.style.opacity = '0';
            document.body.appendChild(textarea);
            textarea.select();
            document.execCommand('copy');
            document.body.removeChild(textarea);
            const original = copyButton.textContent;
            copyButton.textContent = 'Copied!';
            copyButton.classList.add('copied');
            setTimeout(() => {
              copyButton.textContent = original;
              copyButton.classList.remove('copied');
            }, 2000);
          }
        }
      });
    }
  });
</script>

<style>
  /* ========================================
     BASE
     ======================================== */
  .page {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    background: #e0e0e0;
    color: #6b6b6b;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    line-height: 1.7;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 16px 24px 0;
  }

  .nav-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 18px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #e0e0e0;
    border-radius: 20px;
    box-shadow:
      6px 6px 14px #bebebe,
      -6px -6px 14px #ffffff;
  }

  .nav-logo {
    font-weight: 600;
    font-size: 0.95rem;
    color: #777;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.3s ease;
  }

  .nav-logo:hover {
    color: #555;
  }

  .nav-current {
    font-weight: 400;
    font-size: 0.9rem;
    color: #999;
    letter-spacing: 0.02em;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    padding: 100px 24px 80px;
    text-align: center;
  }

  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-label-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 32px;
  }

  .hero-label {
    display: inline-block;
    font-weight: 400;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #999;
    background: #e0e0e0;
    padding: 10px 24px;
    border-radius: 50px;
    box-shadow:
      inset 4px 4px 8px #bebebe,
      inset -4px -4px 8px #ffffff;
  }

  .hero-title {
    font-weight: 600;
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #777;
    margin: 0 0 24px 0;
    text-shadow: 1px 1px 2px #ffffff, -1px -1px 2px #bebebe;
  }

  .hero-tagline {
    font-weight: 300;
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    line-height: 1.6;
    color: #999;
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ========================================
     SECTIONS
     ======================================== */
  .section {
    padding: 72px 24px;
  }

  .section-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-heading {
    font-weight: 600;
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    color: #777;
    margin: 0 0 40px 0;
    letter-spacing: -0.01em;
  }

  /* ========================================
     ABOUT / HISTORY PANELS
     ======================================== */
  .about-panel {
    max-width: 720px;
    background: #e0e0e0;
    padding: 40px;
    border-radius: 24px;
    box-shadow:
      8px 8px 16px #bebebe,
      -8px -8px 16px #ffffff;
  }

  .body-text {
    font-weight: 300;
    font-size: 1.05rem;
    line-height: 1.8;
    color: #6b6b6b;
    margin: 0 0 20px 0;
  }

  .body-text:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 28px;
  }

  .char-card {
    background: #e0e0e0;
    padding: 32px;
    border-radius: 20px;
    box-shadow:
      8px 8px 16px #bebebe,
      -8px -8px 16px #ffffff;
    transition: box-shadow 0.3s ease;
  }

  .char-card:hover {
    box-shadow:
      inset 6px 6px 12px #bebebe,
      inset -6px -6px 12px #ffffff;
  }

  .char-title {
    font-weight: 600;
    font-size: 1.1rem;
    color: #666;
    margin: 0 0 12px 0;
    letter-spacing: -0.01em;
  }

  .char-description {
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.7;
    color: #888;
    margin: 0;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-panel {
    background: #e0e0e0;
    padding: 40px;
    border-radius: 24px;
    box-shadow:
      8px 8px 16px #bebebe,
      -8px -8px 16px #ffffff;
  }

  .prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.8;
    color: #6b6b6b;
    white-space: normal;
    word-wrap: break-word;
    margin: 0 0 28px 0;
    padding: 0;
    background: none;
    border: none;
  }

  .copy-button {
    display: inline-flex;
    align-items: center;
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    letter-spacing: 0.02em;
    color: #777;
    background: #e0e0e0;
    border: none;
    border-radius: 14px;
    padding: 14px 28px;
    cursor: pointer;
    box-shadow:
      6px 6px 12px #bebebe,
      -6px -6px 12px #ffffff;
    transition: box-shadow 0.2s ease;
  }

  .copy-button:hover {
    box-shadow:
      4px 4px 8px #bebebe,
      -4px -4px 8px #ffffff;
  }

  .copy-button:active,
  .copy-button.copied {
    box-shadow:
      inset 4px 4px 8px #bebebe,
      inset -4px -4px 8px #ffffff;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }

  .use-column {
    background: #e0e0e0;
    border-radius: 20px;
    box-shadow:
      8px 8px 16px #bebebe,
      -8px -8px 16px #ffffff;
    padding: 32px;
  }

  .use-heading {
    font-weight: 600;
    font-size: 1rem;
    margin: 0 0 20px 0;
    letter-spacing: 0.02em;
  }

  .use-heading-good {
    color: #6a9a6a;
  }

  .use-heading-not {
    color: #a06a6a;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .use-item {
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.6;
    color: #888;
    padding: 14px 20px;
    background: #e0e0e0;
    border-radius: 12px;
    box-shadow:
      inset 3px 3px 6px #bebebe,
      inset -3px -3px 6px #ffffff;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    padding: 28px 24px;
    background: #e0e0e0;
    border-radius: 18px;
    box-shadow:
      6px 6px 14px #bebebe,
      -6px -6px 14px #ffffff;
    transition: box-shadow 0.3s ease;
  }

  .related-card:hover {
    box-shadow:
      3px 3px 6px #bebebe,
      -3px -3px 6px #ffffff;
  }

  .related-card:active {
    box-shadow:
      inset 4px 4px 8px #bebebe,
      inset -4px -4px 8px #ffffff;
  }

  .related-name {
    font-weight: 600;
    font-size: 1.05rem;
    color: #666;
    letter-spacing: -0.01em;
  }

  .related-relationship {
    font-weight: 300;
    font-size: 0.8rem;
    color: #aaa;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    padding: 60px 24px;
  }

  .footer-inner {
    max-width: 1000px;
    margin: 0 auto;
    padding: 36px 40px;
    background: #e0e0e0;
    border-radius: 24px;
    box-shadow:
      inset 6px 6px 12px #bebebe,
      inset -6px -6px 12px #ffffff;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-logo {
    font-weight: 600;
    font-size: 0.9rem;
    color: #888;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-logo:hover {
    color: #666;
  }

  .footer-tagline {
    font-weight: 300;
    font-size: 0.85rem;
    color: #aaa;
    margin: 0;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 72px 24px 56px;
    }

    .section {
      padding: 48px 20px;
    }

    .section-heading {
      margin-bottom: 28px;
    }

    .about-panel {
      padding: 28px 24px;
    }

    .prompt-panel {
      padding: 28px 24px;
    }

    .characteristics-grid {
      grid-template-columns: 1fr;
    }

    .use-grid {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 16px;
    }

    .footer-inner {
      flex-direction: column;
      gap: 12px;
      text-align: center;
      padding: 28px 24px;
    }

    .nav-inner {
      padding: 14px 24px;
    }
  }

  @media (max-width: 420px) {
    .hero {
      padding: 56px 16px 40px;
    }

    .hero-title {
      font-size: 2.8rem;
    }

    .section {
      padding: 36px 16px;
    }

    .about-panel,
    .prompt-panel {
      padding: 24px 20px;
      border-radius: 18px;
    }

    .char-card {
      padding: 24px 20px;
      border-radius: 16px;
    }

    .use-column {
      padding: 24px 20px;
      border-radius: 16px;
    }

    .related-card {
      padding: 20px 18px;
      border-radius: 14px;
    }

    .related-grid {
      grid-template-columns: 1fr 1fr;
    }

    .copy-button {
      width: 100%;
      justify-content: center;
    }

    .nav {
      padding: 12px 16px 0;
    }

    .nav-inner {
      padding: 12px 18px;
      border-radius: 14px;
    }

    .nav-logo {
      font-size: 0.85rem;
    }

    .nav-current {
      font-size: 0.8rem;
    }
  }
</style>
