---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">//</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-corner hero-corner-tl"></div>
    <div class="hero-corner hero-corner-tr"></div>
    <div class="hero-corner hero-corner-bl"></div>
    <div class="hero-corner hero-corner-br"></div>
    <div class="hero-inner">
      <span class="hero-label">[ A Web Aesthetic ]</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-dimension">
        <span class="dim-serif"></span>
        <span class="dim-line"></span>
        <span class="dim-text">SECTION 01</span>
        <span class="dim-line"></span>
        <span class="dim-serif"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="title-block">
        <span class="title-block-label">SECTION</span>
        <span class="title-block-num">02</span>
        <span class="title-block-desc">// What This Is</span>
      </div>
      <h2 class="section-heading">Technical Overview</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="title-block">
        <span class="title-block-label">SECTION</span>
        <span class="title-block-num">03</span>
        <span class="title-block-desc">// Design Tokens</span>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <div class="char-corner char-corner-tl"></div>
            <div class="char-corner char-corner-tr"></div>
            <div class="char-corner char-corner-bl"></div>
            <div class="char-corner char-corner-br"></div>
            <span class="char-number">ITEM {String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider">
              <span class="dim-serif-sm"></span>
              <span class="dim-line-sm"></span>
              <span class="dim-serif-sm"></span>
            </div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="title-block">
        <span class="title-block-label">SECTION</span>
        <span class="title-block-num">04</span>
        <span class="title-block-desc">// Style Reference</span>
      </div>
      <h2 class="section-heading">Copy & Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">PROMPT SPECIFICATION</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>COPY</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="title-block">
        <span class="title-block-label">SECTION</span>
        <span class="title-block-num">05</span>
        <span class="title-block-desc">// When to Use</span>
      </div>
      <h2 class="section-heading">Application Matrix</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">RECOMMENDED</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">NOT RECOMMENDED</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="title-block">
        <span class="title-block-label">SECTION</span>
        <span class="title-block-num">06</span>
        <span class="title-block-desc">// Origins</span>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="title-block">
        <span class="title-block-label">SECTION</span>
        <span class="title-block-num">07</span>
        <span class="title-block-desc">// Explore</span>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <div class="rel-corner rel-corner-tl"></div>
            <div class="rel-corner rel-corner-tr"></div>
            <div class="rel-corner rel-corner-bl"></div>
            <div class="rel-corner rel-corner-br"></div>
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-dimension">
        <span class="dim-serif"></span>
        <span class="dim-line"></span>
        <span class="dim-serif"></span>
      </div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; BACK TO ALL AESTHETICS</a>
      <div class="footer-dimension">
        <span class="dim-serif"></span>
        <span class="dim-line"></span>
        <span class="dim-serif"></span>
      </div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'COPIED';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Roboto Mono', monospace;
    background-color: #1B3F6B;
    background-image:
      repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.07) 0px,
        rgba(255, 255, 255, 0.07) 1px,
        transparent 1px,
        transparent 40px
      ),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.07) 0px,
        rgba(255, 255, 255, 0.07) 1px,
        transparent 1px,
        transparent 40px
      ),
      repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.15) 0px,
        rgba(255, 255, 255, 0.15) 1px,
        transparent 1px,
        transparent 200px
      ),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.15) 0px,
        rgba(255, 255, 255, 0.15) 1px,
        transparent 1px,
        transparent 200px
      );
    color: #FFFFFF;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(27, 63, 107, 0.95);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Roboto Mono', monospace;
    font-weight: 500;
    font-size: 0.85rem;
    color: #FFFFFF;
    text-decoration: none;
    padding: 6px 16px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    letter-spacing: 0.05em;
    transition: background 0.3s, border-color 0.3s;
  }

  .nav-logo:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .nav-divider {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.3);
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Roboto Mono', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    padding: 6px 16px;
    border: 1px solid transparent;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: border-color 0.3s;
  }

  .nav-current:hover {
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* ========================================
     DIMENSION LINE ELEMENTS
     ======================================== */
  .dim-serif {
    display: block;
    width: 1px;
    height: 12px;
    background: rgba(255, 255, 255, 0.4);
    flex-shrink: 0;
  }

  .dim-line {
    display: block;
    flex: 1;
    max-width: 100px;
    height: 1px;
    background: rgba(255, 255, 255, 0.4);
  }

  .dim-text {
    font-family: 'Roboto Mono', monospace;
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 0 12px;
  }

  .dim-serif-sm {
    display: block;
    width: 1px;
    height: 8px;
    background: rgba(255, 255, 255, 0.3);
    flex-shrink: 0;
  }

  .dim-line-sm {
    display: block;
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.3);
  }

  /* ========================================
     CORNER MARKS
     ======================================== */
  .hero-corner,
  .char-corner,
  .rel-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    pointer-events: none;
  }

  .hero-corner {
    width: 24px;
    height: 24px;
  }

  .hero-corner-tl,
  .char-corner-tl,
  .rel-corner-tl {
    top: 16px;
    left: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.5);
    border-left: 1px solid rgba(255, 255, 255, 0.5);
  }

  .hero-corner-tr,
  .char-corner-tr,
  .rel-corner-tr {
    top: 16px;
    right: 16px;
    border-top: 1px solid rgba(255, 255, 255, 0.5);
    border-right: 1px solid rgba(255, 255, 255, 0.5);
  }

  .hero-corner-bl,
  .char-corner-bl,
  .rel-corner-bl {
    bottom: 16px;
    left: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.5);
    border-left: 1px solid rgba(255, 255, 255, 0.5);
  }

  .hero-corner-br,
  .char-corner-br,
  .rel-corner-br {
    bottom: 16px;
    right: 16px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.5);
    border-right: 1px solid rgba(255, 255, 255, 0.5);
  }

  .char-corner-tl,
  .char-corner-tr,
  .char-corner-bl,
  .char-corner-br {
    width: 12px;
    height: 12px;
  }

  .char-corner-tl,
  .rel-corner-tl {
    top: 8px;
    left: 8px;
  }

  .char-corner-tr,
  .rel-corner-tr {
    top: 8px;
    right: 8px;
  }

  .char-corner-bl,
  .rel-corner-bl {
    bottom: 8px;
    left: 8px;
  }

  .char-corner-br,
  .rel-corner-br {
    bottom: 8px;
    right: 8px;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Roboto Mono', monospace;
    font-weight: 400;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.5);
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'Roboto Mono', monospace;
    font-weight: 700;
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: 1.1;
    margin: 0 0 28px 0;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .hero-dimension {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 28px;
    padding: 0 40px;
  }

  .hero-tagline {
    font-family: 'Roboto Mono', monospace;
    font-weight: 300;
    font-size: clamp(0.85rem, 2vw, 1.05rem);
    line-height: 1.8;
    margin: 0 auto;
    max-width: 520px;
    color: rgba(255, 255, 255, 0.65);
  }

  /* ========================================
     TITLE BLOCK (section headers)
     ======================================== */
  .title-block {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 16px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    max-width: 360px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 20px;
  }

  .title-block-label {
    font-family: 'Roboto Mono', monospace;
    font-weight: 400;
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 8px 14px;
    border-right: 1px solid rgba(255, 255, 255, 0.2);
  }

  .title-block-num {
    font-family: 'Roboto Mono', monospace;
    font-weight: 700;
    font-size: 0.85rem;
    color: #FFFFFF;
    padding: 8px 14px;
    border-right: 1px solid rgba(255, 255, 255, 0.2);
  }

  .title-block-desc {
    font-family: 'Roboto Mono', monospace;
    font-weight: 400;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.55);
    padding: 8px 14px;
    letter-spacing: 0.05em;
    flex: 1;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-heading {
    font-family: 'Roboto Mono', monospace;
    font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    line-height: 1.2;
    margin: 0 0 48px 0;
    text-align: center;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: rgba(255, 255, 255, 0.02);
  }

  .about-content {
    max-width: 640px;
    margin: 0 auto;
    text-align: left;
  }

  .about-paragraph {
    font-family: 'Roboto Mono', monospace;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: rgba(255, 255, 255, 0.8);
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .char-card {
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 32px 24px 24px;
    position: relative;
    text-align: left;
    background: rgba(255, 255, 255, 0.03);
    transition: background 0.3s, border-color 0.3s;
  }

  .char-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.35);
  }

  .char-number {
    font-family: 'Roboto Mono', monospace;
    font-weight: 400;
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.4);
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .char-divider {
    display: flex;
    align-items: center;
    gap: 0;
    margin-bottom: 14px;
  }

  .char-title {
    font-family: 'Roboto Mono', monospace;
    font-weight: 500;
    font-size: 1rem;
    margin: 0 0 12px 0;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .char-description {
    font-family: 'Roboto Mono', monospace;
    font-weight: 300;
    font-size: 0.8rem;
    line-height: 1.8;
    margin: 0;
    color: rgba(255, 255, 255, 0.55);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: rgba(255, 255, 255, 0.02);
  }

  .prompt-block {
    border: 1px solid rgba(255, 255, 255, 0.25);
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.05);
  }

  .prompt-header-label {
    font-family: 'Roboto Mono', monospace;
    font-weight: 400;
    font-size: 0.65rem;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Roboto Mono', monospace;
    font-weight: 500;
    font-size: 0.7rem;
    background: transparent;
    color: #FFFFFF;
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 5px 16px;
    cursor: pointer;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background 0.3s, border-color 0.3s;
  }

  .copy-button:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .copy-button.copied {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .prompt-text {
    font-family: 'Roboto Mono', monospace;
    font-weight: 300;
    font-size: 0.85rem;
    line-height: 1.85;
    color: rgba(255, 255, 255, 0.75);
    padding: 24px 20px;
    margin: 0;
    white-space: normal;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid rgba(255, 255, 255, 0.2);
    overflow: hidden;
    position: relative;
  }

  .use-column-heading {
    font-family: 'Roboto Mono', monospace;
    font-weight: 500;
    font-size: 0.7rem;
    margin: 0;
    padding: 14px 20px;
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .use-good .use-column-heading {
    background: rgba(255, 255, 255, 0.06);
    color: #FFFFFF;
  }

  .use-bad .use-column-heading {
    background: rgba(255, 255, 255, 0.02);
    color: rgba(255, 255, 255, 0.5);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Roboto Mono', monospace;
    font-weight: 300;
    font-size: 0.8rem;
    line-height: 1.5;
    padding: 12px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: rgba(255, 255, 255, 0.75);
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '+';
    color: rgba(255, 255, 255, 0.5);
    flex-shrink: 0;
    font-weight: 500;
  }

  .use-item-bad::before {
    content: '\2013';
    color: rgba(255, 255, 255, 0.3);
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: rgba(255, 255, 255, 0.02);
  }

  .history-content {
    max-width: 640px;
    margin: 0 auto;
    text-align: left;
  }

  .history-paragraph {
    font-family: 'Roboto Mono', monospace;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: rgba(255, 255, 255, 0.8);
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-grid {
    display: grid;
