---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">&loz;</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-ornament-tl"></div>
    <div class="hero-ornament-tr"></div>
    <div class="hero-ornament-bl"></div>
    <div class="hero-ornament-br"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-vine hero-vine-left"></span>
        <span class="hero-flourish"></span>
        <span class="hero-vine hero-vine-right"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">An Organic Philosophy</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Fertile Ground, Barren Soil</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Playfair Display', serif;
    background-color: #F5EFE0;
    color: #4A3F35;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 2px solid #C8A951;
    background: #F5EFE0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 5%, #C8A951 20%, #C8A951 80%, transparent 95%);
  }

  .nav-inner {
    max-width: 940px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 700;
    font-size: 1rem;
    color: #8B2252;
    text-decoration: none;
    padding: 6px 20px;
    border: 2px solid #C8A951;
    border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%;
    transition: background 0.3s, box-shadow 0.3s;
  }

  .nav-logo:hover {
    background: rgba(200, 169, 81, 0.1);
    box-shadow: 0 0 12px rgba(200, 169, 81, 0.2);
  }

  .nav-divider {
    font-size: 1rem;
    color: #C8A951;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.95rem;
    color: #6B7B3C;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid transparent;
    border-radius: 45% 55% 50% 50% / 55% 45% 55% 45%;
    transition: border-color 0.3s;
  }

  .nav-current:hover {
    border-color: #C8A951;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: linear-gradient(180deg, #F5EFE0 0%, #EDE5D0 100%);
    padding: 100px 32px 88px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 2px solid #C8A951;
  }

  /* Ornate Art Nouveau border frame */
  .hero::before {
    content: '';
    position: absolute;
    top: 16px;
    left: 16px;
    right: 16px;
    bottom: 16px;
    border: 2px solid #C8A951;
    border-radius: 12px;
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    top: 22px;
    left: 22px;
    right: 22px;
    bottom: 22px;
    border: 1px solid rgba(200, 169, 81, 0.4);
    border-radius: 8px;
    pointer-events: none;
  }

  /* Corner ornaments - stylized floral motifs */
  .hero-ornament-tl,
  .hero-ornament-tr,
  .hero-ornament-bl,
  .hero-ornament-br {
    position: absolute;
    width: 80px;
    height: 80px;
    pointer-events: none;
  }

  .hero-ornament-tl {
    top: 8px;
    left: 8px;
    background:
      radial-gradient(ellipse 18px 24px at 30px 30px, transparent 60%, #C8A951 61%, #C8A951 64%, transparent 65%),
      radial-gradient(ellipse 12px 18px at 22px 40px, transparent 60%, rgba(200, 169, 81, 0.5) 61%, rgba(200, 169, 81, 0.5) 64%, transparent 65%),
      radial-gradient(ellipse 18px 12px at 40px 22px, transparent 60%, rgba(200, 169, 81, 0.5) 61%, rgba(200, 169, 81, 0.5) 64%, transparent 65%),
      radial-gradient(circle 4px at 28px 28px, #C8A951 50%, transparent 50%);
  }

  .hero-ornament-tr {
    top: 8px;
    right: 8px;
    background:
      radial-gradient(ellipse 18px 24px at 50px 30px, transparent 60%, #C8A951 61%, #C8A951 64%, transparent 65%),
      radial-gradient(ellipse 12px 18px at 58px 40px, transparent 60%, rgba(200, 169, 81, 0.5) 61%, rgba(200, 169, 81, 0.5) 64%, transparent 65%),
      radial-gradient(ellipse 18px 12px at 40px 22px, transparent 60%, rgba(200, 169, 81, 0.5) 61%, rgba(200, 169, 81, 0.5) 64%, transparent 65%),
      radial-gradient(circle 4px at 52px 28px, #C8A951 50%, transparent 50%);
  }

  .hero-ornament-bl {
    bottom: 8px;
    left: 8px;
    background:
      radial-gradient(ellipse 18px 24px at 30px 50px, transparent 60%, #C8A951 61%, #C8A951 64%, transparent 65%),
      radial-gradient(ellipse 12px 18px at 22px 40px, transparent 60%, rgba(200, 169, 81, 0.5) 61%, rgba(200, 169, 81, 0.5) 64%, transparent 65%),
      radial-gradient(ellipse 18px 12px at 40px 58px, transparent 60%, rgba(200, 169, 81, 0.5) 61%, rgba(200, 169, 81, 0.5) 64%, transparent 65%),
      radial-gradient(circle 4px at 28px 52px, #C8A951 50%, transparent 50%);
  }

  .hero-ornament-br {
    bottom: 8px;
    right: 8px;
    background:
      radial-gradient(ellipse 18px 24px at 50px 50px, transparent 60%, #C8A951 61%, #C8A951 64%, transparent 65%),
      radial-gradient(ellipse 12px 18px at 58px 40px, transparent 60%, rgba(200, 169, 81, 0.5) 61%, rgba(200, 169, 81, 0.5) 64%, transparent 65%),
      radial-gradient(ellipse 18px 12px at 40px 58px, transparent 60%, rgba(200, 169, 81, 0.5) 61%, rgba(200, 169, 81, 0.5) 64%, transparent 65%),
      radial-gradient(circle 4px at 52px 52px, #C8A951 50%, transparent 50%);
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: #6B7B3C;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.05;
    margin: 0 0 28px 0;
    color: #8B2252;
    text-shadow: 1px 1px 0 rgba(200, 169, 81, 0.15);
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .hero-vine {
    width: 60px;
    height: 2px;
    position: relative;
  }

  .hero-vine-left {
    background: linear-gradient(90deg, transparent, #C8A951);
    border-radius: 0 50% 50% 0;
  }

  .hero-vine-left::before {
    content: '';
    position: absolute;
    right: 0;
    top: -6px;
    width: 20px;
    height: 14px;
    border: 1px solid rgba(200, 169, 81, 0.5);
    border-radius: 0 80% 0 80%;
    border-left: none;
    border-bottom: none;
  }

  .hero-vine-right {
    background: linear-gradient(90deg, #C8A951, transparent);
    border-radius: 50% 0 0 50%;
  }

  .hero-vine-right::before {
    content: '';
    position: absolute;
    left: 0;
    top: -6px;
    width: 20px;
    height: 14px;
    border: 1px solid rgba(200, 169, 81, 0.5);
    border-radius: 80% 0 80% 0;
    border-right: none;
    border-bottom: none;
  }

  .hero-flourish {
    width: 10px;
    height: 10px;
    background: #C8A951;
    border-radius: 50% 0 50% 0;
    transform: rotate(45deg);
  }

  .hero-tagline {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 520px;
    color: #6B7B3C;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 2px solid #C8A951;
    position: relative;
  }

  .section::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 5%, rgba(200, 169, 81, 0.3) 30%, rgba(200, 169, 81, 0.3) 70%, transparent 95%);
  }

  .section-inner {
    max-width: 940px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 2px;
    background: linear-gradient(90deg, transparent, #C8A951, transparent);
    border-radius: 2px;
  }

  .section-label {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.8rem;
    color: #6B7B3C;
    white-space: nowrap;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 700;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #8B2252;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: linear-gradient(180deg, #EDE5D0 0%, #F5EFE0 100%);
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px solid #C8A951;
    border-radius: 60% 40% 55% 45% / 4% 4% 4% 4%;
    pointer-events: none;
  }

  .about-content {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Playfair Display', serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #4A3F35;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #F5EFE0;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 2px solid #C8A951;
    border-radius: 60% 40% 55% 45% / 6% 8% 6% 8%;
    padding: 36px 28px 28px;
    position: relative;
    text-align: center;
    background: #F5EFE0;
    transition: box-shadow 0.3s, transform 0.3s;
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    bottom: 8px;
    border: 1px solid rgba(200, 169, 81, 0.4);
    border-radius: 55% 45% 50% 50% / 5% 7% 5% 7%;
    pointer-events: none;
  }

  .char-card::after {
    content: '';
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 24px;
    height: 24px;
    background:
      radial-gradient(ellipse 8px 12px at 12px 8px, transparent 55%, #C8A951 56%, #C8A951 60%, transparent 61%),
      radial-gradient(ellipse 8px 12px at 12px 16px, transparent 55%, #C8A951 56%, #C8A951 60%, transparent 61%),
      radial-gradient(circle 3px at 12px 12px, #C8A951 50%, transparent 50%);
    pointer-events: none;
  }

  .char-card:hover {
    box-shadow:
      0 4px 24px rgba(200, 169, 81, 0.15),
      0 0 0 1px rgba(200, 169, 81, 0.1);
    transform: translateY(-2px);
  }

  .char-number {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.75rem;
    color: #C8A951;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 32px;
    height: 2px;
    background: linear-gradient(90deg, transparent, #C8A951, transparent);
    margin: 0 auto 14px;
    border-radius: 2px;
  }

  .char-title {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 700;
    font-size: 1.25rem;
    margin: 0 0 12px 0;
    color: #8B2252;
  }

  .char-description {
    font-family: 'Playfair Display', serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    margin: 0;
    color: #6B7B3C;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: linear-gradient(180deg, #F5EFE0 0%, #EDE5D0 100%);
  }

  .prompt-block {
    border: 2px solid #C8A951;
    border-radius: 12px;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-block::before {
    content: '';
    position: absolute;
    top: 6px;
    left: 6px;
    right: 6px;
    bottom: 6px;
    border: 1px solid rgba(200, 169, 81, 0.35);
    border-radius: 8px;
    pointer-events: none;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 2px solid #C8A951;
    background: linear-gradient(180deg, rgba(200, 169, 81, 0.12) 0%, rgba(200, 169, 81, 0.05) 100%);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.8rem;
    color: #6B7B3C;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 700;
    font-size: 0.85rem;
    background: transparent;
    color: #8B2252;
    border: 2px solid #C8A951;
    border-radius: 45% 55% 50% 50% / 50% 50% 50% 50%;
    padding: 6px 22px;
    cursor: pointer;
    transition: background 0.3s, box-shadow 0.3s;
  }

  .copy-button:hover {
    background: rgba(200, 169, 81, 0.15);
    box-shadow: 0 0 8px rgba(200, 169, 81, 0.2);
  }

  .copy-button.copied {
    background: rgba(200, 169, 81, 0.25);
    box-shadow: 0 0 12px rgba(200, 169, 81, 0.3);
  }

  .prompt-text {
    font-family: 'Playfair Display', serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.85;
    color: #4A3F35;
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #F5EFE0;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 2px solid #C8A951;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }

  .use-column::before {
    content: '';
    position: absolute;
    top: 6px;
    left: 6px;
    right: 6px;
    bottom: 6px;
    border: 1px solid rgba(200, 169, 81, 0.3);
    border-radius: 8px;
    pointer-events: none;
    z-index: 1;
  }

  .use-column-heading {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-weight: 700;
    font-size: 1.05rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 2px solid #C8A951;
  }

  .use-good .use-column-heading {
