---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- LEAF DECORATIONS -->
  <div class="leaf-deco leaf-deco-1"></div>
  <div class="leaf-deco leaf-deco-2"></div>
  <div class="leaf-deco leaf-deco-3"></div>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-sunlight"></div>
    <div class="hero-inner">
      <span class="hero-label">Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
      <div class="hero-vine"></div>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <span class="section-label">Description</span>
      <h2 class="section-heading">What This Is</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <span class="section-label">Design Tokens</span>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <div class="char-leaf"></div>
            <div class="char-index">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <span class="section-label">Copy & Paste</span>
      <h2 class="section-heading">Style Reference</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">prompt.txt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <span class="section-label">Use Cases</span>
      <h2 class="section-heading">When to Use</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Grows Well</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Won't Thrive</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <span class="section-label">Origins</span>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <span class="section-label">Connected</span>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-leaf"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to index</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Quicksand', sans-serif;
    background: linear-gradient(160deg, #FFF8E1, #F0F5E8);
    color: #1A4D2E;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
    overflow-x: hidden;
  }

  /* ========================================
     GLOBAL LEAF DECORATIONS
     ======================================== */
  .leaf-deco {
    position: fixed;
    pointer-events: none;
    z-index: 0;
    opacity: 0.08;
  }

  .leaf-deco-1 {
    top: 120px;
    right: -40px;
    width: 180px;
    height: 180px;
    background: #4CAF50;
    border-radius: 70% 30% 60% 40% / 40% 60% 30% 70%;
    transform: rotate(25deg);
  }

  .leaf-deco-2 {
    top: 55%;
    left: -60px;
    width: 220px;
    height: 140px;
    background: #2E7D32;
    border-radius: 60% 40% 70% 30% / 30% 70% 40% 60%;
    transform: rotate(-15deg);
  }

  .leaf-deco-3 {
    bottom: 200px;
    right: -30px;
    width: 140px;
    height: 100px;
    background: #F9C74F;
    border-radius: 50% 50% 70% 30% / 40% 60% 40% 60%;
    transform: rotate(40deg);
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 2px solid rgba(76, 175, 80, 0.2);
    background: rgba(255, 248, 225, 0.85);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-logo {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #2E7D32;
    text-decoration: none;
    padding: 7px 16px;
    border: 2px solid rgba(76, 175, 80, 0.35);
    border-radius: 20px;
    transition: all 0.25s;
  }

  .nav-logo:hover {
    background: rgba(76, 175, 80, 0.1);
    box-shadow: 0 2px 12px rgba(76, 175, 80, 0.15);
  }

  .nav-divider {
    font-size: 1rem;
    color: rgba(76, 175, 80, 0.35);
    font-weight: 500;
  }

  .nav-current {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    color: #1A4D2E;
    text-decoration: none;
    padding: 7px 16px;
    background: rgba(76, 175, 80, 0.1);
    border-radius: 20px;
    transition: all 0.25s;
  }

  .nav-current:hover {
    background: rgba(76, 175, 80, 0.18);
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    padding: 100px 24px 80px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(160deg, #FFF8E1 0%, #F0F5E8 60%, #E8F5E9 100%);
  }

  .hero-sunlight {
    position: absolute;
    top: -30%;
    left: -10%;
    width: 70%;
    height: 160%;
    background: radial-gradient(ellipse at center, rgba(249, 199, 79, 0.18) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -20px;
    right: 5%;
    width: 200px;
    height: 200px;
    background: #4CAF50;
    opacity: 0.06;
    border-radius: 70% 30% 60% 40% / 40% 60% 30% 70%;
    transform: rotate(15deg);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #4CAF50;
    display: inline-block;
    margin-bottom: 20px;
    padding: 6px 18px;
    background: rgba(76, 175, 80, 0.1);
    border-radius: 20px;
    border: 1px solid rgba(76, 175, 80, 0.25);
  }

  .hero-title {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 6.5rem);
    line-height: 1;
    margin: 0 0 24px 0;
    color: #1A4D2E;
  }

  .hero-tagline {
    font-family: 'Quicksand', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2.2vw, 1.25rem);
    line-height: 1.7;
    margin: 0 0 36px 0;
    max-width: 620px;
    color: rgba(26, 77, 46, 0.7);
  }

  .hero-vine {
    height: 4px;
    max-width: 200px;
    background: linear-gradient(90deg, #4CAF50, #F9C74F);
    border-radius: 4px;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 80px 24px;
    position: relative;
    z-index: 1;
  }

  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: #4CAF50;
    display: inline-block;
    margin-bottom: 10px;
    padding: 5px 14px;
    background: rgba(76, 175, 80, 0.08);
    border-radius: 16px;
  }

  .section-heading {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 4.5vw, 2.8rem);
    line-height: 1.1;
    margin: 0 0 44px 0;
    color: #1A4D2E;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: rgba(255, 255, 255, 0.4);
  }

  .about-content {
    max-width: 700px;
    border-left: 3px solid #4CAF50;
    padding-left: 24px;
    border-radius: 0 0 0 20px;
  }

  .about-paragraph {
    font-family: 'Quicksand', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: rgba(26, 77, 46, 0.8);
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: linear-gradient(180deg, rgba(232, 245, 233, 0.5) 0%, rgba(255, 248, 225, 0.3) 100%);
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }

  .char-card {
    background: rgba(255, 255, 255, 0.7);
    padding: 32px 28px 28px;
    border-radius: 24px 8px 24px 8px;
    border: 1px solid rgba(76, 175, 80, 0.2);
    box-shadow: 0 4px 20px rgba(76, 175, 80, 0.08);
    position: relative;
    overflow: hidden;
    transition: all 0.3s;
  }

  .char-card:hover {
    box-shadow: 0 8px 32px rgba(76, 175, 80, 0.15);
    transform: translateY(-2px);
  }

  .char-leaf {
    position: absolute;
    top: -12px;
    right: -12px;
    width: 50px;
    height: 50px;
    background: rgba(76, 175, 80, 0.06);
    border-radius: 70% 30% 60% 40% / 40% 60% 30% 70%;
    transform: rotate(30deg);
    pointer-events: none;
  }

  .char-index {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: #F9C74F;
    margin-bottom: 14px;
    display: inline-block;
    padding: 3px 10px;
    background: rgba(249, 199, 79, 0.12);
    border-radius: 12px;
  }

  .char-title {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    margin: 0 0 10px 0;
    color: #1A4D2E;
  }

  .char-description {
    font-family: 'Quicksand', sans-serif;
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.75;
    margin: 0;
    color: rgba(26, 77, 46, 0.65);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: rgba(255, 255, 255, 0.3);
  }

  .prompt-block {
    background: rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(76, 175, 80, 0.25);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(76, 175, 80, 0.08);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(76, 175, 80, 0.15);
    background: rgba(76, 175, 80, 0.05);
  }

  .prompt-header-label {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #4CAF50;
  }

  .copy-button {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    background: linear-gradient(135deg, #4CAF50, #2E7D32);
    color: #ffffff;
    border: none;
    padding: 8px 22px;
    cursor: pointer;
    border-radius: 20px;
    transition: all 0.25s;
    box-shadow: 0 2px 8px rgba(76, 175, 80, 0.25);
  }

  .copy-button:hover {
    box-shadow: 0 4px 16px rgba(76, 175, 80, 0.35);
    transform: translateY(-1px);
  }

  .copy-button:active {
    transform: translateY(0);
  }

  .copy-button.copied {
    background: linear-gradient(135deg, #F9C74F, #F0A500);
    box-shadow: 0 2px 8px rgba(249, 199, 79, 0.3);
  }

  .prompt-text {
    font-family: 'Quicksand', sans-serif;
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.85;
    color: rgba(26, 77, 46, 0.7);
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: linear-gradient(180deg, rgba(232, 245, 233, 0.4) 0%, rgba(255, 248, 225, 0.4) 100%);
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .use-column {
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(76, 175, 80, 0.2);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(76, 175, 80, 0.06);
  }

  .use-column-heading {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    margin: 0;
    padding: 16px 24px;
    letter-spacing: 0.05em;
    border-bottom: 1px solid rgba(76, 175, 80, 0.12);
  }

  .use-good .use-column-heading {
    color: #2E7D32;
    background: rgba(76, 175, 80, 0.08);
  }

  .use-bad .use-column-heading {
    color: #8D6E63;
    background: rgba(141, 110, 99, 0.06);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Quicksand', sans-serif;
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.55;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(76, 175, 80, 0.06);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: rgba(26, 77, 46, 0.75);
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '\2727';
    font-size: 0.9rem;
    color: #4CAF50;
    flex-shrink: 0;
  }

  .use-item-bad::before {
    content: '\2022';
    font-size: 1.1rem;
    color: #8D6E63;
    flex-shrink: 0;
    line-height: 1.4;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: rgba(255, 255, 255, 0.35);
  }

  .history-content {
    max-width: 700px;
    border-left: 3px solid #F9C74F;
    padding-left: 24px;
    border-radius: 0 0 0 20px;
  }

  .history-paragraph {
    font-family: 'Quicksand', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: rgba(26, 77, 46, 0.75);
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: linear-gradient(180deg, rgba(232, 245, 233, 0.3) 0%, rgba(255, 248, 225, 0.5) 100%);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    background: rgba(255, 255, 255, 0.65);
    border: 1px solid rgba(76, 175, 80, 0.2);
    border-radius: 20px;
    text-decoration: none;
    color: #1A4D2E;
    position: relative;
    transition: all 0.3s;
    box-shadow: 0 2px 12px rgba(76, 175, 80, 0.06);
  }

  .related-card:hover {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(76, 175, 80, 0.4);
    box-shadow: 0 6px 24px rgba(76, 175, 80, 0.12);
    transform: translateY(-2px);
  }

  .related-relationship {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #4CAF50;
  }

  .related-name {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    color: #1A4D2E;
  }

  .related-arrow {
    font-size: 1.1rem;
    position: absolute;
    bottom: 18px;
    right: 20px;
    color: #4CAF50;
    transition: transform 0.25s;
  }

  .related-card:hover .related-arrow {
    transform: translateX(4px);
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    padding: 60px 24px;
    position: relative;
    z-index: 1;
    background: rgba(232, 245, 233, 0.4);
    border-top: 2px solid rgba(76, 175, 80, 0.15);
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-align: center;
  }

  .footer-leaf {
    width: 40px;
    height: 28px;
    background: linear-gradient(135deg, #4CAF50, #2E7D32);
    border-radius: 70% 30% 60% 40% / 40% 60% 30% 70%;
    opacity: 0.3;
    margin-bottom: 4px;
  }

  .footer-logo {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #2E7D32;
    text-decoration: none;
    padding: 8px 20px;
    border: 2px solid rgba(76, 175, 80, 0.3);
    border-radius: 20px;
    transition: all 0.25s;
  }

  .footer-logo:hover {
    background: rgba(76, 175, 80, 0.1);
    box-shadow: 0 2px 12px rgba(76, 175, 80, 0.15);
  }

  .footer-tagline {
    font-family: 'Quicksand', sans-serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: rgba(26, 77, 46, 0.45);
  }

  .footer-back {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    color: #4CAF50;
    text-decoration: none;
    padding: 8px 20px;
    border: 1px solid rgba(76, 175, 80, 0.3);
    border-radius: 20px;
    transition: all 0.25s;
  }

  .footer-back:hover {
    background: rgba(76, 175, 80, 0.08);
    box-shadow: 0 2px 10px rgba(76, 175, 80, 0.12);
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 64px 20px 56px;
    }

    .section {
      padding: 56px 20px;
    }

    .section-heading {
      margin-bottom: 32px;
    }

    .characteristics-grid {
      grid-template-columns: 1fr;
    }

    .use-grid {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .prompt-text {
      font-size: 0.85rem;
