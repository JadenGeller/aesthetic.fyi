---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

<div class="ot-page">
  <!-- Fixed gradient blobs that drift slowly -->
  <div class="ot-blobs" aria-hidden="true">
    <div class="ot-blob ot-blob-blue"></div>
    <div class="ot-blob ot-blob-purple"></div>
    <div class="ot-blob ot-blob-cyan"></div>
    <div class="ot-blob ot-blob-violet"></div>
  </div>

  <!-- 1. Nav -->
  <nav class="ot-nav">
    <div class="ot-nav-inner">
      <a href="/" class="ot-nav-logo">aesthetic.fyi</a>
      <span class="ot-nav-current">{aesthetic.name}</span>
    </div>
  </nav>

  <!-- 2. Hero -->
  <header class="ot-hero">
    <div class="ot-hero-inner">
      <div class="ot-hero-badge">Aesthetic</div>
      <h1 class="ot-hero-title">{aesthetic.name}</h1>
      <p class="ot-hero-tagline">{aesthetic.tagline}</p>
      <div class="ot-hero-line" aria-hidden="true"></div>
    </div>
  </header>

  <main class="ot-content">
    <!-- 3. What This Is -->
    <section class="ot-section">
      <h2 class="ot-section-title">What This Is</h2>
      <div class="ot-panel ot-about-panel">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="ot-body">{paragraph}</p>
        ))}
      </div>
    </section>

    <!-- 4. Characteristics -->
    <section class="ot-section">
      <h2 class="ot-section-title">Characteristics</h2>
      <div class="ot-chars-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }) => (
          <div class="ot-char-card">
            <div class="ot-char-accent" aria-hidden="true"></div>
            <h3 class="ot-char-title">{char.title}</h3>
            <p class="ot-char-desc">{char.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- 5. Style Reference -->
    <section class="ot-section">
      <h2 class="ot-section-title">Style Reference</h2>
      <div class="ot-panel ot-prompt-panel">
        <pre class="ot-prompt-text">{aesthetic.prompt}</pre>
        <button class="ot-copy-btn" data-prompt={aesthetic.prompt}>
          Copy prompt
        </button>
      </div>
    </section>

    <!-- 6. When to Use -->
    <section class="ot-section">
      <h2 class="ot-section-title">When to Use</h2>
      <div class="ot-panel ot-usage-panel">
        <div class="ot-usage-cols">
          <div class="ot-usage-col">
            <h3 class="ot-usage-heading ot-good">Good for</h3>
            <ul class="ot-usage-list">
              {aesthetic.good_for.map((item: string) => (
                <li class="ot-usage-item">{item}</li>
              ))}
            </ul>
          </div>
          <div class="ot-usage-divider" aria-hidden="true"></div>
          <div class="ot-usage-col">
            <h3 class="ot-usage-heading ot-not">Not for</h3>
            <ul class="ot-usage-list">
              {aesthetic.not_for.map((item: string) => (
                <li class="ot-usage-item">{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- 7. History -->
    <section class="ot-section">
      <h2 class="ot-section-title">History</h2>
      <div class="ot-panel ot-history-panel">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="ot-body">{paragraph}</p>
        ))}
      </div>
    </section>

    <!-- 8. Related Styles -->
    <section class="ot-section">
      <h2 class="ot-section-title">Related Styles</h2>
      <div class="ot-related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="ot-related-card">
            <span class="ot-related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="ot-related-rel">{rel.relationship}</span>
          </a>
        ))}
      </div>
    </section>
  </main>

  <!-- 9. Footer -->
  <footer class="ot-footer">
    <div class="ot-footer-inner">
      <a href="/" class="ot-footer-logo">aesthetic.fyi</a>
      <p class="ot-footer-tagline">Every web aesthetic, demonstrated.</p>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ═══════════════════════════════════════════════
     BASE
     ═══════════════════════════════════════════════ */
  .ot-page {
    --ot-bg: #0D0D1A;
    --ot-text: #F0F0F0;
    --ot-text-muted: rgba(240, 240, 240, 0.55);
    --ot-blue: #64B4FF;
    --ot-purple: #8C64FF;
    --ot-panel-bg: rgba(255, 255, 255, 0.04);
    --ot-panel-bg-hover: rgba(255, 255, 255, 0.07);
    --ot-border: rgba(255, 255, 255, 0.08);
    --ot-border-hover: rgba(255, 255, 255, 0.14);
    --ot-radius: 18px;
    --ot-blur: blur(14px);

    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 400;
    color: var(--ot-text);
    background: var(--ot-bg);
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ═══════════════════════════════════════════════
     DRIFTING GRADIENT BLOBS
     ═══════════════════════════════════════════════ */
  .ot-blobs {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .ot-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .ot-blob-blue {
    width: 55vw;
    height: 55vw;
    max-width: 800px;
    max-height: 800px;
    background: radial-gradient(circle, rgba(100, 180, 255, 0.10) 0%, transparent 70%);
    top: -15%;
    right: -10%;
    animation: ot-drift-blue 26s ease-in-out infinite;
  }

  .ot-blob-purple {
    width: 50vw;
    height: 50vw;
    max-width: 750px;
    max-height: 750px;
    background: radial-gradient(circle, rgba(140, 100, 255, 0.08) 0%, transparent 70%);
    bottom: -10%;
    left: -10%;
    animation: ot-drift-purple 30s ease-in-out infinite;
  }

  .ot-blob-cyan {
    width: 40vw;
    height: 40vw;
    max-width: 600px;
    max-height: 600px;
    background: radial-gradient(circle, rgba(80, 200, 255, 0.06) 0%, transparent 70%);
    top: 40%;
    left: 20%;
    animation: ot-drift-cyan 24s ease-in-out infinite;
  }

  .ot-blob-violet {
    width: 35vw;
    height: 35vw;
    max-width: 500px;
    max-height: 500px;
    background: radial-gradient(circle, rgba(160, 100, 255, 0.05) 0%, transparent 70%);
    top: 10%;
    left: -5%;
    animation: ot-drift-violet 28s ease-in-out infinite;
  }

  @keyframes ot-drift-blue {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-3vw, 4vh) scale(1.06); }
    66% { transform: translate(2vw, -3vh) scale(0.95); }
  }

  @keyframes ot-drift-purple {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(4vw, -3vh) scale(0.96); }
    66% { transform: translate(-2vw, 5vh) scale(1.04); }
  }

  @keyframes ot-drift-cyan {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-5vw, -2vh) scale(1.03); }
    66% { transform: translate(3vw, 4vh) scale(0.97); }
  }

  @keyframes ot-drift-violet {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(3vw, 5vh) scale(1.05); }
    66% { transform: translate(-4vw, -2vh) scale(0.94); }
  }

  /* ═══════════════════════════════════════════════
     NAV
     ═══════════════════════════════════════════════ */
  .ot-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0 24px;
  }

  .ot-nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 14px 28px;
    margin-top: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(13, 13, 26, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--ot-border);
    border-radius: 14px;
  }

  .ot-nav-logo {
    font-weight: 500;
    font-size: 0.9rem;
    color: var(--ot-text);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: opacity 0.3s ease;
  }

  .ot-nav-logo:hover {
    opacity: 0.7;
  }

  .ot-nav-current {
    font-weight: 400;
    font-size: 0.85rem;
    color: var(--ot-text-muted);
    letter-spacing: 0.02em;
  }

  /* ═══════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════ */
  .ot-hero {
    position: relative;
    z-index: 1;
    padding: 120px 24px 80px;
    text-align: center;
  }

  .ot-hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .ot-hero-badge {
    display: inline-block;
    font-weight: 500;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--ot-blue);
    background: rgba(100, 180, 255, 0.08);
    border: 1px solid rgba(100, 180, 255, 0.15);
    border-radius: 100px;
    padding: 6px 18px;
    margin-bottom: 28px;
  }

  .ot-hero-title {
    font-weight: 600;
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--ot-text);
    margin: 0 0 20px 0;
    background: linear-gradient(135deg, #F0F0F0 0%, #64B4FF 50%, #8C64FF 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: ot-title-shimmer 8s ease-in-out infinite;
  }

  @keyframes ot-title-shimmer {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .ot-hero-tagline {
    font-weight: 400;
    font-size: clamp(1.05rem, 2.5vw, 1.3rem);
    color: var(--ot-text-muted);
    margin: 0 0 40px 0;
    letter-spacing: 0.01em;
  }

  .ot-hero-line {
    width: 80px;
    height: 2px;
    margin: 0 auto;
    background: linear-gradient(90deg, var(--ot-blue), var(--ot-purple));
    border-radius: 2px;
    opacity: 0.6;
  }

  /* ═══════════════════════════════════════════════
     CONTENT WRAPPER
     ═══════════════════════════════════════════════ */
  .ot-content {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  /* ═══════════════════════════════════════════════
     SECTIONS
     ═══════════════════════════════════════════════ */
  .ot-section {
    margin-bottom: 72px;
  }

  .ot-section-title {
    font-weight: 600;
    font-size: clamp(1.3rem, 2.5vw, 1.7rem);
    color: var(--ot-text);
    margin: 0 0 24px 0;
    letter-spacing: -0.01em;
    opacity: 0.9;
  }

  /* ═══════════════════════════════════════════════
     PANELS
     ═══════════════════════════════════════════════ */
  .ot-panel {
    background: var(--ot-panel-bg);
    backdrop-filter: var(--ot-blur);
    -webkit-backdrop-filter: var(--ot-blur);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    padding: 40px;
    transition: background 0.4s ease, border-color 0.4s ease;
  }

  .ot-panel:hover {
    background: var(--ot-panel-bg-hover);
    border-color: var(--ot-border-hover);
  }

  /* ═══════════════════════════════════════════════
     BODY TEXT
     ═══════════════════════════════════════════════ */
  .ot-body {
    font-weight: 400;
    font-size: 1.02rem;
    line-height: 1.8;
    color: rgba(240, 240, 240, 0.8);
    margin: 0 0 20px 0;
  }

  .ot-body:last-child {
    margin-bottom: 0;
  }

  /* ═══════════════════════════════════════════════
     ABOUT
     ═══════════════════════════════════════════════ */
  .ot-about-panel {
    max-width: 780px;
  }

  /* ═══════════════════════════════════════════════
     CHARACTERISTICS
     ═══════════════════════════════════════════════ */
  .ot-chars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }

  .ot-char-card {
    position: relative;
    background: var(--ot-panel-bg);
    backdrop-filter: var(--ot-blur);
    -webkit-backdrop-filter: var(--ot-blur);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    overflow: hidden;
    transition: background 0.4s ease, border-color 0.4s ease, transform 0.4s ease;
  }

  .ot-char-card:hover {
    background: var(--ot-panel-bg-hover);
    border-color: var(--ot-border-hover);
    transform: translateY(-2px);
  }

  .ot-char-accent {
    position: absolute;
    top: 0;
    left: 32px;
    right: 32px;
    height: 1px;
    background: linear-gradient(90deg, var(--ot-blue), var(--ot-purple));
    opacity: 0.4;
    transition: opacity 0.4s ease;
  }

  .ot-char-card:hover .ot-char-accent {
    opacity: 0.8;
  }

  .ot-char-title {
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--ot-text);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .ot-char-desc {
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.7;
    color: rgba(240, 240, 240, 0.6);
    margin: 0;
  }

  /* ═══════════════════════════════════════════════
     STYLE REFERENCE / PROMPT
     ═══════════════════════════════════════════════ */
  .ot-prompt-panel {
    position: relative;
  }

  .ot-prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(240, 240, 240, 0.8);
    white-space: normal;
    word-wrap: break-word;
    margin: 0 0 28px 0;
    padding: 0;
    background: none;
    border: none;
  }

  .ot-copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    color: var(--ot-text);
    background: rgba(100, 180, 255, 0.06);
    border: 1px solid rgba(100, 180, 255, 0.18);
    border-radius: 10px;
    padding: 10px 22px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ot-copy-btn:hover {
    background: rgba(100, 180, 255, 0.12);
    border-color: rgba(100, 180, 255, 0.3);
    box-shadow: 0 0 20px rgba(100, 180, 255, 0.08);
  }

  .ot-copy-btn:active {
    transform: scale(0.97);
  }

  .ot-copy-btn.copied {
    background: rgba(140, 100, 255, 0.12);
    border-color: rgba(140, 100, 255, 0.3);
    box-shadow: 0 0 20px rgba(140, 100, 255, 0.08);
  }

  /* ═══════════════════════════════════════════════
     WHEN TO USE
     ═══════════════════════════════════════════════ */
  .ot-usage-cols {
    display: flex;
    gap: 40px;
  }

  .ot-usage-col {
    flex: 1;
    min-width: 0;
  }

  .ot-usage-divider {
    width: 1px;
    background: linear-gradient(180deg, transparent, rgba(100, 180, 255, 0.15), rgba(140, 100, 255, 0.15), transparent);
    align-self: stretch;
    flex-shrink: 0;
  }

  .ot-usage-heading {
    font-weight: 600;
    font-size: 1rem;
    margin: 0 0 20px 0;
    letter-spacing: 0.01em;
  }

  .ot-good {
    color: var(--ot-blue);
  }

  .ot-not {
    color: rgba(200, 140, 255, 0.85);
  }

  .ot-usage-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .ot-usage-item {
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(240, 240, 240, 0.65);
    padding-left: 18px;
    position: relative;
  }

  .ot-usage-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: rgba(100, 180, 255, 0.25);
  }

  /* ═══════════════════════════════════════════════
     HISTORY
     ═══════════════════════════════════════════════ */
  .ot-history-panel {
    max-width: 780px;
  }

  /* ═══════════════════════════════════════════════
     RELATED STYLES
     ═══════════════════════════════════════════════ */
  .ot-related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 14px;
  }

  .ot-related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    padding: 24px;
    background: var(--ot-panel-bg);
    backdrop-filter: var(--ot-blur);
    -webkit-backdrop-filter: var(--ot-blur);
    border: 1px solid var(--ot-border);
    border-radius: var(--ot-radius);
    transition: background 0.4s ease, border-color 0.4s ease, transform 0.4s ease;
  }

  .ot-related-card:hover {
    background: var(--ot-panel-bg-hover);
    border-color: var(--ot-border-hover);
    transform: translateY(-2px);
  }

  .ot-related-name {
    font-weight: 600;
    font-size: 1rem;
    color: var(--ot-text);
    transition: color 0.3s ease;
  }

  .ot-related-card:hover .ot-related-name {
    background: linear-gradient(90deg, var(--ot-blue), var(--ot-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ot-related-rel {
    font-weight: 400;
    font-size: 0.78rem;
    color: var(--ot-text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ═══════════════════════════════════════════════
     FOOTER
     ═══════════════════════════════════════════════ */
  .ot-footer {
    position: relative;
    z-index: 1;
    padding: 0 24px 40px;
  }

  .ot-footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 28px 36px;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid var(--ot-border);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .ot-footer-logo {
    font-weight: 500;
    font-size: 0.88rem;
    color: var(--ot-text);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .ot-footer-logo:hover {
    opacity: 1;
  }

  .ot-footer-tagline {
    font-weight: 400;
    font-size: 0.82rem;
    color: var(--ot-text-muted);
    margin: 0;
  }

  /* ═══════════════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════════════ */
  @media (max-width: 768px) {
    .ot-hero {
      padding: 80px 24px 60px;
    }

    .ot-panel {
      padding: 28px 24px;
    }

    .ot-char-card {
      padding: 24px 20px;
    }

    .ot-char-accent {
      left: 20px;
      right: 20px;
    }

    .ot-section {
      margin-bottom: 56px;
    }

    .ot-usage-cols {
      flex-direction: column;
      gap: 32px;
    }

    .ot-usage-divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(100, 180, 255, 0.15), rgba(140, 100, 255, 0.15), transparent);
      align-self: auto;
    }

    .ot-related-grid {
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 12px;
    }

    .ot-related-card {
      padding: 20px 16px;
    }

    .ot-footer-inner {
      flex-direction: column;
      gap: 12px;
      text-align: center;
      padding: 24px 20px;
    }

    .ot-nav-inner {
      padding: 12px 20px;
    }

    .ot-blob-blue {
      width: 80vw;
      height: 80vw;
    }

    .ot-blob-purple {
      width: 70vw;
      height: 70vw;
    }

    .ot-blob-cyan {
      width: 60vw;
      height: 60vw;
    }

    .ot-blob-violet {
      width: 55vw;
      height: 55vw;
    }
  }

  @media (max-width: 420px) {
    .ot-hero-title {
