---
const { aesthetic } = Astro.props;
---

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-tape hero-tape-left"></div>
    <div class="hero-tape hero-tape-right"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-scrap">
        <p class="hero-tagline">{aesthetic.tagline}</p>
      </div>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">What This Is</span>
      </div>
      <h2 class="section-heading">Assembled, Not Designed</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Design Tokens</span>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class={`char-card char-card-${i + 1}`}>
            <div class="char-tape"></div>
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Style Reference</span>
      </div>
      <h2 class="section-heading">Copy & Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">When to Use</span>
      </div>
      <h2 class="section-heading">Right Context, Wrong Context</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Origins</span>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string, i: number) => (
          <div class={`history-clipping history-clipping-${i + 1}`}>
            <p class="history-paragraph">{paragraph}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Explore</span>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }, i: number) => (
          <a href={`/${rel.slug}`} class={`related-card related-card-${i + 1}`}>
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-strip"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-strip"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: Georgia, 'Times New Roman', serif;
    background-color: #F5F0E8;
    color: #2A2D3E;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 40px,
        rgba(0,0,0,0.015) 40px,
        rgba(0,0,0,0.015) 41px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 40px,
        rgba(0,0,0,0.01) 40px,
        rgba(0,0,0,0.01) 41px
      );
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 2px solid #2A2D3E;
    background: #F5F0E8;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .nav-logo {
    font-family: 'Courier New', Courier, monospace;
    font-weight: 700;
    font-size: 0.9rem;
    color: #2A2D3E;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 6px 16px;
    border: 2px solid #2A2D3E;
    transition: background 0.2s, color 0.2s;
  }

  .nav-logo:hover {
    background: #2A2D3E;
    color: #F5F0E8;
  }

  .nav-divider {
    font-family: 'Courier New', Courier, monospace;
    font-size: 1.2rem;
    color: #999;
    margin: 0 2px;
  }

  .nav-current {
    font-family: Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.95rem;
    color: #E85D4A;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-current:hover {
    color: #2A2D3E;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #F5F0E8;
    padding: 100px 32px 88px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 3px double #2A2D3E;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      linear-gradient(135deg, transparent 48%, rgba(212,168,67,0.06) 49%, rgba(212,168,67,0.06) 51%, transparent 52%),
      linear-gradient(45deg, transparent 48%, rgba(232,93,74,0.04) 49%, rgba(232,93,74,0.04) 51%, transparent 52%);
    background-size: 60px 60px, 45px 45px;
    pointer-events: none;
  }

  .hero-tape {
    position: absolute;
    width: 80px;
    height: 24px;
    background: rgba(212, 168, 67, 0.3);
    border: 1px solid rgba(212, 168, 67, 0.15);
    z-index: 2;
  }

  .hero-tape-left {
    top: 30px;
    left: 40px;
    transform: rotate(-15deg);
  }

  .hero-tape-right {
    top: 24px;
    right: 50px;
    transform: rotate(8deg);
  }

  .hero-inner {
    max-width: 740px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Courier New', Courier, monospace;
    font-weight: 400;
    font-size: 0.75rem;
    color: #3A8C8C;
    display: inline-block;
    margin-bottom: 20px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border: 1px dashed #3A8C8C;
    padding: 4px 14px;
    transform: rotate(-1deg);
  }

  .hero-title {
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: 700;
    font-size: clamp(3.5rem, 10vw, 7rem);
    line-height: 0.95;
    margin: 0 0 32px 0;
    color: #2A2D3E;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    transform: rotate(-1.5deg);
    position: relative;
  }

  .hero-title::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 10%;
    right: 15%;
    height: 4px;
    background: #E85D4A;
    transform: rotate(0.5deg);
  }

  .hero-scrap {
    background: #FFFDF7;
    border: 1px solid #ccc;
    padding: 20px 28px;
    max-width: 480px;
    margin: 0 auto;
    transform: rotate(1.2deg);
    box-shadow: 2px 3px 8px rgba(0,0,0,0.1);
    position: relative;
  }

  .hero-scrap::before {
    content: '';
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 20px;
    background: rgba(58, 140, 140, 0.25);
    border: 1px solid rgba(58, 140, 140, 0.1);
  }

  .hero-tagline {
    font-family: Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    line-height: 1.7;
    margin: 0;
    color: #555;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 80px 32px;
    border-bottom: 2px solid #2A2D3E;
    position: relative;
  }

  .section-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 8px;
  }

  .section-label {
    font-family: 'Courier New', Courier, monospace;
    font-weight: 400;
    font-size: 0.7rem;
    color: #3A8C8C;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: inline-block;
    border-bottom: 1px dashed #3A8C8C;
    padding-bottom: 2px;
  }

  .section-heading {
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.1;
    margin: 0 0 48px 0;
    text-align: center;
    color: #2A2D3E;
    transform: rotate(-0.5deg);
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #EDE8DE;
    clip-path: polygon(0 0, 100% 0.5%, 100% 99.2%, 0% 100%);
  }

  .about-content {
    max-width: 640px;
    margin: 0 auto;
    position: relative;
  }

  .about-content::before {
    content: '';
    position: absolute;
    top: -20px;
    right: -30px;
    width: 70px;
    height: 22px;
    background: rgba(232, 93, 74, 0.25);
    border: 1px solid rgba(232, 93, 74, 0.1);
    transform: rotate(25deg);
    pointer-events: none;
  }

  .about-paragraph {
    font-family: Georgia, serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #2A2D3E;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  .about-paragraph:first-child {
    padding-left: 20px;
    border-left: 3px solid #D4A843;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #F5F0E8;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 28px;
    position: relative;
  }

  .char-card {
    background: #FFFDF7;
    border: 1px solid #ccc;
    padding: 32px 24px 24px;
    position: relative;
    box-shadow: 2px 3px 10px rgba(0,0,0,0.08);
    transition: box-shadow 0.3s, transform 0.3s;
  }

  .char-card:hover {
    box-shadow: 4px 6px 20px rgba(0,0,0,0.12);
    z-index: 2;
  }

  .char-card-1 {
    transform: rotate(-1.5deg);
  }

  .char-card-2 {
    transform: rotate(1deg);
  }

  .char-card-3 {
    transform: rotate(-0.8deg);
  }

  .char-card-4 {
    transform: rotate(1.8deg);
  }

  .char-card-5 {
    transform: rotate(-1deg);
  }

  .char-card-6 {
    transform: rotate(0.5deg);
  }

  .char-tape {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 50px;
    height: 18px;
    background: rgba(212, 168, 67, 0.3);
    border: 1px solid rgba(212, 168, 67, 0.12);
  }

  .char-number {
    font-family: 'Courier New', Courier, monospace;
    font-weight: 700;
    font-size: 0.7rem;
    color: #E85D4A;
    display: block;
    margin-bottom: 8px;
    letter-spacing: 0.1em;
  }

  .char-title {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    margin: 0 0 10px 0;
    color: #2A2D3E;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .char-description {
    font-family: Georgia, serif;
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.7;
    margin: 0;
    color: #555;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #EDE8DE;
    clip-path: polygon(0 0.4%, 100% 0, 100% 100%, 0% 99.5%);
  }

  .prompt-block {
    border: 2px solid #2A2D3E;
    margin: 0 auto;
    position: relative;
    background: #FFFDF7;
    transform: rotate(-0.5deg);
    box-shadow: 3px 4px 12px rgba(0,0,0,0.1);
  }

  .prompt-block::before {
    content: '';
    position: absolute;
    top: -11px;
    right: 40px;
    width: 55px;
    height: 18px;
    background: rgba(58, 140, 140, 0.3);
    border: 1px solid rgba(58, 140, 140, 0.1);
    transform: rotate(5deg);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 20px;
    border-bottom: 2px solid #2A2D3E;
    background: rgba(42, 45, 62, 0.04);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Courier New', Courier, monospace;
    font-weight: 700;
    font-size: 0.75rem;
    color: #2A2D3E;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Courier New', Courier, monospace;
    font-weight: 700;
    font-size: 0.75rem;
    background: transparent;
    color: #2A2D3E;
    border: 2px solid #2A2D3E;
    padding: 5px 18px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: background 0.2s, color 0.2s;
  }

  .copy-button:hover {
    background: #2A2D3E;
    color: #F5F0E8;
  }

  .copy-button.copied {
    background: #3A8C8C;
    color: #F5F0E8;
    border-color: #3A8C8C;
  }

  .prompt-text {
    font-family: 'Courier New', Courier, monospace;
    font-weight: 400;
    font-size: 0.88rem;
    line-height: 1.75;
    color: #2A2D3E;
    padding: 24px 20px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #F5F0E8;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 2px solid #2A2D3E;
    overflow: hidden;
    position: relative;
    background: #FFFDF7;
  }

  .use-good {
    transform: rotate(-1deg);
    box-shadow: 2px 3px 10px rgba(0,0,0,0.08);
  }

  .use-bad {
    transform: rotate(0.8deg);
    box-shadow: 2px 3px 10px rgba(0,0,0,0.08);
  }

  .use-good::before {
    content: '';
    position: absolute;
    top: -10px;
    left: 30px;
    width: 50px;
    height: 18px;
    background: rgba(58, 140, 140, 0.3);
    border: 1px solid rgba(58, 140, 140, 0.1);
    transform: rotate(-8deg);
    z-index: 2;
  }

  .use-bad::before {
    content: '';
    position: absolute;
    top: -10px;
    right: 25px;
    width: 50px;
    height: 18px;
    background: rgba(232, 93, 74, 0.25);
    border: 1px solid rgba(232, 93, 74, 0.1);
    transform: rotate(6deg);
    z-index: 2;
  }

  .use-column-heading {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    margin: 0;
    padding: 14px 20px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 2px solid #2A2D3E;
  }

  .use-good .use-column-heading {
    background: rgba(58, 140, 140, 0.1);
    color: #3A8C8C;
  }

  .use-bad .use-column-heading {
    background: rgba(232, 93, 74, 0.08);
    color: #E85D4A;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: Georgia, serif;
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.5;
    padding: 12px 20px;
    border-bottom: 1px dashed #ccc;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #2A2D3E;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '+';
    font-family: 'Courier New', Courier, monospace;
    font-weight: 700;
    color: #3A8C8C;
    flex-shrink: 0;
  }

  .use-item-bad::before {
    content: '\00d7';
    font-family: 'Courier New', Courier, monospace;
    font-weight: 700;
    color: #E85D4A;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #EDE8DE;
    clip-path: polygon(0 0, 100% 0.6%, 100% 99.4%, 0% 100%);
  }

  .history-content {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .history-clipping {
    background: #FFFDF7;
    border: 1px solid #ccc;
    padding: 24px 28px;
    position: relative;
    box-shadow: 2px 3px 8px rgba(0,0,0,0.07);
  }

  .history-clipping-1 {
    transform: rotate(-0.8deg);
    border-left: 4px solid #E85D4A;
  }

  .history-clipping-1::before {
    content: '';
    position: absolute;
    top: -10px;
    left: 20px;
    width: 50px;
    height: 18px;
    background: rgba(212, 168, 67, 0.3);
    border: 1px solid rgba(212, 168, 67, 0.12);
    transform: rotate(-5deg);
  }

  .history-clipping-2 {
    transform: rotate(0.6deg);
    border-left: 4px solid #D4A843;
  }

  .history-clipping-2::before {
    content: '';
    position: absolute;
    top: -10px;
    right: 30px;
    width: 50px;
    height: 18px;
    background: rgba(58, 140, 140, 0.25);
    border: 1px solid rgba(58, 140, 140, 0.1);
    transform: rotate(8deg);
  }

  .history-clipping-3 {
    transform: rotate(-1.2deg);
    border-left: 4px solid #3A8C8C;
  }

  .history-clipping-3::before {
    content: '';
    position: absolute;
    top: -10px;
    left: 40px;
    width: 55px;
    height: 18px;
    background: rgba(232, 93, 74, 0.2);
    border: 1px solid rgba(232, 93, 74, 0.1);
    transform: rotate(-3deg);
  }

  .history-paragraph {
    font-family: Georgia, serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0;
    color: #2A2D3E;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #F5F0E8;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 24px;
    max-width: 780px;
