---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">&#9670;</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-rosette"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-gem"></span>
        <span class="hero-line"></span>
        <span class="hero-gem"></span>
        <span class="hero-line"></span>
        <span class="hero-gem"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Light Made Structural</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class={`char-card char-card-${(i % 5) + 1}`}>
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Sacred Ground, Profane Ground</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Cormorant Garamond', serif;
    background-color: #1a1a1a;
    color: #e8e0d0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 3px solid #000;
    background: #111;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.5);
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 0.9rem;
    color: #CC8800;
    text-decoration: none;
    padding: 6px 18px;
    border: 2px solid #CC8800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: background 0.3s, box-shadow 0.3s;
  }

  .nav-logo:hover {
    background: rgba(204, 136, 0, 0.15);
    box-shadow: 0 0 12px rgba(204, 136, 0, 0.3);
  }

  .nav-divider {
    font-size: 0.7rem;
    color: #CC8800;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: #e8e0d0;
    text-decoration: none;
    padding: 6px 18px;
    border: 2px solid transparent;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: border-color 0.3s;
  }

  .nav-current:hover {
    border-color: rgba(232, 224, 208, 0.3);
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #141414;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 4px solid #000;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 3px solid #000;
    pointer-events: none;
    box-shadow:
      inset 0 0 30px rgba(155, 27, 48, 0.08),
      inset 0 0 30px rgba(27, 58, 140, 0.08);
  }

  .hero-rosette {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 500px;
    background:
      radial-gradient(circle at center, transparent 30%, rgba(155, 27, 48, 0.06) 31%, rgba(155, 27, 48, 0.06) 32%, transparent 33%),
      radial-gradient(circle at center, transparent 45%, rgba(27, 58, 140, 0.05) 46%, rgba(27, 58, 140, 0.05) 47%, transparent 48%),
      radial-gradient(circle at center, transparent 60%, rgba(204, 136, 0, 0.04) 61%, rgba(204, 136, 0, 0.04) 62%, transparent 63%),
      radial-gradient(circle at center, transparent 75%, rgba(107, 47, 160, 0.03) 76%, rgba(107, 47, 160, 0.03) 77%, transparent 78%);
    opacity: 0.8;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 0.75rem;
    color: #CC8800;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border: 1px solid rgba(204, 136, 0, 0.3);
    padding: 6px 16px;
  }

  .hero-title {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.05;
    margin: 0 0 24px 0;
    color: #e8e0d0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-shadow: 0 0 40px rgba(204, 136, 0, 0.2);
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 24px;
  }

  .hero-gem {
    width: 8px;
    height: 8px;
    background: #CC8800;
    transform: rotate(45deg);
    box-shadow: 0 0 8px rgba(204, 136, 0, 0.5);
  }

  .hero-line {
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, rgba(204, 136, 0, 0.6), rgba(204, 136, 0, 0.1));
  }

  .hero-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 520px;
    color: rgba(232, 224, 208, 0.7);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 4px solid #000;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(204, 136, 0, 0.5), transparent);
  }

  .section-label {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 0.7rem;
    color: #CC8800;
    white-space: nowrap;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #e8e0d0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #141414;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 16px;
    left: 16px;
    right: 16px;
    bottom: 16px;
    border: 3px solid #000;
    pointer-events: none;
    box-shadow: inset 0 0 40px rgba(27, 107, 74, 0.06);
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.2rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: rgba(232, 224, 208, 0.85);
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #1a1a1a;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 4px;
  }

  .char-card {
    border: 3px solid #000;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    transition: box-shadow 0.4s;
  }

  .char-card-1 {
    background: rgba(155, 27, 48, 0.12);
  }
  .char-card-1:hover {
    box-shadow: 0 0 24px rgba(155, 27, 48, 0.3), inset 0 0 24px rgba(155, 27, 48, 0.08);
  }

  .char-card-2 {
    background: rgba(27, 58, 140, 0.12);
  }
  .char-card-2:hover {
    box-shadow: 0 0 24px rgba(27, 58, 140, 0.3), inset 0 0 24px rgba(27, 58, 140, 0.08);
  }

  .char-card-3 {
    background: rgba(27, 107, 74, 0.12);
  }
  .char-card-3:hover {
    box-shadow: 0 0 24px rgba(27, 107, 74, 0.3), inset 0 0 24px rgba(27, 107, 74, 0.08);
  }

  .char-card-4 {
    background: rgba(204, 136, 0, 0.12);
  }
  .char-card-4:hover {
    box-shadow: 0 0 24px rgba(204, 136, 0, 0.3), inset 0 0 24px rgba(204, 136, 0, 0.08);
  }

  .char-card-5 {
    background: rgba(107, 47, 160, 0.12);
  }
  .char-card-5:hover {
    box-shadow: 0 0 24px rgba(107, 47, 160, 0.3), inset 0 0 24px rgba(107, 47, 160, 0.08);
  }

  .char-number {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 0.75rem;
    color: #CC8800;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 24px;
    height: 2px;
    background: rgba(204, 136, 0, 0.4);
    margin: 0 auto 14px;
  }

  .char-title {
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 1.1rem;
    margin: 0 0 12px 0;
    color: #e8e0d0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .char-description {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.75;
    margin: 0;
    color: rgba(232, 224, 208, 0.65);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #141414;
  }

  .prompt-block {
    border: 3px solid #000;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    background: rgba(27, 58, 140, 0.08);
    box-shadow: 0 0 20px rgba(27, 58, 140, 0.15);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 3px solid #000;
    background: rgba(27, 58, 140, 0.1);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 0.7rem;
    color: #CC8800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 0.75rem;
    background: transparent;
    color: #CC8800;
    border: 2px solid #CC8800;
    padding: 6px 20px;
    cursor: pointer;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background 0.3s, box-shadow 0.3s;
  }

  .copy-button:hover {
    background: rgba(204, 136, 0, 0.15);
    box-shadow: 0 0 12px rgba(204, 136, 0, 0.3);
  }

  .copy-button.copied {
    background: rgba(204, 136, 0, 0.2);
    box-shadow: 0 0 16px rgba(204, 136, 0, 0.4);
  }

  .prompt-text {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.85;
    color: rgba(232, 224, 208, 0.8);
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #1a1a1a;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 3px solid #000;
    overflow: hidden;
    position: relative;
  }

  .use-column-heading {
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 0.85rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 3px solid #000;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .use-good .use-column-heading {
    background: rgba(27, 107, 74, 0.2);
    color: #4ae89a;
  }

  .use-bad .use-column-heading {
    background: rgba(155, 27, 48, 0.15);
    color: #e86b6b;
  }

  .use-good {
    background: rgba(27, 107, 74, 0.06);
  }

  .use-bad {
    background: rgba(155, 27, 48, 0.06);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: rgba(232, 224, 208, 0.8);
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 8px;
    height: 8px;
    background: #1B6B4A;
    transform: rotate(45deg);
    flex-shrink: 0;
    margin-top: 5px;
    box-shadow: 0 0 6px rgba(27, 107, 74, 0.5);
  }

  .use-item-bad::before {
    content: '';
    width: 8px;
    height: 8px;
    background: #9B1B30;
    transform: rotate(45deg);
    flex-shrink: 0;
    margin-top: 5px;
    box-shadow: 0 0 6px rgba(155, 27, 48, 0.5);
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #141414;
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 16px;
    left: 16px;
    right: 16px;
    bottom: 16px;
    border: 3px solid #000;
    pointer-events: none;
    box-shadow: inset 0 0 40px rgba(107, 47, 160, 0.06);
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: rgba(232, 224, 208, 0.85);
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #1a1a1a;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 4px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 28px 20px;
    border: 3px solid #000;
    text-decoration: none;
    color: #e8e0d0;
    text-align: center;
    position: relative;
    background: rgba(107, 47, 160, 0.08);
    transition: box-shadow 0.4s, background 0.4s;
  }

  .related-card:hover {
    box-shadow: 0 0 20px rgba(107, 47, 160, 0.25);
    background: rgba(107, 47, 160, 0.14);
  }

  .related-relationship {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 0.6rem;
    color: rgba(232, 224, 208, 0.5);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .related-name {
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 1rem;
    color: #e8e0d0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .related-arrow {
    font-size: 1rem;
    color: #CC8800;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #111;
    padding: 64px 32px;
    border-top: 4px solid #000;
  }

  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-ornament {
