---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">&hearts;</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-sparkles"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-star">&#9734;</span>
        <span class="hero-heart">&hearts;</span>
        <span class="hero-star">&#9734;</span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-deco">&hearts;</span>
        <span class="section-label">What This Is</span>
        <span class="section-deco">&hearts;</span>
      </div>
      <h2 class="section-heading">A Cute Philosophy</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-deco">&#9734;</span>
        <span class="section-label">Design Tokens</span>
        <span class="section-deco">&#9734;</span>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-deco">&hearts;</span>
        <span class="section-label">Style Reference</span>
        <span class="section-deco">&hearts;</span>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-deco">&#9734;</span>
        <span class="section-label">When to Use</span>
        <span class="section-deco">&#9734;</span>
      </div>
      <h2 class="section-heading">Good Fit, Bad Fit</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-deco">&hearts;</span>
        <span class="section-label">Origins</span>
        <span class="section-deco">&hearts;</span>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-deco">&#9734;</span>
        <span class="section-label">Explore</span>
        <span class="section-deco">&#9734;</span>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Quicksand', sans-serif;
    background-color: #FFFFFF;
    color: #6B5B7B;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 2px solid #F5E6F0;
    background: #FFFFFF;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #D4789C;
    text-decoration: none;
    padding: 8px 20px;
    border: 2px solid #FFD6E5;
    border-radius: 20px;
    background: #FFF5F8;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .nav-logo:hover {
    background: #FFE8F0;
    border-color: #FFB7C5;
    transform: scale(1.05);
  }

  .nav-divider {
    font-size: 1rem;
    color: #FFB7C5;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    color: #B68CB8;
    text-decoration: none;
    padding: 8px 20px;
    border: 2px solid transparent;
    border-radius: 20px;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .nav-current:hover {
    border-color: #E6D5F5;
    background: #F9F0FF;
    transform: scale(1.05);
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: linear-gradient(180deg, #FFF5F8 0%, #FFFFFF 100%);
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 2px solid #F5E6F0;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 24px;
    left: 24px;
    right: 24px;
    bottom: 24px;
    border: 2px dashed #FFD6E5;
    border-radius: 24px;
    pointer-events: none;
  }

  .hero-sparkles {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
  }

  .hero-sparkles::before {
    content: '\2726  \2726  \2726';
    position: absolute;
    top: 50px;
    left: 60px;
    font-size: 1.2rem;
    color: #FFB7C5;
    opacity: 0.4;
    letter-spacing: 8px;
    animation: twinkle 3s ease-in-out infinite;
  }

  .hero-sparkles::after {
    content: '\2726  \2726  \2726';
    position: absolute;
    bottom: 50px;
    right: 60px;
    font-size: 1rem;
    color: #E6D5F5;
    opacity: 0.4;
    letter-spacing: 8px;
    animation: twinkle 3s ease-in-out infinite 1.5s;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.1); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  @keyframes bounceIn {
    0% { transform: scale(0.9); opacity: 0; }
    60% { transform: scale(1.05); opacity: 1; }
    100% { transform: scale(1); opacity: 1; }
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    color: #B68CB8;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: #F9F0FF;
    padding: 6px 18px;
    border-radius: 20px;
    border: 1px solid #E6D5F5;
  }

  .hero-title {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.1;
    margin: 0 0 24px 0;
    color: #D4789C;
    animation: bounceIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .hero-star {
    font-size: 1rem;
    color: #FFF5BA;
    filter: drop-shadow(0 0 2px rgba(255, 245, 186, 0.8));
    animation: twinkle 2s ease-in-out infinite;
  }

  .hero-heart {
    font-size: 1.2rem;
    color: #FFB7C5;
    animation: float 3s ease-in-out infinite;
  }

  .hero-tagline {
    font-family: 'Quicksand', sans-serif;
    font-weight: 500;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.8;
    margin: 0 auto;
    max-width: 520px;
    color: #B68CB8;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 2px solid #F5E6F0;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .section-deco {
    color: #FFB7C5;
    font-size: 0.8rem;
    opacity: 0.6;
  }

  .section-label {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    color: #B68CB8;
    white-space: nowrap;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    line-height: 1.2;
    margin: 0 0 48px 0;
    text-align: center;
    color: #D4789C;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: linear-gradient(180deg, #FEF9FF 0%, #FFF5F8 100%);
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px dashed #E6D5F5;
    border-radius: 20px;
    pointer-events: none;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Quicksand', sans-serif;
    font-weight: 500;
    font-size: 1.1rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #6B5B7B;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #FFFFFF;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 2px solid #F5E6F0;
    border-radius: 20px;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: #FFFFFF;
    transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .char-card::before {
    content: '\2665';
    position: absolute;
    top: -10px;
    right: 20px;
    font-size: 0.9rem;
    color: #FFB7C5;
    background: #FFFFFF;
    padding: 0 6px;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .char-card:hover::before {
    opacity: 1;
  }

  .char-card:hover {
    box-shadow: 0 8px 32px rgba(255, 183, 197, 0.2);
    border-color: #FFB7C5;
    transform: translateY(-4px) scale(1.01);
  }

  .char-number {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    color: #B68CB8;
    display: inline-block;
    margin-bottom: 10px;
    letter-spacing: 0.1em;
    background: #F9F0FF;
    padding: 4px 14px;
    border-radius: 12px;
  }

  .char-divider {
    width: 24px;
    height: 2px;
    background: linear-gradient(90deg, #FFB7C5, #E6D5F5);
    margin: 0 auto 14px;
    border-radius: 2px;
  }

  .char-title {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin: 0 0 12px 0;
    color: #D4789C;
  }

  .char-description {
    font-family: 'Quicksand', sans-serif;
    font-weight: 500;
    font-size: 0.92rem;
    line-height: 1.75;
    margin: 0;
    color: #9A8AAB;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: linear-gradient(180deg, #FEFFF5 0%, #F5FFF8 100%);
  }

  .prompt-block {
    border: 2px solid #C8E6D0;
    border-radius: 20px;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    background: #FFFFFF;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 2px solid #D8F0DF;
    background: rgba(181, 234, 215, 0.15);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    color: #7BAF8A;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    background: #E8F8EE;
    color: #7BAF8A;
    border: 2px solid #B5EAD7;
    border-radius: 16px;
    padding: 6px 20px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .copy-button:hover {
    background: #B5EAD7;
    color: #FFFFFF;
    transform: scale(1.05);
  }

  .copy-button.copied {
    background: #B5EAD7;
    color: #FFFFFF;
    border-color: #8DD4B4;
  }

  .prompt-text {
    font-family: 'Quicksand', sans-serif;
    font-weight: 500;
    font-size: 0.98rem;
    line-height: 1.85;
    color: #6B5B7B;
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #FFFFFF;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 2px solid #F5E6F0;
    border-radius: 20px;
    overflow: hidden;
    position: relative;
  }

  .use-column-heading {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 2px solid #F5E6F0;
  }

  .use-good .use-column-heading {
    background: linear-gradient(135deg, rgba(181, 234, 215, 0.25), rgba(255, 245, 186, 0.2));
    color: #7BAF8A;
  }

  .use-good .use-column-heading::before {
    content: '\2726 ';
    color: #B5EAD7;
  }

  .use-bad .use-column-heading {
    background: rgba(230, 213, 245, 0.2);
    color: #B68CB8;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Quicksand', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(245, 230, 240, 0.5);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #6B5B7B;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '\2665';
    color: #FFB7C5;
    flex-shrink: 0;
    font-size: 0.7rem;
    margin-top: 4px;
  }

  .use-item-bad::before {
    content: '\2013';
    color: #E6D5F5;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: linear-gradient(180deg, #FFFDF5 0%, #FFF9FE 100%);
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px dashed #FFEAB5;
    border-radius: 20px;
    pointer-events: none;
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Quicksand', sans-serif;
    font-weight: 500;
    font-size: 1.05rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #6B5B7B;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #FFFFFF;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 28px 20px;
    border: 2px solid #F5E6F0;
    border-radius: 20px;
    text-decoration: none;
    color: #6B5B7B;
    text-align: center;
    position: relative;
    transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    background: #FFFFFF;
  }

  .related-card::after {
    content: '\2726';
    position: absolute;
    top: 10px;
    left: 16px;
    font-size: 0.7rem;
    color: #FFB7C5;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .related-card:hover::after {
    opacity: 0.6;
  }

  .related-card:hover {
    box-shadow: 0 8px 24px rgba(255, 183, 197, 0.18);
    border-color: #FFB7C5;
    transform: translateY(-4px) scale(1.02);
  }

  .related-relationship {
    font-family: 'Quicksand', sans-serif;
    font-weight: 600;
    font-size: 0.7rem;
    color: #B68CB8;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .related-name {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: #D4789C;
  }

  .related-arrow {
    font-size: 1rem;
    color: #FFB7C5;
    transition: transform 0.3s;
  }

  .related-card:hover .related-arrow {
    transform: translateX(4px);
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: linear-gradient(180deg, #FFFFFF 0%, #FFF5F8 100%);
    padding: 64px 32px;
    border-top: 2px solid #F5E6F0;
  }

  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
