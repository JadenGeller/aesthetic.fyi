---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">//</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-deco hero-deco-triangle"></div>
    <div class="hero-deco hero-deco-circle"></div>
    <div class="hero-deco hero-deco-zigzag"></div>
    <div class="hero-deco hero-deco-dot"></div>
    <div class="hero-inner">
      <span class="hero-label">Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <span class="section-label">~ What This Is ~</span>
      <h2 class="section-heading">Philosophy</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <span class="section-label">~ Design Tokens ~</span>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class={`char-card char-card-${i % 6}`}>
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <span class="section-label">~ Copy & Paste ~</span>
      <h2 class="section-heading">Style Reference</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">PROMPT</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <span class="section-label">~ When to Use ~</span>
      <h2 class="section-heading">Use Cases</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good for</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not for</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <span class="section-label">~ Origins ~</span>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <span class="section-label">~ Explore ~</span>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-deco footer-deco-circle"></div>
    <div class="footer-deco footer-deco-triangle"></div>
    <div class="footer-inner">
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to all aesthetics</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Space Grotesk', sans-serif;
    background-color: #FFF8E7;
    color: #1a1a1a;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background: #FFE142;
    border-bottom: 4px dashed #1a1a1a;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-logo {
    font-family: 'Fredoka One', cursive;
    font-size: 1.1rem;
    color: #1a1a1a;
    text-decoration: none;
    background: #FF6B9D;
    padding: 8px 18px;
    border: 3px solid #1a1a1a;
    border-radius: 40px;
    transform: rotate(-2deg);
    transition: transform 0.2s;
  }

  .nav-logo:hover {
    transform: rotate(2deg) scale(1.05);
  }

  .nav-divider {
    font-family: 'Fredoka One', cursive;
    font-size: 1.2rem;
    color: #00BCD4;
    margin: 0 4px;
  }

  .nav-current {
    font-family: 'Fredoka One', cursive;
    font-size: 0.95rem;
    color: #1a1a1a;
    text-decoration: none;
    padding: 8px 18px;
    border: 3px dotted #1a1a1a;
    border-radius: 8px;
    background: #E8D5F5;
    transform: rotate(1deg);
    transition: transform 0.2s;
  }

  .nav-current:hover {
    transform: rotate(-1deg) scale(1.05);
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #FF6B9D;
    border-bottom: 4px solid #1a1a1a;
    padding: 100px 24px 80px;
    position: relative;
    overflow: hidden;
    background-image:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 40px,
        rgba(255, 255, 255, 0.1) 40px,
        rgba(255, 255, 255, 0.1) 42px
      ),
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 40px,
        rgba(255, 255, 255, 0.1) 40px,
        rgba(255, 255, 255, 0.1) 42px
      );
  }

  .hero-deco {
    position: absolute;
    z-index: 1;
  }

  .hero-deco-triangle {
    top: 30px;
    right: 10%;
    width: 0;
    height: 0;
    border-left: 50px solid transparent;
    border-right: 50px solid transparent;
    border-bottom: 86px solid #FFE142;
    transform: rotate(15deg);
  }

  .hero-deco-circle {
    bottom: 40px;
    right: 20%;
    width: 80px;
    height: 80px;
    background: #00BCD4;
    border-radius: 50%;
    border: 4px dashed #1a1a1a;
  }

  .hero-deco-zigzag {
    top: 60px;
    left: 5%;
    width: 120px;
    height: 30px;
    background: repeating-linear-gradient(
      90deg,
      #FFE142 0px,
      #FFE142 10px,
      transparent 10px,
      transparent 20px
    );
    transform: rotate(-10deg);
  }

  .hero-deco-dot {
    bottom: 60px;
    left: 12%;
    width: 40px;
    height: 40px;
    background: #E8D5F5;
    border-radius: 50%;
    border: 3px solid #1a1a1a;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .hero-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    background: #1a1a1a;
    color: #FFE142;
    padding: 8px 20px;
    display: inline-block;
    margin-bottom: 24px;
    border-radius: 40px;
    transform: rotate(-3deg);
  }

  .hero-title {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(4rem, 12vw, 10rem);
    line-height: 0.95;
    margin: 0 0 24px 0;
    letter-spacing: -0.02em;
    color: #1a1a1a;
    text-shadow: 6px 6px 0px #FFE142;
  }

  .hero-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    line-height: 1.6;
    margin: 0;
    max-width: 640px;
    color: #1a1a1a;
    background: rgba(255, 255, 255, 0.3);
    padding: 16px 24px;
    border: 3px dotted #1a1a1a;
    border-radius: 12px;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 80px 24px;
    border-bottom: 4px solid #1a1a1a;
    position: relative;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Fredoka One', cursive;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #FF6B9D;
    display: block;
    margin-bottom: 12px;
  }

  .section-heading {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin: 0 0 48px 0;
    letter-spacing: -0.01em;
    color: #1a1a1a;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #FFF8E7;
    background-image:
      radial-gradient(circle, #00BCD4 1.5px, transparent 1.5px);
    background-size: 30px 30px;
    background-position: 15px 15px;
  }

  .about-content {
    max-width: 740px;
    background: rgba(255, 248, 231, 0.92);
    padding: 40px;
    border: 3px dashed #00BCD4;
    border-radius: 16px;
  }

  .about-paragraph {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.75;
    margin: 0 0 24px 0;
    color: #1a1a1a;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #00BCD4;
    background-image:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 20px,
        rgba(255, 255, 255, 0.08) 20px,
        rgba(255, 255, 255, 0.08) 22px
      );
  }

  .characteristics-section .section-label {
    color: #FFE142;
  }

  .characteristics-section .section-heading {
    color: #1a1a1a;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }

  .char-card {
    padding: 32px 28px 28px;
    border: 4px solid #1a1a1a;
    position: relative;
    transition: transform 0.2s;
  }

  .char-card:hover {
    transform: rotate(-1deg) scale(1.02);
  }

  .char-card-0 {
    background: #FFE142;
    border-radius: 0;
    transform: rotate(-1deg);
    border-style: solid;
  }

  .char-card-0:hover {
    transform: rotate(1deg) scale(1.02);
  }

  .char-card-1 {
    background: #FF6B9D;
    border-radius: 20px;
    transform: rotate(1.5deg);
    border-style: dashed;
  }

  .char-card-1:hover {
    transform: rotate(-0.5deg) scale(1.02);
  }

  .char-card-2 {
    background: #E8D5F5;
    border-radius: 0 30px 0 30px;
    transform: rotate(-0.5deg);
    border-style: dotted;
  }

  .char-card-2:hover {
    transform: rotate(1.5deg) scale(1.02);
  }

  .char-card-3 {
    background: #FF8A65;
    border-radius: 30px 0 30px 0;
    transform: rotate(2deg);
    border-style: double;
  }

  .char-card-3:hover {
    transform: rotate(-1deg) scale(1.02);
  }

  .char-card-4 {
    background: #FFF8E7;
    border-radius: 50px;
    transform: rotate(-2deg);
    border-style: dashed;
  }

  .char-card-4:hover {
    transform: rotate(0.5deg) scale(1.02);
  }

  .char-card-5 {
    background: #FFE142;
    border-radius: 8px;
    transform: rotate(1deg);
    border-style: dotted;
  }

  .char-card-5:hover {
    transform: rotate(-2deg) scale(1.02);
  }

  .char-number {
    font-family: 'Fredoka One', cursive;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: #1a1a1a;
    color: #FFE142;
    padding: 6px 14px;
    position: absolute;
    top: -2px;
    right: -2px;
    border-radius: 0 0 0 12px;
  }

  .char-title {
    font-family: 'Fredoka One', cursive;
    font-size: 1.4rem;
    margin: 0 0 12px 0;
    color: #1a1a1a;
  }

  .char-description {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    color: #1a1a1a;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #E8D5F5;
    background-image:
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 14px,
        rgba(255, 107, 157, 0.15) 14px,
        rgba(255, 107, 157, 0.15) 16px
      );
  }

  .prompt-section .section-label {
    color: #1a1a1a;
  }

  .prompt-block {
    border: 4px solid #1a1a1a;
    border-radius: 16px;
    overflow: hidden;
    background: #1a1a1a;
    transform: rotate(-0.5deg);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    border-bottom: 4px dashed #1a1a1a;
    background: #FFE142;
  }

  .prompt-header-label {
    font-family: 'Fredoka One', cursive;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #1a1a1a;
  }

  .copy-button {
    font-family: 'Fredoka One', cursive;
    font-size: 0.9rem;
    background: #FF6B9D;
    color: #1a1a1a;
    border: 3px solid #1a1a1a;
    padding: 10px 24px;
    cursor: pointer;
    border-radius: 40px;
    transition: transform 0.15s, background 0.15s;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .copy-button:hover {
    transform: scale(1.08) rotate(2deg);
    background: #00BCD4;
  }

  .copy-button:active {
    transform: scale(0.95);
  }

  .copy-button.copied {
    background: #00BCD4;
  }

  .prompt-text {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    color: #FFF8E7;
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #FFF8E7;
    background-image:
      radial-gradient(circle, #FF6B9D 1px, transparent 1px),
      radial-gradient(circle, #00BCD4 1px, transparent 1px);
    background-size: 40px 40px, 40px 40px;
    background-position: 0 0, 20px 20px;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }

  .use-column {
    border: 4px solid #1a1a1a;
    border-radius: 16px;
    overflow: hidden;
    background: #FFF8E7;
  }

  .use-column-heading {
    font-family: 'Fredoka One', cursive;
    font-size: 1.3rem;
    margin: 0;
    padding: 18px 24px;
    border-bottom: 4px solid #1a1a1a;
  }

  .use-good .use-column-heading {
    background: #00BCD4;
    color: #1a1a1a;
  }

  .use-bad .use-column-heading {
    background: #FF8A65;
    color: #1a1a1a;
  }

  .use-good {
    transform: rotate(-1deg);
  }

  .use-bad {
    transform: rotate(1deg);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.5;
    padding: 14px 24px;
    border-bottom: 3px dashed #ccc;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '\25B2';
    font-size: 0.9rem;
    color: #00BCD4;
    flex-shrink: 0;
  }

  .use-item-bad::before {
    content: '\2716';
    font-size: 0.9rem;
    color: #FF8A65;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #FFE142;
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 28px,
        rgba(26, 26, 26, 0.06) 28px,
        rgba(26, 26, 26, 0.06) 30px
      );
  }

  .history-section .section-label {
    color: #1a1a1a;
  }

  .history-content {
    max-width: 740px;
    background: rgba(255, 248, 231, 0.85);
    padding: 40px;
    border: 4px dotted #1a1a1a;
    border-radius: 20px;
  }

  .history-paragraph {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.75;
    margin: 0 0 24px 0;
    color: #1a1a1a;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #FF8A65;
    background-image:
      repeating-linear-gradient(
        135deg,
        transparent,
        transparent 10px,
        rgba(255, 225, 66, 0.3) 10px,
        rgba(255, 225, 66, 0.3) 20px
      );
  }

  .related-section .section-label {
    color: #1a1a1a;
  }

  .related-section .section-heading {
    color: #1a1a1a;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 24px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    border: 4px solid #1a1a1a;
    background: #FFF8E7;
    text-decoration: none;
    color: #1a1a1a;
    transition: transform 0.2s;
    position: relative;
    border-radius: 12px;
  }

  .related-card:nth-child(odd) {
    transform: rotate(-2deg);
  }

  .related-card:nth-child(even) {
    transform: rotate(2deg);
  }

  .related-card:hover {
    transform: rotate(0deg) scale(1.05);
    z-index: 2;
  }

  .related-relationship {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #FFF8E7;
    background: #FF6B9D;
    padding: 5px 12px;
    display: inline-block;
    align-self: flex-start;
    border-radius: 20px;
  }

  .related-name {
    font-family: 'Fredoka One', cursive;
    font-size: 1.3rem;
  }

  .related-arrow {
    font-family: 'Fredoka One', cursive;
    font-size: 1.5rem;
    position: absolute;
    bottom: 18px;
    right: 20px;
    color: #00BCD4;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #1a1a1a;
    padding: 60px 24px;
    border-top: 4px solid #FFE142;
    position: relative;
    overflow: hidden;
    background-image:
      radial-gradient(circle, rgba(255, 107, 157, 0.15) 2px, transparent 2px);
    background-size: 24px 24px;
  }

  .footer-deco {
    position: absolute;
    z-index: 0;
  }

  .footer-deco-circle {
    top: 20px;
    right: 10%;
    width: 60px;
    height: 60px;
    background: #00BCD4;
    border-radius: 50%;
    opacity: 0.4;
  }

  .footer-deco-triangle {
    bottom: 10px;
    left: 8%;
