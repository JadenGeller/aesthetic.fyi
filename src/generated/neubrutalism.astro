---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;700;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-label">Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <span class="section-label">// What This Is</span>
      <h2 class="section-heading">Philosophy</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <span class="section-label">// Design Tokens</span>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class={`char-card char-card-${i % 4}`}>
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <span class="section-label">// Copy & Paste</span>
      <h2 class="section-heading">Style Reference</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">PROMPT</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <span class="section-label">// When to Use</span>
      <h2 class="section-heading">Use Cases</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good for</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not for</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <span class="section-label">// Origins</span>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <span class="section-label">// Explore</span>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to all aesthetics</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'DM Sans', sans-serif;
    background-color: #FFFDF7;
    color: #1a1a1a;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 3px solid #1a1a1a;
    background: #FFFDF7;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-logo {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 1rem;
    color: #1a1a1a;
    text-decoration: none;
    background: #FFE142;
    padding: 6px 14px;
    border: 3px solid #1a1a1a;
    box-shadow: 4px 4px 0px #1a1a1a;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .nav-logo:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px #1a1a1a;
  }

  .nav-divider {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 1.2rem;
    color: #999;
    margin: 0 4px;
  }

  .nav-current {
    font-family: 'Space Mono', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    color: #1a1a1a;
    text-decoration: none;
    padding: 6px 14px;
    border: 3px solid #1a1a1a;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .nav-current:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0px #1a1a1a;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #FFE142;
    border-bottom: 3px solid #1a1a1a;
    padding: 80px 24px 72px;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .hero-label {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    background: #1a1a1a;
    color: #FFE142;
    padding: 6px 16px;
    display: inline-block;
    margin-bottom: 24px;
  }

  .hero-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 900;
    font-size: clamp(3.5rem, 10vw, 8rem);
    line-height: 0.95;
    margin: 0 0 24px 0;
    letter-spacing: -0.03em;
    color: #1a1a1a;
  }

  .hero-tagline {
    font-family: 'Space Mono', monospace;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    line-height: 1.5;
    margin: 0;
    max-width: 700px;
    color: #1a1a1a;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 80px 24px;
    border-bottom: 3px solid #1a1a1a;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #1a1a1a;
    display: block;
    margin-bottom: 12px;
  }

  .section-heading {
    font-family: 'DM Sans', sans-serif;
    font-weight: 900;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.05;
    margin: 0 0 48px 0;
    letter-spacing: -0.02em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #FFFDF7;
  }

  .about-content {
    max-width: 740px;
  }

  .about-paragraph {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 1.2rem;
    line-height: 1.7;
    margin: 0 0 24px 0;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #f5f3ee;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 3px solid #1a1a1a;
    padding: 32px 28px 28px;
    box-shadow: 6px 6px 0px #1a1a1a;
    position: relative;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .char-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 9px 9px 0px #1a1a1a;
  }

  .char-card-0 {
    background: #FFE142;
  }

  .char-card-1 {
    background: #FF6B9D;
  }

  .char-card-2 {
    background: #00C9A7;
  }

  .char-card-3 {
    background: #C3A0FF;
  }

  .char-number {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: #1a1a1a;
    color: #FFFDF7;
    padding: 4px 10px;
    position: absolute;
    top: -1px;
    right: -1px;
    border-left: 3px solid #1a1a1a;
    border-bottom: 3px solid #1a1a1a;
  }

  .char-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 900;
    font-size: 1.5rem;
    margin: 0 0 12px 0;
    letter-spacing: -0.01em;
    color: #1a1a1a;
  }

  .char-description {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    color: #1a1a1a;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #FFFDF7;
  }

  .prompt-block {
    border: 3px solid #1a1a1a;
    box-shadow: 6px 6px 0px #1a1a1a;
    background: #1a1a1a;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 3px solid #1a1a1a;
    background: #FFE142;
  }

  .prompt-header-label {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #1a1a1a;
  }

  .copy-button {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.85rem;
    background: #FFFDF7;
    color: #1a1a1a;
    border: 3px solid #1a1a1a;
    padding: 8px 20px;
    cursor: pointer;
    box-shadow: 4px 4px 0px #1a1a1a;
    transition: transform 0.1s, box-shadow 0.1s;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .copy-button:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px #1a1a1a;
  }

  .copy-button:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px #1a1a1a;
  }

  .copy-button.copied {
    background: #00C9A7;
  }

  .prompt-text {
    font-family: 'Space Mono', monospace;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    color: #FFFDF7;
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #f5f3ee;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .use-column {
    border: 3px solid #1a1a1a;
    box-shadow: 6px 6px 0px #1a1a1a;
  }

  .use-column-heading {
    font-family: 'DM Sans', sans-serif;
    font-weight: 900;
    font-size: 1.3rem;
    margin: 0;
    padding: 18px 24px;
    border-bottom: 3px solid #1a1a1a;
    letter-spacing: -0.01em;
  }

  .use-good .use-column-heading {
    background: #00C9A7;
  }

  .use-bad .use-column-heading {
    background: #FF6B9D;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
    background: #FFFDF7;
  }

  .use-item {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.5;
    padding: 14px 24px;
    border-bottom: 2px solid #1a1a1a;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '+';
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 1.1rem;
    color: #00C9A7;
    flex-shrink: 0;
  }

  .use-item-bad::before {
    content: '\2013';
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 1.1rem;
    color: #FF6B9D;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #FFFDF7;
  }

  .history-content {
    max-width: 740px;
  }

  .history-paragraph {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.75;
    margin: 0 0 24px 0;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #C3A0FF;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    border: 3px solid #1a1a1a;
    background: #FFFDF7;
    box-shadow: 6px 6px 0px #1a1a1a;
    text-decoration: none;
    color: #1a1a1a;
    transition: transform 0.15s, box-shadow 0.15s;
    position: relative;
  }

  .related-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 9px 9px 0px #1a1a1a;
  }

  .related-card:active {
    transform: translate(2px, 2px);
    box-shadow: 3px 3px 0px #1a1a1a;
  }

  .related-relationship {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #C3A0FF;
    background: #1a1a1a;
    padding: 4px 10px;
    display: inline-block;
    align-self: flex-start;
  }

  .related-name {
    font-family: 'DM Sans', sans-serif;
    font-weight: 900;
    font-size: 1.3rem;
    letter-spacing: -0.01em;
  }

  .related-arrow {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 1.2rem;
    position: absolute;
    bottom: 20px;
    right: 20px;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #1a1a1a;
    padding: 60px 24px;
    border-top: 3px solid #1a1a1a;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-logo {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 1.1rem;
    color: #FFE142;
    text-decoration: none;
    background: transparent;
    padding: 8px 18px;
    border: 3px solid #FFE142;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .footer-logo:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0px #FFE142;
  }

  .footer-tagline {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    color: #999;
  }

  .footer-back {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.85rem;
    color: #FFFDF7;
    text-decoration: none;
    padding: 8px 18px;
    border: 3px solid #FFFDF7;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .footer-back:hover {
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0px #FFFDF7;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 56px 20px 48px;
    }

    .section {
      padding: 56px 20px;
    }

    .section-heading {
      margin-bottom: 32px;
    }

    .characteristics-grid {
      grid-template-columns: 1fr;
    }

    .use-grid {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .prompt-text {
      font-size: 0.85rem;
      padding: 20px 16px;
    }

    .prompt-header {
      padding: 12px 16px;
      flex-wrap: wrap;
      gap: 12px;
    }

    .nav-inner {
      padding: 12px 16px;
    }

    .footer {
      padding: 40px 20px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 40px 16px 36px;
    }

    .section {
      padding: 40px 16px;
    }

    .nav-inner {
      padding: 10px 12px;
      gap: 6px;
    }

    .nav-logo {
      font-size: 0.85rem;
      padding: 5px 10px;
    }

    .nav-current {
      font-size: 0.8rem;
      padding: 5px 10px;
    }

    .char-card {
      padding: 24px 20px 20px;
    }

    .copy-button {
      padding: 6px 14px;
      font-size: 0.75rem;
    }

    .use-item {
      padding: 12px 16px;
      font-size: 0.95rem;
    }

    .related-card {
      padding: 18px;
    }
  }
</style>
