---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">&mdash;</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-arch"></div>
    <div class="hero-inner">
      <span class="hero-label">Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-ornament">
        <span class="ornament-line"></span>
        <span class="ornament-diamond"></span>
        <span class="ornament-line"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">I</span>
        <h2 class="section-heading">What This Is</h2>
      </div>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="body-text">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">II</span>
        <h2 class="section-heading">Characteristics</h2>
      </div>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <div class="char-card-border"></div>
            <span class="char-numeral">{['I', 'II', 'III', 'IV', 'V', 'VI'][i]}</span>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">III</span>
        <h2 class="section-heading">Style Reference</h2>
      </div>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">IV</span>
        <h2 class="section-heading">When to Use</h2>
      </div>
      <div class="use-columns">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading use-column-heading-bad">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">V</span>
        <h2 class="section-heading">History</h2>
      </div>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="body-text">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">VI</span>
        <h2 class="section-heading">Related Styles</h2>
      </div>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament">
        <span class="ornament-line"></span>
        <span class="ornament-diamond"></span>
        <span class="ornament-line"></span>
      </div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to all aesthetics</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Crimson Text', Georgia, 'Times New Roman', serif;
    background-color: #0D0D0D;
    color: #E8E0D0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background: #0D0D0D;
    border-bottom: 1px solid #C9A959;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.8);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-logo {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: #C9A959;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    transition: text-shadow 0.3s;
  }

  .nav-logo:hover {
    text-shadow: 0 0 12px rgba(201, 169, 89, 0.6);
  }

  .nav-divider {
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    color: #4A0E4A;
    margin: 0 4px;
  }

  .nav-current {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: #E8E0D0;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.7;
    transition: opacity 0.3s;
  }

  .nav-current:hover {
    opacity: 1;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: linear-gradient(180deg, #1A0A1A 0%, #0D0D0D 100%);
    padding: 120px 32px 100px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: double 4px #C9A959;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 60px,
        rgba(201, 169, 89, 0.03) 60px,
        rgba(201, 169, 89, 0.03) 61px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 60px,
        rgba(201, 169, 89, 0.03) 60px,
        rgba(201, 169, 89, 0.03) 61px
      );
    pointer-events: none;
  }

  .hero-arch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 400px;
    height: 200px;
    border: 1px solid rgba(201, 169, 89, 0.1);
    border-bottom: none;
    border-radius: 200px 200px 0 0;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-label {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: #C9A959;
    display: block;
    margin-bottom: 28px;
  }

  .hero-title {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: clamp(3rem, 10vw, 6.5rem);
    line-height: 1.0;
    margin: 0 0 32px 0;
    letter-spacing: 0.06em;
    color: #E8E0D0;
    text-transform: uppercase;
    text-shadow:
      0 0 20px rgba(139, 0, 0, 0.4),
      0 0 60px rgba(139, 0, 0, 0.15);
  }

  .hero-ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .ornament-line {
    display: block;
    width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #C9A959, transparent);
  }

  .ornament-diamond {
    display: block;
    width: 10px;
    height: 10px;
    background: #8B0000;
    transform: rotate(45deg);
    box-shadow: 0 0 8px rgba(139, 0, 0, 0.6);
    flex-shrink: 0;
  }

  .hero-tagline {
    font-family: 'Crimson Text', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    line-height: 1.7;
    margin: 0;
    color: rgba(232, 224, 208, 0.7);
    max-width: 580px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 80px 32px;
    border-bottom: 1px solid rgba(201, 169, 89, 0.2);
    position: relative;
  }

  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 48px;
    text-align: center;
  }

  .section-label {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    color: #8B0000;
    display: block;
    margin-bottom: 12px;
    text-shadow: 0 0 10px rgba(139, 0, 0, 0.3);
  }

  .section-heading {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1.1;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #E8E0D0;
    text-shadow: 0 0 15px rgba(139, 0, 0, 0.3);
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: linear-gradient(180deg, #0D0D0D 0%, #1A0A1A 50%, #0D0D0D 100%);
  }

  .about-content {
    max-width: 720px;
    margin: 0 auto;
    padding: 40px 48px;
    border: 1px solid rgba(201, 169, 89, 0.2);
    border-top: double 3px #C9A959;
    border-bottom: double 3px #C9A959;
    position: relative;
  }

  .about-content::before,
  .about-content::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    border: 1px solid rgba(201, 169, 89, 0.3);
    transform: rotate(45deg);
  }

  .about-content::before {
    top: -7px;
    left: -7px;
    background: #0D0D0D;
  }

  .about-content::after {
    bottom: -7px;
    right: -7px;
    background: #0D0D0D;
  }

  .body-text {
    font-family: 'Crimson Text', serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #E8E0D0;
  }

  .body-text:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #0D0D0D;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 28px;
  }

  .char-card {
    background: linear-gradient(160deg, #1A0A1A 0%, #110811 100%);
    padding: 36px 32px 32px;
    border: 1px solid rgba(201, 169, 89, 0.25);
    position: relative;
    transition: box-shadow 0.3s, border-color 0.3s;
  }

  .char-card:hover {
    border-color: rgba(201, 169, 89, 0.5);
    box-shadow:
      0 0 30px rgba(139, 0, 0, 0.15),
      inset 0 0 30px rgba(139, 0, 0, 0.03);
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    bottom: 8px;
    border: 1px solid rgba(201, 169, 89, 0.08);
    pointer-events: none;
  }

  .char-numeral {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: #8B0000;
    display: block;
    margin-bottom: 16px;
    text-shadow: 0 0 8px rgba(139, 0, 0, 0.4);
  }

  .char-title {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 1.1rem;
    margin: 0 0 14px 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #C9A959;
  }

  .char-description {
    font-family: 'Crimson Text', serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0;
    color: rgba(232, 224, 208, 0.75);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: linear-gradient(180deg, #0D0D0D 0%, #1A0A1A 100%);
  }

  .prompt-block {
    border: double 3px #C9A959;
    overflow: hidden;
    margin: 0 auto;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(201, 169, 89, 0.3);
    background: rgba(26, 10, 26, 0.6);
  }

  .prompt-header-label {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #C9A959;
  }

  .copy-button {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 0.7rem;
    background: transparent;
    color: #C9A959;
    border: 1px solid #C9A959;
    padding: 8px 20px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: background 0.3s, color 0.3s, box-shadow 0.3s;
  }

  .copy-button:hover {
    background: #8B0000;
    border-color: #8B0000;
    color: #E8E0D0;
    box-shadow: 0 0 15px rgba(139, 0, 0, 0.4);
  }

  .copy-button.copied {
    background: #4A0E4A;
    border-color: #4A0E4A;
    color: #E8E0D0;
  }

  .prompt-text {
    font-family: 'Crimson Text', serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(232, 224, 208, 0.8);
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    background: rgba(13, 13, 13, 0.5);
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #0D0D0D;
  }

  .use-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    max-width: 900px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid rgba(201, 169, 89, 0.2);
    overflow: hidden;
  }

  .use-column-heading {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 0.85rem;
    margin: 0;
    padding: 16px 24px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #E8E0D0;
    border-bottom: 1px solid rgba(201, 169, 89, 0.2);
    background: rgba(74, 14, 74, 0.2);
  }

  .use-column-heading-bad {
    background: rgba(139, 0, 0, 0.15);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Crimson Text', serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.5;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(201, 169, 89, 0.08);
    display: flex;
    align-items: flex-start;
    gap: 14px;
    color: #E8E0D0;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '\2726';
    font-size: 0.75rem;
    color: #C9A959;
    flex-shrink: 0;
    margin-top: 4px;
  }

  .use-item-bad::before {
    content: '\2020';
    font-size: 1rem;
    color: #8B0000;
    flex-shrink: 0;
    text-shadow: 0 0 6px rgba(139, 0, 0, 0.5);
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: linear-gradient(180deg, #0D0D0D 0%, #1A0A1A 50%, #0D0D0D 100%);
  }

  .history-content {
    max-width: 720px;
    margin: 0 auto;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #0D0D0D;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 28px 24px;
    border: 1px solid rgba(201, 169, 89, 0.2);
    background: linear-gradient(160deg, #1A0A1A 0%, #0D0D0D 100%);
    text-decoration: none;
    color: #E8E0D0;
    transition: border-color 0.3s, box-shadow 0.3s;
    position: relative;
  }

  .related-card:hover {
    border-color: #C9A959;
    box-shadow: 0 0 25px rgba(139, 0, 0, 0.2);
  }

  .related-card:hover .related-arrow {
    color: #C9A959;
    text-shadow: 0 0 10px rgba(201, 169, 89, 0.4);
  }

  .related-relationship {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #8B0000;
    text-shadow: 0 0 6px rgba(139, 0, 0, 0.3);
  }

  .related-name {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.04em;
    color: #C9A959;
  }

  .related-arrow {
    font-size: 1.1rem;
    position: absolute;
    bottom: 24px;
    right: 24px;
    color: rgba(201, 169, 89, 0.4);
    transition: color 0.3s, text-shadow 0.3s;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #0D0D0D;
    padding: 72px 32px;
    border-top: double 4px #C9A959;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-ornament {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .footer-logo {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 0.9rem;
    color: #C9A959;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    transition: text-shadow 0.3s;
  }

  .footer-logo:hover {
    text-shadow: 0 0 15px rgba(201, 169, 89, 0.5);
  }

  .footer-tagline {
    font-family: 'Crimson Text', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.95rem;
    color: rgba(232, 224, 208, 0.4);
  }

  .footer-back {
    font-family: 'Cinzel', serif;
    font-weight: 400;
    font-size: 0.7rem;
    color: #8B0000;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 10px 0;
    border-bottom: 1px solid rgba(139, 0, 0, 0.3);
    transition: color 0.3s, border-color 0.3s, text-shadow 0.3s;
  }

  .footer-back:hover {
    color: #C9A959;
    border-color: #C9A959;
    text-shadow: 0 0 10px rgba(201, 169, 89, 0.3);
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 80px 24px 64px;
    }

    .hero-arch {
      width: 280px;
      height: 140px;
      border-radius: 140px 140px 0 0;
    }

    .section {
      padding: 60px 24px;
    }

    .section-header {
      margin-bottom: 36px;
