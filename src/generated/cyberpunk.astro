---
import { Nav, Hero, About, Characteristics, Prompt, Usage, History, Related, Footer } from '../components/aesthetic';
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet" />

<div class="page" data-page="cyberpunk">
  <Nav aesthetic={aesthetic} divider="//" />

  <Hero aesthetic={aesthetic} label="> WEB_AESTHETIC">
    <div slot="decoration" class="hero-scanlines"></div>
  </Hero>

  <About aesthetic={aesthetic} label="> SYS.DESCRIPTION" heading="What This Is" />

  <Characteristics aesthetic={aesthetic} label="> DESIGN.TOKENS" heading="Characteristics" />

  <Prompt
    aesthetic={aesthetic}
    label="> COPY.PASTE"
    heading="Style Reference"
    headerLabel="// PROMPT.TXT"
    copyText="COPY_"
  />

  <Usage
    aesthetic={aesthetic}
    label="> USE.CASES"
    heading="When to Use"
    goodLabel="DEPLOY_FOR"
    badLabel="ABORT_FOR"
  />

  <History aesthetic={aesthetic} label="> SYS.HISTORY" heading="History" />

  <Related aesthetic={aesthetic} label="> LINKED.NODES" heading="Related Styles" />

  <Footer backText="&larr; BACK_TO_INDEX" />
</div>

<style is:global>
  @keyframes glitch-text {
    0%, 95%, 100% { transform: none; }
    96% { transform: skewX(-2deg); }
    97% { transform: skewX(1deg); }
    98% { transform: skewX(-1deg); }
  }

  @keyframes glitch-before {
    0%, 94%, 100% { clip-path: inset(0 0 0 0); transform: none; }
    95% { clip-path: inset(20% 0 40% 0); transform: translateX(-3px); }
    96% { clip-path: inset(60% 0 10% 0); transform: translateX(3px); }
    97% { clip-path: inset(30% 0 30% 0); transform: translateX(-2px); }
    98% { clip-path: inset(0 0 0 0); transform: none; }
  }

  @keyframes glitch-after {
    0%, 93%, 100% { clip-path: inset(0 0 0 0); transform: none; }
    94% { clip-path: inset(50% 0 20% 0); transform: translateX(4px); }
    95% { clip-path: inset(10% 0 60% 0); transform: translateX(-4px); }
    96% { clip-path: inset(40% 0 20% 0); transform: translateX(2px); }
    97% { clip-path: inset(0 0 0 0); transform: none; }
  }

  /* ========================================
     RESET & BASE
     ======================================== */
  [data-page="cyberpunk"] {
    font-family: 'Share Tech Mono', monospace;
    background-color: #0a0a0f;
    color: #c0c0c0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
  }

  /* Global scanline overlay on whole page */
  [data-page="cyberpunk"]::after {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 255, 255, 0.012) 2px,
      rgba(0, 255, 255, 0.012) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* ========================================
     NAV
     ======================================== */
  [data-page="cyberpunk"] .nav {
    border-bottom: 1px solid rgba(0, 255, 255, 0.2);
    background: rgba(10, 10, 15, 0.95);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  [data-page="cyberpunk"] .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  [data-page="cyberpunk"] .nav-logo {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    color: #00FFFF;
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid rgba(0, 255, 255, 0.4);
    text-shadow: 0 0 6px rgba(0, 255, 255, 0.4);
    transition: all 0.2s;
    clip-path: polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px);
  }

  [data-page="cyberpunk"] .nav-logo:hover {
    background: rgba(0, 255, 255, 0.08);
    box-shadow: 0 0 12px rgba(0, 255, 255, 0.2);
  }

  [data-page="cyberpunk"] .nav-divider {
    font-family: 'Share Tech Mono', monospace;
    font-size: 1rem;
    color: rgba(0, 255, 255, 0.3);
    margin: 0 2px;
  }

  [data-page="cyberpunk"] .nav-current {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.85rem;
    color: #FF00FF;
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid rgba(255, 0, 255, 0.3);
    text-shadow: 0 0 6px rgba(255, 0, 255, 0.3);
    transition: all 0.2s;
  }

  [data-page="cyberpunk"] .nav-current:hover {
    background: rgba(255, 0, 255, 0.08);
    box-shadow: 0 0 12px rgba(255, 0, 255, 0.2);
  }

  /* ========================================
     HERO
     ======================================== */
  [data-page="cyberpunk"] .hero {
    background: #0a0a0f;
    padding: 100px 24px 80px;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(0, 255, 255, 0.15);
  }

  [data-page="cyberpunk"] .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(ellipse, rgba(0, 255, 255, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  [data-page="cyberpunk"] .hero::after {
    content: '';
    position: absolute;
    bottom: -30%;
    right: -10%;
    width: 50%;
    height: 160%;
    background: radial-gradient(ellipse, rgba(255, 0, 255, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  [data-page="cyberpunk"] .hero-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0, 255, 255, 0.02) 3px,
      rgba(0, 255, 255, 0.02) 6px
    );
    pointer-events: none;
  }

  [data-page="cyberpunk"] .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* hero-stripe rendered via pseudo-element after the inner content */
  [data-page="cyberpunk"] .hero-inner::after {
    content: '';
    display: block;
    height: 4px;
    max-width: 300px;
    margin-top: 32px;
    background: repeating-linear-gradient(
      -45deg,
      #FFD700,
      #FFD700 6px,
      #0a0a0f 6px,
      #0a0a0f 12px
    );
    box-shadow: 0 0 8px rgba(255, 215, 0, 0.3);
  }

  [data-page="cyberpunk"] .hero-label {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #00FFFF;
    text-shadow: 0 0 8px rgba(0, 255, 255, 0.5);
    display: inline-block;
    margin-bottom: 24px;
    padding: 6px 16px;
    border-left: 3px solid #00FFFF;
    background: rgba(0, 255, 255, 0.05);
  }

  [data-page="cyberpunk"] .hero-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: clamp(3.5rem, 10vw, 8rem);
    line-height: 0.95;
    margin: 0 0 24px 0;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #ffffff;
    position: relative;
    display: inline-block;
    text-shadow:
      0 0 10px rgba(0, 255, 255, 0.5),
      0 0 40px rgba(0, 255, 255, 0.15);
    animation: glitch-text 3s infinite;
  }

  [data-page="cyberpunk"] .hero-title::before,
  [data-page="cyberpunk"] .hero-title::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  [data-page="cyberpunk"] .hero-title::before {
    color: #00FFFF;
    z-index: -1;
    animation: glitch-before 3s infinite;
  }

  [data-page="cyberpunk"] .hero-title::after {
    color: #FF00FF;
    z-index: -2;
    animation: glitch-after 3s infinite;
  }

  [data-page="cyberpunk"] .hero-tagline {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: clamp(0.95rem, 2.2vw, 1.2rem);
    line-height: 1.7;
    margin: 0;
    max-width: 700px;
    color: rgba(255, 255, 255, 0.6);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  [data-page="cyberpunk"] .section {
    padding: 80px 24px;
    border-bottom: 1px solid rgba(0, 255, 255, 0.1);
  }

  [data-page="cyberpunk"] .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  [data-page="cyberpunk"] .section-label {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #00FFFF;
    text-shadow: 0 0 6px rgba(0, 255, 255, 0.4);
    display: block;
    margin-bottom: 12px;
    padding-left: 16px;
    border-left: 3px solid #00FFFF;
  }

  [data-page="cyberpunk"] .section-heading {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.05;
    margin: 0 0 48px 0;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #ffffff;
    text-shadow: 0 0 20px rgba(0, 255, 255, 0.2);
  }

  /* ========================================
     ABOUT
     ======================================== */
  [data-page="cyberpunk"] .about-section {
    background: #0a0a0f;
  }

  [data-page="cyberpunk"] .about-content {
    max-width: 740px;
    border-left: 3px solid rgba(255, 0, 255, 0.4);
    padding-left: 24px;
  }

  [data-page="cyberpunk"] .about-paragraph {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.8;
    margin: 0 0 24px 0;
    color: rgba(255, 255, 255, 0.7);
  }

  [data-page="cyberpunk"] .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  [data-page="cyberpunk"] .characteristics-section {
    background: #0d0d14;
  }

  [data-page="cyberpunk"] .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 20px;
  }

  [data-page="cyberpunk"] .char-card {
    background: #1a1a2e;
    padding: 32px 28px 28px;
    position: relative;
    overflow: hidden;
    clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px));
    transition: all 0.2s;
  }

  [data-page="cyberpunk"] .char-card:hover {
    background: #20203a;
  }

  /* Alternating accent colors via nth-child */
  [data-page="cyberpunk"] .char-card:nth-child(3n+1) {
    border-left: 3px solid #00FFFF;
    box-shadow: inset 0 0 30px rgba(0, 255, 255, 0.03);
  }

  [data-page="cyberpunk"] .char-card:nth-child(3n+2) {
    border-left: 3px solid #FF00FF;
    box-shadow: inset 0 0 30px rgba(255, 0, 255, 0.03);
  }

  [data-page="cyberpunk"] .char-card:nth-child(3n) {
    border-left: 3px solid #FFD700;
    box-shadow: inset 0 0 30px rgba(255, 215, 0, 0.03);
  }

  /* Bottom glow line via pseudo-element */
  [data-page="cyberpunk"] .char-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, rgba(0, 255, 255, 0.3), transparent);
  }

  [data-page="cyberpunk"] .char-number {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: #00FFFF;
    text-shadow: 0 0 6px rgba(0, 255, 255, 0.4);
    margin-bottom: 16px;
    opacity: 0.7;
    display: block;
  }

  [data-page="cyberpunk"] .char-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    margin: 0 0 12px 0;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #ffffff;
  }

  [data-page="cyberpunk"] .char-description {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
    color: rgba(255, 255, 255, 0.55);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  [data-page="cyberpunk"] .prompt-section {
    background: #0a0a0f;
  }

  [data-page="cyberpunk"] .prompt-block {
    background: #0d0d14;
    border: 1px solid rgba(0, 255, 255, 0.2);
    position: relative;
    overflow: hidden;
    clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
  }

  /* Scanlines via pseudo-element */
  [data-page="cyberpunk"] .prompt-block::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 255, 255, 0.01) 2px,
      rgba(0, 255, 255, 0.01) 4px
    );
    pointer-events: none;
    z-index: 0;
  }

  [data-page="cyberpunk"] .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(0, 255, 255, 0.15);
    background: rgba(0, 255, 255, 0.04);
    position: relative;
    z-index: 1;
  }

  [data-page="cyberpunk"] .prompt-header-label {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #00FFFF;
    text-shadow: 0 0 6px rgba(0, 255, 255, 0.3);
  }

  [data-page="cyberpunk"] .copy-button {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    background: transparent;
    color: #FFD700;
    border: 1px solid rgba(255, 215, 0, 0.4);
    padding: 8px 20px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.2s;
    text-shadow: 0 0 6px rgba(255, 215, 0, 0.3);
    clip-path: polygon(6px 0, 100% 0, 100% calc(100% - 6px), calc(100% - 6px) 100%, 0 100%, 0 6px);
  }

  [data-page="cyberpunk"] .copy-button:hover {
    background: rgba(255, 215, 0, 0.1);
    box-shadow: 0 0 12px rgba(255, 215, 0, 0.2);
  }

  [data-page="cyberpunk"] .copy-button:active {
    background: rgba(255, 215, 0, 0.2);
  }

  [data-page="cyberpunk"] .copy-button.copied {
    color: #00FFFF;
    border-color: rgba(0, 255, 255, 0.4);
    text-shadow: 0 0 6px rgba(0, 255, 255, 0.4);
  }

  [data-page="cyberpunk"] .prompt-text {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.6);
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  [data-page="cyberpunk"] .use-section {
    background: #0d0d14;
  }

  [data-page="cyberpunk"] .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  [data-page="cyberpunk"] .use-column {
    background: #1a1a2e;
    border: 1px solid rgba(0, 255, 255, 0.1);
    clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 14px 100%, 0 calc(100% - 14px));
  }

  [data-page="cyberpunk"] .use-column-heading {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    margin: 0;
    padding: 16px 24px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(0, 255, 255, 0.1);
  }

  [data-page="cyberpunk"] .use-good .use-column-heading {
    color: #00FFFF;
    text-shadow: 0 0 8px rgba(0, 255, 255, 0.4);
    background: rgba(0, 255, 255, 0.05);
    border-bottom-color: rgba(0, 255, 255, 0.15);
  }

  [data-page="cyberpunk"] .use-bad .use-column-heading {
    color: #FF00FF;
    text-shadow: 0 0 8px rgba(255, 0, 255, 0.4);
    background: rgba(255, 0, 255, 0.05);
    border-bottom-color: rgba(255, 0, 255, 0.15);
  }

  [data-page="cyberpunk"] .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  [data-page="cyberpunk"] .use-item {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.5;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: rgba(255, 255, 255, 0.6);
  }

  [data-page="cyberpunk"] .use-item:last-child {
    border-bottom: none;
  }

  [data-page="cyberpunk"] .use-item-good::before {
    content: '[+]';
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    color: #00FFFF;
    text-shadow: 0 0 4px rgba(0, 255, 255, 0.3);
    flex-shrink: 0;
  }

  [data-page="cyberpunk"] .use-item-bad::before {
    content: '[x]';
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    color: #FF00FF;
    text-shadow: 0 0 4px rgba(255, 0, 255, 0.3);
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  [data-page="cyberpunk"] .history-section {
    background: #0a0a0f;
  }

  [data-page="cyberpunk"] .history-content {
    max-width: 740px;
    border-left: 3px solid rgba(255, 215, 0, 0.4);
    padding-left: 24px;
  }

  [data-page="cyberpunk"] .history-paragraph {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.8;
    margin: 0 0 24px 0;
    color: rgba(255, 255, 255, 0.65);
  }

  [data-page="cyberpunk"] .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  [data-page="cyberpunk"] .related-section {
    background: #0d0d14;
  }

  [data-page="cyberpunk"] .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  [data-page="cyberpunk"] .related-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px;
    background: #1a1a2e;
    border: 1px solid rgba(0, 255, 255, 0.15);
    text-decoration: none;
    color: #ffffff;
    position: relative;
    transition: all 0.2s;
    clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 14px 100%, 0 calc(100% - 14px));
  }

  [data-page="cyberpunk"] .related-card:hover {
    background: #20203a;
    border-color: rgba(0, 255, 255, 0.3);
    box-shadow: 0 0 20px rgba(0, 255, 255, 0.08);
  }

  [data-page="cyberpunk"] .related-relationship {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #FF00FF;
    text-shadow: 0 0 4px rgba(255, 0, 255, 0.3);
  }

  [data-page="cyberpunk"] .related-name {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.3rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #ffffff;
  }

  /* Arrow via pseudo-element */
  [data-page="cyberpunk"] .related-card::after {
    content: '\2192';
    font-family: 'Share Tech Mono', monospace;
    font-size: 1.1rem;
    position: absolute;
    bottom: 18px;
    right: 18px;
    color: #00FFFF;
    text-shadow: 0 0 6px rgba(0, 255, 255, 0.4);
    transition: transform 0.2s;
  }

  [data-page="cyberpunk"] .related-card:hover::after {
    transform: translateX(4px);
  }

  /* ========================================
     FOOTER
     ======================================== */
  [data-page="cyberpunk"] .footer {
    background: #0a0a0f;
    padding: 60px 24px;
    border-top: 1px solid rgba(0, 255, 255, 0.1);
  }

  [data-page="cyberpunk"] .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  /* Decorative stripe via pseudo-element */
  [data-page="cyberpunk"] .footer-inner::before {
    content: '';
    display: block;
    height: 3px;
    width: 120px;
    margin-bottom: 8px;
    background: repeating-linear-gradient(
      -45deg,
      #FFD700,
      #FFD700 4px,
      transparent 4px,
      transparent 8px
    );
    box-shadow: 0 0 6px rgba(255, 215, 0, 0.3);
  }

  [data-page="cyberpunk"] .footer-logo {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 1rem;
    color: #00FFFF;
    text-decoration: none;
    padding: 8px 18px;
    border: 1px solid rgba(0, 255, 255, 0.3);
    text-shadow: 0 0 6px rgba(0, 255, 255, 0.4);
    transition: all 0.2s;
