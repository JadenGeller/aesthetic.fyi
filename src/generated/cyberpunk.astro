---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">//</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-scanlines"></div>
    <div class="hero-inner">
      <span class="hero-label">&gt; WEB_AESTHETIC</span>
      <h1 class="hero-title">
        <span class="glitch" data-text={aesthetic.name}>{aesthetic.name}</span>
      </h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
      <div class="hero-stripe"></div>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <span class="section-label">&gt; SYS.DESCRIPTION</span>
      <h2 class="section-heading">What This Is</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <span class="section-label">&gt; DESIGN.TOKENS</span>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class={`char-card char-card-${i % 3}`}>
            <div class="char-index">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
            <div class="char-border-glow"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <span class="section-label">&gt; COPY.PASTE</span>
      <h2 class="section-heading">Style Reference</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">// PROMPT.TXT</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>COPY_</button>
        </div>
        <div class="prompt-scanlines"></div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <span class="section-label">&gt; USE.CASES</span>
      <h2 class="section-heading">When to Use</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">DEPLOY_FOR</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">ABORT_FOR</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <span class="section-label">&gt; SYS.HISTORY</span>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <span class="section-label">&gt; LINKED.NODES</span>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-stripe"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; BACK_TO_INDEX</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'COPIED_';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Share Tech Mono', monospace;
    background-color: #0a0a0f;
    color: #c0c0c0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
  }

  /* Global scanline overlay on whole page */
  .page::after {
    content: '';
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 255, 255, 0.012) 2px,
      rgba(0, 255, 255, 0.012) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid rgba(0, 255, 255, 0.2);
    background: rgba(10, 10, 15, 0.95);
    backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-logo {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    color: #00FFFF;
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid rgba(0, 255, 255, 0.4);
    text-shadow: 0 0 6px rgba(0, 255, 255, 0.4);
    transition: all 0.2s;
    clip-path: polygon(8px 0, 100% 0, 100% calc(100% - 8px), calc(100% - 8px) 100%, 0 100%, 0 8px);
  }

  .nav-logo:hover {
    background: rgba(0, 255, 255, 0.08);
    box-shadow: 0 0 12px rgba(0, 255, 255, 0.2);
  }

  .nav-divider {
    font-family: 'Share Tech Mono', monospace;
    font-size: 1rem;
    color: rgba(0, 255, 255, 0.3);
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.85rem;
    color: #FF00FF;
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid rgba(255, 0, 255, 0.3);
    text-shadow: 0 0 6px rgba(255, 0, 255, 0.3);
    transition: all 0.2s;
  }

  .nav-current:hover {
    background: rgba(255, 0, 255, 0.08);
    box-shadow: 0 0 12px rgba(255, 0, 255, 0.2);
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #0a0a0f;
    padding: 100px 24px 80px;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(0, 255, 255, 0.15);
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -20%;
    width: 60%;
    height: 200%;
    background: radial-gradient(ellipse, rgba(0, 255, 255, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -30%;
    right: -10%;
    width: 50%;
    height: 160%;
    background: radial-gradient(ellipse, rgba(255, 0, 255, 0.03) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0, 255, 255, 0.02) 3px,
      rgba(0, 255, 255, 0.02) 6px
    );
    pointer-events: none;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #00FFFF;
    text-shadow: 0 0 8px rgba(0, 255, 255, 0.5);
    display: inline-block;
    margin-bottom: 24px;
    padding: 6px 16px;
    border-left: 3px solid #00FFFF;
    background: rgba(0, 255, 255, 0.05);
  }

  .hero-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: clamp(3.5rem, 10vw, 8rem);
    line-height: 0.95;
    margin: 0 0 24px 0;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #ffffff;
  }

  .glitch {
    position: relative;
    display: inline-block;
    text-shadow:
      0 0 10px rgba(0, 255, 255, 0.5),
      0 0 40px rgba(0, 255, 255, 0.15);
    animation: glitch-text 3s infinite;
  }

  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .glitch::before {
    color: #00FFFF;
    z-index: -1;
    animation: glitch-before 3s infinite;
  }

  .glitch::after {
    color: #FF00FF;
    z-index: -2;
    animation: glitch-after 3s infinite;
  }

  @keyframes glitch-text {
    0%, 95%, 100% { transform: none; }
    96% { transform: skewX(-2deg); }
    97% { transform: skewX(1deg); }
    98% { transform: skewX(-1deg); }
  }

  @keyframes glitch-before {
    0%, 94%, 100% { clip-path: inset(0 0 0 0); transform: none; }
    95% { clip-path: inset(20% 0 40% 0); transform: translateX(-3px); }
    96% { clip-path: inset(60% 0 10% 0); transform: translateX(3px); }
    97% { clip-path: inset(30% 0 30% 0); transform: translateX(-2px); }
    98% { clip-path: inset(0 0 0 0); transform: none; }
  }

  @keyframes glitch-after {
    0%, 93%, 100% { clip-path: inset(0 0 0 0); transform: none; }
    94% { clip-path: inset(50% 0 20% 0); transform: translateX(4px); }
    95% { clip-path: inset(10% 0 60% 0); transform: translateX(-4px); }
    96% { clip-path: inset(40% 0 20% 0); transform: translateX(2px); }
    97% { clip-path: inset(0 0 0 0); transform: none; }
  }

  .hero-tagline {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: clamp(0.95rem, 2.2vw, 1.2rem);
    line-height: 1.7;
    margin: 0 0 32px 0;
    max-width: 700px;
    color: rgba(255, 255, 255, 0.6);
  }

  .hero-stripe {
    height: 4px;
    max-width: 300px;
    background: repeating-linear-gradient(
      -45deg,
      #FFD700,
      #FFD700 6px,
      #0a0a0f 6px,
      #0a0a0f 12px
    );
    box-shadow: 0 0 8px rgba(255, 215, 0, 0.3);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 80px 24px;
    border-bottom: 1px solid rgba(0, 255, 255, 0.1);
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #00FFFF;
    text-shadow: 0 0 6px rgba(0, 255, 255, 0.4);
    display: block;
    margin-bottom: 12px;
    padding-left: 16px;
    border-left: 3px solid #00FFFF;
  }

  .section-heading {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.05;
    margin: 0 0 48px 0;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #ffffff;
    text-shadow: 0 0 20px rgba(0, 255, 255, 0.2);
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #0a0a0f;
  }

  .about-content {
    max-width: 740px;
    border-left: 3px solid rgba(255, 0, 255, 0.4);
    padding-left: 24px;
  }

  .about-paragraph {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.8;
    margin: 0 0 24px 0;
    color: rgba(255, 255, 255, 0.7);
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #0d0d14;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 20px;
  }

  .char-card {
    background: #1a1a2e;
    padding: 32px 28px 28px;
    position: relative;
    overflow: hidden;
    clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px));
    transition: all 0.2s;
  }

  .char-card:hover {
    background: #20203a;
  }

  .char-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid transparent;
    pointer-events: none;
  }

  .char-card-0 {
    border-left: 3px solid #00FFFF;
    box-shadow: inset 0 0 30px rgba(0, 255, 255, 0.03);
  }

  .char-card-1 {
    border-left: 3px solid #FF00FF;
    box-shadow: inset 0 0 30px rgba(255, 0, 255, 0.03);
  }

  .char-card-2 {
    border-left: 3px solid #FFD700;
    box-shadow: inset 0 0 30px rgba(255, 215, 0, 0.03);
  }

  .char-border-glow {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, rgba(0, 255, 255, 0.3), transparent);
  }

  .char-index {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: #00FFFF;
    text-shadow: 0 0 6px rgba(0, 255, 255, 0.4);
    margin-bottom: 16px;
    opacity: 0.7;
  }

  .char-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    margin: 0 0 12px 0;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #ffffff;
  }

  .char-description {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
    color: rgba(255, 255, 255, 0.55);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #0a0a0f;
  }

  .prompt-block {
    background: #0d0d14;
    border: 1px solid rgba(0, 255, 255, 0.2);
    position: relative;
    overflow: hidden;
    clip-path: polygon(0 0, calc(100% - 16px) 0, 100% 16px, 100% 100%, 16px 100%, 0 calc(100% - 16px));
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(0, 255, 255, 0.15);
    background: rgba(0, 255, 255, 0.04);
  }

  .prompt-header-label {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #00FFFF;
    text-shadow: 0 0 6px rgba(0, 255, 255, 0.3);
  }

  .copy-button {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    background: transparent;
    color: #FFD700;
    border: 1px solid rgba(255, 215, 0, 0.4);
    padding: 8px 20px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: all 0.2s;
    text-shadow: 0 0 6px rgba(255, 215, 0, 0.3);
    clip-path: polygon(6px 0, 100% 0, 100% calc(100% - 6px), calc(100% - 6px) 100%, 0 100%, 0 6px);
  }

  .copy-button:hover {
    background: rgba(255, 215, 0, 0.1);
    box-shadow: 0 0 12px rgba(255, 215, 0, 0.2);
  }

  .copy-button:active {
    background: rgba(255, 215, 0, 0.2);
  }

  .copy-button.copied {
    color: #00FFFF;
    border-color: rgba(0, 255, 255, 0.4);
    text-shadow: 0 0 6px rgba(0, 255, 255, 0.4);
  }

  .prompt-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 255, 255, 0.01) 2px,
      rgba(0, 255, 255, 0.01) 4px
    );
    pointer-events: none;
  }

  .prompt-text {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.6);
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #0d0d14;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .use-column {
    background: #1a1a2e;
    border: 1px solid rgba(0, 255, 255, 0.1);
    clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 14px 100%, 0 calc(100% - 14px));
  }

  .use-column-heading {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    margin: 0;
    padding: 16px 24px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(0, 255, 255, 0.1);
  }

  .use-good .use-column-heading {
    color: #00FFFF;
    text-shadow: 0 0 8px rgba(0, 255, 255, 0.4);
    background: rgba(0, 255, 255, 0.05);
    border-bottom-color: rgba(0, 255, 255, 0.15);
  }

  .use-bad .use-column-heading {
    color: #FF00FF;
    text-shadow: 0 0 8px rgba(255, 0, 255, 0.4);
    background: rgba(255, 0, 255, 0.05);
    border-bottom-color: rgba(255, 0, 255, 0.15);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.5;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: rgba(255, 255, 255, 0.6);
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '[+]';
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    color: #00FFFF;
    text-shadow: 0 0 4px rgba(0, 255, 255, 0.3);
    flex-shrink: 0;
  }

  .use-item-bad::before {
    content: '[x]';
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    color: #FF00FF;
    text-shadow: 0 0 4px rgba(255, 0, 255, 0.3);
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #0a0a0f;
  }

  .history-content {
    max-width: 740px;
    border-left: 3px solid rgba(255, 215, 0, 0.4);
    padding-left: 24px;
  }

  .history-paragraph {
    font-family: 'Share Tech Mono', monospace;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.8;
    margin: 0 0 24px 0;
    color: rgba(255, 255, 255, 0.65);
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #0d0d14;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px;
    background: #1a1a2e;
    border: 1px solid rgba(0, 255, 255, 0.15);
    text-decoration: none;
    color: #ffffff;
    position: relative;
    transition: all 0.2s;
    clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 14px, 100% 100%, 14px 100%, 0 calc(100% - 14px));
  }

  .related-card:hover {
    background: #20203a;
    border-color: rgba(0, 255, 255, 0.3);
    box-shadow: 0 0 20px rgba(0, 255, 255, 0.08);
  }

