---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=VT323&family=Inter:wght@400;500&display=swap" rel="stylesheet" />

<div class="page">
  <!-- SCANLINE OVERLAY -->
  <div class="scanlines" aria-hidden="true"></div>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">ａｅｓｔｈｅｔｉｃ．ｆｙｉ</a>
      <span class="nav-divider">／／</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-label">Ｗｅｂ Ａｅｓｔｈｅｔｉｃ</span>
      <h1 class="hero-title glitch-text" data-text={aesthetic.name}>{aesthetic.name}</h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
    <div class="hero-grid-lines" aria-hidden="true"></div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <span class="section-label">// Ｗｈａｔ Ｔｈｉｓ Ｉｓ</span>
      <h2 class="section-heading glitch-text" data-text="Philosophy">Philosophy</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <span class="section-label">// Ｄｅｓｉｇｎ Ｔｏｋｅｎｓ</span>
      <h2 class="section-heading glitch-text" data-text="Characteristics">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class={`char-card char-card-${i % 3}`}>
            <div class="char-window-bar">
              <span class="win-btn"></span>
              <span class="win-btn"></span>
              <span class="win-btn"></span>
              <span class="char-window-title">{char.title}.exe</span>
            </div>
            <div class="char-body">
              <span class="char-number">0{i + 1}</span>
              <h3 class="char-title">{char.title}</h3>
              <p class="char-description">{char.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <span class="section-label">// Ｃｏｐｙ ＆ Ｐａｓｔｅ</span>
      <h2 class="section-heading glitch-text" data-text="Style Reference">Style Reference</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">C:\AESTHETIC\PROMPT.TXT</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <span class="section-label">// Ｗｈｅｎ ｔｏ Ｕｓｅ</span>
      <h2 class="section-heading glitch-text" data-text="Use Cases">Use Cases</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good for</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not for</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <span class="section-label">// Ｏｒｉｇｉｎｓ</span>
      <h2 class="section-heading glitch-text" data-text="History">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <span class="section-label">// Ｅｘｐｌｏｒｅ</span>
      <h2 class="section-heading glitch-text" data-text="Related Styles">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&#x279C;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <a href="/" class="footer-logo">ａｅｓｔｈｅｔｉｃ．ｆｙｉ</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to all aesthetics</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Inter', sans-serif;
    background: linear-gradient(135deg, #1a0a2e 0%, #16213e 40%, #0f3460 100%);
    color: #e0d6f0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
    overflow-x: hidden;
  }

  /* ========================================
     SCANLINE OVERLAY
     ======================================== */
  .scanlines {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 999;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.06) 0px,
      rgba(0, 0, 0, 0.06) 1px,
      transparent 1px,
      transparent 3px
    );
  }

  /* ========================================
     GLITCH TEXT EFFECT
     ======================================== */
  .glitch-text {
    position: relative;
  }

  .glitch-text::before,
  .glitch-text::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .glitch-text::before {
    color: #FF71CE;
    z-index: -1;
    animation: glitch-shift-1 4s infinite linear alternate-reverse;
  }

  .glitch-text::after {
    color: #01CDFE;
    z-index: -1;
    animation: glitch-shift-2 3s infinite linear alternate-reverse;
  }

  @keyframes glitch-shift-1 {
    0%, 90%, 100% { clip-path: inset(0 0 0 0); transform: translate(0); }
    92% { clip-path: inset(20% 0 40% 0); transform: translate(-3px, 1px); }
    94% { clip-path: inset(60% 0 10% 0); transform: translate(3px, -1px); }
    96% { clip-path: inset(40% 0 30% 0); transform: translate(-2px, 2px); }
    98% { clip-path: inset(10% 0 70% 0); transform: translate(2px, -2px); }
  }

  @keyframes glitch-shift-2 {
    0%, 88%, 100% { clip-path: inset(0 0 0 0); transform: translate(0); }
    90% { clip-path: inset(50% 0 20% 0); transform: translate(3px, 1px); }
    93% { clip-path: inset(10% 0 60% 0); transform: translate(-3px, -1px); }
    95% { clip-path: inset(70% 0 5% 0); transform: translate(2px, 2px); }
    97% { clip-path: inset(30% 0 40% 0); transform: translate(-2px, -2px); }
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background: rgba(26, 10, 46, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(185, 103, 255, 0.25);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-logo {
    font-family: 'VT323', monospace;
    font-size: 1rem;
    color: #FF71CE;
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid rgba(255, 113, 206, 0.4);
    background: rgba(255, 113, 206, 0.08);
    transition: background 0.3s, text-shadow 0.3s;
    letter-spacing: 0.05em;
  }

  .nav-logo:hover {
    background: rgba(255, 113, 206, 0.15);
    text-shadow: 0 0 12px rgba(255, 113, 206, 0.6);
  }

  .nav-divider {
    font-family: 'VT323', monospace;
    font-size: 1.1rem;
    color: rgba(185, 103, 255, 0.4);
    margin: 0 4px;
  }

  .nav-current {
    font-family: 'VT323', monospace;
    font-size: 1rem;
    color: #01CDFE;
    text-decoration: none;
    padding: 6px 14px;
    border: 1px solid rgba(1, 205, 254, 0.3);
    background: rgba(1, 205, 254, 0.06);
    transition: background 0.3s, text-shadow 0.3s;
  }

  .nav-current:hover {
    background: rgba(1, 205, 254, 0.12);
    text-shadow: 0 0 12px rgba(1, 205, 254, 0.6);
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: linear-gradient(135deg, #FF71CE 0%, #01CDFE 50%, #B967FF 100%);
    padding: 100px 24px 88px;
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .hero-grid-lines {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 160px;
    background:
      linear-gradient(rgba(255, 255, 255, 0.15) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.15) 1px, transparent 1px);
    background-size: 60px 20px;
    transform: perspective(300px) rotateX(60deg);
    transform-origin: bottom center;
    z-index: 1;
  }

  .hero-label {
    font-family: 'VT323', monospace;
    font-size: 1.1rem;
    letter-spacing: 0.2em;
    background: rgba(26, 10, 46, 0.65);
    color: #FFFB96;
    padding: 8px 20px;
    display: inline-block;
    margin-bottom: 28px;
    border: 1px solid rgba(255, 251, 150, 0.3);
  }

  .hero-title {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(3.5rem, 10vw, 8rem);
    line-height: 0.95;
    margin: 0 0 28px 0;
    letter-spacing: -0.02em;
    color: #fff;
    text-shadow:
      3px 3px 0px #FF71CE,
      -2px -2px 0px #01CDFE;
  }

  .hero-tagline {
    font-family: 'VT323', monospace;
    font-size: clamp(1.15rem, 2.5vw, 1.6rem);
    line-height: 1.5;
    margin: 0;
    max-width: 700px;
    color: rgba(26, 10, 46, 0.85);
    text-shadow: 0 0 20px rgba(255, 255, 255, 0.3);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 80px 24px;
    border-bottom: 1px solid rgba(185, 103, 255, 0.2);
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'VT323', monospace;
    font-size: 1rem;
    letter-spacing: 0.15em;
    color: #FF71CE;
    display: block;
    margin-bottom: 12px;
  }

  .section-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.05;
    margin: 0 0 48px 0;
    letter-spacing: -0.02em;
    color: #fff;
    text-shadow:
      2px 2px 0px #FF71CE,
      -1px -1px 0px #01CDFE;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: rgba(26, 10, 46, 0.4);
  }

  .about-content {
    max-width: 740px;
  }

  .about-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.8;
    margin: 0 0 24px 0;
    color: #d0c8e4;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: rgba(15, 52, 96, 0.35);
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 1px solid rgba(185, 103, 255, 0.3);
    background: rgba(26, 10, 46, 0.5);
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .char-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(185, 103, 255, 0.2);
  }

  .char-window-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: linear-gradient(90deg, rgba(185, 103, 255, 0.25), rgba(1, 205, 254, 0.15));
    border-bottom: 1px solid rgba(185, 103, 255, 0.3);
  }

  .win-btn {
    width: 10px;
    height: 10px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.1);
  }

  .char-window-title {
    font-family: 'VT323', monospace;
    font-size: 0.85rem;
    color: rgba(255, 251, 150, 0.7);
    margin-left: auto;
  }

  .char-body {
    padding: 28px 24px 24px;
  }

  .char-card-0 {
    border-color: rgba(255, 113, 206, 0.4);
  }

  .char-card-1 {
    border-color: rgba(1, 205, 254, 0.4);
  }

  .char-card-2 {
    border-color: rgba(5, 255, 161, 0.4);
  }

  .char-number {
    font-family: 'VT323', monospace;
    font-size: 0.9rem;
    color: #05FFA1;
    display: block;
    margin-bottom: 8px;
  }

  .char-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    margin: 0 0 12px 0;
    color: #fff;
    text-shadow: 0 0 15px rgba(185, 103, 255, 0.3);
  }

  .char-description {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
    color: #c0b8d4;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: rgba(26, 10, 46, 0.5);
  }

  .prompt-block {
    border: 1px solid rgba(1, 205, 254, 0.3);
    background: rgba(15, 10, 30, 0.8);
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(1, 205, 254, 0.3);
    background: linear-gradient(90deg, rgba(185, 103, 255, 0.15), rgba(1, 205, 254, 0.1));
  }

  .prompt-header-label {
    font-family: 'VT323', monospace;
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: #FFFB96;
  }

  .copy-button {
    font-family: 'VT323', monospace;
    font-size: 1rem;
    background: rgba(5, 255, 161, 0.1);
    color: #05FFA1;
    border: 1px solid rgba(5, 255, 161, 0.4);
    padding: 8px 20px;
    cursor: pointer;
    transition: background 0.3s, box-shadow 0.3s;
    letter-spacing: 0.05em;
  }

  .copy-button:hover {
    background: rgba(5, 255, 161, 0.2);
    box-shadow: 0 0 16px rgba(5, 255, 161, 0.3);
  }

  .copy-button:active {
    background: rgba(5, 255, 161, 0.3);
  }

  .copy-button.copied {
    background: rgba(5, 255, 161, 0.25);
    color: #05FFA1;
    text-shadow: 0 0 8px rgba(5, 255, 161, 0.5);
  }

  .prompt-text {
    font-family: 'VT323', monospace;
    font-size: 1.1rem;
    line-height: 1.75;
    color: #01CDFE;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: rgba(15, 52, 96, 0.3);
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .use-column {
    border: 1px solid rgba(185, 103, 255, 0.3);
    background: rgba(26, 10, 46, 0.4);
    overflow: hidden;
  }

  .use-column-heading {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin: 0;
    padding: 18px 24px;
    border-bottom: 1px solid rgba(185, 103, 255, 0.3);
  }

  .use-good .use-column-heading {
    background: linear-gradient(90deg, rgba(5, 255, 161, 0.15), rgba(1, 205, 254, 0.1));
    color: #05FFA1;
  }

  .use-bad .use-column-heading {
    background: linear-gradient(90deg, rgba(255, 113, 206, 0.15), rgba(185, 103, 255, 0.1));
    color: #FF71CE;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(185, 103, 255, 0.1);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: #c0b8d4;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '>';
    font-family: 'VT323', monospace;
    font-size: 1.2rem;
    color: #05FFA1;
    flex-shrink: 0;
    text-shadow: 0 0 8px rgba(5, 255, 161, 0.4);
  }

  .use-item-bad::before {
    content: 'x';
    font-family: 'VT323', monospace;
    font-size: 1.2rem;
    color: #FF71CE;
    flex-shrink: 0;
    text-shadow: 0 0 8px rgba(255, 113, 206, 0.4);
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: rgba(26, 10, 46, 0.45);
  }

  .history-content {
    max-width: 740px;
  }

  .history-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.8;
    margin: 0 0 24px 0;
    color: #d0c8e4;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: linear-gradient(135deg, rgba(185, 103, 255, 0.15), rgba(255, 113, 206, 0.1));
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px;
    border: 1px solid rgba(185, 103, 255, 0.3);
    background: rgba(26, 10, 46, 0.5);
    text-decoration: none;
    color: #e0d6f0;
    transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
    position: relative;
    overflow: hidden;
  }

  .related-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #FF71CE, #01CDFE, #B967FF);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .related-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(185, 103, 255, 0.2);
    border-color: rgba(185, 103, 255, 0.5);
  }

  .related-card:hover::before {
    opacity: 1;
  }

  .related-relationship {
    font-family: 'VT323', monospace;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    color: #FF71CE;
    background: rgba(255, 113, 206, 0.1);
    padding: 4px 10px;
    display: inline-block;
    align-self: flex-start;
    border: 1px solid rgba(255, 113, 206, 0.25);
  }

  .related-name {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    color: #fff;
  }

  .related-arrow {
    font-size: 1.1rem;
    position: absolute;
    bottom: 20px;
    right: 20px;
    color: #01CDFE;
    text-shadow: 0 0 8px rgba(1, 205, 254, 0.4);
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: rgba(10, 5, 20, 0.9);
    padding: 60px 24px;
    border-top: 1px solid rgba(185, 103, 255, 0.2);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
