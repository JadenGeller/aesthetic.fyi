---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
      <div class="nav-status">
        <span class="nav-status-dot"></span>
        <span class="nav-status-text">Live</span>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-metrics">
        <div class="hero-metric-card">
          <span class="hero-metric-label">Aesthetic</span>
          <span class="hero-metric-value">{aesthetic.name}</span>
        </div>
        <div class="hero-metric-card">
          <span class="hero-metric-label">Category</span>
          <span class="hero-metric-value hero-metric-sm">Web Design</span>
        </div>
        <div class="hero-metric-card">
          <span class="hero-metric-label">Status</span>
          <span class="hero-metric-value hero-metric-sm">
            <span class="hero-status-dot"></span>Active
          </span>
        </div>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
      <div class="hero-chart-bar">
        <div class="hero-bar hero-bar-blue" style="width: 72%"><span>Data</span></div>
        <div class="hero-bar hero-bar-green" style="width: 18%"><span>Ink</span></div>
        <div class="hero-bar hero-bar-yellow" style="width: 10%"><span>Chrome</span></div>
      </div>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Overview</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">What This Is</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Metrics</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <div class="char-top">
              <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
              <div class="char-bar-mini">
                <div class="char-bar-fill" style={`width: ${85 - i * 10}%`}></div>
              </div>
            </div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DASHBOARD DEMO -->
  <section class="section demo-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Dashboard</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Visual Language</h2>
      <div class="demo-grid">
        <!-- Metric Cards Row -->
        <div class="demo-metric-card">
          <span class="demo-metric-label">Conversion Rate</span>
          <span class="demo-metric-number">42.7%</span>
          <span class="demo-metric-trend demo-trend-up">+3.2%</span>
        </div>
        <div class="demo-metric-card">
          <span class="demo-metric-label">Revenue</span>
          <span class="demo-metric-number">$1.2M</span>
          <span class="demo-metric-trend demo-trend-up">+12.8%</span>
        </div>
        <div class="demo-metric-card">
          <span class="demo-metric-label">Uptime</span>
          <span class="demo-metric-number">99.9%</span>
          <span class="demo-metric-trend demo-trend-neutral">0.0%</span>
        </div>
        <div class="demo-metric-card">
          <span class="demo-metric-label">Churn</span>
          <span class="demo-metric-number">2.1%</span>
          <span class="demo-metric-trend demo-trend-down">-0.4%</span>
        </div>
        <!-- Bar Chart -->
        <div class="demo-chart-card demo-chart-bars">
          <span class="demo-chart-title">Monthly Performance</span>
          <div class="demo-bars">
            <div class="demo-bar-group">
              <div class="demo-bar" style="height: 45%"></div>
              <span class="demo-bar-label">Jan</span>
            </div>
            <div class="demo-bar-group">
              <div class="demo-bar" style="height: 62%"></div>
              <span class="demo-bar-label">Feb</span>
            </div>
            <div class="demo-bar-group">
              <div class="demo-bar" style="height: 55%"></div>
              <span class="demo-bar-label">Mar</span>
            </div>
            <div class="demo-bar-group">
              <div class="demo-bar" style="height: 78%"></div>
              <span class="demo-bar-label">Apr</span>
            </div>
            <div class="demo-bar-group">
              <div class="demo-bar" style="height: 68%"></div>
              <span class="demo-bar-label">May</span>
            </div>
            <div class="demo-bar-group">
              <div class="demo-bar" style="height: 85%"></div>
              <span class="demo-bar-label">Jun</span>
            </div>
            <div class="demo-bar-group">
              <div class="demo-bar demo-bar-accent" style="height: 92%"></div>
              <span class="demo-bar-label">Jul</span>
            </div>
          </div>
        </div>
        <!-- Pie Chart -->
        <div class="demo-chart-card demo-chart-pie-card">
          <span class="demo-chart-title">Traffic Sources</span>
          <div class="demo-pie-container">
            <div class="demo-pie"></div>
            <div class="demo-pie-legend">
              <div class="demo-legend-item">
                <span class="demo-legend-dot demo-legend-blue"></span>
                <span class="demo-legend-text">Organic 42%</span>
              </div>
              <div class="demo-legend-item">
                <span class="demo-legend-dot demo-legend-red"></span>
                <span class="demo-legend-text">Paid 28%</span>
              </div>
              <div class="demo-legend-item">
                <span class="demo-legend-dot demo-legend-green"></span>
                <span class="demo-legend-text">Referral 18%</span>
              </div>
              <div class="demo-legend-item">
                <span class="demo-legend-dot demo-legend-yellow"></span>
                <span class="demo-legend-text">Direct 12%</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Style Reference</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Analysis</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">When to Use</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Timeline</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Related</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-rule"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-rule"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: #F8F9FA;
    color: #202124;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid #DADCE0;
    background: #FFFFFF;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 12px 32px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-logo {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    color: #202124;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-logo:hover {
    color: #4285F4;
  }

  .nav-divider {
    font-size: 0.85rem;
    color: #DADCE0;
  }

  .nav-current {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.85rem;
    color: #5F6368;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-current:hover {
    color: #4285F4;
  }

  .nav-status {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    background: rgba(52, 168, 83, 0.08);
    border-radius: 12px;
  }

  .nav-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #34A853;
  }

  .nav-status-text {
    font-size: 0.75rem;
    font-weight: 500;
    color: #34A853;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #FFFFFF;
    padding: 48px 32px 40px;
    border-bottom: 1px solid #DADCE0;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
  }

  .hero-metric-card {
    background: #F8F9FA;
    border: 1px solid #DADCE0;
    border-radius: 8px;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .hero-metric-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: #5F6368;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-metric-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: #202124;
    line-height: 1.2;
  }

  .hero-metric-sm {
    font-size: 1.25rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero-status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #34A853;
    display: inline-block;
  }

  .hero-tagline {
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.6;
    margin: 0 0 24px 0;
    color: #5F6368;
    max-width: 700px;
  }

  .hero-chart-bar {
    display: flex;
    height: 32px;
    border-radius: 6px;
    overflow: hidden;
    gap: 2px;
  }

  .hero-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: width 0.6s ease;
  }

  .hero-bar span {
    font-size: 0.7rem;
    font-weight: 600;
    color: #FFFFFF;
    letter-spacing: 0.03em;
  }

  .hero-bar-blue {
    background: #4285F4;
  }

  .hero-bar-green {
    background: #34A853;
  }

  .hero-bar-yellow {
    background: #FBBC04;
  }

  .hero-bar-yellow span {
    color: #202124;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 64px 32px;
    border-bottom: 1px solid #DADCE0;
  }

  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .section-rule {
    flex: 1;
    height: 1px;
    background: #DADCE0;
  }

  .section-label {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.75rem;
    color: #5F6368;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .section-heading {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 2rem);
    line-height: 1.2;
    margin: 0 0 40px 0;
    color: #202124;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #FFFFFF;
  }

  .about-content {
    max-width: 720px;
  }

  .about-paragraph {
    font-size: 1.05rem;
    line-height: 1.8;
    margin: 0 0 20px 0;
    color: #3C4043;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #F8F9FA;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
  }

  .char-card {
    background: #FFFFFF;
    border: 1px solid #DADCE0;
    border-radius: 8px;
    padding: 24px;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .char-card:hover {
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.1);
    border-color: #4285F4;
  }

  .char-top {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .char-number {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.7rem;
    color: #5F6368;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .char-bar-mini {
    flex: 1;
    height: 4px;
    background: #E8EAED;
    border-radius: 2px;
    overflow: hidden;
  }

  .char-bar-fill {
    height: 100%;
    background: #4285F4;
    border-radius: 2px;
    transition: width 0.4s ease;
  }

  .char-title {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    margin: 0 0 8px 0;
    color: #202124;
  }

  .char-description {
    font-size: 0.9rem;
    line-height: 1.65;
    margin: 0;
    color: #5F6368;
  }

  /* ========================================
     DASHBOARD DEMO
     ======================================== */
  .demo-section {
    background: #FFFFFF;
  }

  .demo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .demo-metric-card {
    background: #F8F9FA;
    border: 1px solid #DADCE0;
    border-radius: 8px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .demo-metric-label {
    font-size: 0.7rem;
    font-weight: 500;
    color: #5F6368;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .demo-metric-number {
    font-size: 1.75rem;
    font-weight: 700;
    color: #202124;
    font-variant-numeric: tabular-nums;
  }

  .demo-metric-trend {
    font-size: 0.8rem;
    font-weight: 600;
  }

  .demo-trend-up {
    color: #34A853;
  }

  .demo-trend-up::before {
    content: '\2191 ';
  }

  .demo-trend-down {
    color: #34A853;
  }

  .demo-trend-down::before {
    content: '\2193 ';
  }

  .demo-trend-neutral {
    color: #5F6368;
  }

  .demo-trend-neutral::before {
    content: '\2192 ';
  }

  .demo-chart-card {
    background: #F8F9FA;
    border: 1px solid #DADCE0;
    border-radius: 8px;
    padding: 24px;
  }

  .demo-chart-bars {
    grid-column: 1 / 3;
  }

  .demo-chart-pie-card {
    grid-column: 3 / 5;
  }

  .demo-chart-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: #202124;
    display: block;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Bar Chart */
  .demo-bars {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    height: 140px;
    padding-top: 10px;
    border-bottom: 1px solid #DADCE0;
  }

  .demo-bar-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    justify-content: flex-end;
    gap: 8px;
  }

  .demo-bar {
    width: 100%;
    background: #4285F4;
    border-radius: 4px 4px 0 0;
    min-height: 4px;
    transition: height 0.4s ease;
  }

  .demo-bar-accent {
    background: #34A853;
  }

  .demo-bar-label {
    font-size: 0.65rem;
    font-weight: 500;
    color: #5F6368;
    padding-top: 6px;
  }

  /* Pie Chart */
  .demo-pie-container {
    display: flex;
    align-items: center;
    gap: 24px;
    justify-content: center;
  }

  .demo-pie {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: conic-gradient(
      #4285F4 0deg 151.2deg,
      #EA4335 151.2deg 252deg,
      #34A853 252deg 316.8deg,
      #FBBC04 316.8deg 360deg
    );
    flex-shrink: 0;
    position: relative;
  }

  .demo-pie::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 50px;
    height: 50px;
    background: #F8F9FA;
    border-radius: 50%;
  }

  .demo-pie-legend {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .demo-legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .demo-legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  .demo-legend-blue { background: #4285F4; }
  .demo-legend-red { background: #EA4335; }
  .demo-legend-green { background: #34A853; }
  .demo-legend-yellow { background: #FBBC04; }

  .demo-legend-text {
    font-size: 0.8rem;
    font-weight: 500;
    color: #3C4043;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #F8F9FA;
  }

  .prompt-block {
    background: #FFFFFF;
    border: 1px solid #DADCE0;
    border-radius: 8px;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 20px;
    border-bottom: 1px solid #DADCE0;
    background: #F8F9FA;
  }

  .prompt-header-label {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.75rem;
    color: #5F6368;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .copy-button {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.8rem;
    background: #4285F4;
