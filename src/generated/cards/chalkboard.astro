---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Patrick+Hand&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet" />

<div class="card">
  <div class="card-dust"></div>
  <div class="card-frame"></div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <div class="card-chalk-line">
    <span class="card-line"></span>
  </div>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  .card {
    background: #2D4A2D;
    color: #F0EBE3;
    border: 4px solid #6B4F12;
    border-radius: 4px;
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.3s, border-color 0.3s;
    box-shadow:
      inset 2px 0 0 #8B6914,
      inset -2px 0 0 #8B6914,
      inset 0 2px 0 #8B6914,
      inset 0 -2px 0 #8B6914;
  }

  .card:hover {
    box-shadow:
      inset 2px 0 0 #8B6914,
      inset -2px 0 0 #8B6914,
      inset 0 2px 0 #8B6914,
      inset 0 -2px 0 #8B6914,
      0 4px 20px rgba(0, 0, 0, 0.4);
    border-color: #8B6914;
  }

  .card-dust {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle 1px at 15% 20%, rgba(240,235,227,0.06) 50%, transparent 50%),
      radial-gradient(circle 1px at 30% 60%, rgba(240,235,227,0.04) 50%, transparent 50%),
      radial-gradient(circle 1px at 50% 35%, rgba(240,235,227,0.07) 50%, transparent 50%),
      radial-gradient(circle 1px at 70% 75%, rgba(240,235,227,0.05) 50%, transparent 50%),
      radial-gradient(circle 1px at 85% 15%, rgba(240,235,227,0.06) 50%, transparent 50%),
      radial-gradient(circle 1px at 40% 85%, rgba(240,235,227,0.04) 50%, transparent 50%);
    opacity: 0.8;
    pointer-events: none;
  }

  .card-frame {
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    bottom: 8px;
    border: 1px dashed rgba(240, 235, 227, 0.18);
    border-radius: 2px;
    pointer-events: none;
  }

  .card-name {
    font-family: 'Patrick Hand', cursive;
    font-weight: 400;
    font-size: 24px;
    margin: 0 0 6px 0;
    color: #F0EBE3;
    line-height: 1.2;
    position: relative;
    z-index: 1;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
  }

  .card-chalk-line {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
    position: relative;
    z-index: 1;
  }

  .card-line {
    display: block;
    width: 48px;
    height: 2px;
    background: linear-gradient(90deg,
      transparent,
      rgba(240,235,227,0.4) 20%,
      rgba(240,235,227,0.6) 50%,
      rgba(240,235,227,0.4) 80%,
      transparent
    );
    border-radius: 1px;
  }

  .card-tagline {
    font-family: 'Lora', serif;
    font-size: 13px;
    font-weight: 400;
    font-style: italic;
    margin: 0;
    color: #B8C9A3;
    line-height: 1.5;
    position: relative;
    z-index: 1;
    max-width: 220px;
  }
</style>
