---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet" />

<div class="card">
  <div class="deco-triangle"></div>
  <div class="deco-circle"></div>
  <div class="deco-squiggle"></div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  .card {
    background: #FF6B9D;
    color: #1a1a1a;
    border: 4px solid #1a1a1a;
    border-radius: 16px;
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s;
    background-image:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 12px,
        rgba(255, 255, 255, 0.1) 12px,
        rgba(255, 255, 255, 0.1) 14px
      );
  }

  .card:hover {
    transform: rotate(-1deg) scale(1.03);
  }

  .deco-triangle {
    position: absolute;
    top: 18px;
    right: 22px;
    width: 0;
    height: 0;
    border-left: 24px solid transparent;
    border-right: 24px solid transparent;
    border-bottom: 42px solid #FFE142;
    transform: rotate(12deg);
  }

  .deco-circle {
    position: absolute;
    top: 28px;
    right: 85px;
    width: 32px;
    height: 32px;
    background: #00BCD4;
    border-radius: 50%;
    border: 3px dashed #1a1a1a;
  }

  .deco-squiggle {
    position: absolute;
    top: 16px;
    left: 24px;
    width: 48px;
    height: 12px;
    background: repeating-linear-gradient(
      90deg,
      #E8D5F5 0px,
      #E8D5F5 6px,
      transparent 6px,
      transparent 12px
    );
    border-radius: 4px;
    transform: rotate(-8deg);
  }

  .card-name {
    font-family: 'Fredoka One', cursive;
    font-size: 26px;
    letter-spacing: -0.5px;
    margin: 0 0 8px 0;
    color: #1a1a1a;
    line-height: 1.1;
    text-shadow: 2px 2px 0px #FFE142;
  }

  .card-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 12px;
    font-weight: 400;
    margin: 0;
    color: #1a1a1a;
    line-height: 1.5;
  }
</style>
