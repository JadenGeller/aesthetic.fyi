---
const { aesthetic } = Astro.props;
---

<div class="dense-card">
  <div class="card-header" aria-hidden="true">
    <span class="card-header-left">dense-information.html</span>
    <span class="card-header-right">13px &middot; Verdana</span>
  </div>
  <div class="card-rows" aria-hidden="true">
    <div class="card-row card-row-even">
      <span class="card-meta">1.</span>
      <span class="card-link">bloomberg-terminal-vibes</span>
      <span class="card-pts">142 pts</span>
    </div>
    <div class="card-row card-row-odd">
      <span class="card-meta">2.</span>
      <span class="card-link">hacker-news-aesthetic</span>
      <span class="card-pts">89 pts</span>
    </div>
    <div class="card-row card-row-even">
      <span class="card-meta">3.</span>
      <span class="card-link">old-reddit-density</span>
      <span class="card-pts">67 pts</span>
    </div>
  </div>
  <div class="card-bottom">
    <h3 class="name">{aesthetic.name}</h3>
    <p class="tagline">{aesthetic.tagline}</p>
  </div>
</div>

<style>
  .dense-card {
    position: relative;
    overflow: hidden;
    min-height: 220px;
    padding: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: #F6F6EF;
    color: #000000;
    border: 1px solid #dddddd;
    border-radius: 0;
    font-family: Verdana, Geneva, sans-serif;
  }

  .card-header {
    background: #FF6600;
    padding: 3px 8px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 10px;
    color: #000000;
    font-weight: 700;
  }

  .card-header-right {
    font-weight: 400;
    opacity: 0.7;
  }

  .card-rows {
    flex: 1;
    display: flex;
    flex-direction: column;
    font-size: 11px;
    line-height: 1.3;
  }

  .card-row {
    display: flex;
    align-items: baseline;
    gap: 6px;
    padding: 4px 8px;
    border-bottom: 1px solid #eeeeee;
  }

  .card-row-even {
    background: #FFFFFF;
  }

  .card-row-odd {
    background: #F6F6EF;
  }

  .card-meta {
    color: #828282;
    font-size: 10px;
    flex-shrink: 0;
    width: 16px;
  }

  .card-link {
    color: #0000FF;
    text-decoration: underline;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .card-pts {
    color: #828282;
    font-size: 10px;
    flex-shrink: 0;
  }

  .card-bottom {
    padding: 12px 8px 28px;
    background: #FFFFFF;
    border-top: 1px solid #dddddd;
  }

  .name {
    font-family: Verdana, Geneva, sans-serif;
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 4px 0;
    line-height: 1.1;
    color: #000000;
  }

  .tagline {
    font-family: Verdana, Geneva, sans-serif;
    font-size: 11px;
    color: #828282;
    margin: 0;
    line-height: 1.3;
  }

  .dense-card:hover {
    border-color: #FF6600;
  }

  .dense-card:hover .name {
    color: #0000FF;
  }

  .dense-card:hover .card-bottom {
    background: #FFFFCC;
  }
</style>
