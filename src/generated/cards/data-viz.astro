---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<div class="card">
  <div class="card-chart">
    <div class="card-bar" style="height: 40%"></div>
    <div class="card-bar" style="height: 65%"></div>
    <div class="card-bar card-bar-accent" style="height: 50%"></div>
    <div class="card-bar" style="height: 80%"></div>
    <div class="card-bar card-bar-green" style="height: 70%"></div>
  </div>
  <div class="card-content">
    <div class="card-metric">
      <span class="card-metric-value">98.6</span>
      <span class="card-metric-unit">%</span>
    </div>
    <h3 class="card-name">{aesthetic.name}</h3>
    <p class="card-tagline">{aesthetic.tagline}</p>
  </div>
  <div class="card-status">
    <span class="card-status-dot"></span>
    <span class="card-status-text">Live</span>
  </div>
</div>

<style>
  .card {
    background: #FFFFFF;
    color: #202124;
    border: 1px solid #DADCE0;
    border-radius: 8px;
    min-height: 220px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .card:hover {
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.1);
    border-color: #4285F4;
  }

  .card-chart {
    position: absolute;
    top: 16px;
    left: 20px;
    right: 20px;
    height: 70px;
    display: flex;
    align-items: flex-end;
    gap: 6px;
    border-bottom: 1px solid #E8EAED;
    padding-bottom: 4px;
  }

  .card-bar {
    flex: 1;
    background: #4285F4;
    border-radius: 3px 3px 0 0;
    min-height: 4px;
    opacity: 0.7;
  }

  .card-bar-accent {
    background: #EA4335;
  }

  .card-bar-green {
    background: #34A853;
  }

  .card-content {
    position: relative;
    z-index: 1;
    margin-top: auto;
  }

  .card-metric {
    display: flex;
    align-items: baseline;
    gap: 2px;
    margin-bottom: 6px;
  }

  .card-metric-value {
    font-size: 28px;
    font-weight: 700;
    color: #202124;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .card-metric-unit {
    font-size: 14px;
    font-weight: 600;
    color: #5F6368;
  }

  .card-name {
    font-weight: 600;
    font-size: 15px;
    margin: 0 0 4px 0;
    color: #202124;
    line-height: 1.3;
  }

  .card-tagline {
    font-size: 12px;
    font-weight: 400;
    margin: 0;
    color: #5F6368;
    line-height: 1.4;
    max-width: 240px;
  }

  .card-status {
    position: absolute;
    top: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 3px 8px;
    background: rgba(52, 168, 83, 0.08);
    border-radius: 10px;
    z-index: 1;
  }

  .card-status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #34A853;
  }

  .card-status-text {
    font-size: 10px;
    font-weight: 500;
    color: #34A853;
  }
</style>
