---
const { aesthetic } = Astro.props;
---


<div class="card">
  <div class="card-wave"></div>
  <div class="card-frame"></div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <div class="card-seal-row">
    <span class="card-bar"></span>
    <span class="card-seal"></span>
    <span class="card-bar"></span>
  </div>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700;900&display=swap');
  .card {
    background: #2C3E6B;
    color: #F5ECD7;
    border: 3px solid #1A1A2E;
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
  }

  .card:hover {
    border-color: #C73E1D;
  }

  /* Wave decoration at top of card */
  .card-wave {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 40px;
    background:
      radial-gradient(ellipse 30px 15px at 0% 0%, transparent 12px, rgba(201, 168, 76, 0.2) 12px, rgba(201, 168, 76, 0.2) 14px, transparent 14px),
      radial-gradient(ellipse 30px 15px at 20% 0%, transparent 12px, rgba(201, 168, 76, 0.2) 12px, rgba(201, 168, 76, 0.2) 14px, transparent 14px),
      radial-gradient(ellipse 30px 15px at 40% 0%, transparent 12px, rgba(201, 168, 76, 0.2) 12px, rgba(201, 168, 76, 0.2) 14px, transparent 14px),
      radial-gradient(ellipse 30px 15px at 60% 0%, transparent 12px, rgba(201, 168, 76, 0.2) 12px, rgba(201, 168, 76, 0.2) 14px, transparent 14px),
      radial-gradient(ellipse 30px 15px at 80% 0%, transparent 12px, rgba(201, 168, 76, 0.2) 12px, rgba(201, 168, 76, 0.2) 14px, transparent 14px),
      radial-gradient(ellipse 30px 15px at 100% 0%, transparent 12px, rgba(201, 168, 76, 0.2) 12px, rgba(201, 168, 76, 0.2) 14px, transparent 14px);
    pointer-events: none;
  }

  .card-frame {
    position: absolute;
    top: 7px;
    left: 7px;
    right: 7px;
    bottom: 7px;
    border: 1px solid rgba(201, 168, 76, 0.3);
    pointer-events: none;
  }

  .card-name {
    font-family: 'Noto Serif JP', serif;
    font-weight: 900;
    font-size: 22px;
    margin: 0 0 8px 0;
    color: #F5ECD7;
    line-height: 1.2;
    position: relative;
    z-index: 1;
    letter-spacing: 0.04em;
  }

  .card-seal-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 10px;
    position: relative;
    z-index: 1;
  }

  .card-bar {
    width: 20px;
    height: 2px;
    background: #C9A84C;
  }

  .card-seal {
    width: 10px;
    height: 10px;
    background: #C73E1D;
    transform: rotate(45deg);
  }

  .card-tagline {
    font-family: 'Noto Serif JP', serif;
    font-size: 13px;
    font-weight: 400;
    margin: 0;
    color: rgba(245, 236, 215, 0.6);
    line-height: 1.5;
    position: relative;
    z-index: 1;
    max-width: 220px;
  }
</style>
