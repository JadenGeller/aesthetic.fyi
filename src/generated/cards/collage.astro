---
const { aesthetic } = Astro.props;
---

<div class="card">
  <div class="card-tape"></div>
  <div class="card-accent card-accent-1"></div>
  <div class="card-accent card-accent-2"></div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <div class="card-divider"></div>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  .card {
    background: #FFFDF7;
    color: #2A2D3E;
    border: 2px solid #2A2D3E;
    min-height: 220px;
    padding: 28px 24px 24px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    transform: rotate(-1deg);
    box-shadow: 2px 3px 10px rgba(0,0,0,0.1);
    transition: box-shadow 0.3s, transform 0.3s;
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 32px,
        rgba(0,0,0,0.018) 32px,
        rgba(0,0,0,0.018) 33px
      );
  }

  .card:hover {
    box-shadow: 4px 6px 20px rgba(0,0,0,0.15);
    transform: rotate(-1deg) scale(1.02);
  }

  .card-tape {
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%) rotate(2deg);
    width: 50px;
    height: 18px;
    background: rgba(212, 168, 67, 0.35);
    border: 1px solid rgba(212, 168, 67, 0.15);
    z-index: 2;
  }

  .card-accent-1 {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 24px;
    height: 24px;
    border: 2px solid #E85D4A;
    transform: rotate(15deg);
    opacity: 0.4;
  }

  .card-accent-2 {
    position: absolute;
    bottom: 16px;
    left: 14px;
    width: 18px;
    height: 18px;
    background: rgba(58, 140, 140, 0.2);
    border: 1px solid rgba(58, 140, 140, 0.15);
    border-radius: 50%;
    opacity: 0.5;
  }

  .card-name {
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: 700;
    font-size: 24px;
    margin: 0 0 8px 0;
    color: #2A2D3E;
    line-height: 1.15;
    position: relative;
    z-index: 1;
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }

  .card-divider {
    width: 40px;
    height: 3px;
    background: linear-gradient(90deg, #E85D4A, #D4A843);
    margin-bottom: 10px;
    position: relative;
    z-index: 1;
    transform: rotate(1deg);
  }

  .card-tagline {
    font-family: 'Courier New', Courier, monospace;
    font-size: 11px;
    font-weight: 400;
    margin: 0;
    color: #666;
    line-height: 1.55;
    position: relative;
    z-index: 1;
    max-width: 210px;
    letter-spacing: 0.01em;
  }
</style>
