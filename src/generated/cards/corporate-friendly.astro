---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700&display=swap" rel="stylesheet" />

<div class="card">
  <!-- Decorative blobs -->
  <div class="card-blobs" aria-hidden="true">
    <div class="card-blob card-blob-1"></div>
    <div class="card-blob card-blob-2"></div>
    <div class="card-blob card-blob-3"></div>
  </div>
  <!-- CSS illustration: tiny people -->
  <div class="card-people" aria-hidden="true">
    <div class="mini-person">
      <div class="mini-head mini-head-1"></div>
      <div class="mini-body mini-body-1"></div>
    </div>
    <div class="mini-person">
      <div class="mini-head mini-head-2"></div>
      <div class="mini-body mini-body-2"></div>
    </div>
  </div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  .card {
    background: linear-gradient(135deg, #6C5CE7 0%, #74B9FF 100%);
    color: #ffffff;
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    border-radius: 12px;
  }

  .card-blobs {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .card-blob {
    position: absolute;
    border-radius: 50%;
  }

  .card-blob-1 {
    top: -20px;
    right: -20px;
    width: 90px;
    height: 90px;
    background: rgba(255, 255, 255, 0.12);
  }

  .card-blob-2 {
    top: 40px;
    right: 60px;
    width: 36px;
    height: 36px;
    background: rgba(0, 184, 148, 0.25);
    border-radius: 50%;
  }

  .card-blob-3 {
    top: 20px;
    right: 110px;
    width: 20px;
    height: 20px;
    background: rgba(255, 107, 107, 0.2);
    border-radius: 50%;
  }

  .card-people {
    position: absolute;
    top: 24px;
    left: 28px;
    display: flex;
    gap: 10px;
    pointer-events: none;
  }

  .mini-person {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .mini-head {
    width: 14px;
    height: 14px;
    border-radius: 50%;
  }

  .mini-body {
    width: 12px;
    height: 16px;
    border-radius: 4px 4px 2px 2px;
  }

  .mini-head-1 { background: rgba(255, 107, 107, 0.5); }
  .mini-body-1 { background: rgba(255, 107, 107, 0.35); }
  .mini-head-2 { background: rgba(0, 184, 148, 0.5); }
  .mini-body-2 { background: rgba(0, 184, 148, 0.35); }

  .card-name {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 24px;
    letter-spacing: -0.5px;
    margin: 0 0 8px 0;
    line-height: 1.1;
  }

  .card-tagline {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 400;
    font-size: 13px;
    margin: 0;
    opacity: 0.8;
    line-height: 1.4;
  }
</style>
