---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400&family=Syne:wght@800&display=swap" rel="stylesheet" />

<div class="card">
  <div class="card-grid"></div>
  <div class="card-horizon"></div>
  <div class="card-sun"></div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  .card {
    background: #1a0a2e;
    color: #e0d6f0;
    border: 1px solid rgba(255, 110, 199, 0.35);
    border-radius: 0;
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 20px rgba(255, 110, 199, 0.12), 0 0 40px rgba(185, 103, 255, 0.06);
    transition: box-shadow 0.35s, border-color 0.35s;
  }

  .card:hover {
    box-shadow: 0 0 30px rgba(255, 110, 199, 0.25), 0 0 60px rgba(185, 103, 255, 0.12);
    border-color: rgba(255, 110, 199, 0.6);
  }

  .card-grid {
    position: absolute;
    bottom: 0;
    left: -50%;
    right: -50%;
    height: 50%;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(255, 110, 199, 0.12) 0px,
        transparent 1px,
        transparent 40px
      ),
      repeating-linear-gradient(
        0deg,
        rgba(255, 110, 199, 0.12) 0px,
        transparent 1px,
        transparent 28px
      );
    transform: perspective(300px) rotateX(55deg);
    transform-origin: center top;
    pointer-events: none;
  }

  .card-horizon {
    position: absolute;
    left: 0;
    right: 0;
    top: 45%;
    height: 3px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      #ffa500 20%,
      #ff6ec7 50%,
      #b967ff 80%,
      transparent 100%
    );
    box-shadow:
      0 0 16px rgba(255, 110, 199, 0.5),
      0 0 40px rgba(255, 110, 199, 0.2);
    pointer-events: none;
  }

  .card-sun {
    position: absolute;
    top: 18%;
    left: 50%;
    transform: translateX(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(
      to bottom,
      #ffa500 0%,
      #ff6ec7 50%,
      #b967ff 100%
    );
    box-shadow:
      0 0 20px rgba(255, 110, 199, 0.5),
      0 0 50px rgba(255, 165, 0, 0.3);
    pointer-events: none;
  }

  .card-name {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 24px;
    letter-spacing: -0.5px;
    margin: 0 0 8px 0;
    line-height: 1.1;
    position: relative;
    z-index: 1;
    background: linear-gradient(
      180deg,
      #ffffff 0%,
      #ff6ec7 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 10px rgba(255, 110, 199, 0.4));
  }

  .card-tagline {
    font-family: 'Orbitron', sans-serif;
    font-size: 11px;
    font-weight: 400;
    margin: 0;
    color: #b967ff;
    line-height: 1.5;
    position: relative;
    z-index: 1;
    text-shadow: 0 0 8px rgba(185, 103, 255, 0.4);
    letter-spacing: 0.03em;
  }
</style>
