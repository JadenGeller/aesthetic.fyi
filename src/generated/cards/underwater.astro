---
const { aesthetic } = Astro.props;
---


<div class="card">
  <div class="card-bubbles"></div>
  <div class="card-light"></div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <div class="card-wave">
    <span class="card-wave-line"></span>
  </div>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;1,400&family=Outfit:wght@500;600&display=swap');
  @keyframes cardBubbleRise {
    0% {
      transform: translateY(0);
      opacity: 0;
    }
    15% {
      opacity: 0.5;
    }
    85% {
      opacity: 0.2;
    }
    100% {
      transform: translateY(-200px);
      opacity: 0;
    }
  }

  @keyframes cardWaveFlow {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  @keyframes cardLightShift {
    0%, 100% {
      opacity: 0.04;
    }
    50% {
      opacity: 0.08;
    }
  }

  .card {
    background: linear-gradient(165deg, #0A1628 0%, #0B2A3A 50%, #0D4F4F 100%);
    color: #C8E6E6;
    border: 1px solid rgba(0, 255, 212, 0.12);
    border-radius: 14px;
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.4s, border-color 0.4s, transform 0.4s;
  }

  .card:hover {
    box-shadow: 0 4px 30px rgba(0, 255, 212, 0.12), inset 0 0 40px rgba(0, 255, 212, 0.03);
    border-color: rgba(0, 255, 212, 0.3);
    transform: translateY(-2px);
  }

  .card-bubbles {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle 3px at 20% 75%, rgba(0, 255, 212, 0.2) 50%, transparent 50%),
      radial-gradient(circle 2px at 35% 65%, rgba(127, 255, 212, 0.18) 50%, transparent 50%),
      radial-gradient(circle 4px at 55% 80%, rgba(0, 255, 212, 0.12) 50%, transparent 50%),
      radial-gradient(circle 2px at 75% 70%, rgba(127, 255, 212, 0.22) 50%, transparent 50%),
      radial-gradient(circle 3px at 85% 85%, rgba(0, 255, 212, 0.15) 50%, transparent 50%);
    animation: cardBubbleRise 10s ease-in infinite;
    pointer-events: none;
  }

  .card-light {
    position: absolute;
    top: -30%;
    left: 20%;
    width: 100px;
    height: 130%;
    background: linear-gradient(180deg, rgba(0, 255, 212, 0.05), transparent 60%);
    transform: skewX(-15deg);
    animation: cardLightShift 6s ease-in-out infinite;
    pointer-events: none;
  }

  .card-name {
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 22px;
    margin: 0 0 6px 0;
    color: #FFFFFF;
    line-height: 1.2;
    position: relative;
    z-index: 1;
    text-shadow: 0 0 16px rgba(0, 255, 212, 0.3), 0 0 32px rgba(0, 255, 212, 0.1);
  }

  .card-wave {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
    position: relative;
    z-index: 1;
  }

  .card-wave-line {
    display: block;
    width: 40px;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(90deg, transparent, #00FFD4, #7FFFD4, #00FFD4, transparent);
    background-size: 200% 100%;
    animation: cardWaveFlow 4s ease-in-out infinite;
  }

  .card-tagline {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 400;
    font-style: italic;
    margin: 0;
    color: rgba(127, 255, 212, 0.55);
    line-height: 1.5;
    position: relative;
    z-index: 1;
    max-width: 220px;
  }
</style>
