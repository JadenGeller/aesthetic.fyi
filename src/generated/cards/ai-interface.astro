---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

<div class="card">
  <div class="card-messages">
    <div class="card-bubble card-bubble-user"></div>
    <div class="card-bubble card-bubble-ai"></div>
    <div class="card-bubble card-bubble-user card-bubble-short"></div>
  </div>
  <div class="card-typing">
    <span class="card-typing-dot"></span>
    <span class="card-typing-dot"></span>
    <span class="card-typing-dot"></span>
  </div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  .card {
    background: #F7F7F8;
    color: #1A1A1A;
    border: 1px solid #E5E5E5;
    border-radius: 16px;
    min-height: 220px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .card:hover {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    border-color: #D0D0D0;
  }

  .card-messages {
    position: absolute;
    top: 20px;
    left: 16px;
    right: 16px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    pointer-events: none;
  }

  .card-bubble {
    height: 10px;
    border-radius: 6px;
    opacity: 0.7;
  }

  .card-bubble-user {
    background: #E8F0FE;
    border: 1px solid #DCE8FC;
    width: 55%;
    align-self: flex-end;
    border-radius: 6px 6px 2px 6px;
  }

  .card-bubble-ai {
    background: #FFFFFF;
    border: 1px solid #E5E5E5;
    width: 70%;
    align-self: flex-start;
    border-radius: 6px 6px 6px 2px;
  }

  .card-bubble-short {
    width: 40%;
  }

  .card-typing {
    display: flex;
    align-items: center;
    gap: 3px;
    margin-bottom: 12px;
    padding: 5px 12px;
    background: #FFFFFF;
    border: 1px solid #E5E5E5;
    border-radius: 10px;
    position: relative;
    z-index: 1;
  }

  .card-typing-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #8E8E93;
    animation: cardTypingPulse 1.4s ease-in-out infinite;
  }

  .card-typing-dot:nth-child(2) {
    animation-delay: 0.2s;
  }

  .card-typing-dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes cardTypingPulse {
    0%, 60%, 100% {
      opacity: 0.3;
      transform: scale(0.85);
    }
    30% {
      opacity: 1;
      transform: scale(1);
    }
  }

  .card-name {
    font-weight: 600;
    font-size: 20px;
    margin: 0 0 4px 0;
    color: #1A1A1A;
    line-height: 1.2;
    position: relative;
    z-index: 1;
    letter-spacing: -0.01em;
  }

  .card-tagline {
    font-weight: 400;
    font-size: 12px;
    margin: 0;
    color: #8E8E93;
    line-height: 1.5;
    position: relative;
    z-index: 1;
    max-width: 210px;
  }
</style>
