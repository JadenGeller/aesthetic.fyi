---
const { aesthetic } = Astro.props;
---


<div class="glass-card">
  <h3 class="name">{aesthetic.name}</h3>
  <p class="tagline">{aesthetic.tagline}</p>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Inter:wght@300&display=swap');
  .glass-card {
    position: relative;
    overflow: hidden;
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 20px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    color: #eee;
  }

  .glass-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 20px;
    z-index: -1;
    background:
      radial-gradient(circle at 30% 40%, rgba(100, 60, 220, 0.4), transparent 50%),
      radial-gradient(circle at 80% 60%, rgba(60, 140, 255, 0.3), transparent 50%),
      radial-gradient(circle at 50% 90%, rgba(220, 50, 140, 0.2), transparent 50%);
  }

  .name {
    font-family: "Playfair Display", serif;
    font-weight: 600;
    font-size: 24px;
    letter-spacing: -0.5px;
    margin: 0 0 8px 0;
  }

  .tagline {
    font-family: "Inter", sans-serif;
    font-weight: 300;
    opacity: 0.6;
    margin: 0;
  }
</style>
