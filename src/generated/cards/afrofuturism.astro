---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Nunito:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />

<div class="card">
  <div class="card-starfield"></div>
  <div class="card-chevrons"></div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <div class="card-diamonds">
    <span class="card-diamond"></span>
    <span class="card-line"></span>
    <span class="card-diamond"></span>
  </div>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  .card {
    background: linear-gradient(170deg, #2D1B69 0%, #1A0F3D 40%, #0D0D0D 100%);
    color: #E8E0D0;
    border: 1px solid rgba(212, 175, 55, 0.3);
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.3s, border-color 0.3s;
  }

  .card:hover {
    box-shadow: 0 4px 30px rgba(212, 175, 55, 0.15);
    border-color: rgba(212, 175, 55, 0.6);
  }

  .card-starfield {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle 1.5px at 12% 18%, #D4AF37 100%, transparent 100%),
      radial-gradient(circle 1px at 28% 42%, rgba(255, 255, 255, 0.6) 100%, transparent 100%),
      radial-gradient(circle 1px at 45% 15%, rgba(255, 255, 255, 0.7) 100%, transparent 100%),
      radial-gradient(circle 1.5px at 72% 28%, rgba(212, 175, 55, 0.5) 100%, transparent 100%),
      radial-gradient(circle 1px at 88% 55%, rgba(255, 255, 255, 0.5) 100%, transparent 100%),
      radial-gradient(circle 1px at 55% 72%, rgba(0, 206, 209, 0.4) 100%, transparent 100%),
      radial-gradient(circle 1px at 35% 85%, rgba(212, 175, 55, 0.3) 100%, transparent 100%),
      radial-gradient(circle 1px at 82% 80%, rgba(255, 255, 255, 0.4) 100%, transparent 100%),
      radial-gradient(circle 1px at 18% 60%, rgba(0, 206, 209, 0.3) 100%, transparent 100%),
      radial-gradient(circle 1px at 65% 10%, rgba(255, 255, 255, 0.5) 100%, transparent 100%);
    opacity: 0.6;
    pointer-events: none;
  }

  .card-chevrons {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 24px;
    background:
      linear-gradient(135deg, #D4AF37 25%, transparent 25%) -12px 0,
      linear-gradient(225deg, #D4AF37 25%, transparent 25%) -12px 0,
      linear-gradient(315deg, #D4AF37 25%, transparent 25%),
      linear-gradient(45deg, #D4AF37 25%, transparent 25%);
    background-size: 24px 24px;
    background-color: transparent;
    opacity: 0.1;
    pointer-events: none;
  }

  .card-name {
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    font-size: 20px;
    margin: 0 0 6px 0;
    color: #D4AF37;
    line-height: 1.2;
    position: relative;
    z-index: 1;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 0 20px rgba(212, 175, 55, 0.3);
  }

  .card-diamonds {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-bottom: 8px;
    position: relative;
    z-index: 1;
  }

  .card-diamond {
    width: 5px;
    height: 5px;
    background: #D4AF37;
    transform: rotate(45deg);
  }

  .card-line {
    width: 24px;
    height: 1px;
    background: linear-gradient(90deg, rgba(212, 175, 55, 0.3), #D4AF37, rgba(212, 175, 55, 0.3));
  }

  .card-tagline {
    font-family: 'Nunito', sans-serif;
    font-size: 13px;
    font-weight: 400;
    font-style: italic;
    margin: 0;
    color: rgba(232, 224, 208, 0.6);
    line-height: 1.5;
    position: relative;
    z-index: 1;
    max-width: 220px;
  }
</style>
