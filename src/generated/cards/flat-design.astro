---
const { aesthetic } = Astro.props;
---


<div class="card">
  <div class="card-accent-bar" aria-hidden="true"></div>
  <div class="card-shapes" aria-hidden="true">
    <div class="card-circle"></div>
    <div class="card-square"></div>
  </div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap');
  .card {
    background: #3498db;
    color: #ffffff;
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    border-radius: 2px;
  }

  .card-accent-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: #e67e22;
  }

  .card-shapes {
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .card-circle {
    position: absolute;
    top: 24px;
    right: 24px;
    width: 48px;
    height: 48px;
    background: #2ecc71;
    border-radius: 50%;
    opacity: 0.5;
  }

  .card-square {
    position: absolute;
    top: 44px;
    right: 84px;
    width: 24px;
    height: 24px;
    background: #e74c3c;
    border-radius: 0;
    opacity: 0.4;
  }

  .card-name {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 26px;
    letter-spacing: -0.5px;
    margin: 0 0 8px 0;
    line-height: 1.1;
  }

  .card-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 13px;
    margin: 0;
    opacity: 0.75;
    line-height: 1.4;
  }
</style>
