---
const { aesthetic } = Astro.props;
---


<div class="card">
  <div class="card-halftone"></div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <div class="card-stars">
    <span class="card-star">&#9733;</span>
    <span class="card-star">&#9733;</span>
    <span class="card-star">&#9733;</span>
  </div>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bangers&family=Roboto+Condensed:wght@400;700&display=swap');
  .card {
    background: #FFD700;
    color: #000000;
    border: 3px solid #000000;
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    box-shadow: 5px 5px 0 #000000;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 8px 8px 0 #000000;
    background: #E3242B;
  }

  .card:hover .card-name {
    color: #FFFFFF;
  }

  .card:hover .card-tagline {
    color: #FFFFFF;
  }

  .card:hover .card-star {
    color: #FFD700;
  }

  .card-halftone {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(circle, #000000 1px, transparent 1px);
    background-size: 8px 8px;
    opacity: 0.07;
    pointer-events: none;
  }

  .card-name {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 24px;
    margin: 0 0 6px 0;
    color: #000000;
    line-height: 1.2;
    position: relative;
    z-index: 1;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-shadow: 2px 2px 0 rgba(0, 0, 0, 0.1);
  }

  .card-stars {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-bottom: 8px;
    position: relative;
    z-index: 1;
  }

  .card-star {
    font-size: 12px;
    color: #E3242B;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.15);
  }

  .card-tagline {
    font-family: 'Roboto Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    margin: 0;
    color: #333333;
    line-height: 1.5;
    position: relative;
    z-index: 1;
    max-width: 220px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
</style>
