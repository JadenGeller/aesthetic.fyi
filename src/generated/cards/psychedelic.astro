---
const { aesthetic } = Astro.props;
---


<div class="psychedelic-card">
  <div class="spiral-bg"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Bungee+Shade&family=Righteous&display=swap');
  @keyframes hue-cycle {
    0% { filter: hue-rotate(0deg); }
    100% { filter: hue-rotate(360deg); }
  }

  @keyframes spin-slow {
    0% { transform: translate(-50%, -50%) rotate(0deg); }
    100% { transform: translate(-50%, -50%) rotate(360deg); }
  }

  @keyframes float-pulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.3); opacity: 0.8; }
  }

  .psychedelic-card {
    background: conic-gradient(from 0deg at 50% 50%, #FF0000, #FF7F00, #FFFF00, #00FF00, #0000FF, #8B00FF, #FF0000);
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    border-radius: 16px;
    animation: hue-cycle 10s linear infinite;
  }

  .spiral-bg {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: repeating-conic-gradient(
      from 0deg,
      rgba(255, 255, 255, 0.12) 0deg 10deg,
      transparent 10deg 20deg
    );
    animation: spin-slow 15s linear infinite;
    pointer-events: none;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .orb-1 {
    width: 60px;
    height: 60px;
    top: 15px;
    right: 20px;
    background: radial-gradient(circle, rgba(255, 0, 255, 0.7), transparent 70%);
    animation: float-pulse 4s ease-in-out infinite;
  }

  .orb-2 {
    width: 40px;
    height: 40px;
    top: 30px;
    left: 25px;
    background: radial-gradient(circle, rgba(0, 255, 255, 0.6), transparent 70%);
    animation: float-pulse 5s ease-in-out infinite 1s;
  }

  .orb-3 {
    width: 30px;
    height: 30px;
    top: 50%;
    right: 35%;
    background: radial-gradient(circle, rgba(255, 255, 0, 0.5), transparent 70%);
    animation: float-pulse 3s ease-in-out infinite 0.5s;
  }

  .card-name {
    font-family: 'Bungee Shade', cursive;
    font-size: 26px;
    margin: 0 0 6px 0;
    color: #fff;
    text-shadow:
      2px 2px 0 #FF0000,
      -2px -2px 0 #00FF00,
      3px 0 0 #0000FF,
      -3px 0 0 #FFFF00;
    line-height: 1.1;
    position: relative;
    z-index: 2;
  }

  .card-tagline {
    font-family: 'Righteous', cursive;
    font-size: 12px;
    font-weight: 400;
    margin: 0;
    color: rgba(255, 255, 255, 0.85);
    text-shadow: 0 0 10px rgba(0, 0, 0, 0.5);
    line-height: 1.5;
    position: relative;
    z-index: 2;
  }
</style>
