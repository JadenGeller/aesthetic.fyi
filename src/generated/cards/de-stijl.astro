---
const { aesthetic } = Astro.props;
---


<div class="card">
  <div class="card-grid">
    <div class="block-red"></div>
    <div class="block-white-top"></div>
    <div class="block-blue"></div>
    <div class="block-yellow"></div>
    <div class="block-content">
      <h3 class="card-name">{aesthetic.name}</h3>
      <p class="card-tagline">{aesthetic.tagline}</p>
    </div>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap');
  .card {
    background: #fff;
    color: #000;
    border: 5px solid #000;
    border-radius: 0;
    min-height: 220px;
    padding: 0;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .card-grid {
    display: grid;
    grid-template-columns: 60px 1fr 50px;
    grid-template-rows: 50px 1fr 40px;
    flex: 1;
  }

  .block-red {
    background: #DE3831;
    grid-column: 1;
    grid-row: 1;
    border-right: 4px solid #000;
    border-bottom: 4px solid #000;
  }

  .block-white-top {
    background: #fff;
    grid-column: 2 / 4;
    grid-row: 1;
    border-bottom: 4px solid #000;
  }

  .block-blue {
    background: #1E3F8E;
    grid-column: 3;
    grid-row: 2 / 4;
    border-left: 4px solid #000;
  }

  .block-yellow {
    background: #F2CB05;
    grid-column: 1;
    grid-row: 2 / 4;
    border-right: 4px solid #000;
  }

  .block-content {
    grid-column: 2;
    grid-row: 2 / 4;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .card-name {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 24px;
    letter-spacing: -0.5px;
    margin: 0 0 8px 0;
    color: #000;
    line-height: 1.1;
  }

  .card-tagline {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 400;
    margin: 0;
    color: #000;
    line-height: 1.5;
  }
</style>
