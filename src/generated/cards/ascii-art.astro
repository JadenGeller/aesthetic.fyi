---
const { aesthetic } = Astro.props;
---


<div class="card">
  <div class="card-scanlines"></div>
  <div class="card-border-top">╔══════════════════════════╗</div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <div class="card-divider">────────────</div>
  <p class="card-tagline">{aesthetic.tagline}</p>
  <span class="card-cursor">█</span>
  <div class="card-border-bottom">╚══════════════════════════╝</div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&display=swap');
  .card {
    background: #1a1a2e;
    color: #33FF33;
    border: 1px solid rgba(51, 255, 51, 0.4);
    border-radius: 0;
    min-height: 220px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .card:hover {
    border-color: #33FF33;
    box-shadow: 0 0 20px rgba(51, 255, 51, 0.15), inset 0 0 20px rgba(51, 255, 51, 0.03);
  }

  .card-scanlines {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.1) 2px,
      rgba(0, 0, 0, 0.1) 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  .card-border-top,
  .card-border-bottom {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.5rem;
    color: #33FF33;
    opacity: 0.2;
    overflow: hidden;
    white-space: nowrap;
    letter-spacing: 0.05em;
    position: relative;
    z-index: 2;
  }

  .card-name {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 600;
    font-size: 20px;
    margin: 8px 0 4px 0;
    color: #33FF33;
    line-height: 1.2;
    position: relative;
    z-index: 2;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-shadow: 0 0 12px rgba(51, 255, 51, 0.4);
  }

  .card-divider {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.6rem;
    color: #33FF33;
    opacity: 0.3;
    margin-bottom: 8px;
    position: relative;
    z-index: 2;
    letter-spacing: 0.05em;
  }

  .card-tagline {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    font-weight: 400;
    margin: 0;
    color: #FFB000;
    line-height: 1.5;
    position: relative;
    z-index: 2;
    max-width: 220px;
    opacity: 0.8;
  }

  .card-cursor {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.8rem;
    color: #33FF33;
    margin-top: 8px;
    position: relative;
    z-index: 2;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>
