---
const { aesthetic } = Astro.props;
---

<div class="brutal-card">
  <div class="index-mark">B</div>
  <h3 class="name">{aesthetic.name}</h3>
  <p class="tagline">{aesthetic.tagline}</p>
</div>

<style>
  .brutal-card {
    position: relative;
    overflow: hidden;
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: #fff;
    color: #000;
    border: 1px solid #000;
    border-top: 4px solid #000;
    border-radius: 0;
  }

  .brutal-card:hover {
    background: #000;
    color: #fff;
  }

  .brutal-card:hover .tagline {
    color: #999;
  }

  .index-mark {
    position: absolute;
    top: -20px;
    right: 10px;
    font-family: "Courier New", Courier, monospace;
    font-size: 120px;
    font-weight: bold;
    line-height: 1;
    opacity: 0.06;
    user-select: none;
    pointer-events: none;
  }

  .name {
    font-family: "Courier New", Courier, monospace;
    font-size: 30px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -2px;
    line-height: 1.1;
    margin: 0 0 10px 0;
  }

  .tagline {
    font-family: "Courier New", Courier, monospace;
    font-size: 12px;
    color: #666;
    margin: 0;
    line-height: 1.4;
  }
</style>
