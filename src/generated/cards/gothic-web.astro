---
const { aesthetic } = Astro.props;
---


<div class="gothic-card">
  <div class="card-border-inner"></div>
  <div class="card-arch"></div>
  <div class="card-glow"></div>
  <div class="card-ornament-top">
    <span class="orn-line"></span>
    <span class="orn-diamond"></span>
    <span class="orn-line"></span>
  </div>
  <h3 class="card-name">{aesthetic.name}</h3>
  <p class="card-tagline">{aesthetic.tagline}</p>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Crimson+Text:wght@400&display=swap');
  .gothic-card {
    background: linear-gradient(160deg, #1A0A1A 0%, #0D0D0D 60%, #120612 100%);
    color: #E8E0D0;
    min-height: 220px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(201, 169, 89, 0.3);
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.6),
      inset 0 0 40px rgba(139, 0, 0, 0.04);
  }

  .card-border-inner {
    position: absolute;
    top: 6px;
    left: 6px;
    right: 6px;
    bottom: 6px;
    border: 1px solid rgba(201, 169, 89, 0.1);
    pointer-events: none;
    z-index: 1;
  }

  .card-arch {
    position: absolute;
    top: -60px;
    left: 50%;
    transform: translateX(-50%);
    width: 160px;
    height: 100px;
    border: 1px solid rgba(201, 169, 89, 0.08);
    border-bottom: none;
    border-radius: 80px 80px 0 0;
    pointer-events: none;
  }

  .card-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120px;
    height: 120px;
    background: radial-gradient(circle, rgba(139, 0, 0, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .card-ornament-top {
    position: absolute;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 2;
  }

  .orn-line {
    display: block;
    width: 28px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(201, 169, 89, 0.4), transparent);
  }

  .orn-diamond {
    display: block;
    width: 6px;
    height: 6px;
    background: #8B0000;
    transform: rotate(45deg);
    box-shadow: 0 0 6px rgba(139, 0, 0, 0.5);
    flex-shrink: 0;
  }

  .card-name {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    font-size: 24px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin: 0 0 8px 0;
    color: #C9A959;
    text-shadow: 0 0 12px rgba(139, 0, 0, 0.4);
    line-height: 1.15;
    position: relative;
    z-index: 2;
  }

  .card-tagline {
    font-family: 'Crimson Text', serif;
    font-size: 12px;
    font-style: italic;
    font-weight: 400;
    margin: 0;
    color: rgba(232, 224, 208, 0.5);
    line-height: 1.5;
    position: relative;
    z-index: 2;
  }
</style>
