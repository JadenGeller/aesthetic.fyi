---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Source+Serif+4:ital,wght@0,400;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-tile-pattern"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-bar"></span>
        <span class="hero-diamond"></span>
        <span class="hero-bar"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Earth & Fire</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Good Clay, Wrong Clay</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Source Serif 4', serif;
    background-color: #FFF5EB;
    color: #A0522D;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 2px solid #E8D5B7;
    background: #FFF5EB;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'DM Serif Display', serif;
    font-weight: 400;
    font-size: 1rem;
    color: #CC5500;
    text-decoration: none;
    padding: 6px 18px;
    border: 2px solid #E8D5B7;
    border-radius: 4px;
    transition: background 0.3s, border-color 0.3s;
  }

  .nav-logo:hover {
    background: rgba(204, 85, 0, 0.06);
    border-color: #CC5500;
  }

  .nav-divider {
    font-size: 1.2rem;
    color: #E8D5B7;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'DM Serif Display', serif;
    font-weight: 400;
    font-size: 0.95rem;
    color: #6B7B3C;
    text-decoration: none;
    padding: 6px 18px;
    border: 2px solid transparent;
    border-radius: 4px;
    transition: border-color 0.3s;
  }

  .nav-current:hover {
    border-color: #E8D5B7;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #FFF5EB;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 2px solid #E8D5B7;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px solid #CC5500;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0.25;
  }

  .hero-tile-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 40px,
        rgba(204, 85, 0, 0.03) 40px,
        rgba(204, 85, 0, 0.03) 42px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 40px,
        rgba(204, 85, 0, 0.03) 40px,
        rgba(204, 85, 0, 0.03) 42px
      );
    pointer-events: none;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Source Serif 4', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: #6B7B3C;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'DM Serif Display', serif;
    font-weight: 400;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.05;
    margin: 0 0 28px 0;
    color: #CC5500;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .hero-bar {
    width: 40px;
    height: 2px;
    background: #E8D5B7;
  }

  .hero-diamond {
    width: 8px;
    height: 8px;
    background: #CC5500;
    transform: rotate(45deg);
  }

  .hero-tagline {
    font-family: 'Source Serif 4', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 520px;
    color: #A0522D;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 2px solid #E8D5B7;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 2px;
    background: #E8D5B7;
  }

  .section-label {
    font-family: 'Source Serif 4', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.8rem;
    color: #6B7B3C;
    white-space: nowrap;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'DM Serif Display', serif;
    font-weight: 400;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #CC5500;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #F5E6D0;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px solid rgba(204, 85, 0, 0.15);
    border-radius: 4px;
    pointer-events: none;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Source Serif 4', serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #A0522D;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #FFF5EB;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 2px solid #E8D5B7;
    border-radius: 4px;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: #FFF5EB;
    transition: box-shadow 0.3s, border-color 0.3s;
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    height: 3px;
    background: #CC5500;
    border-radius: 4px 4px 0 0;
    pointer-events: none;
  }

  .char-card:hover {
    box-shadow: 0 4px 20px rgba(160, 82, 45, 0.1);
    border-color: #CC5500;
  }

  .char-number {
    font-family: 'Source Serif 4', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.75rem;
    color: #6B7B3C;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.1em;
  }

  .char-divider {
    width: 24px;
    height: 2px;
    background: #CC5500;
    margin: 0 auto 14px;
  }

  .char-title {
    font-family: 'DM Serif Display', serif;
    font-weight: 400;
    font-size: 1.25rem;
    margin: 0 0 12px 0;
    color: #CC5500;
  }

  .char-description {
    font-family: 'Source Serif 4', serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    margin: 0;
    color: #A0522D;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #F5E6D0;
  }

  .prompt-block {
    border: 2px solid #E8D5B7;
    border-radius: 4px;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-block::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    height: 3px;
    background: #CC5500;
    pointer-events: none;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 2px solid #E8D5B7;
    background: rgba(204, 85, 0, 0.05);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Source Serif 4', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.8rem;
    color: #6B7B3C;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'DM Serif Display', serif;
    font-weight: 400;
    font-size: 0.85rem;
    background: transparent;
    color: #CC5500;
    border: 2px solid #E8D5B7;
    border-radius: 4px;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.3s, border-color 0.3s;
  }

  .copy-button:hover {
    background: rgba(204, 85, 0, 0.06);
    border-color: #CC5500;
  }

  .copy-button.copied {
    background: rgba(204, 85, 0, 0.1);
    border-color: #CC5500;
  }

  .prompt-text {
    font-family: 'Source Serif 4', serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.85;
    color: #A0522D;
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #FFF5EB;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 2px solid #E8D5B7;
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }

  .use-column::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    height: 3px;
    pointer-events: none;
    z-index: 1;
  }

  .use-good::before {
    background: #CC5500;
  }

  .use-bad::before {
    background: #6B7B3C;
  }

  .use-column-heading {
    font-family: 'DM Serif Display', serif;
    font-weight: 400;
    font-size: 1.05rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 2px solid #E8D5B7;
  }

  .use-good .use-column-heading {
    background: rgba(204, 85, 0, 0.06);
    color: #CC5500;
  }

  .use-bad .use-column-heading {
    background: rgba(107, 123, 60, 0.06);
    color: #6B7B3C;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Source Serif 4', serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(232, 213, 183, 0.6);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #A0522D;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 0;
    background: #CC5500;
    flex-shrink: 0;
    margin-top: 7px;
    transform: rotate(45deg);
  }

  .use-item-bad::before {
    content: '\2013';
    color: #6B7B3C;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #F5E6D0;
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px solid rgba(204, 85, 0, 0.15);
    border-radius: 4px;
    pointer-events: none;
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Source Serif 4', serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #A0522D;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #FFF5EB;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 28px 20px;
    border: 2px solid #E8D5B7;
    border-radius: 4px;
    text-decoration: none;
    color: #A0522D;
    text-align: center;
    position: relative;
    transition: box-shadow 0.3s, border-color 0.3s;
  }

  .related-card::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    height: 3px;
    background: #CC5500;
    border-radius: 4px 4px 0 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .related-card:hover {
    box-shadow: 0 4px 16px rgba(160, 82, 45, 0.1);
    border-color: #CC5500;
  }

  .related-card:hover::before {
    opacity: 1;
  }

  .related-relationship {
    font-family: 'Source Serif 4', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.7rem;
    color: #6B7B3C;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .related-name {
    font-family: 'DM Serif Display', serif;
    font-weight: 400;
    font-size: 1.15rem;
    color: #CC5500;
  }

  .related-arrow {
    font-size: 1rem;
    color: #E8D5B7;
    transition: color 0.3s;
  }

  .related-card:hover .related-arrow {
    color: #CC5500;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #F5E6D0;
    padding: 64px 32px;
    border-top: 2px solid #E8D5B7;
  }

  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-ornament {
    width: 80px;
    height: 2px;
    background: linear-gradient(90deg, transparent, #CC5500, transparent);
  }

  .footer-logo {
    font-family: 'DM Serif Display', serif;
    font-weight: 400;
    font-size: 1rem;
    color: #CC5500;
    text-decoration: none;
    padding: 8px 24px;
    border: 2px solid #E8D5B7;
    border-radius: 4px;
    transition: background 0.3s, border-color 0.3s;
  }

  .footer-logo:hover {
    background: rgba(204, 85, 0, 0.06);
    border-color: #CC5500;
  }

  .footer-tagline {
    font-family: 'Source Serif 4', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: #6B7B3C;
  }

  .footer-back {
    font-family: 'DM Serif Display', serif;
    font-weight: 400;
    font-size: 0.9rem;
    color: #CC5500;
    text-decoration: none;
    padding: 6px 20px;
    border: 2px solid transparent;
    border-radius: 4px;
    transition: border-color 0.3s;
  }

  .footer-back:hover {
    border-color: #E8D5B7;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
