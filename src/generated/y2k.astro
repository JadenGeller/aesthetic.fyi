---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Inter:wght@400;500&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">//</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>
    <div class="hero-orb hero-orb-3"></div>
    <div class="hero-inner">
      <span class="hero-label">Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <span class="section-label">What This Is</span>
      <h2 class="section-heading">Philosophy</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <span class="section-label">Design Tokens</span>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class={`char-card char-card-${i % 3}`}>
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <span class="section-label">Copy & Paste</span>
      <h2 class="section-heading">Style Reference</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">PROMPT</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <span class="section-label">When to Use</span>
      <h2 class="section-heading">Use Cases</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good for</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not for</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <span class="section-label">Origins</span>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <span class="section-label">Explore</span>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to all aesthetics</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Inter', sans-serif;
    background: linear-gradient(180deg, #0a0a1a 0%, #0d0d2b 100%);
    color: #e0e0e0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     IRIDESCENT ANIMATION
     ======================================== */
  @keyframes iridescent {
    0% { filter: hue-rotate(0deg); }
    50% { filter: hue-rotate(45deg); }
    100% { filter: hue-rotate(0deg); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }

  @keyframes chrome-shift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background: linear-gradient(135deg, rgba(192, 192, 192, 0.15), rgba(0, 191, 255, 0.1));
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(192, 192, 192, 0.3);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-logo {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 0.9rem;
    color: #00BFFF;
    text-decoration: none;
    padding: 8px 18px;
    background: linear-gradient(135deg, rgba(0, 191, 255, 0.15), rgba(255, 105, 180, 0.1));
    border: 1px solid rgba(0, 191, 255, 0.4);
    border-radius: 50px;
    transition: all 0.3s ease;
    letter-spacing: 0.05em;
  }

  .nav-logo:hover {
    background: linear-gradient(135deg, rgba(0, 191, 255, 0.3), rgba(255, 105, 180, 0.2));
    box-shadow: 0 0 20px rgba(0, 191, 255, 0.3);
  }

  .nav-divider {
    font-family: 'Orbitron', sans-serif;
    font-size: 0.9rem;
    color: rgba(192, 192, 192, 0.4);
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Orbitron', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: #C0C0C0;
    text-decoration: none;
    padding: 8px 18px;
    border: 1px solid rgba(192, 192, 192, 0.25);
    border-radius: 50px;
    transition: all 0.3s ease;
    letter-spacing: 0.05em;
  }

  .nav-current:hover {
    border-color: rgba(0, 191, 255, 0.5);
    color: #00BFFF;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 100px 24px 90px;
    background: linear-gradient(135deg, #0a0a2e 0%, #1a0a3e 30%, #0a1a3e 60%, #0a0a2e 100%);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 50%, rgba(0, 191, 255, 0.15) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 30%, rgba(255, 105, 180, 0.12) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 80%, rgba(0, 255, 127, 0.08) 0%, transparent 50%);
    animation: iridescent 8s ease-in-out infinite;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(1px);
  }

  .hero-orb-1 {
    width: 200px;
    height: 200px;
    top: 10%;
    right: 10%;
    background: radial-gradient(circle at 35% 35%,
      rgba(255, 255, 255, 0.4),
      rgba(0, 191, 255, 0.3) 40%,
      rgba(255, 105, 180, 0.2) 70%,
      transparent 100%);
    animation: float 6s ease-in-out infinite;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .hero-orb-2 {
    width: 120px;
    height: 120px;
    bottom: 15%;
    left: 8%;
    background: radial-gradient(circle at 35% 35%,
      rgba(255, 255, 255, 0.35),
      rgba(255, 105, 180, 0.3) 40%,
      rgba(0, 191, 255, 0.15) 70%,
      transparent 100%);
    animation: float 8s ease-in-out infinite 1s;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .hero-orb-3 {
    width: 80px;
    height: 80px;
    top: 30%;
    left: 35%;
    background: radial-gradient(circle at 35% 35%,
      rgba(255, 255, 255, 0.3),
      rgba(192, 192, 192, 0.3) 40%,
      rgba(0, 191, 255, 0.1) 70%,
      transparent 100%);
    animation: float 7s ease-in-out infinite 2s;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #00BFFF;
    padding: 8px 20px;
    display: inline-block;
    margin-bottom: 28px;
    border: 1px solid rgba(0, 191, 255, 0.4);
    border-radius: 50px;
    background: rgba(0, 191, 255, 0.08);
  }

  .hero-title {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: clamp(4rem, 12vw, 10rem);
    line-height: 0.95;
    margin: 0 0 28px 0;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #C0C0C0 0%, #FFFFFF 25%, #C0C0C0 50%, #FFFFFF 75%, #C0C0C0 100%);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: chrome-shift 4s ease infinite;
  }

  .hero-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    line-height: 1.6;
    margin: 0;
    max-width: 600px;
    color: rgba(192, 192, 192, 0.8);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 80px 24px;
    border-bottom: 1px solid rgba(192, 192, 192, 0.15);
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Orbitron', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #00BFFF;
    display: block;
    margin-bottom: 12px;
  }

  .section-heading {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.1;
    margin: 0 0 48px 0;
    letter-spacing: -0.01em;
    background: linear-gradient(135deg, #FFFFFF, #C0C0C0);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: linear-gradient(180deg, #0a0a1a 0%, #0d0d2b 100%);
  }

  .about-content {
    max-width: 740px;
  }

  .about-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.75;
    margin: 0 0 24px 0;
    color: rgba(224, 224, 224, 0.85);
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: linear-gradient(180deg, #0d0d2b 0%, #0a0a1a 100%);
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 24px;
  }

  .char-card {
    padding: 32px 28px 28px;
    position: relative;
    border-radius: 20px;
    border: 1px solid rgba(192, 192, 192, 0.2);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    overflow: hidden;
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    border-radius: 20px 20px 0 0;
  }

  .char-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 191, 255, 0.15);
  }

  .char-card-0 {
    background: linear-gradient(135deg, rgba(0, 191, 255, 0.12), rgba(0, 191, 255, 0.04));
  }
  .char-card-0::before {
    background: linear-gradient(90deg, #00BFFF, #FF69B4);
  }

  .char-card-1 {
    background: linear-gradient(135deg, rgba(255, 105, 180, 0.12), rgba(255, 105, 180, 0.04));
  }
  .char-card-1::before {
    background: linear-gradient(90deg, #FF69B4, #00BFFF);
  }

  .char-card-2 {
    background: linear-gradient(135deg, rgba(192, 192, 192, 0.12), rgba(192, 192, 192, 0.04));
  }
  .char-card-2::before {
    background: linear-gradient(90deg, #C0C0C0, #00BFFF);
  }

  .char-number {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: #00BFFF;
    padding: 5px 12px;
    position: absolute;
    top: 14px;
    right: 14px;
    border: 1px solid rgba(0, 191, 255, 0.3);
    border-radius: 50px;
    background: rgba(0, 191, 255, 0.08);
  }

  .char-title {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin: 0 0 14px 0;
    color: #FFFFFF;
  }

  .char-description {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
    color: rgba(224, 224, 224, 0.75);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: linear-gradient(180deg, #0a0a1a 0%, #0d0d2b 100%);
  }

  .prompt-block {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(192, 192, 192, 0.2);
    background: rgba(10, 10, 30, 0.8);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    border-bottom: 1px solid rgba(192, 192, 192, 0.15);
    background: linear-gradient(135deg, rgba(0, 191, 255, 0.1), rgba(255, 105, 180, 0.05));
  }

  .prompt-header-label {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #00BFFF;
  }

  .copy-button {
    font-family: 'Orbitron', sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    background: linear-gradient(135deg, rgba(0, 191, 255, 0.15), rgba(255, 105, 180, 0.1));
    color: #C0C0C0;
    border: 1px solid rgba(0, 191, 255, 0.35);
    padding: 8px 22px;
    cursor: pointer;
    border-radius: 50px;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .copy-button:hover {
    background: linear-gradient(135deg, rgba(0, 191, 255, 0.3), rgba(255, 105, 180, 0.2));
    box-shadow: 0 0 20px rgba(0, 191, 255, 0.2);
    color: #FFFFFF;
  }

  .copy-button.copied {
    background: linear-gradient(135deg, rgba(0, 255, 127, 0.2), rgba(0, 191, 255, 0.15));
    border-color: rgba(0, 255, 127, 0.5);
    color: #00FF7F;
  }

  .prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(192, 192, 192, 0.8);
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: linear-gradient(180deg, #0d0d2b 0%, #0a0a1a 100%);
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .use-column {
    border-radius: 20px;
    border: 1px solid rgba(192, 192, 192, 0.15);
    overflow: hidden;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .use-column-heading {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    margin: 0;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(192, 192, 192, 0.15);
    letter-spacing: 0.02em;
  }

  .use-good .use-column-heading {
    background: linear-gradient(135deg, rgba(0, 191, 255, 0.15), rgba(0, 191, 255, 0.05));
    color: #00BFFF;
  }

  .use-bad .use-column-heading {
    background: linear-gradient(135deg, rgba(255, 105, 180, 0.15), rgba(255, 105, 180, 0.05));
    color: #FF69B4;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
    background: rgba(10, 10, 30, 0.6);
  }

  .use-item {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    padding: 16px 24px;
    border-bottom: 1px solid rgba(192, 192, 192, 0.08);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: rgba(224, 224, 224, 0.8);
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '+';
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #00BFFF;
    flex-shrink: 0;
  }

  .use-item-bad::before {
    content: '\2013';
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #FF69B4;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: linear-gradient(180deg, #0a0a1a 0%, #0d0d2b 100%);
  }

  .history-content {
    max-width: 740px;
  }

  .history-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.8;
    margin: 0 0 24px 0;
    color: rgba(224, 224, 224, 0.85);
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: linear-gradient(135deg, #0d0d2b 0%, #1a0a3e 50%, #0a1a3e 100%);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px;
    border: 1px solid rgba(192, 192, 192, 0.2);
    background: linear-gradient(135deg, rgba(0, 191, 255, 0.06), rgba(255, 105, 180, 0.04));
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 20px;
    text-decoration: none;
    color: #e0e0e0;
    transition: all 0.3s ease;
    position: relative;
  }

  .related-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 191, 255, 0.15);
    border-color: rgba(0, 191, 255, 0.4);
  }

  .related-relationship {
    font-family: 'Orbitron', sans-serif;
    font-weight: 400;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #00BFFF;
    padding: 5px 12px;
    display: inline-block;
    align-self: flex-start;
    border: 1px solid rgba(0, 191, 255, 0.3);
    border-radius: 50px;
    background: rgba(0, 191, 255, 0.08);
  }

  .related-name {
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    color: #FFFFFF;
  }

  .related-arrow {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.2rem;
    position: absolute;
    bottom: 20px;
    right: 20px;
    color: rgba(192, 192, 192, 0.4);
    transition: color 0.3s ease;
  }

  .related-card:hover .related-arrow {
    color: #00BFFF;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: linear-gradient(180deg, #0d0d2b 0%, #050510 100%);
    padding: 60px 24px;
