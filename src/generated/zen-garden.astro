---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-sand"></div>
    <div class="hero-inner">
      <div class="hero-stone"></div>
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-stone-dot"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Emptiness as Intention</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <div class="char-stone"></div>
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Place, Wrong Place</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'EB Garamond', serif;
    background-color: #F5F0E0;
    color: #3A3A35;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid #E0D8C4;
    background: #F5F0E0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 18px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 1rem;
    color: #7A7A6D;
    text-decoration: none;
    letter-spacing: 0.06em;
    padding: 6px 18px;
    border: 1px solid #DDD6C2;
    border-radius: 0;
    transition: border-color 0.5s, color 0.5s;
  }

  .nav-logo:hover {
    border-color: #7A7A6D;
    color: #3A3A35;
  }

  .nav-divider {
    font-size: 0.9rem;
    color: #D0C8B0;
    margin: 0 2px;
    font-weight: 300;
  }

  .nav-current {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 0.95rem;
    color: #7A7A6D;
    text-decoration: none;
    letter-spacing: 0.06em;
    padding: 6px 18px;
    border: 1px solid transparent;
    transition: border-color 0.5s;
  }

  .nav-current:hover {
    border-color: #DDD6C2;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #F5F0E0;
    padding: 120px 32px 100px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid #E0D8C4;
  }

  .hero-sand {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 11px,
        #E8E0CC 11px,
        #E8E0CC 12px
      );
    opacity: 0.5;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 680px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-stone {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #918E80, #7A7A6D 50%, #6A6A5E);
    margin: 0 auto 48px;
    box-shadow: 0 4px 16px rgba(58, 58, 53, 0.1);
  }

  .hero-label {
    font-family: 'EB Garamond', serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: #7A7A6D;
    display: inline-block;
    margin-bottom: 28px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.05;
    margin: 0 0 32px 0;
    color: #3A3A35;
    letter-spacing: 0.02em;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 32px;
  }

  .hero-stone-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #7A7A6D;
    opacity: 0.4;
  }

  .hero-tagline {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.9;
    margin: 0 auto;
    max-width: 500px;
    color: #7A7A6D;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 110px 32px;
    border-bottom: 1px solid #E0D8C4;
    position: relative;
  }

  .section-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 14px;
  }

  .section-rule {
    flex: 1;
    max-width: 60px;
    height: 1px;
    background: #D0C8B0;
  }

  .section-label {
    font-family: 'EB Garamond', serif;
    font-weight: 400;
    font-size: 0.75rem;
    color: #7A7A6D;
    white-space: nowrap;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 56px 0;
    text-align: center;
    color: #3A3A35;
    letter-spacing: 0.02em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #F2ECD8;
    position: relative;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 14px,
        #E8E0CC 14px,
        #E8E0CC 15px
      );
    opacity: 0.3;
    pointer-events: none;
  }

  .about-content {
    max-width: 580px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .about-paragraph {
    font-family: 'EB Garamond', serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 2;
    margin: 0 0 32px 0;
    color: #3A3A35;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #F5F0E0;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 32px;
  }

  .char-card {
    border: 1px solid #E0D8C4;
    padding: 40px 28px 32px;
    position: relative;
    text-align: center;
    background: #F5F0E0;
    transition: border-color 0.5s;
  }

  .char-card:hover {
    border-color: #7A7A6D;
  }

  .char-stone {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #8A8A7D, #7A7A6D 60%, #6A6A5E);
    margin: 0 auto 20px;
    opacity: 0.35;
  }

  .char-number {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 0.75rem;
    color: #7A7A6D;
    display: block;
    margin-bottom: 14px;
    letter-spacing: 0.2em;
  }

  .char-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.3rem;
    margin: 0 0 14px 0;
    color: #3A3A35;
    letter-spacing: 0.03em;
  }

  .char-description {
    font-family: 'EB Garamond', serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.85;
    margin: 0;
    color: #7A7A6D;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #F2ECD8;
    position: relative;
  }

  .prompt-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 14px,
        #E8E0CC 14px,
        #E8E0CC 15px
      );
    opacity: 0.3;
    pointer-events: none;
  }

  .prompt-block {
    border: 1px solid #E0D8C4;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    z-index: 1;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid #E0D8C4;
    background: rgba(208, 200, 176, 0.12);
  }

  .prompt-header-label {
    font-family: 'EB Garamond', serif;
    font-weight: 400;
    font-size: 0.75rem;
    color: #7A7A6D;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 0.85rem;
    background: transparent;
    color: #7A7A6D;
    border: 1px solid #DDD6C2;
    padding: 6px 20px;
    cursor: pointer;
    letter-spacing: 0.06em;
    transition: border-color 0.5s, color 0.5s;
  }

  .copy-button:hover {
    border-color: #7A7A6D;
    color: #3A3A35;
  }

  .copy-button.copied {
    border-color: #6B7B5E;
    color: #6B7B5E;
  }

  .prompt-text {
    font-family: 'EB Garamond', serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.95;
    color: #3A3A35;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #F5F0E0;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    max-width: 760px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid #E0D8C4;
    overflow: hidden;
    position: relative;
  }

  .use-column-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.05rem;
    margin: 0;
    padding: 18px 24px;
    text-align: center;
    border-bottom: 1px solid #E0D8C4;
    letter-spacing: 0.04em;
  }

  .use-good .use-column-heading {
    background: rgba(107, 123, 94, 0.06);
    color: #6B7B5E;
  }

  .use-bad .use-column-heading {
    background: rgba(122, 122, 109, 0.06);
    color: #7A7A6D;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'EB Garamond', serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(224, 216, 196, 0.5);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: #3A3A35;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #6B7B5E;
    flex-shrink: 0;
    margin-top: 7px;
    opacity: 0.6;
  }

  .use-item-bad::before {
    content: '\2013';
    color: #D0C8B0;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #F2ECD8;
    position: relative;
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 14px,
        #E8E0CC 14px,
        #E8E0CC 15px
      );
    opacity: 0.3;
    pointer-events: none;
  }

  .history-content {
    max-width: 580px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .history-paragraph {
    font-family: 'EB Garamond', serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 2;
    margin: 0 0 32px 0;
    color: #3A3A35;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #F5F0E0;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 24px;
    max-width: 760px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 36px 20px;
    border: 1px solid #E0D8C4;
    text-decoration: none;
    color: #3A3A35;
    text-align: center;
    position: relative;
    transition: border-color 0.5s;
  }

  .related-card:hover {
    border-color: #7A7A6D;
  }

  .related-relationship {
    font-family: 'EB Garamond', serif;
    font-weight: 400;
    font-size: 0.7rem;
    color: #7A7A6D;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .related-name {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.15rem;
    color: #3A3A35;
    letter-spacing: 0.03em;
  }

  .related-arrow {
    font-size: 1rem;
    color: #D0C8B0;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #F2ECD8;
    padding: 80px 32px;
    border-top: 1px solid #E0D8C4;
    position: relative;
  }

  .footer::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 14px,
        #E8E0CC 14px,
        #E8E0CC 15px
      );
    opacity: 0.2;
    pointer-events: none;
  }

  .footer-inner {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .footer-ornament {
    width: 60px;
    height: 1px;
    background: #D0C8B0;
  }

  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 1rem;
    color: #7A7A6D;
    text-decoration: none;
    padding: 8px 24px;
    border: 1px solid #DDD6C2;
    letter-spacing: 0.06em;
    transition: border-color 0.5s, color 0.5s;
  }

  .footer-logo:hover {
    border-color: #7A7A6D;
    color: #3A3A35;
  }

  .footer-tagline {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: #7A7A6D;
  }

  .footer-back {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 0.9rem;
    color: #7A7A6D;
    text-decoration: none;
    padding: 6px 20px;
    border: 1px solid transparent;
    letter-spacing: 0.04em;
    transition: border-color 0.5s;
  }

  .footer-back:hover {
    border-color: #DDD6C2;
  }

  /* ========================================
     RESPONSIVE - 768px
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 80px 24px 68px;
    }

    .section {
      padding: 80px 24px;
    }

    .section-heading {
      margin-bottom: 40px;
    }

    .characteristics-grid {
      grid-template-columns: 1fr;
    }

