---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;600;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- SCROLL CONTAINER -->
  <div class="scroll-container">

    <!-- HERO -->
    <section class="screen screen-dark">
      <div class="screen-content">
        <span class="hero-label">Web Aesthetic</span>
        <h1 class="hero-title">{aesthetic.name}</h1>
        <p class="hero-tagline">{aesthetic.tagline}</p>
      </div>
    </section>

    <!-- WHAT THIS IS -->
    <section class="screen screen-light">
      <div class="screen-content">
        <span class="section-label">What This Is</span>
        <div class="about-content">
          {aesthetic.about.split('\n\n').map((paragraph: string) => (
            <p class="about-paragraph">{paragraph}</p>
          ))}
        </div>
      </div>
    </section>

    <!-- CHARACTERISTICS — each one gets its own screen -->
    <section class="screen screen-dark">
      <div class="screen-content">
        <span class="section-label section-label-light">Characteristics</span>
        <p class="screen-statement">Six defining traits.</p>
      </div>
    </section>

    {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
      <section class={`screen ${i % 2 === 0 ? 'screen-light' : 'screen-dark'}`}>
        <div class="screen-content char-screen-content">
          <span class={`char-number ${i % 2 === 0 ? '' : 'char-number-light'}`}>{String(i + 1).padStart(2, '0')}</span>
          <h3 class={`char-title ${i % 2 === 0 ? '' : 'char-title-light'}`}>{char.title}</h3>
          <p class={`char-description ${i % 2 === 0 ? '' : 'char-description-light'}`}>{char.description}</p>
        </div>
      </section>
    ))}

    <!-- STYLE REFERENCE -->
    <section class="screen screen-dark">
      <div class="screen-content prompt-screen-content">
        <span class="section-label section-label-light">Style Reference</span>
        <div class="prompt-block">
          <div class="prompt-header">
            <span class="prompt-header-label">Prompt</span>
            <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
          </div>
          <p class="prompt-text">{aesthetic.prompt}</p>
        </div>
      </div>
    </section>

    <!-- WHEN TO USE -->
    <section class="screen screen-light">
      <div class="screen-content use-screen-content">
        <span class="section-label">When to Use</span>
        <div class="use-grid">
          <div class="use-column">
            <h3 class="use-column-heading">Good for</h3>
            <ul class="use-list">
              {aesthetic.good_for.map((item: string) => (
                <li class="use-item">{item}</li>
              ))}
            </ul>
          </div>
          <div class="use-column">
            <h3 class="use-column-heading">Not for</h3>
            <ul class="use-list">
              {aesthetic.not_for.map((item: string) => (
                <li class="use-item">{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- HISTORY -->
    <section class="screen screen-dark">
      <div class="screen-content">
        <span class="section-label section-label-light">History</span>
        <div class="history-content">
          {aesthetic.history.split('\n\n').map((paragraph: string) => (
            <p class="history-paragraph">{paragraph}</p>
          ))}
        </div>
      </div>
    </section>

    <!-- RELATED STYLES -->
    <section class="screen screen-light">
      <div class="screen-content related-screen-content">
        <span class="section-label">Related Styles</span>
        <div class="related-grid">
          {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
            <a href={`/${rel.slug}`} class="related-card">
              <span class="related-relationship">{rel.relationship}</span>
              <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <section class="screen screen-dark footer-screen">
      <div class="screen-content footer-content">
        <a href="/" class="footer-logo">aesthetic.fyi</a>
        <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
        <a href="/" class="footer-back">All aesthetics</a>
      </div>
    </section>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    margin: 0;
    padding: 0;
    background: #000000;
    color: #ffffff;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 18px 32px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-logo {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    transition: color 0.3s;
  }

  .nav-logo:hover {
    color: #0071E3;
  }

  .nav-divider {
    font-weight: 300;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.3);
  }

  .nav-current {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.3s;
  }

  .nav-current:hover {
    color: #ffffff;
  }

  /* ========================================
     SCROLL CONTAINER & SCREENS
     ======================================== */
  .scroll-container {
    height: 100vh;
    overflow-y: scroll;
    scroll-snap-type: y mandatory;
  }

  .screen {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    scroll-snap-align: start;
    padding: 120px 48px;
    box-sizing: border-box;
  }

  .screen-dark {
    background: #000000;
    color: #ffffff;
  }

  .screen-light {
    background: #ffffff;
    color: #000000;
  }

  .screen-content {
    max-width: 800px;
    width: 100%;
    text-align: center;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero-label {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: #0071E3;
    display: block;
    margin-bottom: 32px;
  }

  .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1;
    margin: 0 0 28px 0;
    letter-spacing: -0.03em;
    color: #ffffff;
  }

  .hero-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    line-height: 1.5;
    margin: 0;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.01em;
  }

  /* ========================================
     SECTION LABELS
     ======================================== */
  .section-label {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: rgba(0, 0, 0, 0.35);
    display: block;
    margin-bottom: 40px;
  }

  .section-label-light {
    color: rgba(255, 255, 255, 0.35);
  }

  /* ========================================
     SCREEN STATEMENT (intro to characteristics)
     ======================================== */
  .screen-statement {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1.15;
    margin: 0;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: left;
  }

  .about-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    line-height: 1.85;
    margin: 0 0 28px 0;
    color: #000000;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS (individual screens)
     ======================================== */
  .char-screen-content {
    max-width: 640px;
  }

  .char-number {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: rgba(0, 0, 0, 0.2);
    display: block;
    margin-bottom: 24px;
  }

  .char-number-light {
    color: rgba(255, 255, 255, 0.2);
  }

  .char-title {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 3rem);
    letter-spacing: -0.02em;
    margin: 0 0 20px 0;
    color: #000000;
    line-height: 1.1;
  }

  .char-title-light {
    color: #ffffff;
  }

  .char-description {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: clamp(0.95rem, 1.6vw, 1.1rem);
    line-height: 1.8;
    margin: 0;
    color: rgba(0, 0, 0, 0.6);
    text-align: center;
  }

  .char-description-light {
    color: rgba(255, 255, 255, 0.6);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-screen-content {
    max-width: 700px;
    text-align: left;
  }

  .prompt-block {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 12px;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .prompt-header-label {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: rgba(255, 255, 255, 0.4);
  }

  .copy-button {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: none;
    color: #0071E3;
    border: 1px solid #0071E3;
    border-radius: 6px;
    padding: 8px 20px;
    cursor: pointer;
    transition: background 0.3s, color 0.3s;
  }

  .copy-button:hover {
    background: #0071E3;
    color: #ffffff;
  }

  .copy-button.copied {
    background: #0071E3;
    color: #ffffff;
  }

  .prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.65);
    padding: 24px;
    margin: 0;
    white-space: normal;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-screen-content {
    max-width: 720px;
    text-align: left;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }

  .use-column-heading {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: rgba(0, 0, 0, 0.35);
    margin: 0 0 20px 0;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.6;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    color: #000000;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-content {
    max-width: 600px;
    margin: 0 auto;
    text-align: left;
  }

  .history-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: clamp(0.95rem, 1.6vw, 1.05rem);
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: rgba(255, 255, 255, 0.75);
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-screen-content {
    max-width: 800px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1px;
    background: rgba(0, 0, 0, 0.08);
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 28px 20px;
    text-decoration: none;
    color: #000000;
    background: #ffffff;
    transition: background 0.3s;
  }

  .related-card:hover {
    background: #f5f5f7;
  }

  .related-relationship {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: rgba(0, 0, 0, 0.35);
  }

  .related-name {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: -0.01em;
    color: #000000;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer-screen {
    min-height: 60vh;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .footer-logo {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
    transition: color 0.3s;
  }

  .footer-logo:hover {
    color: #0071E3;
  }

  .footer-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.4);
    letter-spacing: 0.01em;
  }

  .footer-back {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #0071E3;
    text-decoration: none;
    margin-top: 8px;
    transition: color 0.3s;
  }

  .footer-back:hover {
    color: #ffffff;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .screen {
      padding: 100px 28px;
    }

    .nav-inner {
      padding: 14px 24px;
    }

    .use-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .related-grid {
      grid-template-columns: 1fr 1fr;
    }

    .prompt-header {
      padding: 14px 18px;
    }

    .prompt-text {
      padding: 18px;
      font-size: 0.85rem;
    }
  }

  @media (max-width: 480px) {
    .screen {
      padding: 80px 20px;
    }

    .nav-inner {
      padding: 12px 20px;
      gap: 8px;
    }

    .nav-logo {
      font-size: 0.7rem;
    }

    .nav-current {
      font-size: 0.7rem;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .copy-button {
      padding: 6px 14px;
      font-size: 0.6rem;
    }

    .use-item {
      padding: 10px 0;
      font-size: 0.9rem;
    }

    .about-content,
    .history-content {
      max-width: 100%;
    }

    .prompt-block {
      border-radius: 8px;
    }

    .prompt-header {
      padding: 12px 14px;
    }

    .prompt-text {
      padding: 14px;
      font-size: 0.8rem;
    }
  }
</style>
