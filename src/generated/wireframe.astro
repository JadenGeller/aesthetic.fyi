---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-crosshair hero-crosshair-tl"></div>
    <div class="hero-crosshair hero-crosshair-tr"></div>
    <div class="hero-crosshair hero-crosshair-bl"></div>
    <div class="hero-crosshair hero-crosshair-br"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-dash"></span>
        <span class="hero-x">&times;</span>
        <span class="hero-dash"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
    <div class="hero-annotation">hero-section / 1:1</div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Design Intent</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
    <div class="section-annotation">about / description</div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <div class="char-placeholder">
              <span class="char-x">&times;</span>
            </div>
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Fit &amp; Misfit</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-rule"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-rule"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Inter', sans-serif;
    background-color: #F5F5F5;
    color: #333;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 2px dashed #CCC;
    background: #F5F5F5;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .nav-logo {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.85rem;
    color: #333;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 16px;
    border: 1px dashed #999;
    transition: background 0.2s, border-color 0.2s;
  }

  .nav-logo:hover {
    background: #E5E5E5;
    border-color: #666;
  }

  .nav-divider {
    font-size: 1rem;
    color: #CCC;
    font-weight: 400;
  }

  .nav-current {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: #999;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 6px 16px;
    border: 1px dashed transparent;
    transition: border-color 0.2s;
  }

  .nav-current:hover {
    border-color: #CCC;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #F5F5F5;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 2px dashed #CCC;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px dashed #CCC;
    pointer-events: none;
  }

  /* Corner crosshair marks */
  .hero-crosshair {
    position: absolute;
    width: 20px;
    height: 20px;
    z-index: 2;
    pointer-events: none;
  }

  .hero-crosshair::before,
  .hero-crosshair::after {
    content: '';
    position: absolute;
    background: #999;
  }

  .hero-crosshair::before {
    width: 20px;
    height: 1px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  .hero-crosshair::after {
    width: 1px;
    height: 20px;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
  }

  .hero-crosshair-tl { top: 10px; left: 10px; }
  .hero-crosshair-tr { top: 10px; right: 10px; }
  .hero-crosshair-bl { bottom: 10px; left: 10px; }
  .hero-crosshair-br { bottom: 10px; right: 10px; }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.7rem;
    color: #999;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 4px 12px;
    border: 1px dotted #CCC;
  }

  .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.05;
    margin: 0 0 24px 0;
    color: #333;
    letter-spacing: -0.02em;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .hero-dash {
    width: 32px;
    height: 1px;
    border-top: 2px dashed #CCC;
  }

  .hero-x {
    font-size: 1rem;
    color: #999;
    font-weight: 400;
    line-height: 1;
  }

  .hero-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: clamp(0.95rem, 2.5vw, 1.15rem);
    line-height: 1.75;
    margin: 0 auto;
    max-width: 500px;
    color: #666;
  }

  .hero-annotation {
    position: absolute;
    bottom: 28px;
    right: 32px;
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    color: #BBB;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    z-index: 2;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 2px dashed #CCC;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 0;
    border-top: 1px dotted #CCC;
  }

  .section-label {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.65rem;
    color: #999;
    white-space: nowrap;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #333;
    letter-spacing: -0.01em;
  }

  .section-annotation {
    position: absolute;
    bottom: 16px;
    right: 24px;
    font-family: 'Inter', sans-serif;
    font-size: 0.6rem;
    font-weight: 400;
    color: #CCC;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #EFEFEF;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 16px;
    left: 16px;
    right: 16px;
    bottom: 16px;
    border: 1px dotted #CCC;
    pointer-events: none;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #444;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #F5F5F5;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 2px dashed #CCC;
    padding: 0 24px 24px;
    position: relative;
    text-align: center;
    background: #F5F5F5;
    transition: border-color 0.2s;
  }

  .char-card:hover {
    border-color: #999;
  }

  .char-placeholder {
    width: 100%;
    height: 64px;
    border-bottom: 1px dotted #CCC;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    position: relative;
    background:
      linear-gradient(to top right, transparent calc(50% - 0.5px), #E5E5E5 calc(50% - 0.5px), #E5E5E5 calc(50% + 0.5px), transparent calc(50% + 0.5px)),
      linear-gradient(to top left, transparent calc(50% - 0.5px), #E5E5E5 calc(50% - 0.5px), #E5E5E5 calc(50% + 0.5px), transparent calc(50% + 0.5px));
  }

  .char-x {
    font-size: 1.5rem;
    color: #BBB;
    font-weight: 400;
    background: #F5F5F5;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .char-number {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    color: #BBB;
    display: block;
    margin-bottom: 8px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .char-divider {
    width: 24px;
    height: 0;
    border-top: 1px dashed #CCC;
    margin: 0 auto 12px;
  }

  .char-title {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 1.1rem;
    margin: 0 0 10px 0;
    color: #333;
  }

  .char-description {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
    color: #666;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #EFEFEF;
  }

  .prompt-block {
    border: 2px dashed #CCC;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 20px;
    border-bottom: 1px dotted #CCC;
    background: rgba(0, 0, 0, 0.02);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.65rem;
    color: #999;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.75rem;
    background: transparent;
    color: #333;
    border: 1px dashed #999;
    padding: 5px 16px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: background 0.2s, border-color 0.2s;
  }

  .copy-button:hover {
    background: #E5E5E5;
    border-color: #666;
  }

  .copy-button.copied {
    background: #E5E5E5;
    border-color: #666;
  }

  .prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.8;
    color: #444;
    padding: 24px 20px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #F5F5F5;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 2px dashed #CCC;
    overflow: hidden;
    position: relative;
  }

  .use-column-heading {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.7rem;
    margin: 0;
    padding: 14px 20px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-bottom: 1px dotted #CCC;
  }

  .use-good .use-column-heading {
    background: rgba(0, 0, 0, 0.03);
    color: #333;
  }

  .use-bad .use-column-heading {
    background: rgba(0, 0, 0, 0.02);
    color: #999;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.5;
    padding: 12px 20px;
    border-bottom: 1px dotted #E5E5E5;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #444;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 8px;
    height: 8px;
    border: 1px dashed #999;
    flex-shrink: 0;
    margin-top: 5px;
  }

  .use-item-bad::before {
    content: '\00D7';
    color: #BBB;
    flex-shrink: 0;
    font-size: 1rem;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #EFEFEF;
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 16px;
    left: 16px;
    right: 16px;
    bottom: 16px;
    border: 1px dotted #CCC;
    pointer-events: none;
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #444;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #F5F5F5;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 28px 20px;
    border: 2px dashed #CCC;
    text-decoration: none;
    color: #444;
    text-align: center;
    position: relative;
    transition: border-color 0.2s, background 0.2s;
  }

  .related-card:hover {
    border-color: #999;
    background: rgba(0, 0, 0, 0.02);
  }

  .related-relationship {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.6rem;
    color: #BBB;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .related-name {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 1.05rem;
    color: #333;
  }

  .related-arrow {
    font-size: 0.9rem;
    color: #CCC;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #EFEFEF;
    padding: 64px 32px;
    border-top: 2px dashed #CCC;
  }

  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-align: center;
  }

  .footer-rule {
    width: 80px;
    height: 0;
    border-top: 1px dashed #CCC;
  }

  .footer-logo {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.85rem;
    color: #333;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 20px;
    border: 1px dashed #999;
    transition: background 0.2s;
  }

  .footer-logo:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .footer-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: #999;
  }

  .footer-back {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: #666;
    text-decoration: none;
    padding: 5px 16px;
    border: 1px dashed transparent;
    transition: border-color 0.2s;
  }

  .footer-back:hover {
    border-color: #CCC;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 64px 24px 56px;
