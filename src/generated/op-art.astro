---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-pattern"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-line"></span>
        <span class="hero-diamond"></span>
        <span class="hero-line"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="about-pattern"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Perception as Medium</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="prompt-pattern"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy & Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Signal & Noise</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="history-pattern"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Space Grotesk', sans-serif;
    background-color: #FFFFFF;
    color: #000000;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     KEYFRAME ANIMATIONS
     ======================================== */
  @keyframes moire-rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @keyframes pulse-scale {
    0%, 100% { transform: scale(1); opacity: 0.15; }
    50% { transform: scale(1.04); opacity: 0.22; }
  }

  @keyframes shift-lines {
    0% { background-position: 0 0; }
    100% { background-position: 40px 0; }
  }

  @keyframes concentric-pulse {
    0%, 100% { transform: scale(1); opacity: 0.12; }
    50% { transform: scale(1.06); opacity: 0.2; }
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 2px solid #000000;
    background: #FFFFFF;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #000000;
    text-decoration: none;
    padding: 6px 18px;
    border: 2px solid #000000;
    transition: background 0.2s, color 0.2s;
  }

  .nav-logo:hover {
    background: #000000;
    color: #FFFFFF;
  }

  .nav-divider {
    font-size: 1.2rem;
    font-weight: 700;
    color: #000000;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    color: #000000;
    text-decoration: none;
    padding: 6px 18px;
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }

  .nav-current:hover {
    border-color: #000000;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #FFFFFF;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 2px solid #000000;
  }

  .hero-pattern {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background:
      repeating-linear-gradient(
        0deg,
        #000000 0px,
        #000000 2px,
        transparent 2px,
        transparent 8px
      ),
      repeating-linear-gradient(
        85deg,
        #000000 0px,
        #000000 2px,
        transparent 2px,
        transparent 8px
      );
    opacity: 0.12;
    pointer-events: none;
    animation: moire-rotate 120s linear infinite;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 0.8rem;
    color: #000000;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border: 2px solid #000000;
    padding: 6px 16px;
  }

  .hero-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(3.5rem, 10vw, 7rem);
    line-height: 1;
    margin: 0 0 28px 0;
    color: #000000;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .hero-line {
    width: 60px;
    height: 2px;
    background: #000000;
  }

  .hero-diamond {
    width: 8px;
    height: 8px;
    background: #000000;
    transform: rotate(45deg);
  }

  .hero-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 520px;
    color: #000000;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 2px solid #000000;
    position: relative;
    overflow: hidden;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 2px;
    background: #000000;
  }

  .section-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 0.75rem;
    color: #000000;
    white-space: nowrap;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.1;
    margin: 0 0 48px 0;
    text-align: center;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #FFFFFF;
  }

  .about-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-radial-gradient(
        circle at 50% 50%,
        #000000 0px,
        #000000 1px,
        transparent 1px,
        transparent 12px
      );
    opacity: 0.06;
    pointer-events: none;
    animation: concentric-pulse 8s ease-in-out infinite;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #000000;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #000000;
  }

  .characteristics-section .section-rule {
    background: #FFFFFF;
  }

  .characteristics-section .section-label {
    color: #FFFFFF;
  }

  .characteristics-section .section-heading {
    color: #FFFFFF;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2px;
  }

  .char-card {
    border: 2px solid #FFFFFF;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: #000000;
    transition: background 0.2s, color 0.2s;
  }

  .char-card:hover {
    background: #FFFFFF;
    color: #000000;
  }

  .char-card:hover .char-number,
  .char-card:hover .char-title,
  .char-card:hover .char-description {
    color: #000000;
  }

  .char-card:hover .char-divider {
    background: #000000;
  }

  .char-number {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: #FFFFFF;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.2em;
    transition: color 0.2s;
  }

  .char-divider {
    width: 24px;
    height: 2px;
    background: #FFFFFF;
    margin: 0 auto 14px;
    transition: background 0.2s;
  }

  .char-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    margin: 0 0 12px 0;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .char-description {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
    color: #FFFFFF;
    opacity: 0.8;
    transition: color 0.2s, opacity 0.2s;
  }

  .char-card:hover .char-description {
    opacity: 1;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #FFFFFF;
  }

  .prompt-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        90deg,
        #000000 0px,
        #000000 1px,
        transparent 1px,
        transparent 20px
      );
    opacity: 0.04;
    pointer-events: none;
    animation: shift-lines 4s linear infinite;
  }

  .prompt-block {
    border: 2px solid #000000;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 2px solid #000000;
    background: #000000;
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 0.75rem;
    color: #FFFFFF;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    background: transparent;
    color: #FFFFFF;
    border: 2px solid #FFFFFF;
    padding: 6px 20px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: background 0.2s, color 0.2s;
  }

  .copy-button:hover {
    background: #FFFFFF;
    color: #000000;
  }

  .copy-button.copied {
    background: #FFFFFF;
    color: #000000;
  }

  .prompt-text {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.85;
    color: #000000;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #FFFFFF;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    max-width: 780px;
    margin: 0 auto;
    border: 2px solid #000000;
  }

  .use-column {
    position: relative;
  }

  .use-good {
    border-right: 2px solid #000000;
  }

  .use-column-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 2px solid #000000;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .use-good .use-column-heading {
    background: #000000;
    color: #FFFFFF;
  }

  .use-bad .use-column-heading {
    background: #FFFFFF;
    color: #000000;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid #000000;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #000000;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 6px;
    height: 6px;
    background: #000000;
    flex-shrink: 0;
    margin-top: 7px;
  }

  .use-item-bad::before {
    content: '\2013';
    color: #000000;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #000000;
    color: #FFFFFF;
  }

  .history-pattern {
    position: absolute;
    top: -25%;
    left: -25%;
    width: 150%;
    height: 150%;
    background:
      repeating-radial-gradient(
        circle at 50% 50%,
        transparent 0px,
        transparent 3px,
        #FFFFFF 3px,
        #FFFFFF 4px,
        transparent 4px,
        transparent 18px
      );
    opacity: 0.07;
    pointer-events: none;
    animation: pulse-scale 10s ease-in-out infinite;
  }

  .history-section .section-rule {
    background: #FFFFFF;
  }

  .history-section .section-label {
    color: #FFFFFF;
  }

  .history-section .section-heading {
    color: #FFFFFF;
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #FFFFFF;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #FFFFFF;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0;
    max-width: 780px;
    margin: 0 auto;
    border: 2px solid #000000;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 28px 20px;
    border: 1px solid #000000;
    text-decoration: none;
    color: #000000;
    text-align: center;
    position: relative;
    transition: background 0.2s, color 0.2s;
  }

  .related-card:hover {
    background: #000000;
    color: #FFFFFF;
  }

  .related-card:hover .related-relationship,
  .related-card:hover .related-name,
  .related-card:hover .related-arrow {
    color: #FFFFFF;
  }

  .related-relationship {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    color: #000000;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .related-name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .related-arrow {
    font-size: 1rem;
    color: #000000;
    transition: color 0.2s;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #000000;
    padding: 64px 32px;
    border-top: 2px solid #000000;
  }

  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-ornament {
    width: 80px;
    height: 2px;
    background: #FFFFFF;
  }

  .footer-logo {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #FFFFFF;
    text-decoration: none;
    padding: 8px 24px;
    border: 2px solid #FFFFFF;
    transition: background 0.2s, color 0.2s;
  }

  .footer-logo:hover {
    background: #FFFFFF;
    color: #000000;
  }

  .footer-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: #FFFFFF;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .footer-back {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
