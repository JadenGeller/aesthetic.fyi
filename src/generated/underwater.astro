---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;1,400&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bubbles"></div>
    <div class="hero-bubbles hero-bubbles-2"></div>
    <div class="hero-light"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-wave"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Into the Deep</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Depths, Wrong Depths</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'DM Sans', sans-serif;
    background: linear-gradient(180deg, #0A1628 0%, #0C2E3D 40%, #0D4F4F 100%);
    color: #C8E6E6;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
  }

  /* ========================================
     KEYFRAME ANIMATIONS
     ======================================== */
  @keyframes bubbleRise {
    0% {
      transform: translateY(0) scale(1);
      opacity: 0;
    }
    10% {
      opacity: 0.6;
    }
    90% {
      opacity: 0.3;
    }
    100% {
      transform: translateY(-100vh) scale(1.4);
      opacity: 0;
    }
  }

  @keyframes bubbleRise2 {
    0% {
      transform: translateY(0) scale(1) translateX(0);
      opacity: 0;
    }
    10% {
      opacity: 0.4;
    }
    50% {
      transform: translateY(-50vh) scale(1.2) translateX(15px);
    }
    90% {
      opacity: 0.2;
    }
    100% {
      transform: translateY(-100vh) scale(1.5) translateX(-10px);
      opacity: 0;
    }
  }

  @keyframes waveFlow {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  @keyframes gentlePulse {
    0%, 100% {
      opacity: 0.4;
      box-shadow: 0 0 20px rgba(0, 255, 212, 0.1);
    }
    50% {
      opacity: 0.7;
      box-shadow: 0 0 40px rgba(0, 255, 212, 0.2);
    }
  }

  @keyframes lightShaft {
    0%, 100% {
      opacity: 0.03;
      transform: skewX(-15deg) scaleY(1);
    }
    50% {
      opacity: 0.07;
      transform: skewX(-12deg) scaleY(1.05);
    }
  }

  @keyframes glowPulse {
    0%, 100% {
      text-shadow: 0 0 8px rgba(0, 255, 212, 0.3), 0 0 20px rgba(0, 255, 212, 0.1);
    }
    50% {
      text-shadow: 0 0 16px rgba(0, 255, 212, 0.5), 0 0 40px rgba(0, 255, 212, 0.2);
    }
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid rgba(0, 255, 212, 0.12);
    background: rgba(10, 22, 40, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    color: #00FFD4;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid rgba(0, 255, 212, 0.2);
    border-radius: 12px;
    transition: background 0.4s, border-color 0.4s, box-shadow 0.4s;
    text-shadow: 0 0 8px rgba(0, 255, 212, 0.2);
  }

  .nav-logo:hover {
    background: rgba(0, 255, 212, 0.08);
    border-color: rgba(0, 255, 212, 0.4);
    box-shadow: 0 0 16px rgba(0, 255, 212, 0.1);
  }

  .nav-divider {
    font-size: 1rem;
    color: rgba(0, 255, 212, 0.25);
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    color: rgba(127, 255, 212, 0.7);
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid transparent;
    border-radius: 12px;
    transition: border-color 0.4s, color 0.4s;
  }

  .nav-current:hover {
    border-color: rgba(0, 255, 212, 0.2);
    color: #7FFFD4;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: linear-gradient(180deg, #0A1628 0%, #0B2236 50%, #0D3D4A 100%);
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(0, 255, 212, 0.1);
  }

  .hero-light {
    position: absolute;
    top: -20%;
    left: 30%;
    width: 200px;
    height: 120%;
    background: linear-gradient(180deg, rgba(0, 255, 212, 0.06), transparent 70%);
    animation: lightShaft 8s ease-in-out infinite;
    pointer-events: none;
  }

  .hero-light::after {
    content: '';
    position: absolute;
    top: 0;
    left: 180px;
    width: 120px;
    height: 100%;
    background: linear-gradient(180deg, rgba(127, 255, 212, 0.04), transparent 60%);
    animation: lightShaft 10s ease-in-out infinite 2s;
  }

  .hero-bubbles {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle 4px at 15% 80%, rgba(0, 255, 212, 0.25) 50%, transparent 50%),
      radial-gradient(circle 3px at 25% 70%, rgba(127, 255, 212, 0.2) 50%, transparent 50%),
      radial-gradient(circle 5px at 40% 85%, rgba(0, 255, 212, 0.15) 50%, transparent 50%),
      radial-gradient(circle 2px at 55% 75%, rgba(127, 255, 212, 0.3) 50%, transparent 50%),
      radial-gradient(circle 6px at 70% 90%, rgba(0, 255, 212, 0.12) 50%, transparent 50%),
      radial-gradient(circle 3px at 85% 78%, rgba(127, 255, 212, 0.2) 50%, transparent 50%),
      radial-gradient(circle 4px at 92% 88%, rgba(0, 255, 212, 0.18) 50%, transparent 50%),
      radial-gradient(circle 2px at 8% 72%, rgba(0, 255, 212, 0.22) 50%, transparent 50%);
    animation: bubbleRise 12s ease-in infinite;
    pointer-events: none;
  }

  .hero-bubbles-2 {
    background:
      radial-gradient(circle 3px at 20% 90%, rgba(0, 255, 212, 0.2) 50%, transparent 50%),
      radial-gradient(circle 5px at 35% 82%, rgba(127, 255, 212, 0.15) 50%, transparent 50%),
      radial-gradient(circle 2px at 50% 95%, rgba(0, 255, 212, 0.25) 50%, transparent 50%),
      radial-gradient(circle 4px at 65% 85%, rgba(127, 255, 212, 0.18) 50%, transparent 50%),
      radial-gradient(circle 3px at 78% 92%, rgba(0, 255, 212, 0.22) 50%, transparent 50%),
      radial-gradient(circle 6px at 88% 80%, rgba(127, 255, 212, 0.1) 50%, transparent 50%);
    animation: bubbleRise2 16s ease-in infinite 3s;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'DM Sans', sans-serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: rgba(127, 255, 212, 0.6);
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'Outfit', sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.05;
    margin: 0 0 24px 0;
    color: #FFFFFF;
    text-shadow: 0 0 30px rgba(0, 255, 212, 0.3), 0 0 60px rgba(0, 255, 212, 0.1);
    animation: glowPulse 6s ease-in-out infinite;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }

  .hero-wave {
    display: block;
    width: 80px;
    height: 3px;
    border-radius: 3px;
    background: linear-gradient(90deg, transparent, #00FFD4, #7FFFD4, #00FFD4, transparent);
    background-size: 200% 100%;
    animation: waveFlow 4s ease-in-out infinite;
  }

  .hero-tagline {
    font-family: 'DM Sans', sans-serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 520px;
    color: rgba(200, 230, 230, 0.75);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 1px solid rgba(0, 255, 212, 0.08);
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 255, 212, 0.3), transparent);
  }

  .section-label {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: rgba(127, 255, 212, 0.5);
    white-space: nowrap;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #FFFFFF;
    text-shadow: 0 0 16px rgba(0, 255, 212, 0.2);
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: linear-gradient(180deg, rgba(10, 22, 40, 0.6), rgba(13, 50, 60, 0.4));
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 1px solid rgba(0, 255, 212, 0.08);
    border-radius: 16px;
    pointer-events: none;
    animation: gentlePulse 8s ease-in-out infinite;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: rgba(200, 230, 230, 0.85);
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: transparent;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 1px solid rgba(0, 255, 212, 0.12);
    border-radius: 14px;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: rgba(10, 22, 40, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: box-shadow 0.4s, border-color 0.4s, transform 0.4s;
  }

  .char-card:hover {
    box-shadow: 0 4px 30px rgba(0, 255, 212, 0.1), inset 0 0 30px rgba(0, 255, 212, 0.03);
    border-color: rgba(0, 255, 212, 0.25);
    transform: translateY(-2px);
  }

  .char-number {
    font-family: 'Outfit', sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    color: rgba(0, 255, 212, 0.4);
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 24px;
    height: 2px;
    background: linear-gradient(90deg, transparent, #00FFD4, transparent);
    margin: 0 auto 14px;
    border-radius: 2px;
  }

  .char-title {
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 1.25rem;
    margin: 0 0 12px 0;
    color: #7FFFD4;
    text-shadow: 0 0 10px rgba(0, 255, 212, 0.15);
  }

  .char-description {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    margin: 0;
    color: rgba(200, 230, 230, 0.6);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: linear-gradient(180deg, rgba(13, 50, 60, 0.3), rgba(10, 22, 40, 0.5));
  }

  .prompt-block {
    border: 1px solid rgba(0, 255, 212, 0.15);
    border-radius: 14px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    background: rgba(10, 22, 40, 0.4);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(0, 255, 212, 0.1);
    background: rgba(0, 255, 212, 0.04);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: rgba(127, 255, 212, 0.5);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    font-size: 0.85rem;
    background: transparent;
    color: #00FFD4;
    border: 1px solid rgba(0, 255, 212, 0.25);
    border-radius: 10px;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.4s, border-color 0.4s, box-shadow 0.4s;
  }

  .copy-button:hover {
    background: rgba(0, 255, 212, 0.1);
    border-color: rgba(0, 255, 212, 0.4);
    box-shadow: 0 0 12px rgba(0, 255, 212, 0.1);
  }

  .copy-button.copied {
    background: rgba(0, 255, 212, 0.15);
    border-color: #00FFD4;
    box-shadow: 0 0 16px rgba(0, 255, 212, 0.15);
  }

  .prompt-text {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(200, 230, 230, 0.8);
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: transparent;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid rgba(0, 255, 212, 0.12);
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    background: rgba(10, 22, 40, 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .use-column-heading {
    font-family: 'Outfit', sans-serif;
    font-weight: 500;
    font-size: 1.05rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 1px solid rgba(0, 255, 212, 0.1);
  }

  .use-good .use-column-heading {
    background: rgba(0, 255, 212, 0.06);
    color: #7FFFD4;
  }

  .use-bad .use-column-heading {
    background: rgba(200, 230, 230, 0.03);
    color: rgba(200, 230, 230, 0.5);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(0, 255, 212, 0.05);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: rgba(200, 230, 230, 0.75);
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00FFD4;
    box-shadow: 0 0 6px rgba(0, 255, 212, 0.4);
    flex-shrink: 0;
    margin-top: 7px;
  }

