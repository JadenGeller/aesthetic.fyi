---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@500;700&family=Poppins:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">//</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-palms"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-wave">
        <svg viewBox="0 0 120 12" class="hero-wave-svg">
          <path d="M0 6 Q15 0 30 6 Q45 12 60 6 Q75 0 90 6 Q105 12 120 6" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="1.5"/>
        </svg>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
    <div class="hero-sun"></div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Paradise Found</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
    <div class="section-leaf section-leaf-right"></div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy & Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Beach, Wrong Beach</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
    <div class="section-leaf section-leaf-left"></div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Poppins', sans-serif;
    background-color: #FFF1E6;
    color: #2D6A4F;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background: rgba(255, 241, 230, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 2px solid #2EC4B6;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #2D6A4F;
    text-decoration: none;
    padding: 6px 18px;
    border: 2px solid #2EC4B6;
    border-radius: 20px;
    transition: background 0.3s, box-shadow 0.3s;
  }

  .nav-logo:hover {
    background: rgba(46, 196, 182, 0.12);
    box-shadow: 0 2px 12px rgba(46, 196, 182, 0.2);
  }

  .nav-divider {
    font-size: 1rem;
    color: #FF6B6B;
    font-weight: 700;
  }

  .nav-current {
    font-family: 'Quicksand', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    color: #FF6B6B;
    text-decoration: none;
    padding: 6px 18px;
    border: 2px solid transparent;
    border-radius: 20px;
    transition: border-color 0.3s;
  }

  .nav-current:hover {
    border-color: #FF6B6B;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: linear-gradient(
      160deg,
      #FF9F1C 0%,
      #FF6B6B 35%,
      #FF6B6B 50%,
      #c76bcc 80%,
      #8E6FCE 100%
    );
    padding: 100px 32px 88px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero-palms {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    /* Palm leaf top-left */
    background:
      /* Leaf 1 - top left */
      conic-gradient(from 200deg at 8% 0%, rgba(45, 106, 79, 0.18) 0deg, transparent 40deg),
      conic-gradient(from 220deg at 12% 0%, rgba(45, 106, 79, 0.14) 0deg, transparent 35deg),
      conic-gradient(from 240deg at 4% 5%, rgba(45, 106, 79, 0.12) 0deg, transparent 30deg),
      conic-gradient(from 180deg at 16% 0%, rgba(45, 106, 79, 0.1) 0deg, transparent 45deg),
      /* Leaf 2 - top right */
      conic-gradient(from 320deg at 92% 0%, rgba(45, 106, 79, 0.18) 0deg, transparent 40deg),
      conic-gradient(from 300deg at 88% 0%, rgba(45, 106, 79, 0.14) 0deg, transparent 35deg),
      conic-gradient(from 340deg at 96% 5%, rgba(45, 106, 79, 0.12) 0deg, transparent 30deg),
      conic-gradient(from 350deg at 84% 0%, rgba(45, 106, 79, 0.1) 0deg, transparent 45deg),
      /* Leaf 3 - bottom left, subtle */
      conic-gradient(from 140deg at 3% 95%, rgba(45, 106, 79, 0.1) 0deg, transparent 35deg),
      conic-gradient(from 160deg at 7% 100%, rgba(45, 106, 79, 0.08) 0deg, transparent 30deg),
      /* Leaf 4 - bottom right, subtle */
      conic-gradient(from 20deg at 97% 95%, rgba(45, 106, 79, 0.1) 0deg, transparent 35deg),
      conic-gradient(from 0deg at 93% 100%, rgba(45, 106, 79, 0.08) 0deg, transparent 30deg);
  }

  .hero-sun {
    position: absolute;
    top: 18px;
    right: 60px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 159, 28, 0.7) 0%, rgba(255, 159, 28, 0.3) 50%, transparent 70%);
    box-shadow: 0 0 40px rgba(255, 159, 28, 0.4), 0 0 80px rgba(255, 159, 28, 0.2);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.8);
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.05;
    margin: 0 0 24px 0;
    color: #fff;
    text-shadow: 0 2px 20px rgba(255, 107, 107, 0.3);
  }

  .hero-wave {
    display: flex;
    justify-content: center;
    margin-bottom: 24px;
  }

  .hero-wave-svg {
    width: 120px;
    height: 12px;
  }

  .hero-tagline {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-style: italic;
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 520px;
    color: rgba(255, 255, 255, 0.9);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    position: relative;
    overflow: hidden;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 2px;
    background: linear-gradient(90deg, #2EC4B6, #FF6B6B);
    border-radius: 1px;
  }

  .section-label {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    color: #FF6B6B;
    white-space: nowrap;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #2D6A4F;
  }

  /* Decorative leaf shapes for sections */
  .section-leaf {
    position: absolute;
    width: 200px;
    height: 200px;
    pointer-events: none;
    opacity: 0.06;
  }

  .section-leaf-right {
    right: -40px;
    top: 50%;
    transform: translateY(-50%);
    background:
      conic-gradient(from 320deg at 50% 50%, #2D6A4F 0deg, transparent 60deg),
      conic-gradient(from 340deg at 45% 55%, #2D6A4F 0deg, transparent 50deg),
      conic-gradient(from 300deg at 55% 45%, #2D6A4F 0deg, transparent 50deg);
  }

  .section-leaf-left {
    left: -40px;
    top: 50%;
    transform: translateY(-50%);
    background:
      conic-gradient(from 140deg at 50% 50%, #2D6A4F 0deg, transparent 60deg),
      conic-gradient(from 160deg at 55% 55%, #2D6A4F 0deg, transparent 50deg),
      conic-gradient(from 120deg at 45% 45%, #2D6A4F 0deg, transparent 50deg);
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #FFF1E6;
    border-bottom: 2px solid rgba(46, 196, 182, 0.2);
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 1.15rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #2D6A4F;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: linear-gradient(180deg, rgba(46, 196, 182, 0.05) 0%, #FFF1E6 100%);
    border-bottom: 2px solid rgba(46, 196, 182, 0.2);
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 2px solid rgba(46, 196, 182, 0.3);
    border-radius: 20px;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: rgba(255, 255, 255, 0.5);
    transition: box-shadow 0.3s, border-color 0.3s, transform 0.3s;
  }

  .char-card:hover {
    box-shadow: 0 8px 30px rgba(46, 196, 182, 0.15), 0 4px 12px rgba(255, 107, 107, 0.08);
    border-color: #2EC4B6;
    transform: translateY(-2px);
  }

  .char-number {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    color: #FF6B6B;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.1em;
  }

  .char-divider {
    width: 32px;
    height: 3px;
    background: linear-gradient(90deg, #FF6B6B, #2EC4B6);
    margin: 0 auto 14px;
    border-radius: 2px;
  }

  .char-title {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    margin: 0 0 12px 0;
    color: #2D6A4F;
  }

  .char-description {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.75;
    margin: 0;
    color: rgba(45, 106, 79, 0.7);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #FFF1E6;
    border-bottom: 2px solid rgba(46, 196, 182, 0.2);
  }

  .prompt-block {
    border: 2px solid rgba(46, 196, 182, 0.3);
    border-radius: 20px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.4);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 2px solid rgba(46, 196, 182, 0.15);
    background: rgba(46, 196, 182, 0.06);
  }

  .prompt-header-label {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    color: #FF6B6B;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    background: transparent;
    color: #2D6A4F;
    border: 2px solid #2EC4B6;
    border-radius: 16px;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.3s, box-shadow 0.3s;
  }

  .copy-button:hover {
    background: rgba(46, 196, 182, 0.12);
    box-shadow: 0 2px 12px rgba(46, 196, 182, 0.2);
  }

  .copy-button.copied {
    background: rgba(46, 196, 182, 0.2);
    border-color: #2D6A4F;
  }

  .prompt-text {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.85;
    color: #2D6A4F;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: linear-gradient(180deg, #FFF1E6 0%, rgba(255, 159, 28, 0.04) 100%);
    border-bottom: 2px solid rgba(46, 196, 182, 0.2);
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 2px solid rgba(46, 196, 182, 0.3);
    border-radius: 20px;
    overflow: hidden;
  }

  .use-column-heading {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 2px solid rgba(46, 196, 182, 0.15);
  }

  .use-good .use-column-heading {
    background: linear-gradient(135deg, rgba(46, 196, 182, 0.1), rgba(46, 196, 182, 0.05));
    color: #2D6A4F;
  }

  .use-bad .use-column-heading {
    background: rgba(255, 107, 107, 0.06);
    color: #FF6B6B;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(46, 196, 182, 0.1);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #2D6A4F;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #2EC4B6;
    flex-shrink: 0;
    margin-top: 6px;
  }

  .use-item-bad::before {
    content: '\2013';
    color: #FF6B6B;
    flex-shrink: 0;
    font-weight: 700;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #FFF1E6;
    border-bottom: 2px solid rgba(46, 196, 182, 0.2);
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 1.1rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #2D6A4F;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: linear-gradient(180deg, rgba(46, 196, 182, 0.04) 0%, #FFF1E6 100%);
    border-bottom: 2px solid rgba(46, 196, 182, 0.2);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 28px 20px;
    border: 2px solid rgba(46, 196, 182, 0.25);
    border-radius: 20px;
    text-decoration: none;
    color: #2D6A4F;
    text-align: center;
    background: rgba(255, 255, 255, 0.4);
    transition: box-shadow 0.3s, border-color 0.3s, transform 0.3s;
  }

  .related-card:hover {
    box-shadow: 0 8px 24px rgba(46, 196, 182, 0.15), 0 4px 8px rgba(255, 107, 107, 0.08);
    border-color: #2EC4B6;
    transform: translateY(-2px);
  }

  .related-relationship {
    font-family: 'Poppins', sans-serif;
    font-weight: 300;
    font-size: 0.7rem;
    color: #FF6B6B;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .related-name {
    font-family: 'Quicksand', sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    color: #2D6A4F;
  }

  .related-arrow {
    font-size: 1rem;
    color: #2EC4B6;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: linear-gradient(
      160deg,
      #2D6A4F 0%,
      #1B4332 100%
    );
    padding: 64px 32px;
  }

