---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">&middot;</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-starfield"></div>
    <div class="hero-nebula"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-star"></span>
        <span class="hero-star hero-star--bright"></span>
        <span class="hero-star"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-starfield"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Signals from the Void</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-starfield"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-starfield"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-starfield"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Star Charts</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-starfield"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-starfield"></div>
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Space Grotesk', sans-serif;
    background-color: #050510;
    color: #E8E0F0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     STARFIELD — reusable background layer
     ======================================== */
  .hero-starfield,
  .section-starfield {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    background:
      /* bright stars */
      radial-gradient(circle 1.5px at 8% 12%, #ffffff 50%, transparent 50%),
      radial-gradient(circle 1px at 22% 38%, #ffffff 50%, transparent 50%),
      radial-gradient(circle 1.5px at 45% 8%, #ffffff 50%, transparent 50%),
      radial-gradient(circle 1px at 67% 22%, #ffffff 50%, transparent 50%),
      radial-gradient(circle 1.5px at 88% 15%, #ffffff 50%, transparent 50%),
      radial-gradient(circle 1px at 35% 65%, #ffffff 50%, transparent 50%),
      radial-gradient(circle 1.5px at 72% 78%, #ffffff 50%, transparent 50%),
      radial-gradient(circle 1px at 92% 55%, #ffffff 50%, transparent 50%),
      radial-gradient(circle 1px at 15% 82%, #ffffff 50%, transparent 50%),
      radial-gradient(circle 1.5px at 55% 92%, #ffffff 50%, transparent 50%),
      /* colored stars — teal */
      radial-gradient(circle 1px at 30% 18%, #00CED1 50%, transparent 50%),
      radial-gradient(circle 1px at 78% 45%, #00CED1 50%, transparent 50%),
      /* colored stars — magenta */
      radial-gradient(circle 1px at 60% 35%, #C850C0 50%, transparent 50%),
      radial-gradient(circle 1px at 18% 55%, #C850C0 50%, transparent 50%),
      /* colored stars — purple */
      radial-gradient(circle 1px at 42% 72%, #6B2FA0 50%, transparent 50%),
      radial-gradient(circle 1px at 85% 88%, #6B2FA0 50%, transparent 50%),
      /* dim distant stars */
      radial-gradient(circle 0.5px at 5% 45%, rgba(255,255,255,0.4) 50%, transparent 50%),
      radial-gradient(circle 0.5px at 12% 68%, rgba(255,255,255,0.3) 50%, transparent 50%),
      radial-gradient(circle 0.5px at 28% 85%, rgba(255,255,255,0.35) 50%, transparent 50%),
      radial-gradient(circle 0.5px at 38% 28%, rgba(255,255,255,0.4) 50%, transparent 50%),
      radial-gradient(circle 0.5px at 50% 50%, rgba(255,255,255,0.3) 50%, transparent 50%),
      radial-gradient(circle 0.5px at 62% 15%, rgba(255,255,255,0.35) 50%, transparent 50%),
      radial-gradient(circle 0.5px at 75% 62%, rgba(255,255,255,0.4) 50%, transparent 50%),
      radial-gradient(circle 0.5px at 82% 35%, rgba(255,255,255,0.3) 50%, transparent 50%),
      radial-gradient(circle 0.5px at 95% 72%, rgba(255,255,255,0.35) 50%, transparent 50%),
      radial-gradient(circle 0.5px at 48% 42%, rgba(255,255,255,0.25) 50%, transparent 50%);
    opacity: 0.85;
  }

  /* ========================================
     NEBULA OVERLAY — hero only
     ======================================== */
  .hero-nebula {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 600px 400px at 20% 60%, rgba(107,47,160,0.25), transparent),
      radial-gradient(ellipse 500px 350px at 80% 30%, rgba(200,80,192,0.15), transparent),
      radial-gradient(ellipse 400px 300px at 60% 80%, rgba(0,206,209,0.12), transparent),
      radial-gradient(ellipse 300px 200px at 40% 20%, rgba(26,10,62,0.4), transparent);
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid rgba(107,47,160,0.3);
    background: rgba(5,5,16,0.9);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    color: #E8E0F0;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid rgba(107,47,160,0.4);
    border-radius: 8px;
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  .nav-logo:hover {
    background: rgba(107,47,160,0.15);
    border-color: rgba(200,80,192,0.5);
    box-shadow: 0 0 12px rgba(200,80,192,0.2);
  }

  .nav-divider {
    font-size: 1.2rem;
    color: rgba(107,47,160,0.5);
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    color: rgba(232,224,240,0.6);
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid transparent;
    border-radius: 8px;
    transition: border-color 0.3s, color 0.3s;
  }

  .nav-current:hover {
    border-color: rgba(107,47,160,0.3);
    color: #E8E0F0;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #050510;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(107,47,160,0.3);
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: rgba(0,206,209,0.7);
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.05;
    margin: 0 0 24px 0;
    color: #E8E0F0;
    text-shadow:
      0 0 40px rgba(200,80,192,0.4),
      0 0 80px rgba(107,47,160,0.25),
      0 0 120px rgba(0,206,209,0.15);
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .hero-star {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #C850C0;
    box-shadow: 0 0 6px rgba(200,80,192,0.6);
  }

  .hero-star--bright {
    width: 6px;
    height: 6px;
    background: #00CED1;
    box-shadow: 0 0 10px rgba(0,206,209,0.8), 0 0 20px rgba(0,206,209,0.4);
  }

  .hero-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 520px;
    color: rgba(232,224,240,0.65);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 1px solid rgba(107,47,160,0.25);
    position: relative;
    overflow: hidden;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(200,80,192,0.5), transparent);
  }

  .section-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: rgba(0,206,209,0.6);
    white-space: nowrap;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #E8E0F0;
    text-shadow: 0 0 30px rgba(200,80,192,0.3);
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: linear-gradient(180deg, #050510 0%, #0a0520 50%, #050510 100%);
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: rgba(232,224,240,0.8);
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #050510;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 1px solid rgba(107,47,160,0.3);
    border-radius: 10px;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: rgba(10,5,30,0.6);
    transition: box-shadow 0.4s, border-color 0.4s;
  }

  .char-card:hover {
    box-shadow:
      0 0 20px rgba(200,80,192,0.15),
      0 0 40px rgba(107,47,160,0.1),
      inset 0 0 30px rgba(107,47,160,0.05);
    border-color: rgba(200,80,192,0.5);
  }

  .char-number {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    color: rgba(0,206,209,0.5);
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 24px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(200,80,192,0.6), transparent);
    margin: 0 auto 14px;
  }

  .char-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin: 0 0 12px 0;
    color: #E8E0F0;
    text-shadow: 0 0 20px rgba(200,80,192,0.2);
  }

  .char-description {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    margin: 0;
    color: rgba(232,224,240,0.55);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: linear-gradient(180deg, #050510 0%, #0a0520 50%, #050510 100%);
  }

  .prompt-block {
    border: 1px solid rgba(107,47,160,0.3);
    border-radius: 10px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    background: rgba(10,5,30,0.5);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(107,47,160,0.25);
    background: rgba(107,47,160,0.08);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: rgba(0,206,209,0.6);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 0.85rem;
    background: transparent;
    color: #E8E0F0;
    border: 1px solid rgba(107,47,160,0.4);
    border-radius: 6px;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  .copy-button:hover {
    background: rgba(107,47,160,0.2);
    border-color: rgba(200,80,192,0.5);
    box-shadow: 0 0 12px rgba(200,80,192,0.2);
  }

  .copy-button.copied {
    background: rgba(0,206,209,0.15);
    border-color: rgba(0,206,209,0.5);
    box-shadow: 0 0 12px rgba(0,206,209,0.2);
  }

  .prompt-text {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(232,224,240,0.75);
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #050510;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid rgba(107,47,160,0.3);
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    background: rgba(10,5,30,0.4);
  }

  .use-column-heading {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1.05rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 1px solid rgba(107,47,160,0.25);
  }

  .use-good .use-column-heading {
    background: rgba(0,206,209,0.08);
    color: #00CED1;
    text-shadow: 0 0 15px rgba(0,206,209,0.3);
  }

  .use-bad .use-column-heading {
    background: rgba(107,47,160,0.08);
    color: rgba(232,224,240,0.5);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(107,47,160,0.12);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: rgba(232,224,240,0.7);
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00CED1;
    box-shadow: 0 0 6px rgba(0,206,209,0.5);
    flex-shrink: 0;
    margin-top: 7px;
  }

  .use-item-bad::before {
    content: '\2013';
    color: rgba(107,47,160,0.5);
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: linear-gradient(180deg, #050510 0%, #0a0520 50%, #050510 100%);
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: rgba(232,224,240,0.8);
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #050510;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
