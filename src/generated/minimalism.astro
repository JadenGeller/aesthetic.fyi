---
import { Nav, Hero, About, Characteristics, Prompt, Usage, History, Related, Footer } from '../components/aesthetic';
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400&display=swap" rel="stylesheet" />

<div class="page" data-page="minimalism">
  <Nav aesthetic={aesthetic} />
  <Hero aesthetic={aesthetic} />
  <About aesthetic={aesthetic} />
  <Characteristics aesthetic={aesthetic} />
  <Prompt aesthetic={aesthetic} />
  <Usage aesthetic={aesthetic} />
  <History aesthetic={aesthetic} />
  <Related aesthetic={aesthetic} />
  <Footer />
</div>

<style is:global>
  /* ========================================
     RESET & BASE
     ======================================== */
  [data-page="minimalism"] {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    background-color: #ffffff;
    color: #222222;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  [data-page="minimalism"] .nav {
    border-bottom: 1px solid #eeeeee;
    background: #ffffff;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  [data-page="minimalism"] .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 24px 32px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  [data-page="minimalism"] .nav-logo {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #222222;
    text-decoration: none;
  }

  [data-page="minimalism"] .nav-logo:hover {
    color: #999999;
  }

  [data-page="minimalism"] .nav-divider {
    font-weight: 300;
    font-size: 0.85rem;
    color: #cccccc;
  }

  [data-page="minimalism"] .nav-current {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #999999;
    text-decoration: none;
  }

  [data-page="minimalism"] .nav-current:hover {
    color: #222222;
  }

  /* ========================================
     HERO
     ======================================== */
  [data-page="minimalism"] .hero {
    padding: 120px 32px 100px;
    text-align: center;
  }

  [data-page="minimalism"] .hero-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  [data-page="minimalism"] .hero-label {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: #999999;
    display: block;
    margin-bottom: 40px;
  }

  [data-page="minimalism"] .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1;
    margin: 0 0 32px 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #222222;
  }

  [data-page="minimalism"] .hero-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.15rem;
    line-height: 1.6;
    margin: 0;
    color: #999999;
    letter-spacing: 0.02em;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  [data-page="minimalism"] .section {
    padding: 80px 32px;
  }

  [data-page="minimalism"] .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  [data-page="minimalism"] .section-label {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: #999999;
    display: block;
    margin-bottom: 48px;
  }

  /* ========================================
     ABOUT
     ======================================== */
  [data-page="minimalism"] .about-section {
    border-top: 1px solid #eeeeee;
  }

  [data-page="minimalism"] .about-content {
    max-width: 620px;
  }

  [data-page="minimalism"] .about-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.1rem;
    line-height: 1.85;
    margin: 0 0 28px 0;
    color: #222222;
  }

  [data-page="minimalism"] .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  [data-page="minimalism"] .characteristics-section {
    border-top: 1px solid #eeeeee;
  }

  [data-page="minimalism"] .characteristics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  [data-page="minimalism"] .char-card {
    padding: 40px 32px;
    border-bottom: 1px solid #eeeeee;
    border-right: 1px solid #eeeeee;
  }

  [data-page="minimalism"] .char-card:nth-child(2n) {
    border-right: none;
  }

  [data-page="minimalism"] .char-card:nth-last-child(-n+2) {
    border-bottom: none;
  }

  [data-page="minimalism"] .char-number {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: #cccccc;
    display: block;
    margin-bottom: 16px;
  }

  [data-page="minimalism"] .char-title {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    letter-spacing: 0.04em;
    margin: 0 0 12px 0;
    color: #222222;
  }

  [data-page="minimalism"] .char-description {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
    color: #666666;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  [data-page="minimalism"] .prompt-section {
    border-top: 1px solid #eeeeee;
  }

  [data-page="minimalism"] .prompt-block {
    border: 1px solid #eeeeee;
  }

  [data-page="minimalism"] .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    border-bottom: 1px solid #eeeeee;
  }

  [data-page="minimalism"] .prompt-header-label {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #999999;
  }

  [data-page="minimalism"] .copy-button {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: none;
    color: #999999;
    border: 1px solid #dddddd;
    padding: 8px 20px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }

  [data-page="minimalism"] .copy-button:hover {
    color: #222222;
    border-color: #222222;
  }

  [data-page="minimalism"] .copy-button.copied {
    color: #222222;
    border-color: #222222;
  }

  [data-page="minimalism"] .prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #444444;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  [data-page="minimalism"] .use-section {
    border-top: 1px solid #eeeeee;
  }

  [data-page="minimalism"] .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }

  [data-page="minimalism"] .use-column-heading {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #999999;
    margin: 0 0 24px 0;
  }

  [data-page="minimalism"] .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  [data-page="minimalism"] .use-item {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.6;
    padding: 12px 0;
    border-bottom: 1px solid #eeeeee;
    color: #222222;
  }

  [data-page="minimalism"] .use-item:last-child {
    border-bottom: none;
  }

  /* ========================================
     HISTORY
     ======================================== */
  [data-page="minimalism"] .history-section {
    border-top: 1px solid #eeeeee;
  }

  [data-page="minimalism"] .history-content {
    max-width: 620px;
  }

  [data-page="minimalism"] .history-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.85;
    margin: 0 0 28px 0;
    color: #222222;
  }

  [data-page="minimalism"] .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  [data-page="minimalism"] .related-section {
    border-top: 1px solid #eeeeee;
  }

  [data-page="minimalism"] .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0;
  }

  [data-page="minimalism"] .related-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 32px 24px;
    text-decoration: none;
    color: #222222;
    border-right: 1px solid #eeeeee;
    border-bottom: 1px solid #eeeeee;
    transition: background-color 0.2s;
  }

  [data-page="minimalism"] .related-card:hover {
    background-color: #fafafa;
  }

  [data-page="minimalism"] .related-card:last-child {
    border-right: none;
  }

  [data-page="minimalism"] .related-relationship {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #999999;
  }

  [data-page="minimalism"] .related-name {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    letter-spacing: 0.02em;
    color: #222222;
  }

  /* ========================================
     FOOTER
     ======================================== */
  [data-page="minimalism"] .footer {
    border-top: 1px solid #eeeeee;
    padding: 80px 32px;
  }

  [data-page="minimalism"] .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  [data-page="minimalism"] .footer-logo {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #222222;
    text-decoration: none;
  }

  [data-page="minimalism"] .footer-logo:hover {
    color: #999999;
  }

  [data-page="minimalism"] .footer-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    color: #999999;
    letter-spacing: 0.02em;
  }

  [data-page="minimalism"] .footer-back {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #999999;
    text-decoration: none;
    margin-top: 8px;
    transition: color 0.2s;
  }

  [data-page="minimalism"] .footer-back:hover {
    color: #222222;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    [data-page="minimalism"] .hero {
      padding: 80px 24px 64px;
    }

    [data-page="minimalism"] .section {
      padding: 56px 24px;
    }

    [data-page="minimalism"] .section-label {
      margin-bottom: 32px;
    }

    [data-page="minimalism"] .characteristics-grid {
      grid-template-columns: 1fr;
    }

    [data-page="minimalism"] .char-card {
      border-right: none;
      padding: 28px 0;
    }

    [data-page="minimalism"] .char-card:last-child {
      border-bottom: none;
    }

    [data-page="minimalism"] .use-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    [data-page="minimalism"] .related-grid {
      grid-template-columns: 1fr;
    }

    [data-page="minimalism"] .related-card {
      border-right: none;
    }

    [data-page="minimalism"] .related-card:last-child {
      border-bottom: none;
    }

    [data-page="minimalism"] .prompt-text {
      font-size: 0.85rem;
      padding: 20px 16px;
    }

    [data-page="minimalism"] .prompt-header {
      padding: 14px 16px;
    }

    [data-page="minimalism"] .nav-inner {
      padding: 18px 24px;
    }

    [data-page="minimalism"] .footer {
      padding: 56px 24px;
    }
  }

  @media (max-width: 480px) {
    [data-page="minimalism"] .hero {
      padding: 60px 20px 48px;
    }

    [data-page="minimalism"] .hero-label {
      margin-bottom: 28px;
    }

    [data-page="minimalism"] .section {
      padding: 40px 20px;
    }

    [data-page="minimalism"] .nav-inner {
      padding: 14px 20px;
      gap: 8px;
    }

    [data-page="minimalism"] .nav-logo {
      font-size: 0.7rem;
    }

    [data-page="minimalism"] .nav-current {
      font-size: 0.7rem;
    }

    [data-page="minimalism"] .char-card {
      padding: 24px 0;
    }

    [data-page="minimalism"] .copy-button {
      padding: 6px 14px;
      font-size: 0.65rem;
    }

    [data-page="minimalism"] .use-item {
      padding: 10px 0;
      font-size: 0.9rem;
    }

    [data-page="minimalism"] .related-card {
      padding: 24px 0;
    }
  }
</style>
