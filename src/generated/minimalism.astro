---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-label">Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <span class="section-label">What This Is</span>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <span class="section-label">Characteristics</span>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <span class="section-label">Style Reference</span>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <span class="section-label">When to Use</span>
      <div class="use-grid">
        <div class="use-column">
          <h3 class="use-column-heading">Good for</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column">
          <h3 class="use-column-heading">Not for</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <span class="section-label">History</span>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <span class="section-label">Related Styles</span>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">All aesthetics</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    background-color: #ffffff;
    color: #222222;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid #eeeeee;
    background: #ffffff;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 24px 32px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-logo {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #222222;
    text-decoration: none;
  }

  .nav-logo:hover {
    color: #999999;
  }

  .nav-divider {
    font-weight: 300;
    font-size: 0.85rem;
    color: #cccccc;
  }

  .nav-current {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #999999;
    text-decoration: none;
  }

  .nav-current:hover {
    color: #222222;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    padding: 120px 32px 100px;
    text-align: center;
  }

  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .hero-label {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: #999999;
    display: block;
    margin-bottom: 40px;
  }

  .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1;
    margin: 0 0 32px 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #222222;
  }

  .hero-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.15rem;
    line-height: 1.6;
    margin: 0;
    color: #999999;
    letter-spacing: 0.02em;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 80px 32px;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: #999999;
    display: block;
    margin-bottom: 48px;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    border-top: 1px solid #eeeeee;
  }

  .about-content {
    max-width: 620px;
  }

  .about-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1.1rem;
    line-height: 1.85;
    margin: 0 0 28px 0;
    color: #222222;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    border-top: 1px solid #eeeeee;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .char-card {
    padding: 40px 32px;
    border-bottom: 1px solid #eeeeee;
    border-right: 1px solid #eeeeee;
  }

  .char-card:nth-child(2n) {
    border-right: none;
  }

  .char-card:nth-last-child(-n+2) {
    border-bottom: none;
  }

  .char-number {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: #cccccc;
    display: block;
    margin-bottom: 16px;
  }

  .char-title {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    letter-spacing: 0.04em;
    margin: 0 0 12px 0;
    color: #222222;
  }

  .char-description {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
    color: #666666;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    border-top: 1px solid #eeeeee;
  }

  .prompt-block {
    border: 1px solid #eeeeee;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    border-bottom: 1px solid #eeeeee;
  }

  .prompt-header-label {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #999999;
  }

  .copy-button {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: none;
    color: #999999;
    border: 1px solid #dddddd;
    padding: 8px 20px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }

  .copy-button:hover {
    color: #222222;
    border-color: #222222;
  }

  .copy-button.copied {
    color: #222222;
    border-color: #222222;
  }

  .prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #444444;
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    border-top: 1px solid #eeeeee;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }

  .use-column-heading {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #999999;
    margin: 0 0 24px 0;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 1.6;
    padding: 12px 0;
    border-bottom: 1px solid #eeeeee;
    color: #222222;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    border-top: 1px solid #eeeeee;
  }

  .history-content {
    max-width: 620px;
  }

  .history-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.85;
    margin: 0 0 28px 0;
    color: #222222;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    border-top: 1px solid #eeeeee;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 32px 24px;
    text-decoration: none;
    color: #222222;
    border-right: 1px solid #eeeeee;
    border-bottom: 1px solid #eeeeee;
    transition: background-color 0.2s;
  }

  .related-card:hover {
    background-color: #fafafa;
  }

  .related-card:last-child {
    border-right: none;
  }

  .related-relationship {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #999999;
  }

  .related-name {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    letter-spacing: 0.02em;
    color: #222222;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    border-top: 1px solid #eeeeee;
    padding: 80px 32px;
  }

  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-logo {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #222222;
    text-decoration: none;
  }

  .footer-logo:hover {
    color: #999999;
  }

  .footer-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    color: #999999;
    letter-spacing: 0.02em;
  }

  .footer-back {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #999999;
    text-decoration: none;
    margin-top: 8px;
    transition: color 0.2s;
  }

  .footer-back:hover {
    color: #222222;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 80px 24px 64px;
    }

    .section {
      padding: 56px 24px;
    }

    .section-label {
      margin-bottom: 32px;
    }

    .characteristics-grid {
      grid-template-columns: 1fr;
    }

    .char-card {
      border-right: none;
      padding: 28px 0;
    }

    .char-card:last-child {
      border-bottom: none;
    }

    .use-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .related-card {
      border-right: none;
    }

    .related-card:last-child {
      border-bottom: none;
    }

    .prompt-text {
      font-size: 0.85rem;
      padding: 20px 16px;
    }

    .prompt-header {
      padding: 14px 16px;
    }

    .nav-inner {
      padding: 18px 24px;
    }

    .footer {
      padding: 56px 24px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 60px 20px 48px;
    }

    .hero-label {
      margin-bottom: 28px;
    }

    .section {
      padding: 40px 20px;
    }

    .nav-inner {
      padding: 14px 20px;
      gap: 8px;
    }

    .nav-logo {
      font-size: 0.7rem;
    }

    .nav-current {
      font-size: 0.7rem;
    }

    .char-card {
      padding: 24px 0;
    }

    .copy-button {
      padding: 6px 14px;
      font-size: 0.65rem;
    }

    .use-item {
      padding: 10px 0;
      font-size: 0.9rem;
    }

    .related-card {
      padding: 24px 0;
    }
  }
</style>
