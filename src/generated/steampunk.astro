---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;600;700&family=Cutive+Mono&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">&#9881;</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-gear hero-gear-left"></div>
    <div class="hero-gear hero-gear-right"></div>
    <div class="hero-inner">
      <span class="hero-label">Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-rule-rivet"></span>
        <span class="hero-rule-bar"></span>
        <span class="hero-rule-rivet"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
    <div class="hero-pipe-row">
      <div class="hero-pipe"></div>
      <div class="hero-pipe-joint"></div>
      <div class="hero-pipe"></div>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-bolt"></div>
        <span class="section-label">What This Is</span>
        <div class="section-bolt"></div>
      </div>
      <h2 class="section-heading">Philosophy</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-bolt"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-bolt"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <div class="char-rivet char-rivet-tl"></div>
            <div class="char-rivet char-rivet-tr"></div>
            <div class="char-rivet char-rivet-bl"></div>
            <div class="char-rivet char-rivet-br"></div>
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-bolt"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-bolt"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-bolt"></div>
        <span class="section-label">When to Use</span>
        <div class="section-bolt"></div>
      </div>
      <h2 class="section-heading">Use Cases</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-bolt"></div>
        <span class="section-label">Origins</span>
        <div class="section-bolt"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-bolt"></div>
        <span class="section-label">Explore</span>
        <div class="section-bolt"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&#9881;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-pipe"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-pipe"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Spectral', serif;
    background-color: #2C1810;
    color: #E8D5B5;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background:
      linear-gradient(180deg, #3a2218 0%, #2C1810 100%);
    border-bottom: 3px ridge #B87333;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .nav-logo {
    font-family: 'Spectral', serif;
    font-weight: 700;
    font-size: 0.9rem;
    color: #CD9B1D;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding: 8px 20px;
    border: 2px ridge #B87333;
    background: linear-gradient(135deg, rgba(205, 155, 29, 0.1), rgba(184, 115, 51, 0.15));
    transition: background 0.3s, color 0.3s;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }

  .nav-logo:hover {
    background: linear-gradient(135deg, #CD9B1D, #B8860B, #CD9B1D);
    color: #2C1810;
    text-shadow: none;
  }

  .nav-divider {
    font-size: 1rem;
    color: #B87333;
  }

  .nav-current {
    font-family: 'Cutive Mono', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    color: #E8D5B5;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 8px 20px;
    border: 1px solid rgba(184, 115, 51, 0.4);
    transition: border-color 0.3s, background 0.3s;
  }

  .nav-current:hover {
    border-color: #B87333;
    background: rgba(184, 115, 51, 0.1);
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background:
      radial-gradient(ellipse at 30% 20%, rgba(184, 115, 51, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(205, 155, 29, 0.06) 0%, transparent 50%),
      linear-gradient(180deg, #2C1810 0%, #1a0e08 100%);
    padding: 100px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 3px ridge #B87333;
  }

  .hero-gear {
    position: absolute;
    width: 200px;
    height: 200px;
    border: 8px solid rgba(184, 115, 51, 0.12);
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-gear::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 50%;
    height: 50%;
    border: 4px solid rgba(184, 115, 51, 0.1);
    border-radius: 50%;
  }

  .hero-gear::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(45deg);
    width: 90%;
    height: 6px;
    background: rgba(184, 115, 51, 0.08);
    box-shadow:
      0 0 0 0 transparent,
      0 47px 0 -1px rgba(184, 115, 51, 0.08),
      0 -47px 0 -1px rgba(184, 115, 51, 0.08);
  }

  .hero-gear-left {
    top: -40px;
    left: -60px;
  }

  .hero-gear-right {
    bottom: -30px;
    right: -50px;
    width: 160px;
    height: 160px;
  }

  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Cutive Mono', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: #B87333;
    display: inline-block;
    margin-bottom: 28px;
    padding: 6px 24px;
    border: 2px double #B87333;
  }

  .hero-title {
    font-family: 'Spectral', serif;
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 6.5rem);
    line-height: 1;
    margin: 0 0 28px 0;
    letter-spacing: 0.06em;
    color: #E8D5B5;
    text-transform: uppercase;
    text-shadow:
      0 2px 4px rgba(0, 0, 0, 0.6),
      0 0 20px rgba(205, 155, 29, 0.15);
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .hero-rule-bar {
    flex: 1;
    max-width: 240px;
    height: 3px;
    background: linear-gradient(90deg, transparent, #CD9B1D, #B8860B, #CD9B1D, transparent);
    border-radius: 1px;
  }

  .hero-rule-rivet {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #CD9B1D, #8B6914 70%, #5a4510);
    border: 1px solid #463020;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      0 1px 3px rgba(0, 0, 0, 0.5);
    flex-shrink: 0;
  }

  .hero-tagline {
    font-family: 'Spectral', serif;
    font-weight: 400;
    font-size: clamp(1.1rem, 2.5vw, 1.45rem);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 600px;
    color: #E8D5B5;
    font-style: italic;
  }

  .hero-pipe-row {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 60px;
    gap: 0;
  }

  .hero-pipe {
    height: 6px;
    flex: 1;
    max-width: 200px;
    background: linear-gradient(180deg, #B87333, #8B5A2B, #B87333);
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    border-bottom: 1px solid rgba(0, 0, 0, 0.4);
  }

  .hero-pipe-joint {
    width: 20px;
    height: 14px;
    background: linear-gradient(180deg, #CD9B1D, #8B6914, #CD9B1D);
    border: 1px solid #463020;
    border-radius: 2px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 96px 32px;
    border-bottom: 3px ridge rgba(184, 115, 51, 0.5);
  }

  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin-bottom: 16px;
  }

  .section-bolt {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #CD9B1D, #8B6914 70%, #5a4510);
    border: 1px solid #463020;
    box-shadow:
      inset 0 1px 2px rgba(255, 255, 255, 0.3),
      0 1px 3px rgba(0, 0, 0, 0.4);
    flex-shrink: 0;
    position: relative;
  }

  .section-bolt::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 8px;
    height: 2px;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 1px;
  }

  .section-label {
    font-family: 'Cutive Mono', monospace;
    font-weight: 400;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #B87333;
    white-space: nowrap;
  }

  .section-heading {
    font-family: 'Spectral', serif;
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.1;
    margin: 0 0 56px 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
    color: #E8D5B5;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.4);
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 3px,
        rgba(0, 0, 0, 0.015) 3px,
        rgba(0, 0, 0, 0.015) 6px
      ),
      linear-gradient(180deg, #E8D5B5 0%, #DCC9A3 100%);
    color: #2C1810;
  }

  .about-section .section-heading {
    color: #2C1810;
    text-shadow: none;
  }

  .about-section .section-label {
    color: #8B5A2B;
  }

  .about-content {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Spectral', serif;
    font-weight: 400;
    font-size: 1.25rem;
    line-height: 1.85;
    margin: 0 0 28px 0;
    color: #463020;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background:
      radial-gradient(ellipse at 50% 0%, rgba(184, 115, 51, 0.05) 0%, transparent 60%),
      #2C1810;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 28px;
  }

  .char-card {
    border: 2px ridge #8B7355;
    padding: 40px 32px 32px;
    position: relative;
    text-align: center;
    background:
      linear-gradient(180deg, rgba(70, 48, 32, 0.6) 0%, rgba(44, 24, 16, 0.8) 100%);
    transition: background 0.3s, box-shadow 0.3s;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .char-card:hover {
    background:
      linear-gradient(180deg, rgba(70, 48, 32, 0.8) 0%, rgba(44, 24, 16, 0.9) 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 4px 16px rgba(0, 0, 0, 0.3);
  }

  .char-rivet {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #B87333, #6a4520 70%);
    border: 1px solid #463020;
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, 0.25),
      0 1px 2px rgba(0, 0, 0, 0.4);
  }

  .char-rivet-tl { top: 10px; left: 10px; }
  .char-rivet-tr { top: 10px; right: 10px; }
  .char-rivet-bl { bottom: 10px; left: 10px; }
  .char-rivet-br { bottom: 10px; right: 10px; }

  .char-number {
    font-family: 'Cutive Mono', monospace;
    font-weight: 400;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #B87333;
    display: block;
    margin-bottom: 12px;
  }

  .char-divider {
    width: 40px;
    height: 2px;
    background: linear-gradient(90deg, transparent, #CD9B1D, transparent);
    margin: 0 auto 16px;
  }

  .char-title {
    font-family: 'Spectral', serif;
    font-weight: 700;
    font-size: 1.3rem;
    margin: 0 0 14px 0;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #CD9B1D;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
  }

  .char-description {
    font-family: 'Spectral', serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0;
    color: rgba(232, 213, 181, 0.8);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 30px,
        rgba(184, 115, 51, 0.03) 30px,
        rgba(184, 115, 51, 0.03) 31px
      ),
      linear-gradient(180deg, #3a2218 0%, #2C1810 100%);
  }

  .prompt-block {
    border: 2px ridge #8B7355;
    margin: 0 auto;
    position: relative;
    background: rgba(26, 14, 8, 0.6);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 28px;
    border-bottom: 2px ridge #8B7355;
    background: linear-gradient(135deg, rgba(205, 155, 29, 0.08), rgba(184, 115, 51, 0.12));
  }

  .prompt-header-label {
    font-family: 'Cutive Mono', monospace;
    font-weight: 400;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #B87333;
  }

  .copy-button {
    font-family: 'Cutive Mono', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    background: linear-gradient(135deg, rgba(205, 155, 29, 0.15), rgba(184, 115, 51, 0.2));
    color: #CD9B1D;
    border: 2px ridge #B87333;
    padding: 8px 24px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: background 0.3s, color 0.3s;
  }

  .copy-button:hover {
    background: linear-gradient(135deg, #CD9B1D, #B8860B, #CD9B1D);
    color: #2C1810;
  }

  .copy-button.copied {
    background: linear-gradient(135deg, #CD9B1D, #B8860B, #CD9B1D);
    color: #2C1810;
  }

  .prompt-text {
    font-family: 'Cutive Mono', monospace;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.85;
    color: rgba(232, 213, 181, 0.85);
    padding: 32px 28px;
    margin: 0;
    white-space: normal;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 3px,
        rgba(0, 0, 0, 0.015) 3px,
        rgba(0, 0, 0, 0.015) 6px
      ),
      linear-gradient(180deg, #E8D5B5 0%, #DCC9A3 100%);
    color: #2C1810;
  }

  .use-section .section-heading {
    color: #2C1810;
    text-shadow: none;
  }

  .use-section .section-label {
    color: #8B5A2B;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    max-width: 900px;
    margin: 0 auto;
  }

  .use-column {
    border: 2px ridge #8B7355;
    background: rgba(255, 255, 255, 0.3);
  }

  .use-column-heading {
    font-family: 'Spectral', serif;
    font-weight: 700;
    font-size: 1rem;
    margin: 0;
    padding: 18px 24px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-align: center;
    border-bottom: 2px ridge #8B7355;
  }

  .use-good .use-column-heading {
    background: linear-gradient(135deg, rgba(205, 155, 29, 0.2), rgba(184, 115, 51, 0.15));
    color: #2C1810;
  }

  .use-bad .use-column-heading {
    background: rgba(70, 48, 32, 0.1);
    color: #2C1810;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Spectral', serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.5;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(139, 115, 85, 0.3);
    display: flex;
    align-items: flex-start;
