---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />

<div class="ed-page">
  <!-- NAV -->
  <nav class="ed-nav">
    <div class="ed-nav-inner">
      <a href="/" class="ed-nav-logo">aesthetic.fyi</a>
      <div class="ed-nav-rule"></div>
      <a href={`/${aesthetic.slug}`} class="ed-nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <header class="ed-hero">
    <div class="ed-hero-inner">
      <span class="ed-hero-label">Web Aesthetic</span>
      <h1 class="ed-hero-title">{aesthetic.name}</h1>
      <div class="ed-hero-divider"></div>
      <p class="ed-hero-tagline">{aesthetic.tagline}</p>
    </div>
  </header>

  <!-- WHAT THIS IS -->
  <section class="ed-section ed-about">
    <div class="ed-section-inner">
      <div class="ed-section-header">
        <span class="ed-section-number">I</span>
        <h2 class="ed-section-title">What This Is</h2>
      </div>
      <div class="ed-about-body">
        {aesthetic.about.split('\n\n').map((paragraph: string, i: number) => (
          <p class={`ed-body-text ${i === 0 ? 'ed-drop-cap' : ''}`}>{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="ed-section ed-characteristics">
    <div class="ed-section-inner">
      <div class="ed-section-header">
        <span class="ed-section-number">II</span>
        <h2 class="ed-section-title">Characteristics</h2>
      </div>
      <div class="ed-char-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="ed-char-item">
            <h3 class="ed-char-title">{char.title}</h3>
            <div class="ed-char-rule"></div>
            <p class="ed-char-desc">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PULL QUOTE -->
  <section class="ed-pullquote-section">
    <div class="ed-pullquote-inner">
      <blockquote class="ed-pullquote">
        <p>{aesthetic.tagline}</p>
      </blockquote>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="ed-section ed-prompt">
    <div class="ed-section-inner">
      <div class="ed-section-header">
        <span class="ed-section-number">III</span>
        <h2 class="ed-section-title">Style Reference</h2>
      </div>
      <div class="ed-prompt-block">
        <div class="ed-prompt-header">
          <span class="ed-prompt-label">Prompt</span>
          <button class="ed-copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="ed-prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="ed-section ed-usage">
    <div class="ed-section-inner">
      <div class="ed-section-header">
        <span class="ed-section-number">IV</span>
        <h2 class="ed-section-title">When to Use</h2>
      </div>
      <div class="ed-use-columns">
        <div class="ed-use-col">
          <h3 class="ed-use-heading">Good For</h3>
          <ul class="ed-use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="ed-use-item ed-use-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="ed-use-col">
          <h3 class="ed-use-heading ed-use-heading-not">Not For</h3>
          <ul class="ed-use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="ed-use-item ed-use-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="ed-section ed-history">
    <div class="ed-section-inner">
      <div class="ed-section-header">
        <span class="ed-section-number">V</span>
        <h2 class="ed-section-title">History</h2>
      </div>
      <div class="ed-history-body">
        {aesthetic.history.split('\n\n').map((paragraph: string, i: number) => (
          <p class={`ed-body-text ${i === 0 ? 'ed-drop-cap' : ''}`}>{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="ed-section ed-related">
    <div class="ed-section-inner">
      <div class="ed-section-header">
        <span class="ed-section-number">VI</span>
        <h2 class="ed-section-title">Related Styles</h2>
      </div>
      <div class="ed-related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="ed-related-card">
            <span class="ed-related-rel">{rel.relationship}</span>
            <span class="ed-related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="ed-related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="ed-footer">
    <div class="ed-footer-inner">
      <div class="ed-footer-rule"></div>
      <a href="/" class="ed-footer-logo">aesthetic.fyi</a>
      <span class="ed-footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="ed-footer-back">&larr; Back to all aesthetics</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.ed-copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .ed-page {
    font-family: 'Source Serif 4', Georgia, 'Times New Roman', serif;
    background-color: #F8F5F0;
    color: #1A1A1A;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .ed-nav {
    border-bottom: 1px solid #000000;
    background: #F8F5F0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .ed-nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 18px 32px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ed-nav-logo {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #1A1A1A;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .ed-nav-logo:hover {
    color: #CC0000;
  }

  .ed-nav-rule {
    flex: 1;
    height: 1px;
    background: #000000;
  }

  .ed-nav-current {
    font-family: 'Source Serif 4', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.85rem;
    color: #666;
    text-decoration: none;
  }

  .ed-nav-current:hover {
    color: #1A1A1A;
  }

  /* ========================================
     HERO
     ======================================== */
  .ed-hero {
    border-bottom: 1px solid #000000;
    padding: 0;
  }

  .ed-hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 100px 32px 90px;
    text-align: center;
  }

  .ed-hero-label {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 400;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: #CC0000;
    display: block;
    margin-bottom: 32px;
  }

  .ed-hero-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1.0;
    margin: 0 0 36px 0;
    letter-spacing: -0.02em;
    color: #1A1A1A;
  }

  .ed-hero-divider {
    width: 80px;
    height: 1px;
    background: #000000;
    margin: 0 auto 32px;
  }

  .ed-hero-tagline {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.15rem, 2.5vw, 1.5rem);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 560px;
    color: #666;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .ed-section {
    padding: 100px 0;
    border-bottom: 1px solid #000000;
  }

  .ed-section-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .ed-section-header {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 52px;
    border-bottom: 1px solid #000000;
    padding-bottom: 16px;
  }

  .ed-section-number {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 400;
    font-size: 1rem;
    color: #CC0000;
    letter-spacing: 0.05em;
  }

  .ed-section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1;
    margin: 0;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }

  /* ========================================
     ABOUT / BODY TEXT
     ======================================== */
  .ed-about-body {
    max-width: 720px;
    columns: 1;
  }

  .ed-body-text {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #1A1A1A;
    text-align: justify;
    hyphens: auto;
  }

  .ed-body-text:last-child {
    margin-bottom: 0;
  }

  /* Drop cap */
  .ed-drop-cap::first-letter {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 4.2rem;
    float: left;
    line-height: 0.75;
    margin-right: 10px;
    margin-top: 8px;
    color: #1A1A1A;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .ed-char-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid #000000;
  }

  .ed-char-item {
    padding: 36px 32px 36px 0;
    border-bottom: 1px solid #000000;
  }

  .ed-char-item:nth-child(even) {
    padding-left: 32px;
    padding-right: 0;
    border-left: 1px solid #000000;
  }

  .ed-char-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 1.25rem;
    margin: 0 0 12px 0;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }

  .ed-char-rule {
    width: 32px;
    height: 1px;
    background: #CC0000;
    margin-bottom: 12px;
  }

  .ed-char-desc {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    margin: 0;
    color: #666;
    text-align: justify;
    hyphens: auto;
  }

  /* ========================================
     PULL QUOTE
     ======================================== */
  .ed-pullquote-section {
    padding: 80px 0;
    border-bottom: 1px solid #000000;
    background: #F8F5F0;
  }

  .ed-pullquote-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .ed-pullquote {
    margin: 0;
    padding: 0 0 0 32px;
    border-left: 3px solid #CC0000;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .ed-pullquote p {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    line-height: 1.4;
    margin: 0;
    color: #1A1A1A;
    letter-spacing: -0.01em;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .ed-prompt-block {
    border: 1px solid #000000;
    background: #FFFFFF;
  }

  .ed-prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid #000000;
  }

  .ed-prompt-label {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #1A1A1A;
  }

  .ed-copy-button {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 600;
    font-size: 0.75rem;
    background: #F8F5F0;
    color: #1A1A1A;
    border: 1px solid #000000;
    padding: 7px 18px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: background 0.2s, color 0.2s;
  }

  .ed-copy-button:hover {
    background: #1A1A1A;
    color: #F8F5F0;
  }

  .ed-copy-button.copied {
    background: #CC0000;
    color: #FFFFFF;
    border-color: #CC0000;
  }

  .ed-prompt-text {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.85;
    color: #1A1A1A;
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
    text-align: justify;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .ed-use-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .ed-use-col:first-child {
    padding-right: 48px;
    border-right: 1px solid #000000;
  }

  .ed-use-col:last-child {
    padding-left: 48px;
  }

  .ed-use-heading {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 1.1rem;
    margin: 0 0 24px 0;
    color: #1A1A1A;
    padding-bottom: 12px;
    border-bottom: 1px solid #000000;
  }

  .ed-use-heading-not {
    border-bottom-color: #CC0000;
  }

  .ed-use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ed-use-item {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.6;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: #1A1A1A;
  }

  .ed-use-item:last-child {
    border-bottom: none;
  }

  .ed-use-good::before {
    content: '\2713';
    font-weight: 600;
    font-size: 0.9rem;
    color: #1A1A1A;
    flex-shrink: 0;
  }

  .ed-use-bad::before {
    content: '\2013';
    font-weight: 600;
    font-size: 1rem;
    color: #CC0000;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .ed-history-body {
    columns: 2;
    column-gap: 48px;
    column-rule: 1px solid #000000;
    max-width: 100%;
  }

  .ed-history-body .ed-body-text {
    break-inside: avoid;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .ed-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid #000000;
  }

  .ed-related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 28px;
    background: #FFFFFF;
    text-decoration: none;
    color: #1A1A1A;
    border-right: 1px solid #000000;
    border-bottom: 1px solid #000000;
    position: relative;
    transition: background 0.2s, color 0.2s;
  }

  .ed-related-card:nth-child(3n) {
    border-right: none;
  }

  .ed-related-card:nth-last-child(-n+3) {
    border-bottom: none;
  }

  .ed-related-card:hover {
    background: #1A1A1A;
    color: #F8F5F0;
  }

  .ed-related-card:hover .ed-related-rel {
    color: #CC0000;
  }

  .ed-related-card:hover .ed-related-arrow {
    color: #CC0000;
  }

  .ed-related-rel {
    font-family: 'Source Serif 4', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.75rem;
    color: #666;
    transition: color 0.2s;
  }

  .ed-related-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.01em;
  }

  .ed-related-arrow {
    font-size: 1.1rem;
    position: absolute;
    bottom: 24px;
    right: 24px;
    color: #1A1A1A;
    transition: color 0.2s;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .ed-footer {
    background: #1A1A1A;
    padding: 72px 32px;
  }

  .ed-footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .ed-footer-rule {
    width: 48px;
    height: 1px;
    background: #CC0000;
    margin-bottom: 8px;
  }

  .ed-footer-logo {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 700;
    font-size: 1rem;
    color: #F8F5F0;
    text-decoration: none;
  }

  .ed-footer-logo:hover {
    color: #CC0000;
  }

  .ed-footer-tagline {
    font-family: 'Source Serif 4', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: 0.9rem;
    color: #666;
  }

  .ed-footer-back {
    font-family: 'Source Serif 4', Georgia, serif;
    font-weight: 600;
    font-size: 0.8rem;
    color: #F8F5F0;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 8px 0;
    border-bottom: 1px solid #F8F5F0;
    transition: color 0.2s, border-color 0.2s;
  }

  .ed-footer-back:hover {
    color: #CC0000;
    border-color: #CC0000;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 900px) {
    .ed-hero-inner {
      padding: 72px 24px 64px;
    }

    .ed-section {
      padding: 72px 0;
    }

    .ed-section-inner {
      padding: 0 24px;
    }

    .ed-char-grid {
      grid-template-columns: 1fr;
    }

    .ed-char-item:nth-child(even) {
      padding-left: 0;
      border-left: none;
    }

    .ed-char-item {
      padding-right: 0;
    }

    .ed-use-columns {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ed-use-col:first-child {
      padding-right: 0;
      border-right: none;
    }

    .ed-use-col:last-child {
      padding-left: 0;
    }

    .ed-history-body {
      columns: 1;
    }

    .ed-related-grid {
      grid-template-columns: 1fr 1fr;
    }

    .ed-related-card:nth-child(3n) {
      border-right: 1px solid #000000;
    }

    .ed-related-card:nth-child(2n) {
      border-right: none;
    }

    .ed-related-card:nth-last-child(-n+3) {
      border-bottom: 1px solid #000000;
    }

    .ed-related-card:nth-last-child(-n+2) {
      border-bottom: none;
    }

    .ed-pullquote-section {
      padding: 56px 0;
    }

    .ed-pullquote-inner {
      padding: 0 24px;
    }

    .ed-nav-inner {
      padding: 16px 24px;
    }

    .ed-footer {
      padding: 56px 24px;
    }
  }

  @media (max-width: 560px) {
    .ed-hero-inner {
      padding: 56px 16px 48px;
    }

    .ed-section {
      padding: 56px 0;
    }

    .ed-section-inner {
      padding: 0 16px;
    }

    .ed-section-header {
      flex-direction: column;
      gap: 8px;
      margin-bottom: 36px;
    }

    .ed-drop-cap::first-letter {
      font-size: 3.2rem;
      margin-right: 8px;
      margin-top: 6px;
    }

    .ed-pullquote-section {
      padding: 40px 0;
    }

    .ed-pullquote-inner {
      padding: 0 16px;
    }

    .ed-pullquote {
      padding-left: 20px;
    }

    .ed-related-grid {
      grid-template-columns: 1fr;
    }

    .ed-related-card:nth-child(2n),
    .ed-related-card:nth-child(3n) {
      border-right: none;
    }

    .ed-related-card {
      border-bottom: 1px solid #000000;
      border-right: none;
    }

    .ed-related-card:last-child {
      border-bottom: none;
    }

    .ed-nav-inner {
      padding: 14px 16px;
    }

    .ed-nav-logo {
      font-size: 0.85rem;
    }

    .ed-prompt-header {
      flex-wrap: wrap;
      gap: 10px;
    }

    .ed-footer {
      padding: 40px 16px;
    }

    .ed-body-text {
      text-align: left;
    }

    .ed-char-desc {
      text-align: left;
    }
  }
</style>
