---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">//</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-scanlines"></div>
    <div class="hero-inner">
      <span class="hero-label">&lt;web_aesthetic&gt;</span>
      <h1 class="hero-title" data-text={aesthetic.name}>{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-glitch-line"></span>
        <span class="hero-glitch-dot"></span>
        <span class="hero-glitch-line"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// WHAT_THIS_IS</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading" data-text="Signal Corruption">Signal Corruption</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// DATA_FRAGMENTS</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading" data-text="Characteristics">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// STYLE_REF</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading" data-text="Copy & Paste">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">&gt; prompt.txt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// USE_CASES</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading" data-text="Signal / Noise">Signal / Noise</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// ORIGINS</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading" data-text="History">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// LINKED_NODES</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading" data-text="Related Styles">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Space Mono', monospace;
    background-color: #0a0a0a;
    color: #e0e0e0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
  }

  /* Global scanline overlay */
  .page::after {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.15) 2px,
      rgba(0, 0, 0, 0.15) 4px
    );
    pointer-events: none;
    z-index: 1000;
  }

  /* ========================================
     GLITCH KEYFRAMES
     ======================================== */
  @keyframes glitch-text {
    0% {
      text-shadow:
        -2px 0 #ff0040,
        2px 0 #00ffff;
      transform: translate(0);
    }
    2% {
      text-shadow:
        2px 0 #ff0040,
        -2px 0 #00ffff;
      transform: translate(2px, 0);
    }
    4% {
      text-shadow:
        -1px 0 #ff0040,
        1px 0 #00ffff;
      transform: translate(-2px, 0);
    }
    5% {
      text-shadow:
        -2px 0 #ff0040,
        2px 0 #00ffff;
      transform: translate(0);
    }
    40% {
      text-shadow:
        -2px 0 #ff0040,
        2px 0 #00ffff;
      transform: translate(0);
    }
    41% {
      text-shadow:
        4px 0 #ff0040,
        -4px 0 #00ffff;
      transform: translate(4px, 0) skewX(2deg);
    }
    42% {
      text-shadow:
        -3px 0 #ff0040,
        3px 0 #00ffff;
      transform: translate(-3px, 0) skewX(-1deg);
    }
    44% {
      text-shadow:
        -2px 0 #ff0040,
        2px 0 #00ffff;
      transform: translate(0) skewX(0);
    }
    100% {
      text-shadow:
        -2px 0 #ff0040,
        2px 0 #00ffff;
      transform: translate(0);
    }
  }

  @keyframes glitch-skew {
    0% { transform: skewX(0deg); }
    20% { transform: skewX(0deg); }
    21% { transform: skewX(-3deg); }
    22% { transform: skewX(2deg); }
    23% { transform: skewX(0deg); }
    60% { transform: skewX(0deg); }
    61% { transform: skewX(4deg); }
    62% { transform: skewX(-2deg); }
    63% { transform: skewX(0deg); }
    100% { transform: skewX(0deg); }
  }

  @keyframes glitch-clip {
    0% { clip-path: inset(0 0 100% 0); }
    5% { clip-path: inset(40% 0 30% 0); }
    10% { clip-path: inset(80% 0 5% 0); }
    15% { clip-path: inset(10% 0 70% 0); }
    20% { clip-path: inset(0 0 100% 0); }
    100% { clip-path: inset(0 0 100% 0); }
  }

  @keyframes scanline-move {
    0% { transform: translateY(-100%); }
    100% { transform: translateY(100%); }
  }

  @keyframes flicker {
    0% { opacity: 1; }
    3% { opacity: 0.4; }
    6% { opacity: 1; }
    7% { opacity: 0.7; }
    9% { opacity: 1; }
    50% { opacity: 1; }
    52% { opacity: 0.6; }
    53% { opacity: 1; }
    100% { opacity: 1; }
  }

  @keyframes border-glitch {
    0% { border-color: #222; }
    30% { border-color: #222; }
    31% { border-color: #ff0040; }
    33% { border-color: #00ffff; }
    35% { border-color: #222; }
    70% { border-color: #222; }
    71% { border-color: #00ff41; }
    73% { border-color: #222; }
    100% { border-color: #222; }
  }

  @keyframes displacement {
    0% { transform: translateX(0); }
    15% { transform: translateX(0); }
    16% { transform: translateX(-8px); }
    17% { transform: translateX(6px); }
    18% { transform: translateX(-3px); }
    19% { transform: translateX(0); }
    65% { transform: translateX(0); }
    66% { transform: translateX(5px); }
    67% { transform: translateX(-10px); }
    68% { transform: translateX(3px); }
    69% { transform: translateX(0); }
    100% { transform: translateX(0); }
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid #222;
    background: #0a0a0a;
    position: sticky;
    top: 0;
    z-index: 100;
    animation: border-glitch 8s infinite;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.9rem;
    color: #e0e0e0;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid #333;
    transition: all 0.15s;
    text-shadow: -1px 0 #ff0040, 1px 0 #00ffff;
    letter-spacing: 0.02em;
  }

  .nav-logo:hover {
    background: rgba(255, 0, 64, 0.08);
    border-color: #ff0040;
    text-shadow: -2px 0 #ff0040, 2px 0 #00ffff;
  }

  .nav-divider {
    font-size: 0.9rem;
    color: #333;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Space Mono', monospace;
    font-weight: 400;
    font-size: 0.85rem;
    color: #666;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid transparent;
    transition: all 0.15s;
  }

  .nav-current:hover {
    border-color: #333;
    color: #00ffff;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #0a0a0a;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid #222;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      linear-gradient(90deg, transparent 50%, rgba(0, 255, 65, 0.015) 50%),
      linear-gradient(0deg, transparent 50%, rgba(0, 0, 0, 0.1) 50%);
    background-size: 4px 4px;
    pointer-events: none;
  }

  .hero-scanlines {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 200%;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 1px,
      rgba(0, 255, 255, 0.03) 1px,
      rgba(0, 255, 255, 0.03) 2px
    );
    animation: scanline-move 8s linear infinite;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Space Mono', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    color: #00ff41;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.1em;
    opacity: 0.8;
  }

  .hero-title {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: clamp(2.5rem, 9vw, 5rem);
    line-height: 1.1;
    margin: 0 0 24px 0;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    animation: glitch-text 4s infinite;
    position: relative;
  }

  .hero-title::before,
  .hero-title::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    overflow: hidden;
  }

  .hero-title::before {
    color: #ff0040;
    z-index: -1;
    animation: glitch-clip 3s infinite linear alternate-reverse;
    text-shadow: none;
    left: 2px;
  }

  .hero-title::after {
    color: #00ffff;
    z-index: -1;
    animation: glitch-clip 2.5s infinite linear alternate;
    text-shadow: none;
    left: -2px;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .hero-glitch-line {
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, #ff0040, #00ffff);
    animation: flicker 3s infinite;
  }

  .hero-glitch-dot {
    width: 6px;
    height: 6px;
    background: #00ff41;
    box-shadow: 0 0 8px #00ff41;
  }

  .hero-tagline {
    font-family: 'Space Mono', monospace;
    font-weight: 400;
    font-size: clamp(0.85rem, 2vw, 1.05rem);
    line-height: 1.8;
    margin: 0 auto;
    max-width: 520px;
    color: #888;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 1px solid #222;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #333, transparent);
  }

  .section-label {
    font-family: 'Space Mono', monospace;
    font-weight: 400;
    font-size: 0.7rem;
    color: #00ff41;
    white-space: nowrap;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: clamp(1.5rem, 5vw, 2.4rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-shadow: -2px 0 #ff0040, 2px 0 #00ffff;
    position: relative;
  }

  .section-heading::before,
  .section-heading::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    overflow: hidden;
  }

  .section-heading::before {
    color: #ff0040;
    z-index: -1;
    animation: glitch-clip 4s infinite linear alternate-reverse;
    text-shadow: none;
    left: 2px;
  }

  .section-heading::after {
    color: #00ffff;
    z-index: -1;
    animation: glitch-clip 3.5s infinite linear alternate;
    text-shadow: none;
    left: -2px;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #0d0d0d;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 1px solid #1a1a1a;
    pointer-events: none;
    animation: border-glitch 6s infinite;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Space Mono', monospace;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #b0b0b0;
    animation: displacement 10s infinite;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #0a0a0a;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 1px solid #222;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: #0d0d0d;
    transition: all 0.15s;
    overflow: hidden;
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 255, 255, 0.02) 2px,
      rgba(0, 255, 255, 0.02) 4px
    );
    pointer-events: none;
  }

  .char-card:hover {
    border-color: #ff0040;
    box-shadow:
      inset 0 0 30px rgba(255, 0, 64, 0.05),
      0 0 15px rgba(255, 0, 64, 0.1);
    animation: glitch-skew 2s infinite;
  }

  .char-number {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.7rem;
    color: #ff0040;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 30px;
    height: 1px;
    background: linear-gradient(90deg, #ff0040, #00ffff);
    margin: 0 auto 14px;
  }

  .char-title {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 1rem;
    margin: 0 0 12px 0;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: -1px 0 #ff0040, 1px 0 #00ffff;
  }

  .char-description {
    font-family: 'Space Mono', monospace;
    font-weight: 400;
    font-size: 0.8rem;
    line-height: 1.8;
    margin: 0;
    color: #777;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #0d0d0d;
  }

  .prompt-block {
    border: 1px solid #222;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-block::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 255, 65, 0.015) 2px,
      rgba(0, 255, 65, 0.015) 4px
    );
    pointer-events: none;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid #222;
    background: rgba(0, 255, 65, 0.03);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Space Mono', monospace;
    font-weight: 400;
    font-size: 0.75rem;
    color: #00ff41;
    letter-spacing: 0.08em;
  }

  .copy-button {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.75rem;
    background: transparent;
    color: #e0e0e0;
    border: 1px solid #333;
    padding: 6px 20px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: all 0.15s;
  }

  .copy-button:hover {
    background: rgba(255, 0, 64, 0.1);
    border-color: #ff0040;
    color: #ff0040;
  }

  .copy-button.copied {
    background: rgba(0, 255, 65, 0.1);
    border-color: #00ff41;
    color: #00ff41;
  }

  .prompt-text {
    font-family: 'Space Mono', monospace;
    font-weight: 400;
    font-size: 0.85rem;
    line-height: 1.85;
    color: #999;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #0a0a0a;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid #222;
    overflow: hidden;
    position: relative;
  }

  .use-column::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
