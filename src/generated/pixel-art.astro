---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">&gt;</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-scanlines"></div>
    <div class="hero-inner">
      <span class="hero-label">// A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-pixel"></span>
        <span class="hero-pixel"></span>
        <span class="hero-pixel"></span>
        <span class="hero-pixel"></span>
        <span class="hero-pixel"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">The Grid Is the Canvas</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">&gt; prompt.txt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Level, Wrong Level</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">+ Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">- Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&raquo;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&lt;&lt; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Press Start 2P', monospace;
    background-color: #1a1a2e;
    color: #c0c0d0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: none;
    -moz-osx-font-smoothing: unset;
    image-rendering: pixelated;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 3px solid #33ff66;
    background: #0f0f23;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.65rem;
    color: #33ff66;
    text-decoration: none;
    padding: 8px 16px;
    border: 2px solid #33ff66;
    border-radius: 0;
    box-shadow: 3px 3px 0 #1a5c30;
    transition: background 0.15s, box-shadow 0.15s;
  }

  .nav-logo:hover {
    background: #33ff66;
    color: #0f0f23;
    box-shadow: 1px 1px 0 #1a5c30;
  }

  .nav-divider {
    font-size: 0.7rem;
    color: #7a7a9e;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.55rem;
    color: #7a7a9e;
    text-decoration: none;
    padding: 8px 16px;
    border: 2px solid transparent;
    border-radius: 0;
    transition: border-color 0.15s, color 0.15s;
  }

  .nav-current:hover {
    border-color: #7a7a9e;
    color: #c0c0d0;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #0f0f23;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 3px solid #3366ff;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 16px;
    left: 16px;
    right: 16px;
    bottom: 16px;
    border: 2px solid #3366ff;
    border-radius: 0;
    pointer-events: none;
  }

  .hero-scanlines {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.15) 2px,
      rgba(0, 0, 0, 0.15) 4px
    );
    pointer-events: none;
    z-index: 2;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 3;
  }

  .hero-label {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.55rem;
    color: #7a7a9e;
    display: inline-block;
    margin-bottom: 32px;
    letter-spacing: 0.05em;
  }

  .hero-title {
    font-family: 'Press Start 2P', monospace;
    font-weight: 400;
    font-size: clamp(1.8rem, 7vw, 3.5rem);
    line-height: 1.4;
    margin: 0 0 32px 0;
    color: #33ff66;
    text-shadow:
      4px 4px 0 #1a5c30,
      -1px -1px 0 #0f0f23;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 32px;
  }

  .hero-pixel {
    width: 8px;
    height: 8px;
    border-radius: 0;
    background: #ffcc00;
  }

  .hero-tagline {
    font-family: 'Press Start 2P', monospace;
    font-weight: 400;
    font-size: clamp(0.5rem, 1.5vw, 0.7rem);
    line-height: 2.2;
    margin: 0 auto;
    max-width: 560px;
    color: #7a7a9e;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 3px solid #3366ff;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 16px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 2px;
    background: #3366ff;
    border-radius: 0;
  }

  .section-label {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.5rem;
    color: #7a7a9e;
    white-space: nowrap;
    letter-spacing: 0.03em;
  }

  .section-heading {
    font-family: 'Press Start 2P', monospace;
    font-weight: 400;
    font-size: clamp(0.9rem, 3vw, 1.4rem);
    line-height: 1.6;
    margin: 0 0 48px 0;
    text-align: center;
    color: #33ff66;
    text-shadow: 3px 3px 0 #1a5c30;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #0f0f23;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    bottom: 12px;
    border: 2px solid #33ff66;
    border-radius: 0;
    pointer-events: none;
  }

  .about-content {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Press Start 2P', monospace;
    font-weight: 400;
    font-size: 0.6rem;
    line-height: 2.4;
    margin: 0 0 28px 0;
    color: #c0c0d0;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #1a1a2e;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 2px solid #3366ff;
    border-radius: 0;
    padding: 32px 24px 24px;
    position: relative;
    text-align: center;
    background: #0f0f23;
    box-shadow: 4px 4px 0 #1a2a5c;
    transition: box-shadow 0.15s, border-color 0.15s;
  }

  .char-card:hover {
    box-shadow: 6px 6px 0 #1a2a5c;
    border-color: #33ff66;
  }

  .char-number {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.5rem;
    color: #ffcc00;
    display: block;
    margin-bottom: 12px;
    letter-spacing: 0.1em;
  }

  .char-divider {
    width: 32px;
    height: 2px;
    background: #3366ff;
    margin: 0 auto 16px;
    border-radius: 0;
  }

  .char-title {
    font-family: 'Press Start 2P', monospace;
    font-weight: 400;
    font-size: 0.65rem;
    margin: 0 0 16px 0;
    color: #33ff66;
    line-height: 1.6;
  }

  .char-description {
    font-family: 'Press Start 2P', monospace;
    font-weight: 400;
    font-size: 0.5rem;
    line-height: 2.2;
    margin: 0;
    color: #7a7a9e;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #0f0f23;
  }

  .prompt-block {
    border: 2px solid #33ff66;
    border-radius: 0;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    box-shadow: 4px 4px 0 #1a5c30;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 20px;
    border-bottom: 2px solid #33ff66;
    background: rgba(51, 255, 102, 0.05);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.5rem;
    color: #33ff66;
    letter-spacing: 0.03em;
  }

  .copy-button {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.5rem;
    background: transparent;
    color: #ffcc00;
    border: 2px solid #ffcc00;
    border-radius: 0;
    padding: 8px 16px;
    cursor: pointer;
    box-shadow: 2px 2px 0 #7a6600;
    transition: background 0.15s, box-shadow 0.15s;
  }

  .copy-button:hover {
    background: #ffcc00;
    color: #0f0f23;
    box-shadow: 1px 1px 0 #7a6600;
  }

  .copy-button.copied {
    background: #33ff66;
    color: #0f0f23;
    border-color: #33ff66;
    box-shadow: 1px 1px 0 #1a5c30;
  }

  .prompt-text {
    font-family: 'Press Start 2P', monospace;
    font-weight: 400;
    font-size: 0.5rem;
    line-height: 2.4;
    color: #c0c0d0;
    padding: 24px 20px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #1a1a2e;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 2px solid #3366ff;
    border-radius: 0;
    overflow: hidden;
    position: relative;
    box-shadow: 4px 4px 0 #1a2a5c;
  }

  .use-column-heading {
    font-family: 'Press Start 2P', monospace;
    font-weight: 400;
    font-size: 0.55rem;
    margin: 0;
    padding: 16px 20px;
    text-align: center;
    border-bottom: 2px solid #3366ff;
    line-height: 1.6;
  }

  .use-good .use-column-heading {
    background: rgba(51, 255, 102, 0.08);
    color: #33ff66;
  }

  .use-bad .use-column-heading {
    background: rgba(255, 51, 102, 0.08);
    color: #ff3366;
  }

  .use-good {
    border-color: #33ff66;
    box-shadow: 4px 4px 0 #1a5c30;
  }

  .use-good .use-column-heading {
    border-bottom-color: #33ff66;
  }

  .use-bad {
    border-color: #ff3366;
    box-shadow: 4px 4px 0 #5c1a30;
  }

  .use-bad .use-column-heading {
    border-bottom-color: #ff3366;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
    background: #0f0f23;
  }

  .use-item {
    font-family: 'Press Start 2P', monospace;
    font-weight: 400;
    font-size: 0.45rem;
    line-height: 1.8;
    padding: 14px 20px;
    border-bottom: 1px solid rgba(51, 102, 255, 0.2);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #c0c0d0;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '+';
    color: #33ff66;
    flex-shrink: 0;
    font-family: 'Press Start 2P', monospace;
    font-size: 0.45rem;
  }

  .use-item-bad::before {
    content: 'x';
    color: #ff3366;
    flex-shrink: 0;
    font-family: 'Press Start 2P', monospace;
    font-size: 0.45rem;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #0f0f23;
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    bottom: 12px;
    border: 2px solid #ffcc00;
    border-radius: 0;
    pointer-events: none;
  }

  .history-content {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Press Start 2P', monospace;
    font-weight: 400;
    font-size: 0.55rem;
    line-height: 2.4;
    margin: 0 0 28px 0;
    color: #c0c0d0;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #1a1a2e;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 28px 16px;
    border: 2px solid #3366ff;
    border-radius: 0;
    text-decoration: none;
    color: #c0c0d0;
    text-align: center;
    position: relative;
    background: #0f0f23;
    box-shadow: 4px 4px 0 #1a2a5c;
    transition: box-shadow 0.15s, border-color 0.15s;
  }

  .related-card:hover {
    box-shadow: 6px 6px 0 #1a2a5c;
    border-color: #33ff66;
  }

  .related-relationship {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.4rem;
    color: #7a7a9e;
    letter-spacing: 0.03em;
  }

  .related-name {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.6rem;
    color: #33ff66;
    line-height: 1.6;
  }

  .related-arrow {
    font-size: 0.7rem;
    color: #ffcc00;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #0f0f23;
    padding: 64px 32px;
    border-top: 3px solid #33ff66;
  }

  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-ornament {
    width: 80px;
    height: 2px;
    background: #3366ff;
    border-radius: 0;
  }

  .footer-logo {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.6rem;
    color: #33ff66;
    text-decoration: none;
    padding: 10px 20px;
    border: 2px solid #33ff66;
    border-radius: 0;
    box-shadow: 3px 3px 0 #1a5c30;
    transition: background 0.15s, box-shadow 0.15s;
  }

  .footer-logo:hover {
    background: #33ff66;
    color: #0f0f23;
    box-shadow: 1px 1px 0 #1a5c30;
  }

  .footer-tagline {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.45rem;
    color: #7a7a9e;
    line-height: 1.8;
  }

  .footer-back {
    font-family: 'Press Start 2P', monospace;
    font-size: 0.5rem;
    color: #ffcc00;
    text-decoration: none;
    padding: 8px 16px;
    border: 2px solid transparent;
    border-radius: 0;
    transition: border-color 0.15s;
  }

  .footer-back:hover {
    border-color: #ffcc00;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 64px 24px 56px;
    }

    .hero::before {
      top: 10px;
      left: 10px;
      right: 10px;
      bottom: 10px;
    }

    .section {
      padding: 64px 24px;
    }

    .section-heading {
      margin-bottom: 36px;
    }

    .characteristics-grid {
      grid-template-columns: 1fr;
    }

    .use-grid {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .prompt-text {
      font-size: 0.45rem;
      padding: 20px 16px;
    }

    .prompt-header {
      padding: 12px 16px;
      flex-wrap: wrap;
      gap: 10px;
    }

    .nav-inner {
      padding: 12px 20px;
    }

    .footer {
      padding: 48px 24px;
    }

    .about-section::before,
    .history-section::before {
      top: 8px;
      left: 8px;
      right: 8px;
