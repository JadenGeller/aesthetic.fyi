---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Space+Grotesk:wght@400;600;700&family=Pacifico&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- DECORATIVE FLOATING SHAPES -->
  <div class="deco-shape deco-shape-1"></div>
  <div class="deco-shape deco-shape-2"></div>
  <div class="deco-shape deco-shape-3"></div>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">&clubs;</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
      <div class="nav-deco"></div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg-stripe"></div>
    <div class="hero-bg-dots"></div>
    <div class="hero-inner">
      <span class="hero-label">Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
      <div class="hero-deco-row">
        <span class="hero-deco-star">&#10038;</span>
        <span class="hero-deco-diamond">&#9830;</span>
        <span class="hero-deco-star">&#10038;</span>
        <span class="hero-deco-diamond">&#9830;</span>
        <span class="hero-deco-star">&#10038;</span>
      </div>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="about-accent-bar"></div>
    <div class="section-inner">
      <span class="section-label">What This Is</span>
      <h2 class="section-heading about-heading">Philosophy</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <span class="section-label char-label">Design Tokens</span>
      <h2 class="section-heading char-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class={`char-card char-card-${i % 6}`}>
            <span class="char-number">#{String(i + 1).padStart(2, '0')}</span>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <span class="section-label prompt-label">Copy & Paste</span>
      <h2 class="section-heading prompt-heading">Style Reference</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">PROMPT</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <span class="section-label use-label">When to Use</span>
      <h2 class="section-heading use-heading">Use Cases</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good for</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not for</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <span class="section-label history-label">Origins</span>
      <h2 class="section-heading history-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <span class="section-label related-label">Explore</span>
      <h2 class="section-heading related-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }, i: number) => (
          <a href={`/${rel.slug}`} class={`related-card related-card-${i % 6}`}>
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to all aesthetics</a>
      <div class="footer-deco-row">
        <span class="footer-deco">&#10038;</span>
        <span class="footer-deco">&#9830;</span>
        <span class="footer-deco">&#10038;</span>
        <span class="footer-deco">&#9830;</span>
        <span class="footer-deco">&#10038;</span>
      </div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     KEYFRAMES
     ======================================== */
  @keyframes bgScroll {
    0% { background-position: 0 0; }
    100% { background-position: 200px 200px; }
  }

  @keyframes floatBounce {
    0%, 100% { transform: translateY(0) rotate(12deg); }
    50% { transform: translateY(-20px) rotate(-8deg); }
  }

  @keyframes floatBounce2 {
    0%, 100% { transform: translateY(0) rotate(-15deg); }
    50% { transform: translateY(-30px) rotate(10deg); }
  }

  @keyframes floatBounce3 {
    0%, 100% { transform: translateY(0) rotate(5deg); }
    50% { transform: translateY(-15px) rotate(-20deg); }
  }

  @keyframes rainbowShift {
    0% { filter: hue-rotate(0deg); }
    100% { filter: hue-rotate(360deg); }
  }

  @keyframes wiggle {
    0%, 100% { transform: rotate(-3deg); }
    50% { transform: rotate(3deg); }
  }

  /* ========================================
     BASE
     ======================================== */
  .page {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
    overflow-x: hidden;
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 20px,
        rgba(255, 20, 147, 0.04) 20px,
        rgba(255, 20, 147, 0.04) 40px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 30px,
        rgba(0, 191, 255, 0.04) 30px,
        rgba(0, 191, 255, 0.04) 60px
      ),
      #FFFDF7;
  }

  /* ========================================
     FLOATING DECORATIVE SHAPES
     ======================================== */
  .deco-shape {
    position: fixed;
    z-index: 0;
    pointer-events: none;
  }

  .deco-shape-1 {
    width: 120px;
    height: 120px;
    background: linear-gradient(135deg, #FF1493, #FFD700);
    border: 4px dashed #8B00FF;
    border-radius: 50%;
    top: 15%;
    right: 3%;
    opacity: 0.25;
    animation: floatBounce 6s ease-in-out infinite;
  }

  .deco-shape-2 {
    width: 80px;
    height: 80px;
    background: linear-gradient(45deg, #00BFFF, #32CD32);
    border: 3px double #FF6600;
    top: 45%;
    left: 2%;
    opacity: 0.2;
    animation: floatBounce2 8s ease-in-out infinite;
  }

  .deco-shape-3 {
    width: 60px;
    height: 60px;
    background: linear-gradient(90deg, #FFD700, #FF1493);
    border: 3px dotted #00BFFF;
    border-radius: 50% 0 50% 0;
    bottom: 20%;
    right: 5%;
    opacity: 0.2;
    animation: floatBounce3 7s ease-in-out infinite;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background:
      repeating-linear-gradient(
        90deg,
        #FF1493 0px,
        #FF1493 4px,
        transparent 4px,
        transparent 12px
      ),
      linear-gradient(135deg, #1a1a1a, #2a1a3a);
    border-bottom: 4px double #FFD700;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow:
      0 4px 0 #FF1493,
      0 8px 0 #00BFFF;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    position: relative;
  }

  .nav-logo {
    font-family: 'Pacifico', cursive;
    font-size: 1.2rem;
    color: #FFD700;
    text-decoration: none;
    text-shadow: 2px 2px 0 #FF1493, -1px -1px 0 #00BFFF;
    padding: 6px 16px;
    border: 2px dashed #FFD700;
    border-radius: 20px;
    transition: transform 0.2s, text-shadow 0.2s;
  }

  .nav-logo:hover {
    transform: scale(1.1) rotate(-3deg);
    text-shadow: 3px 3px 0 #FF1493, -2px -2px 0 #00BFFF, 0 0 20px #FFD700;
  }

  .nav-divider {
    font-size: 1.4rem;
    color: #FF6600;
    animation: wiggle 2s ease-in-out infinite;
  }

  .nav-current {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #32CD32;
    text-decoration: none;
    padding: 6px 14px;
    border: 2px dotted #32CD32;
    border-radius: 0 12px 0 12px;
    transition: all 0.2s;
  }

  .nav-current:hover {
    background: #32CD32;
    color: #1a1a1a;
    border-style: solid;
  }

  .nav-deco {
    margin-left: auto;
    width: 30px;
    height: 30px;
    background: linear-gradient(45deg, #FF1493, #00BFFF, #32CD32, #FFD700);
    border-radius: 50%;
    border: 2px solid #FFD700;
    animation: rainbowShift 4s linear infinite;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    position: relative;
    padding: 100px 24px 90px;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 40px,
        rgba(255, 215, 0, 0.15) 40px,
        rgba(255, 215, 0, 0.15) 42px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 40px,
        rgba(139, 0, 255, 0.1) 40px,
        rgba(139, 0, 255, 0.1) 42px
      ),
      linear-gradient(
        135deg,
        #FF1493 0%,
        #8B00FF 25%,
        #00BFFF 50%,
        #32CD32 75%,
        #FFD700 100%
      );
    overflow: hidden;
  }

  .hero-bg-stripe {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 30px,
        rgba(255, 255, 255, 0.06) 30px,
        rgba(255, 255, 255, 0.06) 60px
      );
    animation: bgScroll 20s linear infinite;
    pointer-events: none;
  }

  .hero-bg-dots {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.12) 2px, transparent 2px);
    background-size: 24px 24px;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    background: #1a1a1a;
    color: #FFD700;
    padding: 8px 20px;
    display: inline-block;
    margin-bottom: 28px;
    border: 2px solid #FFD700;
    box-shadow: 4px 4px 0 #FF1493, -2px -2px 0 #00BFFF;
    transform: rotate(-2deg);
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: clamp(4rem, 12vw, 10rem);
    line-height: 0.9;
    margin: 0 0 28px 0;
    letter-spacing: -0.02em;
    color: #fff;
    text-shadow:
      4px 4px 0 #FF1493,
      -3px -3px 0 #00BFFF,
      6px -2px 0 #FFD700,
      -2px 4px 0 #32CD32;
  }

  .hero-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    line-height: 1.5;
    margin: 0;
    max-width: 700px;
    color: #fff;
    text-shadow: 2px 2px 0 rgba(0, 0, 0, 0.3);
    background: rgba(0, 0, 0, 0.25);
    padding: 12px 20px;
    border-left: 5px solid #FFD700;
    border-right: 5px dashed #FF1493;
  }

  .hero-deco-row {
    display: flex;
    gap: 20px;
    margin-top: 36px;
    font-size: 2rem;
  }

  .hero-deco-star {
    color: #FFD700;
    text-shadow: 2px 2px 0 #FF1493;
    animation: wiggle 1.5s ease-in-out infinite;
  }

  .hero-deco-diamond {
    color: #00BFFF;
    text-shadow: 2px 2px 0 #32CD32;
    animation: wiggle 2s ease-in-out infinite reverse;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 80px 24px;
    position: relative;
    z-index: 1;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    display: inline-block;
    margin-bottom: 12px;
    padding: 4px 12px;
  }

  .section-heading {
    font-weight: 900;
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 1.05;
    margin: 0 0 48px 0;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 60px,
        rgba(139, 0, 255, 0.06) 60px,
        rgba(139, 0, 255, 0.06) 62px
      ),
      linear-gradient(180deg, #FFFDF7, #FFF0F5);
    border-top: 5px dashed #8B00FF;
    border-bottom: 5px dotted #FF6600;
  }

  .about-accent-bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 8px;
    height: 100%;
    background: repeating-linear-gradient(
      180deg,
      #FF1493 0px,
      #FF1493 20px,
      #FFD700 20px,
      #FFD700 40px,
      #00BFFF 40px,
      #00BFFF 60px,
      #32CD32 60px,
      #32CD32 80px
    );
  }

  .about-section .section-label {
    color: #8B00FF;
    border: 2px dashed #8B00FF;
    background: rgba(139, 0, 255, 0.08);
  }

  .about-heading {
    font-family: 'Playfair Display', serif;
    color: #8B00FF;
    text-shadow: 2px 2px 0 rgba(255, 20, 147, 0.2);
  }

  .about-content {
    max-width: 760px;
  }

  .about-paragraph {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1.2rem;
    line-height: 1.8;
    margin: 0 0 24px 0;
    color: #2a1a3a;
    padding-left: 20px;
    border-left: 3px solid #FF1493;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
    border-left-color: #00BFFF;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 15px,
        rgba(255, 20, 147, 0.05) 15px,
        rgba(255, 20, 147, 0.05) 30px
      ),
      repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 15px,
        rgba(0, 191, 255, 0.05) 15px,
        rgba(0, 191, 255, 0.05) 30px
      ),
      linear-gradient(180deg, #1a1a2e, #16213e);
    border-top: 4px double #FFD700;
    border-bottom: 4px double #FF1493;
  }

  .char-label {
    color: #FFD700;
    border: 2px solid #FFD700;
    background: rgba(255, 215, 0, 0.1);
  }

  .char-heading {
    font-family: 'Pacifico', cursive;
    color: #FFD700;
    text-shadow: 3px 3px 0 #FF1493;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  .char-card {
    padding: 32px 24px 24px;
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s;
    overflow: hidden;
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    opacity: 0.08;
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 8px,
        currentColor 8px,
        currentColor 9px
      );
    pointer-events: none;
  }

  .char-card:hover {
    transform: rotate(-1deg) scale(1.03);
    z-index: 2;
  }

  .char-card-0 {
    background: #FF1493;
    border: 3px solid #FFD700;
    box-shadow: 6px 6px 0 #FFD700, -3px -3px 0 #00BFFF;
    border-radius: 0;
    color: #fff;
  }

  .char-card-1 {
    background: #00BFFF;
    border: 3px dashed #1a1a1a;
    box-shadow: 6px 6px 0 #FF1493, 10px 10px 0 rgba(0, 0, 0, 0.2);
    border-radius: 20px 0 20px 0;
    color: #1a1a1a;
  }

  .char-card-2 {
    background: #FFD700;
    border: 3px dotted #8B00FF;
    box-shadow: -4px 6px 0 #32CD32, 4px -4px 0 #FF6600;
    border-radius: 0 20px 0 20px;
    color: #1a1a1a;
  }

  .char-card-3 {
    background: #32CD32;
    border: 4px double #1a1a1a;
    box-shadow: 6px 6px 0 #FF1493;
    border-radius: 50px 0 0 0;
    color: #1a1a1a;
  }

  .char-card-4 {
    background: #8B00FF;
    border: 3px solid #FFD700;
    box-shadow: 6px 6px 0 #FF6600, -4px -4px 0 #00BFFF;
    border-radius: 0 0 30px 0;
    color: #fff;
  }

  .char-card-5 {
    background: #FF6600;
    border: 3px dashed #fff;
    box-shadow: 6px 6px 0 #8B00FF, -3px 8px 0 #FF1493;
    border-radius: 0 30px 0 30px;
    color: #fff;
  }

  .char-number {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    background: rgba(0, 0, 0, 0.3);
    color: #FFD700;
    padding: 4px 10px;
    position: absolute;
    top: 8px;
    right: 8px;
    border-radius: 10px;
  }

  .char-title {
    font-family: 'Playfair Display', serif;
    font-weight: 900;
    font-size: 1.5rem;
    margin: 0 0 12px 0;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.15);
  }

  .char-description {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 4px,
        rgba(255, 102, 0, 0.06) 4px,
        rgba(255, 102, 0, 0.06) 8px
      ),
      linear-gradient(135deg, #FFF0F5, #F0F8FF, #FFFFF0);
    border-top: 5px solid #FF6600;
    border-bottom: 5px dashed #32CD32;
  }

  .prompt-label {
    color: #FF6600;
    border: 2px solid #FF6600;
    background: rgba(255, 102, 0, 0.08);
  }

  .prompt-heading {
    font-family: 'Playfair Display', serif;
    color: #FF6600;
    text-shadow: 2px 2px 0 rgba(255, 20, 147, 0.15);
  }

  .prompt-block {
    border: 4px solid #1a1a1a;
    box-shadow:
      8px 8px 0 #FF1493,
      -4px -4px 0 #00BFFF,
      12px 12px 0 #FFD700;
    border-radius: 0 24px 0 24px;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 24px;
    border-bottom: 3px dashed #FFD700;
    background:
      repeating-linear-gradient(
        90deg,
        #FF1493 0px,
        #FF1493 20px,
        #8B00FF 20px,
