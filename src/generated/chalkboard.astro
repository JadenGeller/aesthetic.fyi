---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Patrick+Hand&family=Lora:ital,wght@0,400;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-dust"></div>
    <div class="hero-inner">
      <span class="hero-label">~ A Web Aesthetic ~</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-chalk-line"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Written on the Board</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Lesson, Wrong Room</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Lora', serif;
    background-color: #2D4A2D;
    color: #F0EBE3;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    position: relative;
    /* Wood frame border around entire page */
    border-left: 12px solid #6B4F12;
    border-right: 12px solid #6B4F12;
    box-shadow:
      inset 3px 0 0 #8B6914,
      inset -3px 0 0 #8B6914;
  }

  /* Chalk dust texture overlay on all sections */
  .page::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle 1px at 10% 15%, rgba(240,235,227,0.04) 50%, transparent 50%),
      radial-gradient(circle 1px at 25% 35%, rgba(240,235,227,0.03) 50%, transparent 50%),
      radial-gradient(circle 1px at 40% 10%, rgba(240,235,227,0.05) 50%, transparent 50%),
      radial-gradient(circle 1px at 55% 55%, rgba(240,235,227,0.03) 50%, transparent 50%),
      radial-gradient(circle 1px at 70% 25%, rgba(240,235,227,0.04) 50%, transparent 50%),
      radial-gradient(circle 1px at 85% 45%, rgba(240,235,227,0.05) 50%, transparent 50%),
      radial-gradient(circle 1px at 15% 65%, rgba(240,235,227,0.03) 50%, transparent 50%),
      radial-gradient(circle 1px at 30% 80%, rgba(240,235,227,0.04) 50%, transparent 50%),
      radial-gradient(circle 1px at 50% 90%, rgba(240,235,227,0.03) 50%, transparent 50%),
      radial-gradient(circle 1px at 65% 70%, rgba(240,235,227,0.05) 50%, transparent 50%),
      radial-gradient(circle 1px at 80% 85%, rgba(240,235,227,0.04) 50%, transparent 50%),
      radial-gradient(circle 1px at 92% 60%, rgba(240,235,227,0.03) 50%, transparent 50%),
      radial-gradient(circle 1px at 5% 40%, rgba(240,235,227,0.04) 50%, transparent 50%),
      radial-gradient(circle 1px at 48% 30%, rgba(240,235,227,0.03) 50%, transparent 50%),
      radial-gradient(circle 1px at 73% 50%, rgba(240,235,227,0.05) 50%, transparent 50%),
      radial-gradient(circle 1px at 35% 95%, rgba(240,235,227,0.03) 50%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 2px dashed #5C7A52;
    background: #2D4A2D;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Patrick Hand', cursive;
    font-weight: 400;
    font-size: 1.1rem;
    color: #F0EBE3;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px dashed #7A9A6D;
    border-radius: 4px;
    transition: background 0.3s, border-color 0.3s;
  }

  .nav-logo:hover {
    background: rgba(122, 154, 109, 0.2);
    border-color: #F0EBE3;
  }

  .nav-divider {
    font-family: 'Patrick Hand', cursive;
    font-size: 1.2rem;
    color: #7A9A6D;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Patrick Hand', cursive;
    font-weight: 400;
    font-size: 1rem;
    color: #B8C9A3;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px dashed transparent;
    border-radius: 4px;
    transition: border-color 0.3s;
  }

  .nav-current:hover {
    border-color: #7A9A6D;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #2B5016;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 2px dashed #5C7A52;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px dotted rgba(240, 235, 227, 0.2);
    border-radius: 2px;
    pointer-events: none;
  }

  .hero-dust {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(circle 2px at 8% 25%, rgba(240,235,227,0.08) 50%, transparent 50%),
      radial-gradient(circle 1px at 20% 60%, rgba(240,235,227,0.06) 50%, transparent 50%),
      radial-gradient(circle 2px at 35% 15%, rgba(240,235,227,0.07) 50%, transparent 50%),
      radial-gradient(circle 1px at 50% 80%, rgba(240,235,227,0.05) 50%, transparent 50%),
      radial-gradient(circle 2px at 65% 40%, rgba(240,235,227,0.08) 50%, transparent 50%),
      radial-gradient(circle 1px at 80% 70%, rgba(240,235,227,0.06) 50%, transparent 50%),
      radial-gradient(circle 2px at 92% 20%, rgba(240,235,227,0.07) 50%, transparent 50%),
      radial-gradient(circle 1px at 15% 85%, rgba(240,235,227,0.05) 50%, transparent 50%),
      radial-gradient(circle 1px at 45% 45%, rgba(240,235,227,0.06) 50%, transparent 50%),
      radial-gradient(circle 2px at 75% 10%, rgba(240,235,227,0.08) 50%, transparent 50%);
    opacity: 0.7;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Patrick Hand', cursive;
    font-weight: 400;
    font-size: 1rem;
    color: #B8C9A3;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.08em;
  }

  .hero-title {
    font-family: 'Patrick Hand', cursive;
    font-weight: 400;
    font-size: clamp(3.2rem, 10vw, 6rem);
    line-height: 1.05;
    margin: 0 0 24px 0;
    color: #F0EBE3;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }

  .hero-chalk-line {
    display: block;
    width: 120px;
    height: 2px;
    background: linear-gradient(90deg,
      transparent,
      rgba(240,235,227,0.3) 10%,
      rgba(240,235,227,0.6) 30%,
      rgba(240,235,227,0.5) 50%,
      rgba(240,235,227,0.7) 70%,
      rgba(240,235,227,0.3) 90%,
      transparent
    );
    border-radius: 1px;
  }

  .hero-tagline {
    font-family: 'Lora', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 520px;
    color: #B8C9A3;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 2px dashed #5C7A52;
    position: relative;
    z-index: 1;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg,
      transparent,
      rgba(240,235,227,0.4),
      transparent
    );
  }

  .section-label {
    font-family: 'Patrick Hand', cursive;
    font-weight: 400;
    font-size: 0.9rem;
    color: #B8C9A3;
    white-space: nowrap;
    letter-spacing: 0.05em;
  }

  .section-heading {
    font-family: 'Patrick Hand', cursive;
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #F0EBE3;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #2B5016;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px dotted rgba(240, 235, 227, 0.15);
    border-radius: 2px;
    pointer-events: none;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #F0EBE3;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #2D4A2D;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 1px dashed #5C7A52;
    border-radius: 4px;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: rgba(43, 80, 22, 0.5);
    transition: box-shadow 0.3s, border-color 0.3s;
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    bottom: 8px;
    border: 1px dotted rgba(240, 235, 227, 0.12);
    border-radius: 2px;
    pointer-events: none;
  }

  .char-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    border-color: #7A9A6D;
  }

  .char-number {
    font-family: 'Patrick Hand', cursive;
    font-weight: 400;
    font-size: 0.85rem;
    color: #F5E6A3;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.1em;
  }

  .char-divider {
    width: 32px;
    height: 2px;
    background: linear-gradient(90deg,
      transparent,
      rgba(240,235,227,0.4),
      transparent
    );
    margin: 0 auto 14px;
  }

  .char-title {
    font-family: 'Patrick Hand', cursive;
    font-weight: 400;
    font-size: 1.35rem;
    margin: 0 0 12px 0;
    color: #F5E6A3;
  }

  .char-description {
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    margin: 0;
    color: #B8C9A3;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #2B5016;
  }

  .prompt-block {
    border: 1px dashed #5C7A52;
    border-radius: 4px;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-block::before {
    content: '';
    position: absolute;
    top: 6px;
    left: 6px;
    right: 6px;
    bottom: 6px;
    border: 1px dotted rgba(240, 235, 227, 0.12);
    border-radius: 2px;
    pointer-events: none;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px dashed #5C7A52;
    background: rgba(122, 154, 109, 0.1);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Patrick Hand', cursive;
    font-weight: 400;
    font-size: 0.9rem;
    color: #B8C9A3;
    letter-spacing: 0.05em;
  }

  .copy-button {
    font-family: 'Patrick Hand', cursive;
    font-weight: 400;
    font-size: 0.95rem;
    background: transparent;
    color: #F0EBE3;
    border: 1px dashed #7A9A6D;
    border-radius: 4px;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.3s, border-color 0.3s;
  }

  .copy-button:hover {
    background: rgba(122, 154, 109, 0.2);
    border-color: #F0EBE3;
  }

  .copy-button.copied {
    background: rgba(122, 154, 109, 0.3);
    border-color: #F0EBE3;
  }

  .prompt-text {
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.85;
    color: #F0EBE3;
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #2D4A2D;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px dashed #5C7A52;
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }

  .use-column::before {
    content: '';
    position: absolute;
    top: 6px;
    left: 6px;
    right: 6px;
    bottom: 6px;
    border: 1px dotted rgba(240, 235, 227, 0.1);
    border-radius: 2px;
    pointer-events: none;
    z-index: 1;
  }

  .use-column-heading {
    font-family: 'Patrick Hand', cursive;
    font-weight: 400;
    font-size: 1.15rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 1px dashed #5C7A52;
  }

  .use-good .use-column-heading {
    background: rgba(122, 154, 109, 0.15);
    color: #F5E6A3;
  }

  .use-bad .use-column-heading {
    background: rgba(212, 115, 108, 0.1);
    color: #D4736C;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px dotted rgba(92, 122, 82, 0.5);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #F0EBE3;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #7A9A6D;
    flex-shrink: 0;
    margin-top: 7px;
  }

  .use-item-bad::before {
    content: '\2013';
    color: #D4736C;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #2B5016;
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px dotted rgba(240, 235, 227, 0.15);
    border-radius: 2px;
    pointer-events: none;
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Lora', serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #F0EBE3;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #2D4A2D;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 28px 20px;
    border: 1px dashed #5C7A52;
    border-radius: 4px;
    text-decoration: none;
    color: #F0EBE3;
    text-align: center;
    position: relative;
    transition: box-shadow 0.3s, border-color 0.3s;
  }

  .related-card::before {
    content: '';
