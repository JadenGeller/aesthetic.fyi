---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Audiowide&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-starburst"></div>
    <div class="hero-orbit hero-orbit-1"></div>
    <div class="hero-orbit hero-orbit-2"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-atom">
          <span class="atom-nucleus"></span>
          <span class="atom-ring atom-ring-1"></span>
          <span class="atom-ring atom-ring-2"></span>
          <span class="atom-ring atom-ring-3"></span>
        </span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">The Future We Imagined</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Launchpad or Graveyard</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Space Grotesk', sans-serif;
    background-color: #FFF8E1;
    color: #2D2D2D;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 2px solid #C0C0C0;
    background: linear-gradient(180deg, #FFF8E1 0%, #F5EDD0 100%);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Audiowide', cursive;
    font-weight: 400;
    font-size: 0.9rem;
    color: #E65100;
    text-decoration: none;
    padding: 8px 22px;
    border: 2px solid #C0C0C0;
    border-radius: 50px;
    background: linear-gradient(135deg, rgba(192,192,192,0.1) 0%, rgba(192,192,192,0.05) 100%);
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.75rem;
  }

  .nav-logo:hover {
    background: rgba(230, 81, 0, 0.08);
    border-color: #E65100;
    box-shadow: 0 0 12px rgba(230, 81, 0, 0.15);
  }

  .nav-divider {
    font-family: 'Audiowide', cursive;
    font-size: 1rem;
    color: #C0C0C0;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Audiowide', cursive;
    font-weight: 400;
    font-size: 0.75rem;
    color: #00838F;
    text-decoration: none;
    padding: 8px 22px;
    border: 2px solid transparent;
    border-radius: 50px;
    transition: border-color 0.3s;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-current:hover {
    border-color: #C0C0C0;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: linear-gradient(170deg, #FFF8E1 0%, #F5EDD0 40%, #FFF8E1 100%);
    padding: 100px 32px 88px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 2px solid #C0C0C0;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px solid rgba(192, 192, 192, 0.4);
    border-radius: 40px;
    pointer-events: none;
  }

  /* Starburst pattern behind hero */
  .hero-starburst {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 600px;
    height: 600px;
    transform: translate(-50%, -50%);
    background: conic-gradient(
      from 0deg,
      transparent 0deg, rgba(230, 81, 0, 0.04) 5deg, transparent 10deg,
      transparent 20deg, rgba(230, 81, 0, 0.04) 25deg, transparent 30deg,
      transparent 40deg, rgba(230, 81, 0, 0.04) 45deg, transparent 50deg,
      transparent 60deg, rgba(230, 81, 0, 0.04) 65deg, transparent 70deg,
      transparent 80deg, rgba(230, 81, 0, 0.04) 85deg, transparent 90deg,
      transparent 100deg, rgba(230, 81, 0, 0.04) 105deg, transparent 110deg,
      transparent 120deg, rgba(230, 81, 0, 0.04) 125deg, transparent 130deg,
      transparent 140deg, rgba(230, 81, 0, 0.04) 145deg, transparent 150deg,
      transparent 160deg, rgba(230, 81, 0, 0.04) 165deg, transparent 170deg,
      transparent 180deg, rgba(230, 81, 0, 0.04) 185deg, transparent 190deg,
      transparent 200deg, rgba(230, 81, 0, 0.04) 205deg, transparent 210deg,
      transparent 220deg, rgba(230, 81, 0, 0.04) 225deg, transparent 230deg,
      transparent 240deg, rgba(230, 81, 0, 0.04) 245deg, transparent 250deg,
      transparent 260deg, rgba(230, 81, 0, 0.04) 265deg, transparent 270deg,
      transparent 280deg, rgba(230, 81, 0, 0.04) 285deg, transparent 290deg,
      transparent 300deg, rgba(230, 81, 0, 0.04) 305deg, transparent 310deg,
      transparent 320deg, rgba(230, 81, 0, 0.04) 325deg, transparent 330deg,
      transparent 340deg, rgba(230, 81, 0, 0.04) 345deg, transparent 350deg
    );
    border-radius: 50%;
    pointer-events: none;
    opacity: 1;
  }

  /* Orbiting rings */
  .hero-orbit {
    position: absolute;
    border: 1px solid rgba(0, 131, 143, 0.12);
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-orbit-1 {
    width: 400px;
    height: 400px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(25deg);
  }

  .hero-orbit-2 {
    width: 500px;
    height: 280px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-15deg);
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 0.8rem;
    color: #00838F;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 6px 20px;
    border: 1px solid rgba(0, 131, 143, 0.3);
    border-radius: 50px;
  }

  .hero-title {
    font-family: 'Audiowide', cursive;
    font-weight: 400;
    font-size: clamp(2.8rem, 8vw, 5rem);
    line-height: 1.1;
    margin: 0 0 28px 0;
    color: #E65100;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 28px;
  }

  /* Atom symbol */
  .hero-atom {
    position: relative;
    display: inline-block;
    width: 40px;
    height: 40px;
  }

  .atom-nucleus {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    background: #E65100;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 8px rgba(230, 81, 0, 0.4);
  }

  .atom-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    border: 1px solid #C0C0C0;
    border-radius: 50%;
  }

  .atom-ring-1 {
    width: 36px;
    height: 14px;
    transform: translate(-50%, -50%) rotate(0deg);
  }

  .atom-ring-2 {
    width: 36px;
    height: 14px;
    transform: translate(-50%, -50%) rotate(60deg);
  }

  .atom-ring-3 {
    width: 36px;
    height: 14px;
    transform: translate(-50%, -50%) rotate(120deg);
  }

  .hero-tagline {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 520px;
    color: #555;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 2px solid #C0C0C0;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 2px;
    background: linear-gradient(90deg, transparent, #C0C0C0, transparent);
  }

  .section-label {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: 0.75rem;
    color: #00838F;
    white-space: nowrap;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Audiowide', cursive;
    font-weight: 400;
    font-size: clamp(1.6rem, 5vw, 2.5rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #E65100;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: linear-gradient(180deg, #F5EDD0 0%, #FFF8E1 100%);
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px solid rgba(192, 192, 192, 0.3);
    border-radius: 30px;
    pointer-events: none;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #2D2D2D;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #FFF8E1;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 2px solid #C0C0C0;
    border-radius: 24px;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: linear-gradient(135deg, #FFF8E1 0%, #F5EDD0 100%);
    transition: box-shadow 0.3s, border-color 0.3s, transform 0.3s;
    overflow: hidden;
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: -30px;
    right: -30px;
    width: 80px;
    height: 80px;
    background: conic-gradient(
      from 0deg,
      transparent 0deg, rgba(230, 81, 0, 0.06) 10deg, transparent 20deg,
      transparent 40deg, rgba(230, 81, 0, 0.06) 50deg, transparent 60deg,
      transparent 80deg, rgba(230, 81, 0, 0.06) 90deg, transparent 100deg,
      transparent 120deg, rgba(230, 81, 0, 0.06) 130deg, transparent 140deg,
      transparent 160deg, rgba(230, 81, 0, 0.06) 170deg, transparent 180deg,
      transparent 200deg, rgba(230, 81, 0, 0.06) 210deg, transparent 220deg,
      transparent 240deg, rgba(230, 81, 0, 0.06) 250deg, transparent 260deg,
      transparent 280deg, rgba(230, 81, 0, 0.06) 290deg, transparent 300deg,
      transparent 320deg, rgba(230, 81, 0, 0.06) 330deg, transparent 340deg
    );
    border-radius: 50%;
    pointer-events: none;
  }

  .char-card:hover {
    box-shadow: 0 6px 24px rgba(230, 81, 0, 0.1);
    border-color: #E65100;
    transform: translateY(-2px);
  }

  .char-number {
    font-family: 'Audiowide', cursive;
    font-weight: 400;
    font-size: 0.7rem;
    color: #00838F;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 32px;
    height: 2px;
    background: linear-gradient(90deg, #C0C0C0, #E65100, #C0C0C0);
    margin: 0 auto 14px;
    border-radius: 2px;
  }

  .char-title {
    font-family: 'Audiowide', cursive;
    font-weight: 400;
    font-size: 1.1rem;
    margin: 0 0 12px 0;
    color: #E65100;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .char-description {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
    color: #555;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: linear-gradient(180deg, #F5EDD0 0%, #FFF8E1 100%);
  }

  .prompt-block {
    border: 2px solid #C0C0C0;
    border-radius: 24px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 2px solid #C0C0C0;
    background: linear-gradient(135deg, rgba(192,192,192,0.1) 0%, rgba(192,192,192,0.05) 100%);
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Audiowide', cursive;
    font-weight: 400;
    font-size: 0.7rem;
    color: #00838F;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Audiowide', cursive;
    font-weight: 400;
    font-size: 0.7rem;
    background: transparent;
    color: #E65100;
    border: 2px solid #C0C0C0;
    border-radius: 50px;
    padding: 6px 22px;
    cursor: pointer;
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .copy-button:hover {
    background: rgba(230, 81, 0, 0.08);
    border-color: #E65100;
    box-shadow: 0 0 10px rgba(230, 81, 0, 0.12);
  }

  .copy-button.copied {
    background: rgba(230, 81, 0, 0.12);
    border-color: #E65100;
    box-shadow: 0 0 10px rgba(230, 81, 0, 0.15);
  }

  .prompt-text {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.85;
    color: #2D2D2D;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #FFF8E1;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 2px solid #C0C0C0;
    border-radius: 24px;
    overflow: hidden;
    position: relative;
    transition: box-shadow 0.3s;
  }

  .use-column:hover {
    box-shadow: 0 4px 16px rgba(192, 192, 192, 0.3);
  }

  .use-column-heading {
    font-family: 'Audiowide', cursive;
    font-weight: 400;
    font-size: 0.85rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 2px solid #C0C0C0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .use-good .use-column-heading {
    background: linear-gradient(135deg, rgba(0, 131, 143, 0.08) 0%, rgba(0, 131, 143, 0.03) 100%);
    color: #00838F;
  }

  .use-bad .use-column-heading {
    background: linear-gradient(135deg, rgba(192, 192, 192, 0.12) 0%, rgba(192, 192, 192, 0.04) 100%);
    color: #888;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(192, 192, 192, 0.3);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #2D2D2D;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #00838F;
    flex-shrink: 0;
    margin-top: 6px;
    box-shadow: 0 0 4px rgba(0, 131, 143, 0.3);
  }

  .use-item-bad::before {
    content: '\2013';
    color: #C0C0C0;
    flex-shrink: 0;
    font-weight: 600;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
