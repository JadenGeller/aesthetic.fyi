---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">AESTHETIC.FYI</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title" aria-label={aesthetic.name}>
        <span class="hero-title-line">BRUTALIST</span>
        <span class="hero-title-line hero-title-line-overlap">TYPOGRAPHY</span>
      </h1>
      <div class="hero-rule"></div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
    <div class="hero-bg-text" aria-hidden="true">TYPE</div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">WHAT THIS IS</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">RAW MATERIAL</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">DESIGN TOKENS</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">CHARACTERISTICS</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">STYLE REFERENCE</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">COPY & PASTE</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">PROMPT</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>COPY</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">WHEN TO USE</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">USE IT / LOSE IT</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">GOOD FOR</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">NOT FOR</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">ORIGINS</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">HISTORY</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">EXPLORE</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">RELATED STYLES</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-rule"></div>
      <a href="/" class="footer-logo">AESTHETIC.FYI</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; BACK TO ALL AESTHETICS</a>
      <div class="footer-rule"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'COPIED!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Inter', sans-serif;
    background-color: #000000;
    color: #FFFFFF;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 3px solid #FFFFFF;
    background: #000000;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .nav-logo {
    font-family: 'Anton', sans-serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: #FFFFFF;
    text-decoration: none;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 6px 16px;
    border: 2px solid #FFFFFF;
    transition: background 0.15s, color 0.15s;
  }

  .nav-logo:hover {
    background: #FFFFFF;
    color: #000000;
  }

  .nav-divider {
    font-family: 'Anton', sans-serif;
    font-size: 1.2rem;
    color: #FFFFFF;
    opacity: 0.4;
  }

  .nav-current {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    color: #FFFFFF;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding: 6px 16px;
    border: 2px solid transparent;
    transition: border-color 0.15s;
  }

  .nav-current:hover {
    border-color: #FFFFFF;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #000000;
    padding: 80px 32px 96px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 3px solid #FFFFFF;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .hero-label {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: #FFFFFF;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    border: 2px solid #FFFFFF;
    padding: 8px 24px;
  }

  .hero-title {
    font-family: 'Anton', sans-serif;
    font-weight: 400;
    font-size: clamp(6rem, 20vw, 12rem);
    line-height: 0.85;
    margin: 0 0 32px 0;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: -0.03em;
  }

  .hero-title-line {
    display: block;
  }

  .hero-title-line-overlap {
    margin-top: -0.08em;
    opacity: 0.92;
  }

  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Anton', sans-serif;
    font-weight: 400;
    font-size: clamp(20rem, 50vw, 45rem);
    color: #FFFFFF;
    opacity: 0.03;
    text-transform: uppercase;
    letter-spacing: -0.05em;
    line-height: 1;
    pointer-events: none;
    z-index: 1;
    white-space: nowrap;
  }

  .hero-rule {
    width: 120px;
    height: 4px;
    background: #FFFFFF;
    margin: 0 auto 32px;
  }

  .hero-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: clamp(0.85rem, 2vw, 1.1rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 600px;
    color: #FFFFFF;
    opacity: 0.7;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 96px 32px;
    border-bottom: 3px solid #FFFFFF;
    position: relative;
  }

  .section-inner {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 2px;
    background: #FFFFFF;
    opacity: 0.3;
  }

  .section-label {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.65rem;
    color: #FFFFFF;
    white-space: nowrap;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  .section-heading {
    font-family: 'Anton', sans-serif;
    font-weight: 400;
    font-size: clamp(2.5rem, 8vw, 5rem);
    line-height: 0.9;
    margin: 0 0 56px 0;
    text-align: center;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #FFFFFF;
    color: #000000;
  }

  .about-section .section-rule {
    background: #000000;
  }

  .about-section .section-label {
    color: #000000;
  }

  .about-section .section-heading {
    color: #000000;
  }

  .about-content {
    max-width: 680px;
    margin: 0 auto;
  }

  .about-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #000000;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #000000;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 0;
  }

  .char-card {
    border: 2px solid #FFFFFF;
    padding: 36px 28px 28px;
    position: relative;
    margin: -1px;
  }

  .char-card:hover {
    background: #FFFFFF;
    color: #000000;
  }

  .char-card:hover .char-number,
  .char-card:hover .char-title,
  .char-card:hover .char-description {
    color: #000000;
  }

  .char-card:hover .char-divider {
    background: #000000;
  }

  .char-number {
    font-family: 'Anton', sans-serif;
    font-weight: 400;
    font-size: 2.5rem;
    color: #FFFFFF;
    display: block;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
    line-height: 1;
    opacity: 0.3;
  }

  .char-divider {
    width: 40px;
    height: 3px;
    background: #FFFFFF;
    margin: 0 0 16px;
  }

  .char-title {
    font-family: 'Anton', sans-serif;
    font-weight: 400;
    font-size: 1.4rem;
    margin: 0 0 12px 0;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .char-description {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.85rem;
    line-height: 1.7;
    margin: 0;
    color: #FFFFFF;
    opacity: 0.6;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #FFFFFF;
    color: #000000;
  }

  .prompt-section .section-rule {
    background: #000000;
  }

  .prompt-section .section-label {
    color: #000000;
  }

  .prompt-section .section-heading {
    color: #000000;
  }

  .prompt-block {
    border: 3px solid #000000;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 3px solid #000000;
    background: #000000;
    color: #FFFFFF;
  }

  .prompt-header-label {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: #FFFFFF;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Anton', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    background: transparent;
    color: #FFFFFF;
    border: 2px solid #FFFFFF;
    padding: 6px 20px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: background 0.15s, color 0.15s;
  }

  .copy-button:hover {
    background: #FFFFFF;
    color: #000000;
  }

  .copy-button.copied {
    background: #FFFFFF;
    color: #000000;
  }

  .prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.8;
    color: #000000;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #000000;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    max-width: 800px;
    margin: 0 auto;
  }

  .use-column {
    border: 2px solid #FFFFFF;
    overflow: hidden;
    position: relative;
  }

  .use-good {
    margin-right: -1px;
  }

  .use-column-heading {
    font-family: 'Anton', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    margin: 0;
    padding: 18px 22px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    border-bottom: 2px solid #FFFFFF;
  }

  .use-good .use-column-heading {
    background: #FFFFFF;
    color: #000000;
  }

  .use-bad .use-column-heading {
    background: #000000;
    color: #FFFFFF;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.85rem;
    line-height: 1.5;
    padding: 14px 22px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '+';
    font-family: 'Anton', sans-serif;
    font-size: 1rem;
    color: #FFFFFF;
    flex-shrink: 0;
  }

  .use-item-bad::before {
    content: '\2013';
    font-family: 'Anton', sans-serif;
    color: #FFFFFF;
    flex-shrink: 0;
    opacity: 0.4;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #FFFFFF;
    color: #000000;
  }

  .history-section .section-rule {
    background: #000000;
  }

  .history-section .section-label {
    color: #000000;
  }

  .history-section .section-heading {
    color: #000000;
  }

  .history-content {
    max-width: 680px;
    margin: 0 auto;
  }

  .history-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #000000;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #000000;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0;
    max-width: 800px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    padding: 28px 22px;
    border: 2px solid #FFFFFF;
    margin: -1px;
    text-decoration: none;
    color: #FFFFFF;
    position: relative;
    transition: background 0.15s, color 0.15s;
  }

  .related-card:hover {
    background: #FFFFFF;
    color: #000000;
  }

  .related-card:hover .related-relationship,
  .related-card:hover .related-name,
  .related-card:hover .related-arrow {
    color: #000000;
  }

  .related-relationship {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.6rem;
    color: #FFFFFF;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  .related-name {
    font-family: 'Anton', sans-serif;
    font-weight: 400;
    font-size: 1.3rem;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .related-arrow {
    font-size: 1.2rem;
    color: #FFFFFF;
    opacity: 0.4;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #000000;
    padding: 64px 32px;
    border-top: 3px solid #FFFFFF;
  }

  .footer-inner {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
  }

  .footer-rule {
    width: 120px;
    height: 3px;
    background: #FFFFFF;
    opacity: 0.2;
  }

  .footer-logo {
    font-family: 'Anton', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    color: #FFFFFF;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 8px 24px;
    border: 2px solid #FFFFFF;
    transition: background 0.15s, color 0.15s;
  }

  .footer-logo:hover {
    background: #FFFFFF;
    color: #000000;
  }

  .footer-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.75rem;
    color: #FFFFFF;
    opacity: 0.4;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .footer-back {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    color: #FFFFFF;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding: 8px 20px;
    border: 2px solid transparent;
    transition: border-color 0.15s;
  }

  .footer-back:hover {
    border-color: #FFFFFF;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 56px 24px 72px;
    }

    .hero-title {
      font-size: clamp(4rem, 18vw, 8rem);
    }

    .hero-bg-text {
      font-size: clamp(12rem, 40vw, 25rem);
    }

    .section {
      padding: 72px 24px;
    }

    .section-heading {
      margin-bottom: 40px;
    }

    .characteristics-grid {
      grid-template-columns: 1fr;
    }

    .use-grid {
      grid-template-columns: 1fr;
    }

    .use-good {
      margin-right: 0;
    }

    .related-grid {
      grid-template-columns: 1fr 1fr;
    }

    .prompt-text {
      font-size: 0.85rem;
      padding: 22px 18px;
    }

    .prompt-header {
      padding: 12px 18px;
      flex-wrap: wrap;
      gap: 10px;
    }

    .nav-inner {
      padding: 12px 20px;
    }

    .footer {
      padding: 48px 24px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 40px 16px 56px;
    }

    .hero-title {
      font-size: clamp(3rem, 16vw, 5rem);
    }

    .hero-bg-text {
      font-size: clamp(8rem, 35vw, 16rem);
    }

    .hero-label {
      font-size: 0.6rem;
      padding: 6px 16px;
    }

    .section {
      padding: 48px 16px;
    }

    .section-heading {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .nav-inner {
      padding: 10px 16px;
      gap: 8px;
