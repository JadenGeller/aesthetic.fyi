---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-clouds"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-bubbles">
        <span class="hero-bubble hero-bubble-1"></span>
        <span class="hero-bubble hero-bubble-2"></span>
        <span class="hero-bubble hero-bubble-3"></span>
        <span class="hero-bubble hero-bubble-4"></span>
        <span class="hero-bubble hero-bubble-5"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule section-rule-left"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule section-rule-right"></div>
      </div>
      <h2 class="section-heading">A Gentle Philosophy</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule section-rule-left"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule section-rule-right"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule section-rule-left"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule section-rule-right"></div>
      </div>
      <h2 class="section-heading">Copy & Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule section-rule-left"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule section-rule-right"></div>
      </div>
      <h2 class="section-heading">Soft Ground, Hard Ground</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule section-rule-left"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule section-rule-right"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule section-rule-left"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule section-rule-right"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Nunito', sans-serif;
    background-color: #FFFFFF;
    color: #6B6087;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid #E8D5F5;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #9B7FBF;
    text-decoration: none;
    padding: 6px 18px;
    border: 1.5px solid #E8D5F5;
    border-radius: 20px;
    background: linear-gradient(135deg, rgba(232, 213, 245, 0.2), rgba(255, 209, 220, 0.2));
    transition: background 0.3s, box-shadow 0.3s;
  }

  .nav-logo:hover {
    background: linear-gradient(135deg, rgba(232, 213, 245, 0.4), rgba(255, 209, 220, 0.4));
    box-shadow: 0 2px 12px rgba(232, 213, 245, 0.4);
  }

  .nav-divider {
    font-size: 1rem;
    color: #E8D5F5;
    font-weight: 400;
  }

  .nav-current {
    font-family: 'Nunito', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    color: #B8A0D2;
    text-decoration: none;
    padding: 6px 18px;
    border: 1.5px solid transparent;
    border-radius: 20px;
    transition: border-color 0.3s, background 0.3s;
  }

  .nav-current:hover {
    border-color: #E8D5F5;
    background: rgba(232, 213, 245, 0.15);
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: linear-gradient(170deg, #FFFFFF 0%, #F5EAFC 25%, #FFF0F5 50%, #EAF7F0 75%, #F0F4FA 100%);
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid #E8D5F5;
  }

  .hero-clouds {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(ellipse 120px 60px at 10% 30%, rgba(232, 213, 245, 0.35) 0%, transparent 100%),
      radial-gradient(ellipse 100px 50px at 85% 20%, rgba(255, 209, 220, 0.3) 0%, transparent 100%),
      radial-gradient(ellipse 140px 70px at 70% 70%, rgba(193, 240, 219, 0.3) 0%, transparent 100%),
      radial-gradient(ellipse 110px 55px at 20% 75%, rgba(184, 212, 227, 0.3) 0%, transparent 100%),
      radial-gradient(ellipse 90px 45px at 50% 15%, rgba(255, 218, 185, 0.25) 0%, transparent 100%);
    pointer-events: none;
    animation: cloudsDrift 20s ease-in-out infinite alternate;
  }

  @keyframes cloudsDrift {
    0% { transform: translateX(0) translateY(0); }
    100% { transform: translateX(15px) translateY(-8px); }
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Nunito', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    color: #B8A0D2;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: rgba(232, 213, 245, 0.25);
    padding: 6px 20px;
    border-radius: 20px;
  }

  .hero-title {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.1;
    margin: 0 0 28px 0;
    background: linear-gradient(135deg, #C9A6E3, #FFB8C9, #A8D8C6, #A3C4D9);
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientShift 8s ease-in-out infinite;
  }

  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .hero-bubbles {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .hero-bubble {
    border-radius: 50%;
    animation: float 3s ease-in-out infinite;
  }

  .hero-bubble-1 {
    width: 10px;
    height: 10px;
    background: #E8D5F5;
    animation-delay: 0s;
  }

  .hero-bubble-2 {
    width: 7px;
    height: 7px;
    background: #FFDAB9;
    animation-delay: 0.4s;
  }

  .hero-bubble-3 {
    width: 12px;
    height: 12px;
    background: #FFD1DC;
    animation-delay: 0.8s;
  }

  .hero-bubble-4 {
    width: 7px;
    height: 7px;
    background: #C1F0DB;
    animation-delay: 1.2s;
  }

  .hero-bubble-5 {
    width: 10px;
    height: 10px;
    background: #B8D4E3;
    animation-delay: 1.6s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .hero-tagline {
    font-family: 'Nunito', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.8;
    margin: 0 auto;
    max-width: 520px;
    color: #9B8AAE;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 2px;
    border-radius: 1px;
  }

  .section-rule-left {
    background: linear-gradient(90deg, transparent, #E8D5F5);
  }

  .section-rule-right {
    background: linear-gradient(90deg, #E8D5F5, transparent);
  }

  .section-label {
    font-family: 'Nunito', sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    color: #B8A0D2;
    white-space: nowrap;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #7B6893;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: linear-gradient(180deg, #FFFFFF 0%, #F9F0FE 50%, #FFF5F8 100%);
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(232, 213, 245, 0.5);
    border-radius: 20px;
    padding: 40px 36px;
    box-shadow: 0 4px 24px rgba(232, 213, 245, 0.2);
  }

  .about-paragraph {
    font-family: 'Nunito', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.9;
    margin: 0 0 20px 0;
    color: #6B6087;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: linear-gradient(180deg, #FFF5F8 0%, #FFFFFF 50%, #F0F8F4 100%);
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 1px solid rgba(232, 213, 245, 0.4);
    border-radius: 18px;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: rgba(255, 255, 255, 0.7);
    transition: box-shadow 0.4s, transform 0.4s, border-color 0.4s;
  }

  .char-card:nth-child(1) {
    box-shadow: 0 4px 20px rgba(232, 213, 245, 0.2);
  }
  .char-card:nth-child(2) {
    box-shadow: 0 4px 20px rgba(255, 218, 185, 0.2);
  }
  .char-card:nth-child(3) {
    box-shadow: 0 4px 20px rgba(193, 240, 219, 0.2);
  }
  .char-card:nth-child(4) {
    box-shadow: 0 4px 20px rgba(184, 212, 227, 0.2);
  }
  .char-card:nth-child(5) {
    box-shadow: 0 4px 20px rgba(255, 209, 220, 0.2);
  }
  .char-card:nth-child(6) {
    box-shadow: 0 4px 20px rgba(232, 213, 245, 0.2);
  }

  .char-card:hover {
    transform: translateY(-4px);
    border-color: rgba(232, 213, 245, 0.6);
  }

  .char-card:nth-child(1):hover { box-shadow: 0 8px 32px rgba(232, 213, 245, 0.35); }
  .char-card:nth-child(2):hover { box-shadow: 0 8px 32px rgba(255, 218, 185, 0.35); }
  .char-card:nth-child(3):hover { box-shadow: 0 8px 32px rgba(193, 240, 219, 0.35); }
  .char-card:nth-child(4):hover { box-shadow: 0 8px 32px rgba(184, 212, 227, 0.35); }
  .char-card:nth-child(5):hover { box-shadow: 0 8px 32px rgba(255, 209, 220, 0.35); }
  .char-card:nth-child(6):hover { box-shadow: 0 8px 32px rgba(232, 213, 245, 0.35); }

  .char-number {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: #C9A6E3;
    display: inline-block;
    margin-bottom: 10px;
    letter-spacing: 0.1em;
    background: rgba(232, 213, 245, 0.2);
    padding: 3px 12px;
    border-radius: 12px;
  }

  .char-divider {
    width: 32px;
    height: 3px;
    background: linear-gradient(90deg, #E8D5F5, #FFD1DC);
    margin: 0 auto 14px;
    border-radius: 2px;
  }

  .char-title {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin: 0 0 12px 0;
    color: #7B6893;
  }

  .char-description {
    font-family: 'Nunito', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    margin: 0;
    color: #9B8AAE;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: linear-gradient(180deg, #F0F8F4 0%, #F2F0FA 50%, #FFF8F0 100%);
  }

  .prompt-block {
    border: 1px solid rgba(232, 213, 245, 0.5);
    border-radius: 18px;
    margin: 0 auto;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.6);
    box-shadow: 0 4px 24px rgba(232, 213, 245, 0.15);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(232, 213, 245, 0.35);
    background: linear-gradient(135deg, rgba(232, 213, 245, 0.15), rgba(255, 218, 185, 0.1));
  }

  .prompt-header-label {
    font-family: 'Nunito', sans-serif;
    font-weight: 600;
    font-size: 0.75rem;
    color: #B8A0D2;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Nunito', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    background: linear-gradient(135deg, rgba(232, 213, 245, 0.25), rgba(255, 209, 220, 0.25));
    color: #7B6893;
    border: 1.5px solid #E8D5F5;
    border-radius: 16px;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.3s, box-shadow 0.3s, transform 0.2s;
  }

  .copy-button:hover {
    background: linear-gradient(135deg, rgba(232, 213, 245, 0.45), rgba(255, 209, 220, 0.45));
    box-shadow: 0 2px 12px rgba(232, 213, 245, 0.3);
    transform: translateY(-1px);
  }

  .copy-button.copied {
    background: linear-gradient(135deg, rgba(193, 240, 219, 0.4), rgba(184, 212, 227, 0.4));
    border-color: #C1F0DB;
    color: #6BA88E;
  }

  .prompt-text {
    font-family: 'Nunito', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.85;
    color: #6B6087;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: linear-gradient(180deg, #FFF8F0 0%, #FFFFFF 50%, #F5EAFC 100%);
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border-radius: 18px;
    overflow: hidden;
    position: relative;
    background: rgba(255, 255, 255, 0.6);
    transition: box-shadow 0.3s;
  }

  .use-good {
    border: 1px solid rgba(193, 240, 219, 0.5);
    box-shadow: 0 4px 20px rgba(193, 240, 219, 0.15);
  }

  .use-bad {
    border: 1px solid rgba(255, 209, 220, 0.5);
    box-shadow: 0 4px 20px rgba(255, 209, 220, 0.15);
  }

  .use-good:hover {
    box-shadow: 0 6px 28px rgba(193, 240, 219, 0.3);
  }

  .use-bad:hover {
    box-shadow: 0 6px 28px rgba(255, 209, 220, 0.3);
  }

  .use-column-heading {
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 1px solid rgba(232, 213, 245, 0.3);
  }

  .use-good .use-column-heading {
    background: linear-gradient(135deg, rgba(193, 240, 219, 0.25), rgba(184, 212, 227, 0.15));
    color: #5E9A7E;
  }

  .use-bad .use-column-heading {
    background: linear-gradient(135deg, rgba(255, 209, 220, 0.25), rgba(232, 213, 245, 0.15));
    color: #C48A9B;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Nunito', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(232, 213, 245, 0.2);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #6B6087;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, #C1F0DB, #B8D4E3);
    flex-shrink: 0;
    margin-top: 6px;
  }

  .use-item-bad::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, #FFD1DC, #E8D5F5);
    flex-shrink: 0;
    margin-top: 6px;
