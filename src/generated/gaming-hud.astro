---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <span class="nav-bracket">[</span> aesthetic.fyi <span class="nav-bracket">]</span>
      </a>
      <span class="nav-divider">//</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">
        <span class="nav-status"></span>
        {aesthetic.name}
      </a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-scanlines"></div>
    <div class="hero-crosshair"></div>
    <div class="hero-inner">
      <span class="hero-label">/// ACTIVE PROFILE</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-bar">
        <div class="hero-bar-fill"></div>
        <span class="hero-bar-label">SYSTEM ONLINE</span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <span class="hero-stat-label">STATUS</span>
        <span class="hero-stat-value">ACTIVE</span>
      </div>
      <div class="hero-stat">
        <span class="hero-stat-label">SIGNAL</span>
        <span class="hero-stat-value">100%</span>
      </div>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// INTEL BRIEFING</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Mission Overview</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// SYSTEM SPECS</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <div class="char-corner char-corner-tl"></div>
            <div class="char-corner char-corner-tr"></div>
            <div class="char-corner char-corner-bl"></div>
            <div class="char-corner char-corner-br"></div>
            <span class="char-number">0{i + 1}</span>
            <div class="char-bar">
              <div class="char-bar-fill" style={`width: ${80 + i * 4}%`}></div>
            </div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// STYLE PAYLOAD</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">&gt;_ PROMPT</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>COPY</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// DEPLOYMENT ZONES</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Viable Targets</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">
            <span class="use-icon use-icon-good"></span>
            DEPLOY
          </h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">
            <span class="use-icon use-icon-bad"></span>
            AVOID
          </h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// ORIGIN LOG</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">// LINKED NODES</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&gt;&gt;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">
        <span class="footer-bracket">[</span> aesthetic.fyi <span class="footer-bracket">]</span>
      </a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&lt;&lt; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'COPIED!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Rajdhani', sans-serif;
    background-color: #0a0a0a;
    color: #c0c0c0;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid rgba(0, 255, 65, 0.2);
    background: rgba(10, 10, 10, 0.95);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(8px);
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }

  .nav-logo {
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 0.8rem;
    color: #00FF41;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid rgba(0, 255, 65, 0.3);
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
    letter-spacing: 0.05em;
    clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    background: rgba(0, 255, 65, 0.05);
  }

  .nav-logo:hover {
    background: rgba(0, 255, 65, 0.1);
    border-color: #00FF41;
    box-shadow: 0 0 12px rgba(0, 255, 65, 0.15);
  }

  .nav-bracket {
    color: #FF6600;
  }

  .nav-divider {
    font-family: 'Orbitron', monospace;
    font-size: 0.7rem;
    color: rgba(0, 255, 65, 0.3);
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    color: rgba(0, 255, 65, 0.7);
    text-decoration: none;
    padding: 6px 18px;
    display: flex;
    align-items: center;
    gap: 8px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.3s;
  }

  .nav-current:hover {
    color: #00FF41;
  }

  .nav-status {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00FF41;
    box-shadow: 0 0 6px rgba(0, 255, 65, 0.5);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: rgba(10, 10, 10, 0.95);
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(0, 255, 65, 0.15);
  }

  .hero-scanlines {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 255, 65, 0.015) 2px,
      rgba(0, 255, 65, 0.015) 4px
    );
    pointer-events: none;
    z-index: 1;
  }

  .hero-crosshair {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120px;
    height: 120px;
    pointer-events: none;
    z-index: 1;
    opacity: 0.15;
  }

  .hero-crosshair::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, #00FF41 20%, transparent 40%, transparent 60%, #00FF41 80%, transparent);
  }

  .hero-crosshair::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: linear-gradient(180deg, transparent, #00FF41 20%, transparent 40%, transparent 60%, #00FF41 80%, transparent);
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .hero-label {
    font-family: 'Orbitron', monospace;
    font-weight: 400;
    font-size: 0.7rem;
    color: #FF6600;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.0;
    margin: 0 0 28px 0;
    color: #00FF41;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-shadow: 0 0 30px rgba(0, 255, 65, 0.3), 0 0 60px rgba(0, 255, 65, 0.1);
  }

  .hero-bar {
    max-width: 300px;
    margin: 0 auto 28px;
    height: 4px;
    background: rgba(0, 255, 65, 0.1);
    position: relative;
    overflow: hidden;
  }

  .hero-bar::before,
  .hero-bar::after {
    content: '';
    position: absolute;
    top: -2px;
    width: 1px;
    height: 8px;
    background: rgba(0, 255, 65, 0.4);
  }

  .hero-bar::before { left: 0; }
  .hero-bar::after { right: 0; }

  .hero-bar-fill {
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, #00FF41, rgba(0, 255, 65, 0.6));
    animation: bar-load 2s ease-out;
  }

  @keyframes bar-load {
    from { width: 0; }
    to { width: 100%; }
  }

  .hero-bar-label {
    position: absolute;
    top: 10px;
    right: 0;
    font-family: 'Orbitron', monospace;
    font-size: 0.55rem;
    color: rgba(0, 255, 65, 0.5);
    letter-spacing: 0.15em;
  }

  .hero-tagline {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 500;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 520px;
    color: rgba(192, 192, 192, 0.7);
  }

  .hero-stats {
    position: absolute;
    bottom: 24px;
    right: 32px;
    display: flex;
    gap: 20px;
    z-index: 2;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }

  .hero-stat-label {
    font-family: 'Orbitron', monospace;
    font-size: 0.5rem;
    color: rgba(0, 255, 65, 0.4);
    letter-spacing: 0.15em;
  }

  .hero-stat-value {
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 0.75rem;
    color: #00FF41;
    letter-spacing: 0.1em;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 1px solid rgba(0, 255, 65, 0.1);
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 255, 65, 0.3));
  }

  .section-rule:last-child {
    background: linear-gradient(90deg, rgba(0, 255, 65, 0.3), transparent);
  }

  .section-label {
    font-family: 'Orbitron', monospace;
    font-weight: 400;
    font-size: 0.6rem;
    color: #FF6600;
    white-space: nowrap;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.1;
    margin: 0 0 48px 0;
    text-align: center;
    color: #00FF41;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-shadow: 0 0 20px rgba(0, 255, 65, 0.15);
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: rgba(0, 255, 65, 0.02);
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 1px solid rgba(0, 255, 65, 0.08);
    pointer-events: none;
    clip-path: polygon(16px 0, calc(100% - 16px) 0, 100% 16px, 100% calc(100% - 16px), calc(100% - 16px) 100%, 16px 100%, 0 calc(100% - 16px), 0 16px);
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 500;
    font-size: 1.15rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: rgba(192, 192, 192, 0.85);
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: rgba(10, 10, 10, 0.98);
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .char-card {
    border: 1px solid rgba(0, 255, 65, 0.15);
    padding: 28px 24px 24px;
    position: relative;
    background: rgba(0, 255, 65, 0.03);
    transition: border-color 0.3s, box-shadow 0.3s, background 0.3s;
    clip-path: polygon(12px 0, calc(100% - 12px) 0, 100% 12px, 100% calc(100% - 12px), calc(100% - 12px) 100%, 12px 100%, 0 calc(100% - 12px), 0 12px);
  }

  .char-card:hover {
    border-color: rgba(0, 255, 65, 0.35);
    box-shadow: 0 0 20px rgba(0, 255, 65, 0.08), inset 0 0 30px rgba(0, 255, 65, 0.03);
    background: rgba(0, 255, 65, 0.05);
  }

  .char-corner {
    position: absolute;
    width: 12px;
    height: 12px;
    pointer-events: none;
  }

  .char-corner::before,
  .char-corner::after {
    content: '';
    position: absolute;
    background: rgba(0, 255, 65, 0.4);
  }

  .char-corner-tl { top: 6px; left: 6px; }
  .char-corner-tl::before { top: 0; left: 0; width: 12px; height: 1px; }
  .char-corner-tl::after { top: 0; left: 0; width: 1px; height: 12px; }

  .char-corner-tr { top: 6px; right: 6px; }
  .char-corner-tr::before { top: 0; right: 0; width: 12px; height: 1px; }
  .char-corner-tr::after { top: 0; right: 0; width: 1px; height: 12px; }

  .char-corner-bl { bottom: 6px; left: 6px; }
  .char-corner-bl::before { bottom: 0; left: 0; width: 12px; height: 1px; }
  .char-corner-bl::after { bottom: 0; left: 0; width: 1px; height: 12px; }

  .char-corner-br { bottom: 6px; right: 6px; }
  .char-corner-br::before { bottom: 0; right: 0; width: 12px; height: 1px; }
  .char-corner-br::after { bottom: 0; right: 0; width: 1px; height: 12px; }

  .char-number {
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 0.7rem;
    color: #FF6600;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-bar {
    height: 3px;
    background: rgba(0, 255, 65, 0.1);
    margin-bottom: 14px;
    position: relative;
  }

  .char-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #00FF41, rgba(0, 255, 65, 0.4));
    transition: width 0.6s ease-out;
  }

  .char-title {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin: 0 0 10px 0;
    color: #00FF41;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .char-description {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 500;
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
    color: rgba(192, 192, 192, 0.6);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: rgba(0, 255, 65, 0.02);
  }

  .prompt-block {
    border: 1px solid rgba(0, 255, 65, 0.2);
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    clip-path: polygon(10px 0, calc(100% - 10px) 0, 100% 10px, 100% calc(100% - 10px), calc(100% - 10px) 100%, 10px 100%, 0 calc(100% - 10px), 0 10px);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(0, 255, 65, 0.15);
    background: rgba(0, 255, 65, 0.05);
  }

  .prompt-header-label {
    font-family: 'Orbitron', monospace;
    font-weight: 400;
    font-size: 0.65rem;
    color: #FF6600;
    letter-spacing: 0.12em;
  }

  .copy-button {
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 0.65rem;
    background: transparent;
    color: #00FF41;
    border: 1px solid rgba(0, 255, 65, 0.3);
    padding: 6px 20px;
    cursor: pointer;
    letter-spacing: 0.1em;
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
    clip-path: polygon(6px 0, calc(100% - 6px) 0, 100% 6px, 100% calc(100% - 6px), calc(100% - 6px) 100%, 6px 100%, 0 calc(100% - 6px), 0 6px);
  }

  .copy-button:hover {
    background: rgba(0, 255, 65, 0.1);
    border-color: #00FF41;
    box-shadow: 0 0 10px rgba(0, 255, 65, 0.15);
  }

  .copy-button.copied {
    background: rgba(0, 255, 65, 0.15);
    border-color: #00FF41;
    color: #00FF41;
  }

  .prompt-text {
    font-family: 'Rajdhani', sans-serif;
    font-weight: 500;
    font-size: 1rem;
    line-height: 1.85;
    color: rgba(192, 192, 192, 0.8);
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: rgba(10, 10, 10, 0.98);
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid rgba(0, 255, 65, 0.12);
    overflow: hidden;
    position: relative;
    clip-path: polygon(10px 0, calc(100% - 10px) 0, 100% 10px, 100% calc(100% - 10px), calc(100% - 10px) 100%, 10px 100%, 0 calc(100% - 10px), 0 10px);
  }

  .use-column-heading {
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 0.7rem;
    margin: 0;
    padding: 14px 22px;
    text-align: center;
