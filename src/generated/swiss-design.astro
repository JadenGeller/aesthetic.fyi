---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-stripe"></div>
      <div class="hero-content">
        <span class="hero-label">Web Aesthetic</span>
        <h1 class="hero-title">{aesthetic.name}</h1>
        <div class="hero-rule"></div>
        <p class="hero-tagline">{aesthetic.tagline}</p>
      </div>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-grid">
      <div class="section-stripe"></div>
      <div class="section-meta">
        <span class="section-number">01</span>
        <span class="section-label">About</span>
      </div>
      <div class="section-body">
        <h2 class="section-heading">What This Is</h2>
        <div class="about-content">
          {aesthetic.about.split('\n\n').map((paragraph: string) => (
            <p class="body-text">{paragraph}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-grid">
      <div class="section-stripe"></div>
      <div class="section-meta">
        <span class="section-number">02</span>
        <span class="section-label">Traits</span>
      </div>
      <div class="section-body">
        <h2 class="section-heading">Characteristics</h2>
        <div class="characteristics-list">
          {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
            <div class="char-item">
              <div class="char-index-wrap">
                <span class="char-bg-number">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <div class="char-content">
                <h3 class="char-title">{char.title}</h3>
                <div class="char-rule"></div>
                <p class="char-description">{char.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-grid">
      <div class="section-stripe"></div>
      <div class="section-meta">
        <span class="section-number">03</span>
        <span class="section-label">Prompt</span>
      </div>
      <div class="section-body">
        <h2 class="section-heading">Style Reference</h2>
        <div class="prompt-block">
          <div class="prompt-header">
            <span class="prompt-header-label">Prompt</span>
            <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
          </div>
          <p class="prompt-text">{aesthetic.prompt}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-grid">
      <div class="section-stripe"></div>
      <div class="section-meta">
        <span class="section-number">04</span>
        <span class="section-label">Usage</span>
      </div>
      <div class="section-body">
        <h2 class="section-heading">When to Use</h2>
        <div class="use-columns">
          <div class="use-column">
            <h3 class="use-column-heading">Good For</h3>
            <ul class="use-list">
              {aesthetic.good_for.map((item: string) => (
                <li class="use-item use-item-good">{item}</li>
              ))}
            </ul>
          </div>
          <div class="use-column">
            <h3 class="use-column-heading use-column-heading-bad">Not For</h3>
            <ul class="use-list">
              {aesthetic.not_for.map((item: string) => (
                <li class="use-item use-item-bad">{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-grid">
      <div class="section-stripe"></div>
      <div class="section-meta">
        <span class="section-number">05</span>
        <span class="section-label">Origins</span>
      </div>
      <div class="section-body">
        <h2 class="section-heading">History</h2>
        <div class="history-content">
          {aesthetic.history.split('\n\n').map((paragraph: string) => (
            <p class="body-text">{paragraph}</p>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-grid">
      <div class="section-stripe section-stripe-red"></div>
      <div class="section-meta">
        <span class="section-number">06</span>
        <span class="section-label">Related</span>
      </div>
      <div class="section-body">
        <h2 class="section-heading">Related Styles</h2>
        <div class="related-grid">
          {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
            <a href={`/${rel.slug}`} class="related-card">
              <span class="related-relationship">{rel.relationship}</span>
              <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
              <span class="related-arrow">&rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-rule"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to all aesthetics</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Inter', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    background-color: #ffffff;
    color: #000000;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     GRID SYSTEM
     The signature Swiss asymmetric grid:
     8px red stripe | meta column | body column
     ======================================== */
  .section-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 8px 180px 1fr;
    grid-template-rows: auto;
    gap: 0;
    padding: 0 24px;
  }

  .section-stripe {
    background: #ff0000;
    grid-row: 1 / -1;
  }

  .section-stripe-red {
    background: #ff0000;
  }

  .section-meta {
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 4px;
  }

  .section-number {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 3rem;
    line-height: 1;
    color: rgba(0, 0, 0, 0.06);
    letter-spacing: -0.02em;
  }

  .section-label {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #666;
  }

  .section-body {
    padding: 0;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid #000000;
    background: #ffffff;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-logo {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    color: #000000;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 6px 0;
  }

  .nav-logo:hover {
    color: #ff0000;
  }

  .nav-divider {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    color: #ccc;
    margin: 0 4px;
  }

  .nav-current {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: #666;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 6px 0;
  }

  .nav-current:hover {
    color: #000000;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    padding: 0;
    border-bottom: 1px solid #000000;
  }

  .hero-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 8px 1fr;
    padding: 0 24px;
  }

  .hero-stripe {
    background: #ff0000;
  }

  .hero-content {
    padding: 80px 0 72px 32px;
  }

  .hero-label {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #666;
    display: block;
    margin-bottom: 24px;
  }

  .hero-title {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    line-height: 1.0;
    margin: 0 0 28px 0;
    letter-spacing: -0.03em;
    color: #000000;
    text-transform: uppercase;
    max-width: 900px;
  }

  .hero-rule {
    width: 60px;
    height: 2px;
    background: #ff0000;
    margin-bottom: 24px;
  }

  .hero-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.6;
    margin: 0;
    max-width: 600px;
    color: #666;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 72px 0;
    border-bottom: 1px solid #000000;
  }

  .section-heading {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1.1;
    margin: 0 0 40px 0;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #000000;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-content {
    max-width: 680px;
  }

  .body-text {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.75;
    margin: 0 0 20px 0;
    color: #000000;
  }

  .body-text:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #ffffff;
  }

  .characteristics-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .char-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0;
    border-top: 1px solid #000000;
    padding: 28px 0;
  }

  .char-item:last-child {
    border-bottom: 1px solid #000000;
  }

  .char-index-wrap {
    position: relative;
  }

  .char-bg-number {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 3rem;
    color: rgba(0, 0, 0, 0.06);
    line-height: 1;
    letter-spacing: -0.02em;
    user-select: none;
  }

  .char-content {
    padding-right: 24px;
  }

  .char-title {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    margin: 0 0 10px 0;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #000000;
  }

  .char-rule {
    width: 24px;
    height: 2px;
    background: #ff0000;
    margin-bottom: 10px;
  }

  .char-description {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
    color: #666;
    max-width: 560px;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-block {
    border: 1px solid #000000;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 20px;
    border-bottom: 1px solid #000000;
    background: #ffffff;
  }

  .prompt-header-label {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #000000;
  }

  .copy-button {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    background: #ffffff;
    color: #000000;
    border: 1px solid #000000;
    padding: 6px 16px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: background 0.15s, color 0.15s;
  }

  .copy-button:hover {
    background: #000000;
    color: #ffffff;
  }

  .copy-button.copied {
    background: #ff0000;
    color: #ffffff;
    border-color: #ff0000;
  }

  .prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #000000;
    padding: 24px 20px;
    margin: 0;
    white-space: normal;
    background: #f8f8f8;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  .use-column-heading {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    margin: 0 0 20px 0;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #000000;
    padding-bottom: 12px;
    border-bottom: 2px solid #000000;
  }

  .use-column-heading-bad {
    border-bottom-color: #ff0000;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 10px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: #000000;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '+';
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #000000;
    flex-shrink: 0;
  }

  .use-item-bad::before {
    content: '\2013';
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: #ff0000;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-content {
    max-width: 680px;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1px;
    background: #000000;
    border: 1px solid #000000;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    background: #ffffff;
    text-decoration: none;
    color: #000000;
    transition: background 0.15s, color 0.15s;
    position: relative;
  }

  .related-card:hover {
    background: #000000;
    color: #ffffff;
  }

  .related-card:hover .related-relationship {
    color: #ff0000;
  }

  .related-card:hover .related-arrow {
    color: #ff0000;
  }

  .related-relationship {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #666;
    transition: color 0.15s;
  }

  .related-name {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.02em;
  }

  .related-arrow {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    position: absolute;
    bottom: 20px;
    right: 20px;
    color: #000000;
    transition: color 0.15s;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #000000;
    padding: 60px 24px;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .footer-rule {
    width: 40px;
    height: 2px;
    background: #ff0000;
    margin-bottom: 8px;
  }

  .footer-logo {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    color: #ffffff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .footer-logo:hover {
    color: #ff0000;
  }

  .footer-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: #666;
  }

  .footer-back {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: #ffffff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: 8px 0;
    border-bottom: 1px solid #ffffff;
    transition: color 0.15s, border-color 0.15s;
  }

  .footer-back:hover {
    color: #ff0000;
    border-color: #ff0000;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 900px) {
    .section-grid {
      grid-template-columns: 4px 1fr;
      padding: 0 20px;
    }

    .section-meta {
      display: none;
    }

    .section-body {
      padding-left: 20px;
    }

    .hero-grid {
      grid-template-columns: 4px 1fr;
      padding: 0 20px;
    }

    .hero-content {
      padding: 56px 0 48px 20px;
    }

    .use-columns {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .char-item {
      grid-template-columns: 60px 1fr;
    }

    .related-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 560px) {
    .section-grid {
      grid-template-columns: 3px 1fr;
      padding: 0 16px;
    }

    .section-body {
      padding-left: 16px;
    }

    .hero-grid {
      grid-template-columns: 3px 1fr;
      padding: 0 16px;
    }

    .hero-content {
      padding: 40px 0 36px 16px;
    }

    .hero-title {
      letter-spacing: -0.01em;
    }

    .section {
      padding: 48px 0;
    }

    .section-heading {
      margin-bottom: 28px;
    }

    .char-item {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .char-bg-number {
      font-size: 2rem;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .nav-inner {
      padding: 12px 16px;
    }

    .nav-logo {
      font-size: 0.7rem;
    }

    .nav-current {
      font-size: 0.7rem;
    }

    .prompt-header {
      flex-wrap: wrap;
      gap: 10px;
    }

    .footer {
      padding: 40px 16px;
    }
  }
</style>
