---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Nunito+Sans:wght@600;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <div class="hero-line"></div>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">A Quiet Philosophy</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy & Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Fit, Wrong Fit</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background-color: #FFFFFF;
    color: #2C3E50;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 1px solid #E8E8E8;
    background: #FFFFFF;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 920px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #2C3E50;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid #E8E8E8;
    border-radius: 8px;
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  .nav-logo:hover {
    background: #F8F6F3;
    border-color: #D0D0D0;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  }

  .nav-divider {
    font-size: 0.9rem;
    color: #D0D0D0;
    margin: 0 2px;
    font-weight: 400;
  }

  .nav-current {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    color: #8FA5B2;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid transparent;
    border-radius: 8px;
    transition: border-color 0.3s, background 0.3s;
  }

  .nav-current:hover {
    border-color: #E8E8E8;
    background: #FAFAFA;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #FFFFFF;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    border-bottom: 1px solid #E8E8E8;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.8rem;
    color: #8FA5B2;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 5rem);
    line-height: 1.05;
    margin: 0 0 28px 0;
    color: #2C3E50;
    letter-spacing: -0.02em;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 28px;
  }

  .hero-line {
    width: 48px;
    height: 2px;
    background: #E8DDD0;
    border-radius: 1px;
  }

  .hero-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    line-height: 1.8;
    margin: 0 auto;
    max-width: 520px;
    color: #8FA5B2;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 1px solid #E8E8E8;
    position: relative;
  }

  .section-inner {
    max-width: 920px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 60px;
    height: 1px;
    background: #E8DDD0;
  }

  .section-label {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.75rem;
    color: #8FA5B2;
    white-space: nowrap;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #2C3E50;
    letter-spacing: -0.01em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #FAFAF8;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #2C3E50;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #FFFFFF;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 1px solid #E8E8E8;
    border-radius: 12px;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: #FFFFFF;
    transition: box-shadow 0.3s, border-color 0.3s, transform 0.3s;
  }

  .char-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    border-color: #E8DDD0;
    transform: translateY(-2px);
  }

  .char-number {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 600;
    font-size: 0.7rem;
    color: #8FA5B2;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 24px;
    height: 2px;
    background: #E8DDD0;
    margin: 0 auto 14px;
    border-radius: 1px;
  }

  .char-title {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    margin: 0 0 12px 0;
    color: #2C3E50;
  }

  .char-description {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.75;
    margin: 0;
    color: #8FA5B2;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #FAFAF8;
  }

  .prompt-block {
    border: 1px solid #E8E8E8;
    border-radius: 12px;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    background: #FFFFFF;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.03);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid #E8E8E8;
    background: #FAFAF8;
  }

  .prompt-header-label {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.75rem;
    color: #8FA5B2;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 600;
    font-size: 0.8rem;
    background: transparent;
    color: #2C3E50;
    border: 1px solid #E8E8E8;
    border-radius: 8px;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  .copy-button:hover {
    background: #F8F6F3;
    border-color: #D0D0D0;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  }

  .copy-button.copied {
    background: #E8DDD0;
    border-color: #D0C4B4;
    color: #2C3E50;
  }

  .prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.85;
    color: #2C3E50;
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #FFFFFF;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 1px solid #E8E8E8;
    border-radius: 12px;
    overflow: hidden;
    background: #FFFFFF;
    transition: box-shadow 0.3s;
  }

  .use-column:hover {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
  }

  .use-column-heading {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 1px solid #E8E8E8;
    letter-spacing: 0.02em;
  }

  .use-good .use-column-heading {
    background: #F8F6F3;
    color: #2C3E50;
  }

  .use-bad .use-column-heading {
    background: #FAFAFA;
    color: #8FA5B2;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(232, 232, 232, 0.6);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #2C3E50;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #E8DDD0;
    flex-shrink: 0;
    margin-top: 7px;
  }

  .use-item-bad::before {
    content: '\2013';
    color: #D0D0D0;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #FAFAF8;
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.9;
    margin: 0 0 24px 0;
    color: #2C3E50;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #FFFFFF;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 28px 20px;
    border: 1px solid #E8E8E8;
    border-radius: 12px;
    text-decoration: none;
    color: #2C3E50;
    text-align: center;
    background: #FFFFFF;
    transition: box-shadow 0.3s, border-color 0.3s, transform 0.3s;
  }

  .related-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    border-color: #E8DDD0;
    transform: translateY(-2px);
  }

  .related-relationship {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.65rem;
    color: #8FA5B2;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .related-name {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: #2C3E50;
  }

  .related-arrow {
    font-size: 1rem;
    color: #E8DDD0;
    transition: color 0.3s;
  }

  .related-card:hover .related-arrow {
    color: #8FA5B2;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #F8F6F3;
    padding: 64px 32px;
    border-top: 1px solid #E8E8E8;
  }

  .footer-inner {
    max-width: 920px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-ornament {
    width: 48px;
    height: 2px;
    background: #E8DDD0;
    border-radius: 1px;
  }

  .footer-logo {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    color: #2C3E50;
    text-decoration: none;
    padding: 8px 24px;
    border: 1px solid #E8E8E8;
    border-radius: 8px;
    transition: background 0.3s, box-shadow 0.3s;
  }

  .footer-logo:hover {
    background: #FFFFFF;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.04);
  }

  .footer-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: #8FA5B2;
  }

  .footer-back {
    font-family: 'Nunito Sans', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    color: #2C3E50;
    text-decoration: none;
    padding: 6px 20px;
    border: 1px solid transparent;
    border-radius: 8px;
    transition: border-color 0.3s, background 0.3s;
  }

  .footer-back:hover {
    border-color: #E8E8E8;
    background: #FFFFFF;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 64px 24px 56px;
    }

    .section {
      padding: 64px 24px;
    }

    .section-heading {
      margin-bottom: 36px;
    }

    .characteristics-grid {
      grid-template-columns: 1fr;
    }

    .use-grid {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .prompt-text {
      font-size: 0.88rem;
      padding: 22px 18px;
    }

    .prompt-header {
      padding: 12px 18px;
      flex-wrap: wrap;
      gap: 10px;
    }

    .nav-inner {
      padding: 12px 20px;
    }

    .footer {
      padding: 48px 24px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 48px 16px 40px;
    }

    .section {
      padding: 48px 16px;
    }

    .nav-inner {
      padding: 10px 16px;
      gap: 8px;
    }

    .nav-logo {
      font-size: 0.85rem;
      padding: 5px 14px;
    }

    .nav-current {
      font-size: 0.8rem;
      padding: 5px 12px;
    }

    .char-card {
      padding: 24px 20px 20px;
    }

    .copy-button {
      padding: 5px 14px;
      font-size: 0.75rem;
    }

    .use-item {
      padding: 11px 16px;
      font-size: 0.88rem;
    }

    .related-card {
      padding: 22px 16px;
    }

    .section-header {
      gap: 10px;
    }

    .section-rule {
      max-width: 30px;
    }

    .hero-title {
      font-size: clamp(2.2rem, 9vw, 5rem);
    }
  }
</style>
