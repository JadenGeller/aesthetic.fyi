---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&family=Inter:wght@300&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-label">Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- EDITORIAL IMAGE PLACEHOLDER -->
  <section class="editorial-image">
    <div class="image-placeholder image-placeholder-wide"></div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <span class="section-label">What This Is</span>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <span class="section-label">Characteristics</span>
      <div class="characteristics-list">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-item">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <span class="section-label">Style Reference</span>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- EDITORIAL IMAGE PLACEHOLDER 2 -->
  <section class="editorial-image editorial-image-white">
    <div class="image-placeholder image-placeholder-portrait"></div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <span class="section-label">When to Use</span>
      <div class="use-grid">
        <div class="use-column">
          <h3 class="use-column-heading">Good for</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column">
          <h3 class="use-column-heading">Not for</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <span class="section-label">History</span>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <span class="section-label">Related Styles</span>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">All Aesthetics</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    background-color: #000000;
    color: #FFFFFF;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background: #000000;
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: none;
  }

  .nav-inner {
    max-width: 100%;
    margin: 0;
    padding: 28px 48px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #FFFFFF;
    text-decoration: none;
    transition: opacity 0.3s;
  }

  .nav-logo:hover {
    opacity: 0.5;
  }

  .nav-divider {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.75rem;
    color: #E0E0E0;
    opacity: 0.3;
  }

  .nav-current {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #E0E0E0;
    text-decoration: none;
    opacity: 0.5;
    transition: opacity 0.3s;
  }

  .nav-current:hover {
    opacity: 1;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #000000;
    padding: 160px 48px 140px;
    text-align: center;
  }

  .hero-inner {
    max-width: 100%;
    margin: 0 auto;
  }

  .hero-label {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.5em;
    color: #E0E0E0;
    display: block;
    margin-bottom: 60px;
    opacity: 0.5;
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(3.5rem, 10vw, 8rem);
    line-height: 0.95;
    margin: 0 0 48px 0;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #FFFFFF;
  }

  .hero-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    line-height: 1.8;
    margin: 0;
    color: #E0E0E0;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  /* ========================================
     EDITORIAL IMAGE PLACEHOLDERS
     ======================================== */
  .editorial-image {
    background: #000000;
    padding: 0 48px;
  }

  .editorial-image-white {
    background: #FFFFFF;
  }

  .image-placeholder {
    width: 100%;
    background: linear-gradient(135deg, #1A1A1A 0%, #000000 50%, #1A1A1A 100%);
  }

  .image-placeholder-wide {
    aspect-ratio: 21 / 9;
  }

  .image-placeholder-portrait {
    aspect-ratio: 3 / 4;
    max-width: 600px;
    margin: 0 auto;
    background: linear-gradient(180deg, #E0E0E0 0%, #FFFFFF 50%, #E0E0E0 100%);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 120px 48px;
    text-align: center;
  }

  .section-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.5em;
    display: block;
    margin-bottom: 64px;
    opacity: 0.5;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #FFFFFF;
    color: #000000;
  }

  .about-section .section-label {
    color: #000000;
  }

  .about-content {
    max-width: 560px;
    margin: 0 auto;
    text-align: left;
  }

  .about-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 2;
    margin: 0 0 32px 0;
    color: #1A1A1A;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #000000;
    color: #FFFFFF;
  }

  .characteristics-section .section-label {
    color: #FFFFFF;
  }

  .characteristics-list {
    text-align: left;
    max-width: 560px;
    margin: 0 auto;
  }

  .char-item {
    padding: 48px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .char-item:first-child {
    padding-top: 0;
  }

  .char-item:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .char-number {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    color: #E0E0E0;
    display: block;
    margin-bottom: 20px;
    opacity: 0.4;
  }

  .char-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 1.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin: 0 0 16px 0;
    color: #FFFFFF;
  }

  .char-description {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    line-height: 1.9;
    margin: 0;
    color: #E0E0E0;
    opacity: 0.7;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #FFFFFF;
    color: #000000;
  }

  .prompt-section .section-label {
    color: #000000;
  }

  .prompt-block {
    border: 1px solid #E0E0E0;
    text-align: left;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 28px;
    border-bottom: 1px solid #E0E0E0;
  }

  .prompt-header-label {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: #1A1A1A;
    opacity: 0.5;
  }

  .copy-button {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.6rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    background: none;
    color: #1A1A1A;
    border: 1px solid #E0E0E0;
    padding: 10px 24px;
    cursor: pointer;
    transition: color 0.3s, border-color 0.3s;
  }

  .copy-button:hover {
    color: #000000;
    border-color: #000000;
  }

  .copy-button.copied {
    color: #000000;
    border-color: #000000;
  }

  .prompt-text {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    line-height: 1.9;
    color: #1A1A1A;
    padding: 28px;
    margin: 0;
    white-space: normal;
    opacity: 0.7;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #000000;
    color: #FFFFFF;
  }

  .use-section .section-label {
    color: #FFFFFF;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    text-align: left;
  }

  .use-column-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: #FFFFFF;
    margin: 0 0 32px 0;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.85rem;
    line-height: 1.7;
    padding: 16px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    color: #E0E0E0;
    opacity: 0.8;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #FFFFFF;
    color: #000000;
  }

  .history-section .section-label {
    color: #000000;
  }

  .history-content {
    max-width: 560px;
    margin: 0 auto;
    text-align: left;
  }

  .history-paragraph {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    line-height: 2;
    margin: 0 0 32px 0;
    color: #1A1A1A;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #000000;
    color: #FFFFFF;
  }

  .related-section .section-label {
    color: #FFFFFF;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 48px 32px;
    text-decoration: none;
    color: #FFFFFF;
    border-right: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    text-align: left;
    transition: background-color 0.3s;
  }

  .related-card:hover {
    background-color: #1A1A1A;
  }

  .related-card:nth-child(3n) {
    border-right: none;
  }

  .related-card:nth-last-child(-n+3) {
    border-bottom: none;
  }

  .related-relationship {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    color: #E0E0E0;
    opacity: 0.4;
  }

  .related-name {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 1.3rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #FFFFFF;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #FFFFFF;
    color: #000000;
    padding: 120px 48px;
  }

  .footer-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
  }

  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #000000;
    text-decoration: none;
    transition: opacity 0.3s;
  }

  .footer-logo:hover {
    opacity: 0.4;
  }

  .footer-tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.75rem;
    color: #1A1A1A;
    letter-spacing: 0.1em;
    opacity: 0.5;
  }

  .footer-back {
    font-family: 'Inter', sans-serif;
    font-weight: 300;
    font-size: 0.55rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: #1A1A1A;
    text-decoration: none;
    margin-top: 12px;
    transition: opacity 0.3s;
    opacity: 0.5;
  }

  .footer-back:hover {
    opacity: 1;
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 120px 32px 100px;
    }

    .nav-inner {
      padding: 24px 32px;
    }

    .section {
      padding: 80px 32px;
    }

    .editorial-image {
      padding: 0 32px;
    }

    .section-label {
      margin-bottom: 48px;
    }

    .characteristics-list {
      max-width: 100%;
    }

    .about-content,
    .history-content {
      max-width: 100%;
    }

    .use-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .related-card {
      border-right: none;
      padding: 32px 0;
    }

    .related-card:last-child {
      border-bottom: none;
    }

    .prompt-text {
      font-size: 0.8rem;
      padding: 20px;
    }

    .prompt-header {
      padding: 16px 20px;
    }

    .footer {
      padding: 80px 32px;
    }

    .image-placeholder-portrait {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 80px 24px 60px;
    }

    .hero-label {
      margin-bottom: 40px;
    }

    .hero-tagline {
      font-size: 0.75rem;
    }

    .nav-inner {
      padding: 20px 24px;
      gap: 10px;
    }

    .nav-logo {
      font-size: 0.65rem;
    }

    .nav-current {
      font-size: 0.55rem;
    }

    .section {
      padding: 60px 24px;
    }

    .editorial-image {
      padding: 0 24px;
    }

    .char-item {
      padding: 32px 0;
    }

    .char-title {
      font-size: 1.3rem;
    }

    .copy-button {
      padding: 8px 16px;
      font-size: 0.55rem;
    }

    .use-item {
      padding: 12px 0;
      font-size: 0.8rem;
    }

    .related-card {
      padding: 24px 0;
    }

    .footer {
      padding: 60px 24px;
    }
  }
</style>
