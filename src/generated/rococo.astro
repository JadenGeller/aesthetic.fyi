---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">&loz;</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-scrollwork"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-flourish hero-flourish-left"></span>
        <span class="hero-diamond"></span>
        <span class="hero-flourish hero-flourish-right"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-ornament">&diams;</span>
        <span class="section-label">What This Is</span>
        <span class="section-ornament">&diams;</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">An Ornamental Philosophy</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-ornament">&diams;</span>
        <span class="section-label">Design Tokens</span>
        <span class="section-ornament">&diams;</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider">
              <span class="char-divider-diamond"></span>
            </div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-ornament">&diams;</span>
        <span class="section-label">Style Reference</span>
        <span class="section-ornament">&diams;</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-ornament">&diams;</span>
        <span class="section-label">When to Use</span>
        <span class="section-ornament">&diams;</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Gilded Ground, Bare Ground</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-ornament">&diams;</span>
        <span class="section-label">Origins</span>
        <span class="section-ornament">&diams;</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-ornament">&diams;</span>
        <span class="section-label">Explore</span>
        <span class="section-ornament">&diams;</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament-line"></div>
      <div class="footer-flourish">
        <span class="footer-flourish-wing"></span>
        <span class="footer-flourish-diamond">&loz;</span>
        <span class="footer-flourish-wing"></span>
      </div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament-line"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Cormorant Garamond', serif;
    background-color: #FFF8F0;
    color: #4A3728;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 2px solid #C9A84C;
    background: linear-gradient(180deg, #FFF8F0, #FDF2E9);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 12px rgba(201, 168, 76, 0.12);
  }

  .nav::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 5%, #C9A84C 30%, #E8D5A3 50%, #C9A84C 70%, transparent 95%);
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    font-size: 1rem;
    color: #C9A84C;
    text-decoration: none;
    padding: 6px 20px;
    border: 1px solid #C9A84C;
    border-radius: 4px;
    transition: background 0.3s, box-shadow 0.3s;
    letter-spacing: 0.05em;
    position: relative;
  }

  .nav-logo::before {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    right: 3px;
    bottom: 3px;
    border: 1px dashed rgba(201, 168, 76, 0.5);
    border-radius: 2px;
    pointer-events: none;
  }

  .nav-logo:hover {
    background: rgba(201, 168, 76, 0.08);
    box-shadow: 0 0 12px rgba(201, 168, 76, 0.15);
  }

  .nav-divider {
    font-size: 1rem;
    color: #C9A84C;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-style: italic;
    font-size: 0.95rem;
    color: #8B7355;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid transparent;
    border-radius: 4px;
    transition: border-color 0.3s, color 0.3s;
    letter-spacing: 0.03em;
  }

  .nav-current:hover {
    border-color: rgba(201, 168, 76, 0.4);
    color: #C9A84C;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: linear-gradient(175deg, #FFF8F0 0%, #F4C2C2 35%, #B5D8EB 65%, #FFF8F0 100%);
    padding: 110px 32px 96px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 2px solid #C9A84C;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 2px solid #C9A84C;
    border-radius: 8px;
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    top: 28px;
    left: 28px;
    right: 28px;
    bottom: 28px;
    border: 1px dashed rgba(201, 168, 76, 0.6);
    border-radius: 6px;
    pointer-events: none;
  }

  .hero-scrollwork {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      /* Corner rosettes - top left */
      radial-gradient(circle 8px at 6% 10%, rgba(201, 168, 76, 0.2) 50%, transparent 50%),
      radial-gradient(circle 5px at 4% 8%, rgba(201, 168, 76, 0.15) 50%, transparent 50%),
      radial-gradient(circle 5px at 8% 12%, rgba(201, 168, 76, 0.15) 50%, transparent 50%),
      radial-gradient(circle 3px at 5% 14%, rgba(201, 168, 76, 0.12) 50%, transparent 50%),
      radial-gradient(circle 3px at 9% 7%, rgba(201, 168, 76, 0.12) 50%, transparent 50%),
      radial-gradient(circle 4px at 3% 12%, rgba(201, 168, 76, 0.1) 50%, transparent 50%),
      /* Corner rosettes - top right */
      radial-gradient(circle 8px at 94% 10%, rgba(201, 168, 76, 0.2) 50%, transparent 50%),
      radial-gradient(circle 5px at 96% 8%, rgba(201, 168, 76, 0.15) 50%, transparent 50%),
      radial-gradient(circle 5px at 92% 12%, rgba(201, 168, 76, 0.15) 50%, transparent 50%),
      radial-gradient(circle 3px at 95% 14%, rgba(201, 168, 76, 0.12) 50%, transparent 50%),
      radial-gradient(circle 3px at 91% 7%, rgba(201, 168, 76, 0.12) 50%, transparent 50%),
      radial-gradient(circle 4px at 97% 12%, rgba(201, 168, 76, 0.1) 50%, transparent 50%),
      /* Corner rosettes - bottom left */
      radial-gradient(circle 8px at 6% 90%, rgba(201, 168, 76, 0.2) 50%, transparent 50%),
      radial-gradient(circle 5px at 4% 92%, rgba(201, 168, 76, 0.15) 50%, transparent 50%),
      radial-gradient(circle 5px at 8% 88%, rgba(201, 168, 76, 0.15) 50%, transparent 50%),
      radial-gradient(circle 3px at 5% 86%, rgba(201, 168, 76, 0.12) 50%, transparent 50%),
      radial-gradient(circle 3px at 9% 93%, rgba(201, 168, 76, 0.12) 50%, transparent 50%),
      /* Corner rosettes - bottom right */
      radial-gradient(circle 8px at 94% 90%, rgba(201, 168, 76, 0.2) 50%, transparent 50%),
      radial-gradient(circle 5px at 96% 92%, rgba(201, 168, 76, 0.15) 50%, transparent 50%),
      radial-gradient(circle 5px at 92% 88%, rgba(201, 168, 76, 0.15) 50%, transparent 50%),
      radial-gradient(circle 3px at 95% 86%, rgba(201, 168, 76, 0.12) 50%, transparent 50%),
      radial-gradient(circle 3px at 91% 93%, rgba(201, 168, 76, 0.12) 50%, transparent 50%),
      /* Scattered small ornaments */
      radial-gradient(circle 2px at 25% 25%, rgba(201, 168, 76, 0.08) 50%, transparent 50%),
      radial-gradient(circle 2px at 75% 25%, rgba(201, 168, 76, 0.08) 50%, transparent 50%),
      radial-gradient(circle 2px at 25% 75%, rgba(201, 168, 76, 0.08) 50%, transparent 50%),
      radial-gradient(circle 2px at 75% 75%, rgba(201, 168, 76, 0.08) 50%, transparent 50%),
      radial-gradient(circle 2px at 50% 15%, rgba(201, 168, 76, 0.08) 50%, transparent 50%),
      radial-gradient(circle 2px at 50% 85%, rgba(201, 168, 76, 0.08) 50%, transparent 50%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-style: italic;
    font-size: 0.9rem;
    color: #C9A84C;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 4px 20px;
    border-top: 1px solid rgba(201, 168, 76, 0.4);
    border-bottom: 1px solid rgba(201, 168, 76, 0.4);
  }

  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    font-size: clamp(3.5rem, 10vw, 6.5rem);
    line-height: 1.0;
    margin: 0 0 28px 0;
    color: #4A3728;
    text-shadow: 0 2px 4px rgba(201, 168, 76, 0.15);
    letter-spacing: 0.04em;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .hero-flourish {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, #C9A84C);
    position: relative;
  }

  .hero-flourish-right {
    background: linear-gradient(90deg, #C9A84C, transparent);
  }

  .hero-flourish::after {
    content: '';
    position: absolute;
    top: -3px;
    width: 8px;
    height: 8px;
    border: 1px solid #C9A84C;
    border-radius: 50%;
    background: #FFF8F0;
  }

  .hero-flourish-left::after {
    left: 0;
  }

  .hero-flourish-right::after {
    right: 0;
  }

  .hero-diamond {
    width: 8px;
    height: 8px;
    background: #C9A84C;
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  .hero-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1.1rem, 2.5vw, 1.4rem);
    line-height: 1.8;
    margin: 0 auto;
    max-width: 540px;
    color: #6B5744;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 96px 32px;
    border-bottom: 2px solid #C9A84C;
    position: relative;
  }

  .section::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 10%, rgba(201, 168, 76, 0.4) 50%, transparent 90%);
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #C9A84C, transparent);
  }

  .section-ornament {
    font-size: 0.6rem;
    color: #C9A84C;
    line-height: 1;
  }

  .section-label {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-style: italic;
    font-size: 0.85rem;
    color: #C9A84C;
    white-space: nowrap;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.15;
    margin: 0 0 52px 0;
    text-align: center;
    color: #4A3728;
    letter-spacing: 0.02em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: linear-gradient(180deg, #F4C2C2 0%, #FFF8F0 100%);
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 18px;
    left: 18px;
    right: 18px;
    bottom: 18px;
    border: 2px solid rgba(201, 168, 76, 0.35);
    border-radius: 8px;
    pointer-events: none;
  }

  .about-content {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .about-content::before {
    content: '\201C';
    font-family: 'Cormorant Garamond', serif;
    font-size: 6rem;
    font-weight: 700;
    color: rgba(201, 168, 76, 0.2);
    position: absolute;
    top: -50px;
    left: -10px;
    line-height: 1;
    pointer-events: none;
  }

  .about-paragraph {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1.2rem;
    line-height: 1.95;
    margin: 0 0 28px 0;
    color: #4A3728;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #FFF8F0;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 28px;
  }

  .char-card {
    border: 2px solid #C9A84C;
    border-radius: 8px;
    padding: 36px 28px 28px;
    position: relative;
    text-align: center;
    background: linear-gradient(170deg, #FFF8F0, #FEFAF4);
    transition: box-shadow 0.3s, transform 0.3s;
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: 7px;
    left: 7px;
    right: 7px;
    bottom: 7px;
    border: 1px dashed rgba(201, 168, 76, 0.5);
    border-radius: 5px;
    pointer-events: none;
  }

  .char-card::after {
    content: '';
    position: absolute;
    top: -1px;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 3px;
    background: linear-gradient(90deg, transparent, #C9A84C, transparent);
    border-radius: 0 0 3px 3px;
  }

  .char-card:hover {
    box-shadow: 0 6px 28px rgba(201, 168, 76, 0.18), 0 2px 8px rgba(201, 168, 76, 0.1);
    transform: translateY(-2px);
  }

  .char-number {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-style: italic;
    font-size: 0.8rem;
    color: #C9A84C;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 0 auto 14px;
    position: relative;
  }

  .char-divider::before,
  .char-divider::after {
    content: '';
    width: 24px;
    height: 1px;
    background: linear-gradient(90deg, transparent, #C9A84C);
  }

  .char-divider::after {
    background: linear-gradient(90deg, #C9A84C, transparent);
  }

  .char-divider-diamond {
    width: 5px;
    height: 5px;
    background: #C9A84C;
    transform: rotate(45deg);
    flex-shrink: 0;
  }

  .char-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    font-size: 1.3rem;
    margin: 0 0 14px 0;
    color: #4A3728;
    letter-spacing: 0.02em;
  }

  .char-description {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.8;
    margin: 0;
    color: #8B7355;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: linear-gradient(180deg, #B5D8EB 0%, #FFF8F0 100%);
  }

  .prompt-section::before {
    content: '';
    position: absolute;
    top: 18px;
    left: 18px;
    right: 18px;
    bottom: 18px;
    border: 2px solid rgba(201, 168, 76, 0.3);
    border-radius: 8px;
    pointer-events: none;
  }

  .prompt-block {
    border: 2px solid #C9A84C;
    border-radius: 8px;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(201, 168, 76, 0.1);
  }

  .prompt-block::before {
    content: '';
    position: absolute;
    top: 5px;
    left: 5px;
    right: 5px;
    bottom: 5px;
    border: 1px dashed rgba(201, 168, 76, 0.45);
    border-radius: 5px;
    pointer-events: none;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(201, 168, 76, 0.3);
    background: linear-gradient(180deg, rgba(201, 168, 76, 0.1), rgba(201, 168, 76, 0.04));
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 600;
    font-style: italic;
    font-size: 0.85rem;
