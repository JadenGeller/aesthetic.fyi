---
const { aesthetic } = Astro.props;
---

<div class="page">
  <!-- TASKBAR (fixed at bottom) -->
  <div class="taskbar">
    <div class="taskbar-inner">
      <div class="start-button">
        <span class="start-icon">&#9632;</span>
        <span class="start-label">Start</span>
      </div>
      <div class="taskbar-divider"></div>
      <div class="taskbar-items">
        <a href="/" class="taskbar-item taskbar-item-active">aesthetic.fyi</a>
        <a href={`/${aesthetic.slug}`} class="taskbar-item">{aesthetic.name}</a>
      </div>
      <div class="taskbar-spacer"></div>
      <div class="taskbar-tray">
        <span class="tray-indicator"></span>
        <span class="tray-clock">12:00 PM</span>
      </div>
    </div>
  </div>

  <!-- DESKTOP -->
  <div class="desktop">
    <!-- Desktop Icons -->
    <div class="desktop-icons">
      <a href="/" class="desktop-icon">
        <div class="icon-img">&#128193;</div>
        <span class="icon-label">Home</span>
      </a>
      <div class="desktop-icon">
        <div class="icon-img">&#128196;</div>
        <span class="icon-label">About</span>
      </div>
      <div class="desktop-icon">
        <div class="icon-img">&#128230;</div>
        <span class="icon-label">Archive</span>
      </div>
    </div>

    <!-- NAV WINDOW -->
    <div class="window nav-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">Navigation</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-body nav-body">
        <a href="/" class="nav-link">aesthetic.fyi</a>
        <span class="nav-separator">&#9654;</span>
        <a href={`/${aesthetic.slug}`} class="nav-link nav-link-current">{aesthetic.name}</a>
      </div>
    </div>

    <!-- HERO WINDOW -->
    <div class="window hero-window">
      <div class="window-titlebar titlebar-active">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">{aesthetic.name} - Welcome</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-body hero-body">
        <div class="hero-badge">A Web Aesthetic</div>
        <h1 class="hero-title">{aesthetic.name}</h1>
        <div class="hero-divider"></div>
        <p class="hero-tagline">{aesthetic.tagline}</p>
      </div>
    </div>

    <!-- ABOUT WINDOW -->
    <div class="window about-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">About - What This Is</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-menubar">
        <span class="menu-item">File</span>
        <span class="menu-item">Edit</span>
        <span class="menu-item">View</span>
        <span class="menu-item">Help</span>
      </div>
      <div class="window-body about-body">
        <div class="window-section-label">What This Is</div>
        <h2 class="window-heading">A Digital Workspace</h2>
        <div class="about-content">
          {aesthetic.about.split('\n\n').map((paragraph: string) => (
            <p class="about-paragraph">{paragraph}</p>
          ))}
        </div>
      </div>
    </div>

    <!-- CHARACTERISTICS WINDOW -->
    <div class="window characteristics-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">Properties - Characteristics</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-body characteristics-body">
        <div class="window-section-label">Design Tokens</div>
        <h2 class="window-heading">Characteristics</h2>
        <div class="characteristics-grid">
          {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
            <div class="char-card">
              <div class="char-titlebar">
                <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
                <span class="char-title">{char.title}</span>
              </div>
              <div class="char-body">
                <p class="char-description">{char.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- STYLE REFERENCE WINDOW -->
    <div class="window prompt-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">Notepad - Style Reference</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-menubar">
        <span class="menu-item">File</span>
        <span class="menu-item">Edit</span>
        <span class="menu-item">Format</span>
        <span class="menu-item">Help</span>
      </div>
      <div class="window-body prompt-body">
        <div class="window-section-label">Style Reference</div>
        <h2 class="window-heading">Copy &amp; Paste</h2>
        <div class="prompt-block">
          <div class="prompt-header">
            <span class="prompt-header-label">prompt.txt</span>
            <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
          </div>
          <div class="prompt-text-area">
            <p class="prompt-text">{aesthetic.prompt}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- WHEN TO USE WINDOW -->
    <div class="window use-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">Explorer - When to Use</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-body use-body">
        <div class="window-section-label">When to Use</div>
        <h2 class="window-heading">Good Fit, Bad Fit</h2>
        <div class="use-grid">
          <div class="use-column use-good">
            <div class="use-column-header">
              <span class="use-column-icon">&#9989;</span>
              <h3 class="use-column-heading">Good For</h3>
            </div>
            <ul class="use-list">
              {aesthetic.good_for.map((item: string) => (
                <li class="use-item use-item-good">{item}</li>
              ))}
            </ul>
          </div>
          <div class="use-column use-bad">
            <div class="use-column-header">
              <span class="use-column-icon">&#10060;</span>
              <h3 class="use-column-heading">Not For</h3>
            </div>
            <ul class="use-list">
              {aesthetic.not_for.map((item: string) => (
                <li class="use-item use-item-bad">{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- HISTORY WINDOW -->
    <div class="window history-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">History - Origins</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-menubar">
        <span class="menu-item">File</span>
        <span class="menu-item">Edit</span>
        <span class="menu-item">View</span>
        <span class="menu-item">Help</span>
      </div>
      <div class="window-body history-body">
        <div class="window-section-label">Origins</div>
        <h2 class="window-heading">History</h2>
        <div class="history-content">
          {aesthetic.history.split('\n\n').map((paragraph: string) => (
            <p class="history-paragraph">{paragraph}</p>
          ))}
        </div>
      </div>
    </div>

    <!-- RELATED STYLES WINDOW -->
    <div class="window related-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">Explorer - Related Styles</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-body related-body">
        <div class="window-section-label">Explore</div>
        <h2 class="window-heading">Related Styles</h2>
        <div class="related-grid">
          {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
            <a href={`/${rel.slug}`} class="related-card">
              <div class="related-icon">&#128193;</div>
              <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
              <span class="related-relationship">{rel.relationship}</span>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- FOOTER WINDOW -->
    <div class="window footer-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">About aesthetic.fyi</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-body footer-body">
        <a href="/" class="footer-logo">aesthetic.fyi</a>
        <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
        <div class="footer-divider"></div>
        <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
        <span class="footer-version">Version 1.0</span>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }

    // Update clock in taskbar
    function updateClock() {
      const clock = document.querySelector('.tray-clock');
      if (clock) {
        const now = new Date();
        clock.textContent = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      }
    }
    updateClock();
    setInterval(updateClock, 60000);
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: -apple-system, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: #008080;
    color: #000000;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: auto;
    -moz-osx-font-smoothing: auto;
  }

  /* ========================================
     TASKBAR
     ======================================== */
  .taskbar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: #C0C0C0;
    border-top: 2px solid #FFFFFF;
    box-shadow: inset 0 1px 0 #DFDFDF;
    height: 36px;
  }

  .taskbar-inner {
    display: flex;
    align-items: center;
    height: 100%;
    padding: 2px 4px;
    gap: 4px;
  }

  .start-button {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    height: 28px;
    background: #C0C0C0;
    border: 2px outset #DFDFDF;
    cursor: pointer;
    font-size: 12px;
    font-weight: 700;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    color: #000;
  }

  .start-button:active {
    border-style: inset;
  }

  .start-icon {
    font-size: 14px;
    color: #000080;
  }

  .start-label {
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .taskbar-divider {
    width: 2px;
    height: 24px;
    border-left: 1px solid #808080;
    border-right: 1px solid #FFFFFF;
    margin: 0 2px;
  }

  .taskbar-items {
    display: flex;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  .taskbar-item {
    display: flex;
    align-items: center;
    padding: 2px 12px;
    height: 24px;
    background: #C0C0C0;
    border: 2px outset #DFDFDF;
    font-size: 11px;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    color: #000;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 160px;
  }

  .taskbar-item-active {
    border-style: inset;
    background: #D4D0C8;
    font-weight: 700;
  }

  .taskbar-spacer {
    flex: 1;
  }

  .taskbar-tray {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 2px 8px;
    height: 24px;
    border: 2px inset #DFDFDF;
    background: #C0C0C0;
  }

  .tray-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #00AA00;
  }

  .tray-clock {
    font-size: 11px;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    color: #000;
    white-space: nowrap;
  }

  /* ========================================
     DESKTOP
     ======================================== */
  .desktop {
    background: linear-gradient(135deg, #008080 0%, #006666 40%, #007070 60%, #008080 100%);
    min-height: 100vh;
    padding: 24px 32px 56px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
    position: relative;
  }

  /* ========================================
     DESKTOP ICONS
     ======================================== */
  .desktop-icons {
    position: absolute;
    top: 20px;
    left: 20px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    z-index: 1;
  }

  .desktop-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-decoration: none;
    cursor: pointer;
    padding: 4px;
  }

  .desktop-icon:hover .icon-label {
    background: #000080;
    color: #FFFFFF;
  }

  .icon-img {
    font-size: 32px;
    line-height: 1;
    filter: drop-shadow(1px 1px 0 rgba(0, 0, 0, 0.3));
  }

  .icon-label {
    font-size: 11px;
    color: #FFFFFF;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.7);
    padding: 1px 4px;
    text-align: center;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  /* ========================================
     WINDOW CHROME
     ======================================== */
  .window {
    width: 100%;
    max-width: 900px;
    border: 2px outset #DFDFDF;
    background: #C0C0C0;
    box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.3);
    position: relative;
    z-index: 2;
  }

  .window-titlebar {
    display: flex;
    align-items: center;
    padding: 3px 4px;
    background: linear-gradient(180deg, #808080 0%, #A0A0A0 100%);
    min-height: 24px;
    gap: 6px;
    user-select: none;
  }

  .titlebar-active {
    background: linear-gradient(90deg, #000080 0%, #1084D0 100%);
  }

  .titlebar-active .window-title {
    color: #FFFFFF;
  }

  .window-controls {
    display: flex;
    gap: 6px;
    padding: 0 2px;
  }

  .window-controls-spacer {
    width: 52px;
    flex-shrink: 0;
  }

  .window-btn {
    width: 14px;
    height: 14px;
    border-radius: 2px;
    border: 1px solid #666;
    cursor: pointer;
  }

  .btn-close {
    background: #C75050;
    border-color: #A03030;
  }

  .btn-minimize {
    background: #D4AA00;
    border-color: #AA8800;
  }

  .btn-maximize {
    background: #50A050;
    border-color: #308030;
  }

  .window-title {
    flex: 1;
    text-align: center;
    font-size: 12px;
    font-weight: 700;
    color: #C0C0C0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  .window-menubar {
    display: flex;
    gap: 0;
    padding: 2px 4px;
    background: #C0C0C0;
    border-bottom: 1px solid #808080;
    border-top: 1px solid #FFFFFF;
  }

  .menu-item {
    font-size: 12px;
    padding: 2px 10px;
    color: #000;
    cursor: pointer;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  .menu-item:hover {
    background: #000080;
    color: #FFFFFF;
  }

  .window-body {
    background: #FFFFFF;
    border: 2px inset #DFDFDF;
    margin: 2px;
    padding: 24px;
  }

  .window-section-label {
    font-size: 11px;
    color: #808080;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    text-align: center;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  .window-heading {
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 700;
    margin: 0 0 28px 0;
    text-align: center;
    color: #000080;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  /* ========================================
     NAV WINDOW
     ======================================== */
  .nav-window {
    z-index: 10;
  }

  .nav-body {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    background: #FFFFFF;
    font-size: 13px;
  }

  .nav-link {
    color: #000080;
    text-decoration: underline;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    font-size: 13px;
  }

  .nav-link:hover {
    color: #0000FF;
  }

  .nav-link-current {
    color: #000;
    text-decoration: none;
    font-weight: 700;
  }

  .nav-separator {
    font-size: 9px;
    color: #808080;
  }

  /* ========================================
     HERO WINDOW
     ======================================== */
  .hero-body {
    text-align: center;
    padding: 48px 32px;
  }

  .hero-badge {
    display: inline-block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #808080;
    border: 1px solid #C0C0C0;
    padding: 4px 16px;
    margin-bottom: 20px;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  .hero-title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 700;
    margin: 0 0 16px 0;
    color: #000080;
    line-height: 1.1;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  .hero-divider {
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, #000080, #1084D0);
    margin: 0 auto 20px;
  }

  .hero-tagline {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 500px;
    color: #444;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  /* ========================================
     ABOUT WINDOW
     ======================================== */
  .about-body {
    padding: 32px;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
  }

  .about-paragraph {
    font-size: 1rem;
    line-height: 1.8;
    margin: 0 0 20px 0;
    color: #222;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-body {
    padding: 32px;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  .char-card {
    border: 2px outset #DFDFDF;
    background: #C0C0C0;
    overflow: hidden;
  }

  .char-titlebar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 10px;
    background: linear-gradient(90deg, #000080 0%, #1084D0 100%);
    color: #FFFFFF;
    font-size: 12px;
    font-weight: 700;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  .char-number {
    font-weight: 400;
    opacity: 0.7;
    font-size: 11px;
  }

  .char-title {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .char-body {
    background: #FFFFFF;
    border: 2px inset #DFDFDF;
    margin: 2px;
    padding: 16px;
  }

  .char-description {
    font-size: 0.9rem;
    line-height: 1.7;
    margin: 0;
    color: #333;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  /* ========================================
     PROMPT / STYLE REFERENCE
     ======================================== */
  .prompt-body {
    padding: 32px;
  }

  .prompt-block {
    border: 2px inset #DFDFDF;
    background: #FFFFFF;
    max-width: 720px;
    margin: 0 auto;
    overflow: hidden;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 12px;
    background: #C0C0C0;
    border-bottom: 1px solid #808080;
  }

  .prompt-header-label {
    font-size: 12px;
    color: #000;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  .copy-button {
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    font-size: 11px;
    font-weight: 400;
    background: #C0C0C0;
    color: #000;
    border: 2px outset #DFDFDF;
    padding: 2px 16px;
