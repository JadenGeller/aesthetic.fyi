---
import { Nav, About, Characteristics, Prompt, Usage, History, Related, Footer } from '../components/aesthetic';
const { aesthetic } = Astro.props;
---

<div class="page" data-page="os-desktop">
  <!-- TASKBAR (fixed at bottom) -->
  <div class="taskbar">
    <div class="taskbar-inner">
      <div class="start-button">
        <span class="start-icon">&#9632;</span>
        <span class="start-label">Start</span>
      </div>
      <div class="taskbar-divider"></div>
      <div class="taskbar-items">
        <a href="/" class="taskbar-item taskbar-item-active">aesthetic.fyi</a>
        <a href={`/${aesthetic.slug}`} class="taskbar-item">{aesthetic.name}</a>
      </div>
      <div class="taskbar-spacer"></div>
      <div class="taskbar-tray">
        <span class="tray-indicator"></span>
        <span class="tray-clock">12:00 PM</span>
      </div>
    </div>
  </div>

  <!-- DESKTOP -->
  <div class="desktop">
    <!-- Desktop Icons -->
    <div class="desktop-icons">
      <a href="/" class="desktop-icon">
        <div class="icon-img">&#128193;</div>
        <span class="icon-label">Home</span>
      </a>
      <div class="desktop-icon">
        <div class="icon-img">&#128196;</div>
        <span class="icon-label">About</span>
      </div>
      <div class="desktop-icon">
        <div class="icon-img">&#128230;</div>
        <span class="icon-label">Archive</span>
      </div>
    </div>

    <!-- NAV WINDOW -->
    <div class="window nav-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">Navigation</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-body nav-body">
        <Nav aesthetic={aesthetic} divider="&#9654;" />
      </div>
    </div>

    <!-- HERO WINDOW (kept as custom HTML — too page-specific for a generic component) -->
    <div class="window hero-window">
      <div class="window-titlebar titlebar-active">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">{aesthetic.name} - Welcome</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-body hero-body">
        <div class="hero-badge">A Web Aesthetic</div>
        <h1 class="hero-title">{aesthetic.name}</h1>
        <div class="hero-divider"></div>
        <p class="hero-tagline">{aesthetic.tagline}</p>
      </div>
    </div>

    <!-- ABOUT WINDOW -->
    <div class="window about-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">About - What This Is</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-menubar">
        <span class="menu-item">File</span>
        <span class="menu-item">Edit</span>
        <span class="menu-item">View</span>
        <span class="menu-item">Help</span>
      </div>
      <div class="window-body about-body">
        <About aesthetic={aesthetic} heading="A Digital Workspace" />
      </div>
    </div>

    <!-- CHARACTERISTICS WINDOW -->
    <div class="window characteristics-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">Properties - Characteristics</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-body characteristics-body">
        <Characteristics aesthetic={aesthetic} heading="Characteristics" />
      </div>
    </div>

    <!-- STYLE REFERENCE WINDOW -->
    <div class="window prompt-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">Notepad - Style Reference</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-menubar">
        <span class="menu-item">File</span>
        <span class="menu-item">Edit</span>
        <span class="menu-item">Format</span>
        <span class="menu-item">Help</span>
      </div>
      <div class="window-body prompt-body">
        <Prompt aesthetic={aesthetic} heading="Copy &amp; Paste" headerLabel="prompt.txt" />
      </div>
    </div>

    <!-- WHEN TO USE WINDOW -->
    <div class="window use-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">Explorer - When to Use</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-body use-body">
        <Usage aesthetic={aesthetic} heading="Good Fit, Bad Fit" goodLabel="Good For" badLabel="Not For" />
      </div>
    </div>

    <!-- HISTORY WINDOW -->
    <div class="window history-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">History - Origins</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-menubar">
        <span class="menu-item">File</span>
        <span class="menu-item">Edit</span>
        <span class="menu-item">View</span>
        <span class="menu-item">Help</span>
      </div>
      <div class="window-body history-body">
        <History aesthetic={aesthetic} heading="History" />
      </div>
    </div>

    <!-- RELATED STYLES WINDOW -->
    <div class="window related-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">Explorer - Related Styles</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-body related-body">
        <Related aesthetic={aesthetic} heading="Related Styles" />
      </div>
    </div>

    <!-- FOOTER WINDOW -->
    <div class="window footer-window">
      <div class="window-titlebar">
        <div class="window-controls">
          <span class="window-btn btn-close"></span>
          <span class="window-btn btn-minimize"></span>
          <span class="window-btn btn-maximize"></span>
        </div>
        <span class="window-title">About aesthetic.fyi</span>
        <div class="window-controls-spacer"></div>
      </div>
      <div class="window-body footer-body">
        <Footer backText="&larr; Back to All Aesthetics" />
      </div>
    </div>
  </div>
</div>

<style is:global>
  /* ========================================
     RESET & BASE
     ======================================== */
  [data-page="os-desktop"] {
    font-family: -apple-system, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: #008080;
    color: #000000;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: auto;
    -moz-osx-font-smoothing: auto;
  }

  /* ========================================
     TASKBAR
     ======================================== */
  [data-page="os-desktop"] .taskbar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: #C0C0C0;
    border-top: 2px solid #FFFFFF;
    box-shadow: inset 0 1px 0 #DFDFDF;
    height: 36px;
  }

  [data-page="os-desktop"] .taskbar-inner {
    display: flex;
    align-items: center;
    height: 100%;
    padding: 2px 4px;
    gap: 4px;
  }

  [data-page="os-desktop"] .start-button {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 2px 8px;
    height: 28px;
    background: #C0C0C0;
    border: 2px outset #DFDFDF;
    cursor: pointer;
    font-size: 12px;
    font-weight: 700;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    color: #000;
  }

  [data-page="os-desktop"] .start-button:active {
    border-style: inset;
  }

  [data-page="os-desktop"] .start-icon {
    font-size: 14px;
    color: #000080;
  }

  [data-page="os-desktop"] .start-label {
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  [data-page="os-desktop"] .taskbar-divider {
    width: 2px;
    height: 24px;
    border-left: 1px solid #808080;
    border-right: 1px solid #FFFFFF;
    margin: 0 2px;
  }

  [data-page="os-desktop"] .taskbar-items {
    display: flex;
    gap: 2px;
    flex: 1;
    min-width: 0;
  }

  [data-page="os-desktop"] .taskbar-item {
    display: flex;
    align-items: center;
    padding: 2px 12px;
    height: 24px;
    background: #C0C0C0;
    border: 2px outset #DFDFDF;
    font-size: 11px;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    color: #000;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 160px;
  }

  [data-page="os-desktop"] .taskbar-item-active {
    border-style: inset;
    background: #D4D0C8;
    font-weight: 700;
  }

  [data-page="os-desktop"] .taskbar-spacer {
    flex: 1;
  }

  [data-page="os-desktop"] .taskbar-tray {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 2px 8px;
    height: 24px;
    border: 2px inset #DFDFDF;
    background: #C0C0C0;
  }

  [data-page="os-desktop"] .tray-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #00AA00;
  }

  [data-page="os-desktop"] .tray-clock {
    font-size: 11px;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    color: #000;
    white-space: nowrap;
  }

  /* ========================================
     DESKTOP
     ======================================== */
  [data-page="os-desktop"] .desktop {
    background: linear-gradient(135deg, #008080 0%, #006666 40%, #007070 60%, #008080 100%);
    min-height: 100vh;
    padding: 24px 32px 56px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
    position: relative;
  }

  [data-page="os-desktop"] .desktop-icons {
    position: absolute;
    top: 20px;
    left: 20px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    z-index: 1;
  }

  [data-page="os-desktop"] .desktop-icon {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-decoration: none;
    cursor: pointer;
    padding: 4px;
  }

  [data-page="os-desktop"] .desktop-icon:hover .icon-label {
    background: #000080;
    color: #FFFFFF;
  }

  [data-page="os-desktop"] .icon-img {
    font-size: 32px;
    line-height: 1;
    filter: drop-shadow(1px 1px 0 rgba(0, 0, 0, 0.3));
  }

  [data-page="os-desktop"] .icon-label {
    font-size: 11px;
    color: #FFFFFF;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.7);
    padding: 1px 4px;
    text-align: center;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  /* ========================================
     WINDOW CHROME
     ======================================== */
  [data-page="os-desktop"] .window {
    width: 100%;
    max-width: 900px;
    border: 2px outset #DFDFDF;
    background: #C0C0C0;
    box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.3);
    position: relative;
    z-index: 2;
  }

  [data-page="os-desktop"] .window-titlebar {
    display: flex;
    align-items: center;
    padding: 3px 4px;
    background: linear-gradient(180deg, #808080 0%, #A0A0A0 100%);
    min-height: 24px;
    gap: 6px;
    user-select: none;
  }

  [data-page="os-desktop"] .titlebar-active {
    background: linear-gradient(90deg, #000080 0%, #1084D0 100%);
  }

  [data-page="os-desktop"] .titlebar-active .window-title {
    color: #FFFFFF;
  }

  [data-page="os-desktop"] .window-controls {
    display: flex;
    gap: 6px;
    padding: 0 2px;
  }

  [data-page="os-desktop"] .window-controls-spacer {
    width: 52px;
    flex-shrink: 0;
  }

  [data-page="os-desktop"] .window-btn {
    width: 14px;
    height: 14px;
    border-radius: 2px;
    border: 1px solid #666;
    cursor: pointer;
  }

  [data-page="os-desktop"] .btn-close { background: #C75050; border-color: #A03030; }
  [data-page="os-desktop"] .btn-minimize { background: #D4AA00; border-color: #AA8800; }
  [data-page="os-desktop"] .btn-maximize { background: #50A050; border-color: #308030; }

  [data-page="os-desktop"] .window-title {
    flex: 1;
    text-align: center;
    font-size: 12px;
    font-weight: 700;
    color: #C0C0C0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  [data-page="os-desktop"] .window-menubar {
    display: flex;
    gap: 0;
    padding: 2px 4px;
    background: #C0C0C0;
    border-bottom: 1px solid #808080;
    border-top: 1px solid #FFFFFF;
  }

  [data-page="os-desktop"] .menu-item {
    font-size: 12px;
    padding: 2px 10px;
    color: #000;
    cursor: pointer;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  [data-page="os-desktop"] .menu-item:hover {
    background: #000080;
    color: #FFFFFF;
  }

  [data-page="os-desktop"] .window-body {
    background: #FFFFFF;
    border: 2px inset #DFDFDF;
    margin: 2px;
    padding: 24px;
  }

  /* ========================================
     COMPONENT WRAPPER OVERRIDES
     Suppress section padding/max-width inside windows.
     ======================================== */
  [data-page="os-desktop"] .window-body .section {
    padding: 0;
  }

  [data-page="os-desktop"] .window-body .section-inner {
    max-width: none;
    margin: 0;
  }

  [data-page="os-desktop"] .window-body .section-label {
    font-size: 11px;
    color: #808080;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
    text-align: center;
    display: block;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  [data-page="os-desktop"] .window-body .section-heading {
    font-size: clamp(1.4rem, 4vw, 2rem);
    font-weight: 700;
    margin: 0 0 28px 0;
    text-align: center;
    color: #000080;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  /* ========================================
     NAV WINDOW — override Nav component styles
     ======================================== */
  [data-page="os-desktop"] .nav-window .nav {
    position: static;
    border: none;
    background: none;
    backdrop-filter: none;
  }

  [data-page="os-desktop"] .nav-window .nav-inner {
    max-width: none;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
  }

  [data-page="os-desktop"] .nav-window .nav-logo {
    color: #000080;
    text-decoration: underline;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    font-size: 13px;
    text-transform: none;
    letter-spacing: 0;
  }

  [data-page="os-desktop"] .nav-window .nav-logo:hover {
    color: #0000FF;
  }

  [data-page="os-desktop"] .nav-window .nav-divider {
    font-size: 9px;
    color: #808080;
    font-weight: 400;
  }

  [data-page="os-desktop"] .nav-window .nav-current {
    color: #000;
    text-decoration: none;
    font-weight: 700;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    font-size: 13px;
    text-transform: none;
    letter-spacing: 0;
  }

  [data-page="os-desktop"] .nav-window .nav-current:hover {
    color: #000080;
  }

  /* ========================================
     HERO WINDOW — native to this page
     ======================================== */
  [data-page="os-desktop"] .hero-body {
    text-align: center;
    padding: 48px 32px;
  }

  [data-page="os-desktop"] .hero-badge {
    display: inline-block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #808080;
    border: 1px solid #C0C0C0;
    padding: 4px 16px;
    margin-bottom: 20px;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  [data-page="os-desktop"] .hero-title {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 700;
    margin: 0 0 16px 0;
    color: #000080;
    line-height: 1.1;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  [data-page="os-desktop"] .hero-divider {
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, #000080, #1084D0);
    margin: 0 auto 20px;
  }

  [data-page="os-desktop"] .hero-tagline {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 500px;
    color: #444;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  /* ========================================
     ABOUT WINDOW — override About component
     ======================================== */
  [data-page="os-desktop"] .about-body {
    padding: 32px;
  }

  [data-page="os-desktop"] .about-content {
    max-width: 620px;
    margin: 0 auto;
  }

  [data-page="os-desktop"] .about-paragraph {
    font-size: 1rem;
    line-height: 1.8;
    margin: 0 0 20px 0;
    color: #222;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  [data-page="os-desktop"] .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS WINDOW
     CSS grid replicates the titlebar+body window look
     ======================================== */
  [data-page="os-desktop"] .characteristics-body {
    padding: 32px;
  }

  [data-page="os-desktop"] .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }

  /* Style char-card as a mini-window using CSS grid */
  [data-page="os-desktop"] .char-card {
    border: 2px outset #DFDFDF;
    background: #C0C0C0;
    overflow: hidden;
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    padding: 0;
  }

  [data-page="os-desktop"] .char-number {
    grid-column: 1;
    grid-row: 1;
    background: linear-gradient(90deg, #000080 0%, #1084D0 100%);
    color: #FFFFFF;
    font-weight: 400;
    opacity: 0.7;
    font-size: 11px;
    padding: 4px 4px 4px 10px;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    display: block;
    margin: 0;
  }

  [data-page="os-desktop"] .char-title {
    grid-column: 2;
    grid-row: 1;
    background: linear-gradient(90deg, #000080 0%, #1084D0 100%);
    color: #FFFFFF;
    font-weight: 700;
    font-size: 12px;
    padding: 4px 10px;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin: 0;
    display: block;
  }

  [data-page="os-desktop"] .char-description {
    grid-column: 1 / -1;
    grid-row: 2;
    background: #FFFFFF;
    border: 2px inset #DFDFDF;
    margin: 2px;
    padding: 16px;
    font-size: 0.9rem;
    line-height: 1.7;
    color: #333;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  /* ========================================
     PROMPT WINDOW — override Prompt component
     ======================================== */
  [data-page="os-desktop"] .prompt-body {
    padding: 32px;
  }

  [data-page="os-desktop"] .prompt-block {
    border: 2px inset #DFDFDF;
    background: #FFFFFF;
    overflow: hidden;
  }

  [data-page="os-desktop"] .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 6px 12px;
    background: #C0C0C0;
    border-bottom: 1px solid #808080;
  }

  [data-page="os-desktop"] .prompt-header-label {
    font-size: 12px;
    color: #000;
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
  }

  [data-page="os-desktop"] .copy-button {
    font-family: -apple-system, 'Segoe UI', Tahoma, sans-serif;
    font-size: 11px;
    font-weight: 400;
    background: #C0C0C0;
    color: #000;
    border: 2px outset #DFDFDF;
    padding: 2px 16px;
    cursor: pointer;
  }

  [data-page="os-desktop"] .copy-button:active {
    border-style: inset;
  }

  [data-page="os-desktop"] .copy-button.copied {
    border-style: inset;
    background: #D4D0C8;
  }

  /* max-height replaces the old .prompt-text-area wrapper */
  [data-page="os-desktop"] .prompt-text {
    font-family: 'Courier New', Courier, monospace;
    font-size: 13px;
    line-height: 1.7;
    color: #000;
    padding: 16px;
    margin: 0;
    white-space: normal;
    max-height: 300px;
    overflow-y: auto;
    display: block;
  }

  /* ========================================
     WHEN TO USE WINDOW — override Usage component
     ======================================== */
  [data-page="os-desktop"] .use-body {
    padding: 32px;
  }

  [data-page="os-desktop"] .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    max-width: 780px;
    margin: 0 auto;
  }

  [data-page="os-desktop"] .use-column {
    border: 2px outset #DFDFDF;
