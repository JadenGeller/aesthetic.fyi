---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

<div class="dark-page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="hero-dots" aria-hidden="true">
        <span class="dot dot-1"></span>
        <span class="dot dot-2"></span>
        <span class="dot dot-3"></span>
      </div>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <h2 class="section-heading">What This Is</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="body-text">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <h2 class="section-heading">Style Reference</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-label">PROMPT</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <pre class="prompt-text">{aesthetic.prompt}</pre>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <h2 class="section-heading">When to Use</h2>
      <div class="use-columns">
        <div class="use-column use-column-good">
          <h3 class="use-heading use-heading-good">Good for</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-column-not">
          <h3 class="use-heading use-heading-not">Not for</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-not">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="body-text">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; All aesthetics</a>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     BASE
     ======================================== */
  .dark-page {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 400;
    background: #000000;
    color: #F5F5F7;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background: #1C1C1E;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-logo {
    font-weight: 600;
    font-size: 0.95rem;
    color: #F5F5F7;
    text-decoration: none;
    padding: 6px 14px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    letter-spacing: 0.01em;
    transition: background 0.2s ease;
  }

  .nav-logo:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .nav-divider {
    font-size: 1rem;
    color: #98989D;
    margin: 0 4px;
  }

  .nav-current {
    font-weight: 500;
    font-size: 0.9rem;
    color: #98989D;
    text-decoration: none;
    padding: 6px 14px;
    transition: color 0.2s ease;
  }

  .nav-current:hover {
    color: #F5F5F7;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #000000;
    padding: 100px 24px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(10, 132, 255, 0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-dots {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .dot {
    position: absolute;
    border-radius: 50%;
    background: #0A84FF;
  }

  .dot-1 {
    width: 8px;
    height: 8px;
    top: 20%;
    right: 15%;
    opacity: 0.6;
    box-shadow: 0 0 12px rgba(10, 132, 255, 0.5);
  }

  .dot-2 {
    width: 6px;
    height: 6px;
    top: 55%;
    right: 30%;
    opacity: 0.4;
    box-shadow: 0 0 10px rgba(10, 132, 255, 0.4);
  }

  .dot-3 {
    width: 10px;
    height: 10px;
    top: 35%;
    right: 8%;
    opacity: 0.3;
    box-shadow: 0 0 16px rgba(10, 132, 255, 0.6);
  }

  .hero-title {
    font-weight: 600;
    font-size: clamp(3rem, 9vw, 7rem);
    line-height: 1;
    margin: 0 0 20px 0;
    color: #F5F5F7;
    letter-spacing: -0.03em;
    position: relative;
    z-index: 1;
  }

  .hero-tagline {
    font-weight: 400;
    font-size: clamp(1.05rem, 2.5vw, 1.35rem);
    line-height: 1.5;
    color: #98989D;
    margin: 0;
    max-width: 500px;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 72px 24px;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-heading {
    font-weight: 600;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.1;
    margin: 0 0 40px 0;
    color: #F5F5F7;
    letter-spacing: -0.02em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #1C1C1E;
  }

  .about-content {
    max-width: 720px;
  }

  .body-text {
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.75;
    margin: 0 0 20px 0;
    color: #F5F5F7;
  }

  .body-text:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #000000;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
  }

  .char-card {
    padding: 28px 24px 24px;
    border-radius: 14px;
    background: #1C1C1E;
    border: 1px solid rgba(255, 255, 255, 0.08);
    position: relative;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .char-card:hover {
    background: #2C2C2E;
    border-color: rgba(255, 255, 255, 0.12);
  }

  .char-number {
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0A84FF;
    display: block;
    margin-bottom: 12px;
  }

  .char-title {
    font-weight: 600;
    font-size: 1.35rem;
    margin: 0 0 10px 0;
    letter-spacing: -0.01em;
    color: #F5F5F7;
  }

  .char-description {
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    color: #98989D;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #1C1C1E;
  }

  .prompt-block {
    background: #2C2C2E;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .prompt-label {
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #98989D;
  }

  .copy-button {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 500;
    font-size: 0.8rem;
    background: #0A84FF;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    padding: 8px 20px;
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: filter 0.2s ease;
    box-shadow: 0 0 12px rgba(10, 132, 255, 0.2);
  }

  .copy-button:hover {
    filter: brightness(1.15);
  }

  .copy-button.copied {
    background: #30D158;
    box-shadow: 0 0 12px rgba(48, 209, 88, 0.2);
  }

  .prompt-text {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.75;
    color: #F5F5F7;
    padding: 24px;
    margin: 0;
    white-space: normal;
    word-wrap: break-word;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #000000;
  }

  .use-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .use-column {
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #1C1C1E;
  }

  .use-heading {
    font-weight: 600;
    font-size: 1.1rem;
    margin: 0;
    padding: 16px 24px;
    color: #F5F5F7;
  }

  .use-heading-good {
    background: rgba(48, 209, 88, 0.12);
    border-bottom: 1px solid rgba(48, 209, 88, 0.15);
  }

  .use-heading-not {
    background: rgba(255, 69, 58, 0.12);
    border-bottom: 1px solid rgba(255, 69, 58, 0.15);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.5;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #F5F5F7;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '+';
    font-weight: 600;
    color: #30D158;
    flex-shrink: 0;
  }

  .use-item-not::before {
    content: '\2013';
    font-weight: 600;
    color: #FF453A;
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #1C1C1E;
  }

  .history-content {
    max-width: 720px;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #000000;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 24px;
    background: #1C1C1E;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 14px;
    text-decoration: none;
    color: #F5F5F7;
    position: relative;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .related-card:hover {
    background: #2C2C2E;
    border-color: rgba(10, 132, 255, 0.3);
    box-shadow: 0 0 16px rgba(10, 132, 255, 0.1);
  }

  .related-relationship {
    font-weight: 500;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0A84FF;
  }

  .related-name {
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
    color: #F5F5F7;
  }

  .related-arrow {
    font-size: 1.1rem;
    position: absolute;
    bottom: 20px;
    right: 20px;
    color: #98989D;
    transition: color 0.2s ease;
  }

  .related-card:hover .related-arrow {
    color: #0A84FF;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #1C1C1E;
    padding: 48px 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    text-align: center;
  }

  .footer-logo {
    font-weight: 600;
    font-size: 1rem;
    color: #F5F5F7;
    text-decoration: none;
    padding: 8px 18px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    transition: background 0.2s ease;
  }

  .footer-logo:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .footer-tagline {
    font-weight: 400;
    font-size: 0.9rem;
    color: #98989D;
  }

  .footer-back {
    font-weight: 500;
    font-size: 0.85rem;
    color: #0A84FF;
    text-decoration: none;
    padding: 8px 18px;
    border: 1px solid rgba(10, 132, 255, 0.3);
    border-radius: 10px;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .footer-back:hover {
    background: rgba(10, 132, 255, 0.08);
    border-color: rgba(10, 132, 255, 0.5);
  }

  /* ========================================
     RESPONSIVE
     ======================================== */
  @media (max-width: 768px) {
    .hero {
      padding: 64px 20px 56px;
    }

    .section {
      padding: 56px 20px;
    }

    .section-heading {
      margin-bottom: 28px;
    }

    .characteristics-grid {
      grid-template-columns: 1fr;
    }

    .use-columns {
      grid-template-columns: 1fr;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .hero-dots {
      opacity: 0.5;
      width: 100%;
    }

    .prompt-header {
      padding: 12px 16px;
      flex-wrap: wrap;
      gap: 10px;
    }

    .prompt-text {
      padding: 20px 16px;
      font-size: 0.85rem;
    }

    .nav-inner {
      padding: 12px 16px;
    }

    .footer {
      padding: 36px 20px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 48px 16px 40px;
    }

    .section {
      padding: 40px 16px;
    }

    .nav-inner {
      padding: 10px 12px;
      gap: 6px;
    }

    .nav-logo {
      font-size: 0.85rem;
      padding: 5px 10px;
    }

    .nav-current {
      font-size: 0.8rem;
      padding: 5px 10px;
    }

    .char-card {
      padding: 22px 18px 18px;
    }

    .copy-button {
      padding: 6px 14px;
      font-size: 0.75rem;
    }

    .use-item {
      padding: 12px 16px;
      font-size: 0.95rem;
    }

    .related-card {
      padding: 18px;
    }
  }
</style>
