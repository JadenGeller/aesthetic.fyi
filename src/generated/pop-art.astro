---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bangers&family=Roboto+Condensed:wght@400;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">//</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-halftone"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-star">&#9733;</span>
        <span class="hero-star">&#9733;</span>
        <span class="hero-star">&#9733;</span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Loud & Clear</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy & Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Scene, Wrong Scene</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Roboto Condensed', sans-serif;
    background-color: #FFFFFF;
    color: #000000;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 4px solid #000000;
    background: #FFD700;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 1.1rem;
    color: #000000;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 6px 16px;
    border: 3px solid #000000;
    background: #FFFFFF;
    box-shadow: 3px 3px 0 #000000;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .nav-logo:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 #000000;
  }

  .nav-divider {
    font-family: 'Bangers', cursive;
    font-size: 1.2rem;
    color: #000000;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 1rem;
    color: #000000;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 6px 16px;
    border: 3px solid #000000;
    background: #E3242B;
    color: #FFFFFF;
    box-shadow: 3px 3px 0 #000000;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .nav-current:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 #000000;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #E3242B;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 4px solid #000000;
  }

  .hero-halftone {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(circle, #000000 1px, transparent 1px);
    background-size: 8px 8px;
    opacity: 0.08;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 760px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: #FFD700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    display: inline-block;
    margin-bottom: 20px;
    padding: 4px 16px;
    border: 2px solid #FFD700;
  }

  .hero-title {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: clamp(3.5rem, 12vw, 7rem);
    line-height: 0.95;
    margin: 0 0 24px 0;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-shadow: 4px 4px 0 #000000, -1px -1px 0 #000000, 1px -1px 0 #000000, -1px 1px 0 #000000;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .hero-star {
    font-size: 1.2rem;
    color: #FFD700;
    text-shadow: 1px 1px 0 #000000;
  }

  .hero-tagline {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 700;
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    line-height: 1.6;
    margin: 0 auto;
    max-width: 540px;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 4px solid #000000;
    position: relative;
  }

  .section-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 4px;
    background: #000000;
  }

  .section-label {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    color: #E3242B;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    white-space: nowrap;
  }

  .section-heading {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.1;
    margin: 0 0 48px 0;
    text-align: center;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #FFD700;
    position: relative;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(circle, #000000 1px, transparent 1px);
    background-size: 10px 10px;
    opacity: 0.06;
    pointer-events: none;
  }

  .about-content {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .about-paragraph {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 400;
    font-size: 1.15rem;
    line-height: 1.8;
    margin: 0 0 24px 0;
    color: #000000;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #FFFFFF;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 3px solid #000000;
    padding: 28px 24px 24px;
    position: relative;
    text-align: center;
    background: #FFFFFF;
    box-shadow: 5px 5px 0 #000000;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .char-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 8px 8px 0 #000000;
  }

  .char-card:nth-child(6n+1) { background: #FFFFFF; }
  .char-card:nth-child(6n+2) { background: #FFD700; }
  .char-card:nth-child(6n+3) { background: #FFFFFF; }
  .char-card:nth-child(6n+4) {
    background: #005BBB;
    color: #FFFFFF;
  }
  .char-card:nth-child(6n+4) .char-title,
  .char-card:nth-child(6n+4) .char-description,
  .char-card:nth-child(6n+4) .char-number {
    color: #FFFFFF;
  }
  .char-card:nth-child(6n+5) { background: #FFFFFF; }
  .char-card:nth-child(6n+6) {
    background: #E3242B;
    color: #FFFFFF;
  }
  .char-card:nth-child(6n+6) .char-title,
  .char-card:nth-child(6n+6) .char-description,
  .char-card:nth-child(6n+6) .char-number {
    color: #FFFFFF;
  }

  .char-number {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 0.9rem;
    color: #E3242B;
    display: block;
    margin-bottom: 8px;
    letter-spacing: 0.1em;
  }

  .char-divider {
    width: 40px;
    height: 4px;
    background: #000000;
    margin: 0 auto 14px;
  }

  .char-title {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 1.35rem;
    margin: 0 0 12px 0;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .char-description {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
    color: #333333;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #005BBB;
    position: relative;
  }

  .prompt-section .section-label {
    color: #FFD700;
  }

  .prompt-section .section-heading {
    color: #FFFFFF;
  }

  .prompt-section .section-rule {
    background: #FFFFFF;
  }

  .prompt-block {
    border: 3px solid #000000;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    background: #FFFFFF;
    box-shadow: 5px 5px 0 #000000;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 3px solid #000000;
    background: #FFD700;
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 0.95rem;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .copy-button {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 0.9rem;
    background: #E3242B;
    color: #FFFFFF;
    border: 3px solid #000000;
    padding: 6px 20px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    box-shadow: 3px 3px 0 #000000;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .copy-button:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 #000000;
  }

  .copy-button.copied {
    background: #00C853;
  }

  .prompt-text {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.8;
    color: #000000;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #FFFFFF;
    position: relative;
  }

  .use-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(circle, #E3242B 0.8px, transparent 0.8px);
    background-size: 12px 12px;
    opacity: 0.06;
    pointer-events: none;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .use-column {
    border: 3px solid #000000;
    overflow: hidden;
    position: relative;
    box-shadow: 5px 5px 0 #000000;
  }

  .use-column-heading {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 1.15rem;
    margin: 0;
    padding: 14px 22px;
    text-align: center;
    border-bottom: 3px solid #000000;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .use-good .use-column-heading {
    background: #00C853;
    color: #FFFFFF;
  }

  .use-bad .use-column-heading {
    background: #E3242B;
    color: #FFFFFF;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
    background: #FFFFFF;
  }

  .use-item {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 2px solid #000000;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #000000;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '\2605';
    color: #00C853;
    flex-shrink: 0;
    font-size: 0.8rem;
    margin-top: 2px;
  }

  .use-item-bad::before {
    content: '\2716';
    color: #E3242B;
    flex-shrink: 0;
    font-size: 0.75rem;
    margin-top: 3px;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #FFD700;
    position: relative;
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(circle, #000000 1px, transparent 1px);
    background-size: 8px 8px;
    opacity: 0.05;
    pointer-events: none;
  }

  .history-content {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .history-paragraph {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.8;
    margin: 0 0 24px 0;
    color: #000000;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #FFFFFF;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 24px 20px;
    border: 3px solid #000000;
    text-decoration: none;
    color: #000000;
    text-align: center;
    position: relative;
    background: #FFFFFF;
    box-shadow: 4px 4px 0 #000000;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .related-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 7px 7px 0 #000000;
    background: #FFD700;
  }

  .related-relationship {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: #E3242B;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .related-name {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 1.2rem;
    color: #000000;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .related-arrow {
    font-size: 1.2rem;
    color: #005BBB;
    font-weight: 700;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #E3242B;
    padding: 64px 32px;
    border-top: 4px solid #000000;
  }

  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-ornament {
    width: 80px;
    height: 4px;
    background: #FFD700;
  }

  .footer-logo {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 1.1rem;
    color: #000000;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 8px 24px;
    border: 3px solid #000000;
    background: #FFD700;
    box-shadow: 3px 3px 0 #000000;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .footer-logo:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 #000000;
  }

  .footer-tagline {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: #FFFFFF;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .footer-back {
    font-family: 'Bangers', cursive;
