---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-shimmer"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <div class="hero-rule-line"></div>
        <span class="hero-rule-diamond"></span>
        <div class="hero-rule-line"></div>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Light in Motion</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Light, Wrong Light</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     ANIMATIONS
     ======================================== */
  @keyframes holographic-shift {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  @keyframes holographic-text {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }

  @keyframes shimmer-float {
    0%, 100% {
      opacity: 0.4;
      transform: translateY(0);
    }
    50% {
      opacity: 0.7;
      transform: translateY(-8px);
    }
  }

  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Plus Jakarta Sans', sans-serif;
    background-color: #F0F0F5;
    color: #1A1A2E;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    background: rgba(240, 240, 245, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.5);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-weight: 600;
    font-size: 0.95rem;
    color: #1A1A2E;
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid rgba(155, 89, 182, 0.2);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.5);
    transition: all 0.3s;
  }

  .nav-logo:hover {
    background: rgba(255, 255, 255, 0.8);
    border-color: rgba(155, 89, 182, 0.4);
    box-shadow: 0 2px 12px rgba(155, 89, 182, 0.15);
  }

  .nav-divider {
    font-size: 1rem;
    color: rgba(26, 26, 46, 0.25);
    margin: 0 2px;
  }

  .nav-current {
    font-weight: 500;
    font-size: 0.9rem;
    color: rgba(26, 26, 46, 0.6);
    text-decoration: none;
    padding: 6px 18px;
    border: 1px solid transparent;
    border-radius: 20px;
    transition: all 0.3s;
  }

  .nav-current:hover {
    border-color: rgba(155, 89, 182, 0.2);
    background: rgba(255, 255, 255, 0.4);
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background:
      linear-gradient(
        135deg,
        #FF6B9D 0%,
        #FF8EC4 8%,
        #C98BDB 16%,
        #9B59B6 22%,
        #7B68EE 30%,
        #45B7D1 38%,
        #7FDBCA 46%,
        #98E8C1 52%,
        #F0C27F 60%,
        #F7D794 66%,
        #FF6B9D 74%,
        #FF8EC4 80%,
        #9B59B6 86%,
        #45B7D1 92%,
        #7FDBCA 100%
      );
    background-size: 400% 400%;
    animation: holographic-shift 8s ease infinite;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.3);
  }

  .hero-shimmer {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(ellipse 600px 300px at 20% 50%, rgba(255, 255, 255, 0.3) 0%, transparent 70%),
      radial-gradient(ellipse 400px 200px at 80% 30%, rgba(255, 255, 255, 0.25) 0%, transparent 70%),
      radial-gradient(ellipse 500px 250px at 60% 80%, rgba(255, 255, 255, 0.2) 0%, transparent 70%);
    animation: shimmer-float 6s ease-in-out infinite;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-weight: 500;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.85);
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    padding: 6px 20px;
    border-radius: 20px;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .hero-title {
    font-weight: 700;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.05;
    margin: 0 0 24px 0;
    color: #fff;
    text-shadow: 0 2px 20px rgba(155, 89, 182, 0.3);
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .hero-rule-line {
    width: 48px;
    height: 1px;
    background: rgba(255, 255, 255, 0.5);
  }

  .hero-rule-diamond {
    width: 8px;
    height: 8px;
    background: rgba(255, 255, 255, 0.7);
    transform: rotate(45deg);
  }

  .hero-tagline {
    font-weight: 400;
    font-style: italic;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.7;
    margin: 0 auto;
    max-width: 520px;
    color: rgba(255, 255, 255, 0.9);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(155, 89, 182, 0.3),
      rgba(69, 183, 209, 0.3),
      transparent
    );
  }

  .section-label {
    font-weight: 500;
    font-size: 0.75rem;
    color: rgba(26, 26, 46, 0.45);
    white-space: nowrap;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-heading {
    font-weight: 700;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    background:
      linear-gradient(
        90deg,
        #FF6B9D 0%,
        #9B59B6 20%,
        #45B7D1 40%,
        #7FDBCA 60%,
        #F0C27F 80%,
        #FF6B9D 100%
      );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: holographic-text 6s ease infinite;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background:
      linear-gradient(
        160deg,
        rgba(255, 107, 157, 0.05) 0%,
        rgba(69, 183, 209, 0.05) 50%,
        rgba(155, 89, 182, 0.05) 100%
      ),
      #F0F0F5;
  }

  .about-content {
    max-width: 640px;
    margin: 0 auto;
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 16px;
    padding: 48px 40px;
    box-shadow:
      0 4px 24px rgba(155, 89, 182, 0.06),
      0 1px 3px rgba(69, 183, 209, 0.04);
  }

  .about-paragraph {
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
    color: #1A1A2E;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #F0F0F5;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 14px;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    transition: all 0.4s;
    overflow: hidden;
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background:
      linear-gradient(
        90deg,
        #FF6B9D,
        #9B59B6,
        #45B7D1,
        #7FDBCA,
        #F0C27F,
        #FF6B9D
      );
    background-size: 200% auto;
    animation: holographic-shift 6s ease infinite;
    opacity: 0.7;
  }

  .char-card:hover {
    box-shadow:
      0 8px 32px rgba(155, 89, 182, 0.1),
      0 4px 16px rgba(69, 183, 209, 0.08),
      0 2px 8px rgba(255, 107, 157, 0.06);
    border-color: rgba(155, 89, 182, 0.2);
    transform: translateY(-2px);
  }

  .char-number {
    font-weight: 600;
    font-size: 0.7rem;
    color: rgba(26, 26, 46, 0.3);
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.1em;
  }

  .char-divider {
    width: 32px;
    height: 2px;
    margin: 0 auto 14px;
    background: linear-gradient(90deg, #FF6B9D, #45B7D1, #9B59B6);
    border-radius: 1px;
  }

  .char-title {
    font-weight: 600;
    font-size: 1.15rem;
    margin: 0 0 12px 0;
    color: #1A1A2E;
  }

  .char-description {
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.75;
    margin: 0;
    color: rgba(26, 26, 46, 0.6);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background:
      linear-gradient(
        200deg,
        rgba(127, 219, 202, 0.06) 0%,
        rgba(155, 89, 182, 0.06) 50%,
        rgba(240, 194, 127, 0.06) 100%
      ),
      #F0F0F5;
  }

  .prompt-block {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 14px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-block::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background:
      linear-gradient(
        90deg,
        #7FDBCA,
        #45B7D1,
        #9B59B6,
        #FF6B9D,
        #F0C27F,
        #7FDBCA
      );
    background-size: 200% auto;
    animation: holographic-shift 6s ease infinite;
    opacity: 0.7;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 1px solid rgba(155, 89, 182, 0.08);
    background: rgba(255, 255, 255, 0.3);
  }

  .prompt-header-label {
    font-weight: 500;
    font-size: 0.75rem;
    color: rgba(26, 26, 46, 0.45);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 500;
    font-size: 0.8rem;
    background: rgba(255, 255, 255, 0.5);
    color: #1A1A2E;
    border: 1px solid rgba(155, 89, 182, 0.15);
    border-radius: 20px;
    padding: 6px 20px;
    cursor: pointer;
    transition: all 0.3s;
  }

  .copy-button:hover {
    background: rgba(255, 255, 255, 0.8);
    border-color: rgba(155, 89, 182, 0.3);
    box-shadow: 0 2px 12px rgba(155, 89, 182, 0.1);
  }

  .copy-button.copied {
    background: rgba(155, 89, 182, 0.1);
    border-color: rgba(155, 89, 182, 0.3);
  }

  .prompt-text {
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.85;
    color: #1A1A2E;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #F0F0F5;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 14px;
    overflow: hidden;
    position: relative;
  }

  .use-column::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background:
      linear-gradient(
        90deg,
        #FF6B9D,
        #9B59B6,
        #45B7D1,
        #7FDBCA,
        #F0C27F,
        #FF6B9D
      );
    background-size: 200% auto;
    animation: holographic-shift 6s ease infinite;
    opacity: 0.7;
  }

  .use-column-heading {
    font-weight: 600;
    font-size: 0.95rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 1px solid rgba(155, 89, 182, 0.08);
  }

  .use-good .use-column-heading {
    background: rgba(127, 219, 202, 0.08);
    color: #1A1A2E;
  }

  .use-bad .use-column-heading {
    background: rgba(255, 107, 157, 0.05);
    color: rgba(26, 26, 46, 0.6);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-weight: 400;
    font-size: 0.92rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(155, 89, 182, 0.05);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #1A1A2E;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: linear-gradient(135deg, #7FDBCA, #45B7D1);
    flex-shrink: 0;
    margin-top: 7px;
  }

  .use-item-bad::before {
    content: '\2013';
    color: rgba(26, 26, 46, 0.25);
    flex-shrink: 0;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background:
      linear-gradient(
        340deg,
        rgba(255, 107, 157, 0.05) 0%,
        rgba(240, 194, 127, 0.05) 50%,
        rgba(69, 183, 209, 0.05) 100%
      ),
      #F0F0F5;
  }

  .history-content {
    max-width: 640px;
    margin: 0 auto;
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 16px;
    padding: 48px 40px;
    box-shadow:
      0 4px 24px rgba(155, 89, 182, 0.06),
      0 1px 3px rgba(69, 183, 209, 0.04);
  }

  .history-paragraph {
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0 0 24px 0;
