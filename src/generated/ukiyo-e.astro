---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700;900&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-wave-top"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-bar"></span>
        <span class="hero-seal"></span>
        <span class="hero-bar"></span>
      </div>
      <p class="hero-tagline">{aesthetic.tagline}</p>
    </div>
    <div class="hero-wave-bottom"></div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">The Floating World</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Right Block, Wrong Block</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        navigator.clipboard.writeText(prompt).then(() => {
          const original = copyButton.textContent;
          copyButton.textContent = 'Copied!';
          copyButton.classList.add('copied');
          setTimeout(() => {
            copyButton.textContent = original;
            copyButton.classList.remove('copied');
          }, 2000);
        });
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Noto Serif JP', serif;
    background-color: #F5ECD7;
    color: #2C3E6B;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    /* Subtle washi paper texture */
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 3px,
        rgba(44, 62, 107, 0.015) 3px,
        rgba(44, 62, 107, 0.015) 4px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 5px,
        rgba(44, 62, 107, 0.01) 5px,
        rgba(44, 62, 107, 0.01) 6px
      );
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 3px solid #1A1A2E;
    background: #2C3E6B;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Noto Serif JP', serif;
    font-weight: 700;
    font-size: 1rem;
    color: #F5ECD7;
    text-decoration: none;
    padding: 6px 18px;
    border: 2px solid #C9A84C;
    transition: background 0.3s;
  }

  .nav-logo:hover {
    background: rgba(201, 168, 76, 0.15);
  }

  .nav-divider {
    font-size: 1.2rem;
    color: #C9A84C;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Noto Serif JP', serif;
    font-weight: 400;
    font-size: 0.95rem;
    color: #C9A84C;
    text-decoration: none;
    padding: 6px 18px;
    border: 2px solid transparent;
    transition: border-color 0.3s;
  }

  .nav-current:hover {
    border-color: #C9A84C;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #2C3E6B;
    padding: 96px 32px 80px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 4px solid #1A1A2E;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 16px;
    left: 16px;
    right: 16px;
    bottom: 16px;
    border: 3px solid #C9A84C;
    pointer-events: none;
  }

  /* Wave pattern at top of hero */
  .hero-wave-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    background:
      radial-gradient(circle 20px at 10% 100%, transparent 18px, #F5ECD7 18px, #F5ECD7 20px, transparent 20px),
      radial-gradient(circle 20px at 30% 100%, transparent 18px, #F5ECD7 18px, #F5ECD7 20px, transparent 20px),
      radial-gradient(circle 20px at 50% 100%, transparent 18px, #F5ECD7 18px, #F5ECD7 20px, transparent 20px),
      radial-gradient(circle 20px at 70% 100%, transparent 18px, #F5ECD7 18px, #F5ECD7 20px, transparent 20px),
      radial-gradient(circle 20px at 90% 100%, transparent 18px, #F5ECD7 18px, #F5ECD7 20px, transparent 20px);
    opacity: 0.08;
    pointer-events: none;
  }

  /* Wave pattern at bottom of hero */
  .hero-wave-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40px;
    background:
      radial-gradient(ellipse 40px 20px at 0% 0%, transparent 17px, #C9A84C 17px, #C9A84C 19px, transparent 19px),
      radial-gradient(ellipse 40px 20px at 10% 0%, transparent 17px, #C9A84C 17px, #C9A84C 19px, transparent 19px),
      radial-gradient(ellipse 40px 20px at 20% 0%, transparent 17px, #C9A84C 17px, #C9A84C 19px, transparent 19px),
      radial-gradient(ellipse 40px 20px at 30% 0%, transparent 17px, #C9A84C 17px, #C9A84C 19px, transparent 19px),
      radial-gradient(ellipse 40px 20px at 40% 0%, transparent 17px, #C9A84C 17px, #C9A84C 19px, transparent 19px),
      radial-gradient(ellipse 40px 20px at 50% 0%, transparent 17px, #C9A84C 17px, #C9A84C 19px, transparent 19px),
      radial-gradient(ellipse 40px 20px at 60% 0%, transparent 17px, #C9A84C 17px, #C9A84C 19px, transparent 19px),
      radial-gradient(ellipse 40px 20px at 70% 0%, transparent 17px, #C9A84C 17px, #C9A84C 19px, transparent 19px),
      radial-gradient(ellipse 40px 20px at 80% 0%, transparent 17px, #C9A84C 17px, #C9A84C 19px, transparent 19px),
      radial-gradient(ellipse 40px 20px at 90% 0%, transparent 17px, #C9A84C 17px, #C9A84C 19px, transparent 19px),
      radial-gradient(ellipse 40px 20px at 100% 0%, transparent 17px, #C9A84C 17px, #C9A84C 19px, transparent 19px);
    opacity: 0.3;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Noto Serif JP', serif;
    font-weight: 400;
    font-size: 0.85rem;
    color: #C9A84C;
    display: inline-block;
    margin-bottom: 24px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .hero-title {
    font-family: 'Noto Serif JP', serif;
    font-weight: 900;
    font-size: clamp(3rem, 9vw, 5.5rem);
    line-height: 1.05;
    margin: 0 0 28px 0;
    color: #F5ECD7;
    letter-spacing: 0.05em;
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 28px;
  }

  .hero-bar {
    width: 60px;
    height: 3px;
    background: #C9A84C;
  }

  /* Vermillion seal mark */
  .hero-seal {
    width: 18px;
    height: 18px;
    background: #C73E1D;
    border: 2px solid #F5ECD7;
    transform: rotate(45deg);
  }

  .hero-tagline {
    font-family: 'Noto Serif JP', serif;
    font-weight: 400;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.8;
    margin: 0 auto;
    max-width: 520px;
    color: rgba(245, 236, 215, 0.75);
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 88px 32px;
    border-bottom: 3px solid #1A1A2E;
    position: relative;
  }

  .section-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 3px;
    background: #C9A84C;
  }

  .section-label {
    font-family: 'Noto Serif JP', serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: #C73E1D;
    white-space: nowrap;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Noto Serif JP', serif;
    font-weight: 900;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    line-height: 1.15;
    margin: 0 0 48px 0;
    text-align: center;
    color: #2C3E6B;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #F5ECD7;
    /* Woodblock grain texture */
    background-image:
      repeating-linear-gradient(
        87deg,
        transparent,
        transparent 8px,
        rgba(44, 62, 107, 0.02) 8px,
        rgba(44, 62, 107, 0.02) 9px
      );
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 3px solid #2C3E6B;
    pointer-events: none;
  }

  .about-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .about-paragraph {
    font-family: 'Noto Serif JP', serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.95;
    margin: 0 0 24px 0;
    color: #2C3E6B;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #2C3E6B;
  }

  .characteristics-section .section-label {
    color: #C9A84C;
  }

  .characteristics-section .section-heading {
    color: #F5ECD7;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .char-card {
    border: 3px solid #F5ECD7;
    padding: 32px 28px 28px;
    position: relative;
    text-align: center;
    background: #2C3E6B;
    transition: border-color 0.3s;
  }

  .char-card::before {
    content: '';
    position: absolute;
    top: 6px;
    left: 6px;
    right: 6px;
    bottom: 6px;
    border: 1px solid rgba(201, 168, 76, 0.3);
    pointer-events: none;
  }

  .char-card:hover {
    border-color: #C9A84C;
  }

  .char-number {
    font-family: 'Noto Serif JP', serif;
    font-weight: 700;
    font-size: 0.75rem;
    color: #C73E1D;
    display: block;
    margin-bottom: 10px;
    letter-spacing: 0.15em;
  }

  .char-divider {
    width: 28px;
    height: 3px;
    background: #C9A84C;
    margin: 0 auto 14px;
  }

  .char-title {
    font-family: 'Noto Serif JP', serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin: 0 0 12px 0;
    color: #F5ECD7;
  }

  .char-description {
    font-family: 'Noto Serif JP', serif;
    font-weight: 400;
    font-size: 0.9rem;
    line-height: 1.8;
    margin: 0;
    color: rgba(245, 236, 215, 0.7);
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #F5ECD7;
    background-image:
      repeating-linear-gradient(
        93deg,
        transparent,
        transparent 6px,
        rgba(44, 62, 107, 0.018) 6px,
        rgba(44, 62, 107, 0.018) 7px
      );
  }

  .prompt-block {
    border: 3px solid #1A1A2E;
    max-width: 720px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
  }

  .prompt-block::before {
    content: '';
    position: absolute;
    top: 5px;
    left: 5px;
    right: 5px;
    bottom: 5px;
    border: 1px solid rgba(201, 168, 76, 0.4);
    pointer-events: none;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 3px solid #1A1A2E;
    background: #2C3E6B;
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Noto Serif JP', serif;
    font-weight: 400;
    font-size: 0.8rem;
    color: #C9A84C;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .copy-button {
    font-family: 'Noto Serif JP', serif;
    font-weight: 700;
    font-size: 0.85rem;
    background: transparent;
    color: #F5ECD7;
    border: 2px solid #C9A84C;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.3s, color 0.3s;
  }

  .copy-button:hover {
    background: #C9A84C;
    color: #1A1A2E;
  }

  .copy-button.copied {
    background: #C73E1D;
    border-color: #C73E1D;
    color: #F5ECD7;
  }

  .prompt-text {
    font-family: 'Noto Serif JP', serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.9;
    color: #2C3E6B;
    padding: 28px 24px;
    margin: 0;
    white-space: pre-wrap;
    position: relative;
    z-index: 1;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #F5ECD7;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 780px;
    margin: 0 auto;
  }

  .use-column {
    border: 3px solid #1A1A2E;
    overflow: hidden;
    position: relative;
  }

  .use-column::before {
    content: '';
    position: absolute;
    top: 5px;
    left: 5px;
    right: 5px;
    bottom: 5px;
    border: 1px solid rgba(201, 168, 76, 0.25);
    pointer-events: none;
    z-index: 1;
  }

  .use-column-heading {
    font-family: 'Noto Serif JP', serif;
    font-weight: 700;
    font-size: 1.05rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 3px solid #1A1A2E;
  }

  .use-good .use-column-heading {
    background: #2C3E6B;
    color: #C9A84C;
  }

  .use-bad .use-column-heading {
    background: #1A1A2E;
    color: rgba(245, 236, 215, 0.6);
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Noto Serif JP', serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 1px solid rgba(26, 26, 46, 0.15);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #2C3E6B;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '';
    width: 8px;
    height: 8px;
    background: #C73E1D;
    flex-shrink: 0;
    margin-top: 6px;
    transform: rotate(45deg);
  }

  .use-item-bad::before {
    content: '\2013';
    color: #2C3E6B;
    flex-shrink: 0;
    font-weight: 700;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #2C3E6B;
  }

  .history-section .section-label {
    color: #C9A84C;
  }

  .history-section .section-heading {
    color: #F5ECD7;
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 20px;
    left: 20px;
    right: 20px;
    bottom: 20px;
    border: 3px solid #C9A84C;
    pointer-events: none;
  }

  .history-section .section-rule {
    background: #C73E1D;
  }

  .history-content {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .history-paragraph {
    font-family: 'Noto Serif JP', serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.95;
    margin: 0 0 24px 0;
    color: rgba(245, 236, 215, 0.85);
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #F5ECD7;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 780px;
    margin: 0 auto;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 28px 20px;
    border: 3px solid #1A1A2E;
    text-decoration: none;
    color: #2C3E6B;
    text-align: center;
    position: relative;
    transition: border-color 0.3s, background 0.3s;
  }

  .related-card::before {
    content: '';
    position: absolute;
