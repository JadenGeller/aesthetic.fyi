---
const { aesthetic } = Astro.props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Bangers&family=Roboto+Condensed:wght@400;700&display=swap" rel="stylesheet" />

<div class="page">
  <!-- NAV -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">aesthetic.fyi</a>
      <span class="nav-divider">/</span>
      <a href={`/${aesthetic.slug}`} class="nav-current">{aesthetic.name}</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-action-lines"></div>
    <div class="hero-halftone"></div>
    <div class="hero-inner">
      <span class="hero-label">A Web Aesthetic</span>
      <h1 class="hero-title">{aesthetic.name}</h1>
      <div class="hero-rule">
        <span class="hero-star">&#9733;</span>
        <span class="hero-star">&#9733;</span>
        <span class="hero-star">&#9733;</span>
      </div>
      <div class="hero-speech-bubble">
        <p class="hero-tagline">{aesthetic.tagline}</p>
      </div>
    </div>
  </section>

  <!-- WHAT THIS IS -->
  <section class="section about-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">What This Is</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Origin Story</h2>
      <div class="about-content">
        {aesthetic.about.split('\n\n').map((paragraph: string) => (
          <p class="about-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CHARACTERISTICS -->
  <section class="section characteristics-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Design Tokens</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Characteristics</h2>
      <div class="characteristics-grid">
        {aesthetic.characteristics.map((char: { title: string; description: string }, i: number) => (
          <div class="char-card">
            <span class="char-number">{String(i + 1).padStart(2, '0')}</span>
            <div class="char-divider"></div>
            <h3 class="char-title">{char.title}</h3>
            <p class="char-description">{char.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STYLE REFERENCE -->
  <section class="section prompt-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Style Reference</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Copy &amp; Paste</h2>
      <div class="prompt-block">
        <div class="prompt-header">
          <span class="prompt-header-label">Prompt</span>
          <button class="copy-button" data-prompt={aesthetic.prompt}>Copy</button>
        </div>
        <p class="prompt-text">{aesthetic.prompt}</p>
      </div>
    </div>
  </section>

  <!-- WHEN TO USE -->
  <section class="section use-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">When to Use</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Hero or Villain?</h2>
      <div class="use-grid">
        <div class="use-column use-good">
          <h3 class="use-column-heading">Good For</h3>
          <ul class="use-list">
            {aesthetic.good_for.map((item: string) => (
              <li class="use-item use-item-good">{item}</li>
            ))}
          </ul>
        </div>
        <div class="use-column use-bad">
          <h3 class="use-column-heading">Not For</h3>
          <ul class="use-list">
            {aesthetic.not_for.map((item: string) => (
              <li class="use-item use-item-bad">{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTORY -->
  <section class="section history-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Origins</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">History</h2>
      <div class="history-content">
        {aesthetic.history.split('\n\n').map((paragraph: string) => (
          <p class="history-paragraph">{paragraph}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED STYLES -->
  <section class="section related-section">
    <div class="section-inner">
      <div class="section-header">
        <div class="section-rule"></div>
        <span class="section-label">Explore</span>
        <div class="section-rule"></div>
      </div>
      <h2 class="section-heading">Related Styles</h2>
      <div class="related-grid">
        {aesthetic.related.map((rel: { slug: string; relationship: string }) => (
          <a href={`/${rel.slug}`} class="related-card">
            <span class="related-relationship">{rel.relationship}</span>
            <span class="related-name">{rel.slug.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ')}</span>
            <span class="related-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-ornament"></div>
      <a href="/" class="footer-logo">aesthetic.fyi</a>
      <span class="footer-tagline">Every web aesthetic, demonstrated.</span>
      <a href="/" class="footer-back">&larr; Back to All Aesthetics</a>
      <div class="footer-ornament"></div>
    </div>
  </footer>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButton = document.querySelector('.copy-button');
    if (copyButton) {
      copyButton.addEventListener('click', () => {
        const prompt = copyButton.getAttribute('data-prompt') || '';
        const el = document.createElement('textarea');
        el.value = prompt;
        el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(el);
        el.select();
        document.execCommand('copy');
        document.body.removeChild(el);
        const original = copyButton.textContent;
        copyButton.textContent = 'Copied!';
        copyButton.classList.add('copied');
        setTimeout(() => {
          copyButton.textContent = original;
          copyButton.classList.remove('copied');
        }, 2000);
      });
    }
  });
</script>

<style>
  /* ========================================
     RESET & BASE
     ======================================== */
  .page {
    font-family: 'Roboto Condensed', sans-serif;
    background-color: #FFFFFF;
    color: #111111;
    margin: 0;
    padding: 0;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* ========================================
     NAV
     ======================================== */
  .nav {
    border-bottom: 4px solid #111;
    background: #FDD835;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .nav-logo {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 1.1rem;
    color: #111;
    text-decoration: none;
    padding: 6px 18px;
    border: 3px solid #111;
    border-radius: 4px;
    background: #FFF;
    transition: background 0.2s, transform 0.2s;
    letter-spacing: 0.03em;
  }

  .nav-logo:hover {
    background: #E53935;
    color: #FFF;
    transform: rotate(-2deg);
  }

  .nav-divider {
    font-family: 'Bangers', cursive;
    font-size: 1.4rem;
    color: #111;
    margin: 0 2px;
  }

  .nav-current {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 1rem;
    color: #111;
    text-decoration: none;
    padding: 6px 18px;
    border: 3px solid transparent;
    border-radius: 4px;
    transition: border-color 0.2s;
    letter-spacing: 0.03em;
  }

  .nav-current:hover {
    border-color: #111;
  }

  /* ========================================
     HERO
     ======================================== */
  .hero {
    background: #1E88E5;
    padding: 96px 32px 88px;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-bottom: 4px solid #111;
  }

  .hero-action-lines {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 200%;
    height: 200%;
    transform: translate(-50%, -50%);
    background: repeating-conic-gradient(
      rgba(255, 255, 255, 0.08) 0deg 5deg,
      transparent 5deg 10deg
    );
    pointer-events: none;
  }

  .hero-halftone {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(circle 2px, rgba(0, 0, 0, 0.1) 50%, transparent 50%);
    background-size: 12px 12px;
    pointer-events: none;
  }

  .hero-inner {
    max-width: 740px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-label {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    color: #FDD835;
    display: inline-block;
    margin-bottom: 20px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: #111;
    padding: 6px 16px;
    border: 3px solid #FDD835;
    border-radius: 4px;
  }

  .hero-title {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: clamp(3.5rem, 10vw, 7rem);
    line-height: 1;
    margin: 0 0 24px 0;
    color: #FDD835;
    text-shadow:
      4px 4px 0 #111,
      -1px -1px 0 #111,
      1px -1px 0 #111,
      -1px 1px 0 #111,
      1px 1px 0 #111;
    letter-spacing: 0.04em;
    transform: rotate(-2deg);
  }

  .hero-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .hero-star {
    font-size: 1.2rem;
    color: #FDD835;
    text-shadow: 1px 1px 0 #111;
  }

  .hero-speech-bubble {
    display: inline-block;
    background: #FFF;
    border: 3px solid #111;
    border-radius: 28px;
    padding: 20px 32px;
    position: relative;
    max-width: 520px;
    margin: 0 auto;
    box-shadow: 4px 4px 0 #111;
  }

  .hero-speech-bubble::after {
    content: '';
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 14px solid transparent;
    border-right: 14px solid transparent;
    border-top: 20px solid #111;
  }

  .hero-speech-bubble::before {
    content: '';
    position: absolute;
    bottom: -15px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 11px solid transparent;
    border-right: 11px solid transparent;
    border-top: 17px solid #FFF;
    z-index: 1;
  }

  .hero-tagline {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 700;
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    line-height: 1.6;
    margin: 0;
    color: #111;
  }

  /* ========================================
     SECTIONS - SHARED
     ======================================== */
  .section {
    padding: 80px 32px;
    border-bottom: 4px solid #111;
    position: relative;
  }

  .section-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-rule {
    flex: 1;
    max-width: 80px;
    height: 3px;
    background: #111;
  }

  .section-label {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 700;
    font-size: 0.8rem;
    color: #E53935;
    white-space: nowrap;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .section-heading {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.1;
    margin: 0 0 48px 0;
    text-align: center;
    color: #111;
    letter-spacing: 0.03em;
  }

  /* ========================================
     ABOUT
     ======================================== */
  .about-section {
    background: #FFF;
    position: relative;
  }

  .about-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(circle 1.5px, rgba(30, 136, 229, 0.08) 50%, transparent 50%);
    background-size: 10px 10px;
    pointer-events: none;
  }

  .about-content {
    max-width: 640px;
    margin: 0 auto;
    text-align: left;
    background: #FFF;
    border: 3px solid #111;
    border-radius: 6px;
    padding: 36px 32px;
    position: relative;
    box-shadow: 4px 4px 0 #111;
  }

  .about-paragraph {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 400;
    font-size: 1.1rem;
    line-height: 1.8;
    margin: 0 0 20px 0;
    color: #111;
  }

  .about-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     CHARACTERISTICS
     ======================================== */
  .characteristics-section {
    background: #FDD835;
    position: relative;
  }

  .characteristics-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(circle 1.5px, rgba(0, 0, 0, 0.06) 50%, transparent 50%);
    background-size: 10px 10px;
    pointer-events: none;
  }

  .characteristics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0;
    border: 3px solid #111;
    border-radius: 6px;
    overflow: hidden;
    position: relative;
  }

  .char-card {
    border: 2px solid #111;
    padding: 28px 24px 24px;
    position: relative;
    text-align: left;
    background: #FFF;
    transition: background 0.2s;
  }

  .char-card:hover {
    background: #FFF9E0;
  }

  .char-number {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 0.9rem;
    color: #E53935;
    display: block;
    margin-bottom: 8px;
    letter-spacing: 0.1em;
  }

  .char-divider {
    width: 32px;
    height: 3px;
    background: #E53935;
    margin: 0 0 12px;
  }

  .char-title {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 1.3rem;
    margin: 0 0 10px 0;
    color: #111;
    letter-spacing: 0.03em;
  }

  .char-description {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
    color: #333;
  }

  /* ========================================
     STYLE REFERENCE / PROMPT
     ======================================== */
  .prompt-section {
    background: #FFF;
    position: relative;
  }

  .prompt-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(circle 1.5px, rgba(229, 57, 53, 0.06) 50%, transparent 50%);
    background-size: 10px 10px;
    pointer-events: none;
  }

  .prompt-block {
    border: 3px solid #111;
    border-radius: 6px;
    margin: 0 auto;
    position: relative;
    overflow: hidden;
    box-shadow: 4px 4px 0 #111;
  }

  .prompt-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 24px;
    border-bottom: 3px solid #111;
    background: #1E88E5;
    position: relative;
    z-index: 1;
  }

  .prompt-header-label {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 1rem;
    color: #FFF;
    letter-spacing: 0.08em;
  }

  .copy-button {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 0.95rem;
    background: #FDD835;
    color: #111;
    border: 3px solid #111;
    border-radius: 4px;
    padding: 6px 20px;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    letter-spacing: 0.05em;
  }

  .copy-button:hover {
    background: #FFF;
    transform: scale(1.05);
  }

  .copy-button.copied {
    background: #E53935;
    color: #FFF;
  }

  .prompt-text {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    line-height: 1.8;
    color: #111;
    padding: 28px 24px;
    margin: 0;
    white-space: normal;
    position: relative;
    z-index: 1;
    background: #FFF;
  }

  /* ========================================
     WHEN TO USE
     ======================================== */
  .use-section {
    background: #E53935;
    position: relative;
  }

  .use-section .section-label {
    color: #FDD835;
  }

  .use-section .section-heading {
    color: #FFF;
  }

  .use-section .section-rule {
    background: #FDD835;
  }

  .use-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    max-width: 780px;
    margin: 0 auto;
    border: 3px solid #111;
    border-radius: 6px;
    overflow: hidden;
  }

  .use-column {
    position: relative;
    background: #FFF;
  }

  .use-good {
    border-right: 3px solid #111;
  }

  .use-column-heading {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 1.15rem;
    margin: 0;
    padding: 16px 22px;
    text-align: center;
    border-bottom: 3px solid #111;
    letter-spacing: 0.05em;
  }

  .use-good .use-column-heading {
    background: #1E88E5;
    color: #FFF;
  }

  .use-bad .use-column-heading {
    background: #111;
    color: #FDD835;
  }

  .use-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .use-item {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.5;
    padding: 13px 22px;
    border-bottom: 2px solid rgba(17, 17, 17, 0.15);
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: #111;
  }

  .use-item:last-child {
    border-bottom: none;
  }

  .use-item-good::before {
    content: '\2605';
    color: #1E88E5;
    flex-shrink: 0;
    font-size: 0.8rem;
    margin-top: 2px;
  }

  .use-item-bad::before {
    content: '\2716';
    color: #E53935;
    flex-shrink: 0;
    font-size: 0.75rem;
    margin-top: 3px;
  }

  /* ========================================
     HISTORY
     ======================================== */
  .history-section {
    background: #FFF;
    position: relative;
  }

  .history-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: radial-gradient(circle 1.5px, rgba(253, 216, 53, 0.12) 50%, transparent 50%);
    background-size: 10px 10px;
    pointer-events: none;
  }

  .history-content {
    max-width: 640px;
    margin: 0 auto;
    text-align: left;
    background: #FFF;
    border: 3px solid #111;
    border-radius: 6px;
    padding: 36px 32px;
    position: relative;
    box-shadow: 4px 4px 0 #111;
  }

  .history-paragraph {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 400;
    font-size: 1.05rem;
    line-height: 1.85;
    margin: 0 0 20px 0;
    color: #111;
  }

  .history-paragraph:last-child {
    margin-bottom: 0;
  }

  /* ========================================
     RELATED STYLES
     ======================================== */
  .related-section {
    background: #1E88E5;
    position: relative;
  }

  .related-section .section-label {
    color: #FDD835;
  }

  .related-section .section-heading {
    color: #FFF;
  }

  .related-section .section-rule {
    background: #FDD835;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0;
    max-width: 780px;
    margin: 0 auto;
    border: 3px solid #111;
    border-radius: 6px;
    overflow: hidden;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 24px 20px;
    border: 2px solid #111;
    text-decoration: none;
    color: #111;
    text-align: center;
    position: relative;
    background: #FFF;
    transition: background 0.2s, transform 0.15s;
  }

  .related-card:hover {
    background: #FDD835;
    transform: scale(1.03);
    z-index: 2;
  }

  .related-relationship {
    font-family: 'Roboto Condensed', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    color: #E53935;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .related-name {
    font-family: 'Bangers', cursive;
    font-weight: 400;
    font-size: 1.2rem;
    color: #111;
    letter-spacing: 0.03em;
  }

  .related-arrow {
    font-size: 1.1rem;
    color: #1E88E5;
    font-weight: 700;
  }

  /* ========================================
     FOOTER
     ======================================== */
  .footer {
    background: #111;
    padding: 56px 32px;
    border-top: 4px solid #111;
  }

  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
  }

  .footer-ornament {
    width: 80px;
    height: 3px;
    background: linear-gradient(90deg, #E53935, #FDD835, #1E88E5);
