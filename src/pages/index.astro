---
import Base from '../layouts/Base.astro';
import HomeHeader from '../components/HomeHeader.astro';
import { loadAllAesthetics } from '../lib/aesthetics';

const aesthetics = loadAllAesthetics();

const cardComponents = await Promise.all(
  aesthetics.map(async (a) => ({
    aesthetic: a,
    Card: (await import(`../generated/cards/${a.slug}.astro`)).default,
  }))
);

const ERA_LABELS: Record<string, string> = {
  'fine-art':        'Fine Art Traditions',
  'print-analog':    'Print & Analog',
  'early-web':       'Early Web',
  '2000s':           'The 2000s',
  '2010s':           'The 2010s',
  'contemporary':    'Contemporary',
  'internet-culture':'Internet Culture',
};

const VIBE_LABELS: Record<string, string> = {
  'dark-moody':           'Dark & Moody',
  'clean-minimal':        'Clean & Minimal',
  'colorful-playful':     'Colorful & Playful',
  'nostalgic':            'Nostalgic',
  'organic-natural':      'Organic & Natural',
  'technical-functional': 'Technical & Functional',
  'luxurious-editorial':  'Luxurious & Editorial',
  'raw-experimental':     'Raw & Experimental',
};

const ERA_ORDER = ['fine-art','print-analog','early-web','2000s','2010s','contemporary','internet-culture'];
const VIBE_ORDER = ['dark-moody','clean-minimal','colorful-playful','nostalgic','organic-natural','technical-functional','luxurious-editorial','raw-experimental'];

const sorted = [...cardComponents].sort((a, b) => a.aesthetic.name.localeCompare(b.aesthetic.name));
---

<Base title="Every web aesthetic, demonstrated" description="A visual reference for web design aesthetics. Each page is designed in the style it describes.">
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />

  <div class="page">
    <header>
      <HomeHeader />
    </header>

    <!-- Picker: hidden until JS runs -->
    <div class="picker" role="group" aria-label="Group aesthetics by" hidden>
      <button class="pick-btn" data-mode="random">Randomized ↺</button>
      <button class="pick-btn" data-mode="alpha">Alphabetical</button>
      <button class="pick-btn" data-mode="era">By Era</button>
      <button class="pick-btn" data-mode="vibe">By Vibe</button>
    </div>

    <!-- Cards rendered once, alphabetically. JS rearranges in place. -->
    <div id="view">
      <div class="grid" id="card-grid">
        {sorted.map(({ aesthetic, Card }) => (
          <a
            href={`/${aesthetic.slug}`}
            class="card-link"
            data-name={aesthetic.name}
            data-era={aesthetic.era}
            data-vibe={aesthetic.vibe}
          >
            <Card aesthetic={aesthetic} />
          </a>
        ))}
      </div>
    </div>
  </div>
</Base>

<script define:vars={{ ERA_ORDER, ERA_LABELS, VIBE_ORDER, VIBE_LABELS }}>
  const view = document.getElementById('view');
  const picker = document.querySelector('.picker');
  const buttons = document.querySelectorAll('.pick-btn');

  // Capture all 86 card elements once — they live here regardless of view
  const allCards = Array.from(document.getElementById('card-grid').children);

  picker.hidden = false;

  function makeGrid(cards) {
    const grid = document.createElement('div');
    grid.className = 'grid flat';
    grid.append(...cards);
    return grid;
  }

  function makeGroupedView(groupOrder, groupLabels, attr) {
    const frag = document.createDocumentFragment();
    for (const key of groupOrder) {
      const cards = allCards.filter(c => c.dataset[attr] === key);
      if (cards.length === 0) continue;
      const section = document.createElement('section');
      section.className = 'group';
      const h2 = document.createElement('h2');
      h2.className = 'group-label';
      h2.textContent = groupLabels[key];
      section.appendChild(h2);
      section.appendChild(makeGrid(cards));
      frag.appendChild(section);
    }
    return frag;
  }

  function shuffled(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function activate(mode) {
    buttons.forEach(b => b.classList.toggle('active', b.dataset.mode === mode));

    if (mode === 'random') {
      view.replaceChildren(makeGrid(shuffled(allCards)));
    } else if (mode === 'alpha') {
      const s = [...allCards].sort((a, b) => a.dataset.name.localeCompare(b.dataset.name));
      view.replaceChildren(makeGrid(s));
    } else if (mode === 'era') {
      view.replaceChildren(makeGroupedView(ERA_ORDER, ERA_LABELS, 'era'));
    } else if (mode === 'vibe') {
      view.replaceChildren(makeGroupedView(VIBE_ORDER, VIBE_LABELS, 'vibe'));
    }
  }

  buttons.forEach(btn => btn.addEventListener('click', () => activate(btn.dataset.mode)));

  activate('random');
</script>

<!-- Scoped: elements rendered by Astro -->
<style>
  .page {
    background: #111;
    color: #eee;
    font-family: 'Inter', sans-serif;
    min-height: 100vh;
    padding: 24px;
  }

  header {
    max-width: 1200px;
    margin: 0 auto 32px;
    padding: 0 8px;
  }

  .picker {
    max-width: 1200px;
    margin: 0 auto 32px;
    padding: 0 8px;
    display: flex;
    gap: 8px;
  }

  .pick-btn {
    background: transparent;
    border: 1px solid #444;
    color: #999;
    padding: 6px 16px;
    border-radius: 20px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .pick-btn:hover {
    border-color: #888;
    color: #ccc;
  }

  .pick-btn.active {
    background: #eee;
    border-color: #eee;
    color: #111;
  }

  .card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.2s;
  }

  .card-link:hover {
    transform: translateY(-4px);
  }
</style>

<!-- Global: elements created by JS at runtime -->
<style is:global>
  .grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .grid.flat {
    padding: 0 8px;
  }

  .group {
    max-width: 1200px;
    margin: 0 auto 48px;
    padding: 0 8px;
  }

  .group-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #666;
    margin: 0 0 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid #222;
  }

  .group .grid {
    padding: 0;
  }

  @media (max-width: 660px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
